	font-size: 24rpx;
	color: #999999;
	margin-bottom: 12rpx;
}

.preview-content {
	padding: 20rpx;
	background-color: #f8f9fa;
	border-radius: 8rpx;
}

.preview-text {
	font-size: 26rpx;
	color: #333333;
	lines: 3;
}

.search-bar {
	padding-top: 20rpx;
	padding-bottom: 20rpx;
	padding-left: 28rpx;
	padding-right: 28rpx;
	background-color: #ffffff;
	margin-bottom: 20rpx;
}

.search-input-wrapper {
	flex-direction: row;
	align-items: center;
	background-color: #f8f9fa;
	border-radius: 30rpx;
	padding-top: 12rpx;
	padding-bottom: 12rpx;
	padding-left: 24rpx;
	padding-right: 24rpx;
}

.search-icon {
	font-size: 28rpx;
	margin-right: 12rpx;
}

.search-input-field {
	flex: 1;
	font-size: 26rpx;
}

.friend-list {
	flex: 1;
	background-color: #ffffff;
	flex-direction: column;
}

.list-header {
	flex-direction: row;
	justify-content: space-between;
	align-items: center;
	padding-top: 24rpx;
	padding-bottom: 24rpx;
	padding-left: 28rpx;
	padding-right: 28rpx;
	border-bottom-width: 2rpx;
	border-bottom-style: solid;
	border-bottom-color: #f0f0f0;
}

.header-title {
	font-size: 28rpx;
	color: #333333;
	font-weight: bold;
}

.selected-count {
	font-size: 24rpx;
	color: #37B1F2;
}

.scroll-view {
	flex: 1;
}

.friend-item {
	flex-direction: row;
	align-items: center;
	padding-top: 24rpx;
	padding-bottom: 24rpx;
	padding-left: 28rpx;
	padding-right: 28rpx;
	border-bottom-width: 2rpx;
	border-bottom-style: solid;
	border-bottom-color: #f0f0f0;
}

.checkbox {
	width: 40rpx;
	height: 40rpx;
	border-width: 2rpx;
	border-style: solid;
	border-color: #e0e0e0;
	border-radius: 20rpx;
	flex-direction: row;
	align-items: center;
	justify-content: center;
	margin-right: 20rpx;
}

.checkbox.checked {
	background-color: #37B1F2;
	border-color: #37B1F2;
}

.check-icon {
	font-size: 24rpx;
	color: #ffffff;
}

.friend-name {
	margin-left: 20rpx;
