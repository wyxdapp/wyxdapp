// ========== 消息监听器 ==========
// ========== ChatMessage 转换函数 ==========
/**
 * 将 ChatMessage 类实例转换为普通对象（plain object）
 * 解决 MessageType/MessageStatus 枚举在 JSON.stringify 时无法正确序列化为字符串的问题
 * 转换后的对象格式与 parseApiMessages 输出一致
 */
const convertChatMessageToPlainObject = (msg: any): UTSJSONObject => {
	let msgId = ''
	let msgTempId = ''
	let msgContent = ''
	let msgSenderId = ''
	let msgReceiverId = ''
	let msgCreateTime = ''
	let msgConversationId = ''
	let typeStr = 'text'
	let statusStr = 'pending'
	let msgMediaUrl = ''
	let msgThumbUrl = ''
	let msgDuration = 0
	let msgSendTime = ''

	try {
		// ⭐ 修复：通过 JSON.stringify → JSON.parse 安全转换 ChatMessage 类实例
		// 在 APP 端，class 实例不能直接 as UTSJSONObject，get() 会返回 null
		const jsonStr = JSON.stringify(msg)
		const jsonObj = JSON.parse(jsonStr) as UTSJSONObject
		if (jsonObj != null) {
			const idVal = jsonObj.get('id')
			if (idVal != null) msgId = idVal.toString()

			const tempIdVal = jsonObj.get('tempId')
			if (tempIdVal != null && tempIdVal.toString() != '') msgTempId = tempIdVal.toString()

			const contentVal = jsonObj.get('content')
			if (contentVal != null) msgContent = contentVal.toString()

			const senderIdVal = jsonObj.get('senderId')
			if (senderIdVal != null) msgSenderId = senderIdVal.toString()

			const receiverIdVal = jsonObj.get('receiverId')
			if (receiverIdVal != null) msgReceiverId = receiverIdVal.toString()

			const createTimeVal = jsonObj.get('createTime')
			if (createTimeVal != null) msgCreateTime = createTimeVal.toString()

			const conversationIdVal = jsonObj.get('conversationId')
			if (conversationIdVal != null) msgConversationId = conversationIdVal.toString()

			// 处理 MessageType 枚举（可能序列化为 {value: "text"} 或直接 "text"）
			const typeVal = jsonObj.get('type')
			if (typeVal != null) {
				const typeString = typeVal.toString()
				if (typeString == 'text' || typeString == 'image' || typeString == 'voice' || typeString == 'video' || typeString == 'share' || typeString == 'gift' || typeString == 'system_notification') {
					typeStr = typeString
				} else {
					// 枚举对象序列化为 {value: "xxx"} 的情况
					try {
						const typeJsonObj = JSON.parse(JSON.stringify(typeVal)) as UTSJSONObject
						if (typeJsonObj != null) {
							const valueField = typeJsonObj.get('value')
							if (valueField != null && valueField.toString() != '') {
								typeStr = valueField.toString()
							}
						}
					} catch (e2) {}
				}
			}

			// 处理 MessageStatus 枚举
			const statusVal = jsonObj.get('status')
			if (statusVal != null) {
				const statusString = statusVal.toString()
				if (statusString == 'pending' || statusString == 'sending' || statusString == 'sent' || statusString == 'failed' || statusString == 'received') {
					statusStr = statusString
				} else {
					try {
						const statusJsonObj = JSON.parse(JSON.stringify(statusVal)) as UTSJSONObject
						if (statusJsonObj != null) {
							const valueField = statusJsonObj.get('value')
							if (valueField != null && valueField.toString() != '') {
								statusStr = valueField.toString()
							}
						}
					} catch (e2) {}
				}
			}

			const mediaUrlVal = jsonObj.get('mediaUrl')
			if (mediaUrlVal != null && mediaUrlVal.toString() != '') msgMediaUrl = mediaUrlVal.toString()

			const thumbUrlVal = jsonObj.get('thumbUrl')
			if (thumbUrlVal != null && thumbUrlVal.toString() != '') msgThumbUrl = thumbUrlVal.toString()

			const durationVal = jsonObj.get('duration')
			if (durationVal != null) {
				const durationNum = parseInt(durationVal.toString())
				if (isNaN(durationNum) == false) msgDuration = durationNum
			}

			const sendTimeVal = jsonObj.get('sendTime')
			if (sendTimeVal != null && sendTimeVal.toString() != '') msgSendTime = sendTimeVal.toString()
		}
	} catch (e) {
		// fallback：逐字段提取
		msgId = getAnyString(msg, 'id')
		msgTempId = getAnyString(msg, 'tempId')
		msgContent = getAnyString(msg, 'content')
		msgSenderId = getAnyString(msg, 'senderId')
		msgReceiverId = getAnyString(msg, 'receiverId')
		msgCreateTime = getAnyString(msg, 'createTime')
		msgConversationId = getAnyString(msg, 'conversationId')
		msgMediaUrl = getAnyString(msg, 'mediaUrl')
		msgThumbUrl = getAnyString(msg, 'thumbUrl')
		msgSendTime = getAnyString(msg, 'sendTime')
	}

	// 如果 createTime 为空，使用 sendTime
	if (msgCreateTime == '' && msgSendTime != '') {
		msgCreateTime = msgSendTime
	}

	// 获取 messageType 数字值（与 parseApiMessages 输出一致）
	const messageTypeNum = getMessageTypeNumber(typeStr)

	// 构造与 parseApiMessages 输出格式一致的普通对象
	const plainObj = new UTSJSONObject()
	plainObj.set('id', msgId)
	plainObj.set('tempId', msgTempId)
	plainObj.set('senderId', msgSenderId)
	plainObj.set('receiverId', msgReceiverId)
	plainObj.set('fromUserKid', msgSenderId)
	plainObj.set('toUserKid', msgReceiverId)
	plainObj.set('type', typeStr)
	plainObj.set('messageType', messageTypeNum)
	plainObj.set('content', msgContent)
	plainObj.set('createTime', msgCreateTime)
	plainObj.set('status', statusStr)
	plainObj.set('mediaUrl', msgMediaUrl)
	plainObj.set('thumbUrl', msgThumbUrl)
	plainObj.set('duration', msgDuration)
	plainObj.set('sendTime', msgSendTime)
	plainObj.set('conversationId', msgConversationId)

	return plainObj
}

let offMessageChange: (() => void) | null = null

const setupMessageListeners = () => {
	// 清理旧监听器
	const existingMessageChange = offMessageChange
	if (existingMessageChange != null) {
		existingMessageChange()
		offMessageChange = null
	}
	
	// 监听消息变化（保留用于接收其他用户的消息 + 处理自发消息确认）
	offMessageChange = chatService.onMessageChange((messages) => {
		console.log('🔔 [detail] onMessageChange 触发, 消息数:', messages.length)
		const currentUserIdVal = currentUserId.value
		const targetUserIdVal = targetUserId.value

		// 🔧 修复：同时处理两类消息
		// 1. 接收到的对方消息 → 合并到 messageList
		// 2. 自己发送的已确认消息（tempId→realId 映射完成）→ 更新 messageList 中的临时消息 ID 和 createTime
		const currentConversationMessages: Array<UTSJSONObject> = []
		
		for (let i = 0; i < messages.length; i = i + 1) {
			const msg = messages[i]
			if (msg == null) continue

			const plainMsg = convertChatMessageToPlainObject(msg)

			const msgSenderId = getObjString(plainMsg, 'senderId')
			const msgReceiverId = getObjString(plainMsg, 'receiverId')
			const fromUserKid = getObjString(plainMsg, 'fromUserKid')
			const toUserKid = getObjString(plainMsg, 'toUserKid')

			const senderIdFinal = (msgSenderId != '') ? msgSenderId : fromUserKid
			const receiverIdFinal = (msgReceiverId != '') ? msgReceiverId : toUserKid

			const isCurrentConversation =
				(senderIdFinal == currentUserIdVal && receiverIdFinal == targetUserIdVal) ||
				(senderIdFinal == targetUserIdVal && receiverIdFinal == currentUserIdVal)

			if (isCurrentConversation == false) continue

			console.log('🔔 [detail] 匹配到当前会话消息, sender:', senderIdFinal, 'receiver:', receiverIdFinal, 'status:', getObjString(plainMsg, 'status'))

			const isReceivedMessage = senderIdFinal == targetUserIdVal
			const isSentByMe = senderIdFinal == currentUserIdVal

			if (isReceivedMessage == true) {
				// 对方消息 → 收集后合并
				currentConversationMessages.push(plainMsg)
			} else if (isSentByMe == true) {
				// 🔧 修复：自己发送的已确认消息 → 检查是否需要更新 messageList 中的临时消息
				const msgId = getObjString(plainMsg, 'id')
				const msgTempId = getObjString(plainMsg, 'tempId')
				const msgStatus = getObjString(plainMsg, 'status')
				const serverCreateTime = getObjString(plainMsg, 'createTime')
				
				// 如果有 tempId 且状态为 sent，说明 handleMessageSent 已完成 tempId→realId 映射
				if (msgTempId != '' && msgId != '' && msgId != msgTempId) {
					// 在 messageList 中查找临时消息并替换
					for (let j = 0; j < messageList.value.length; j = j + 1) {
						const existingMsg = messageList.value[j]
						const existingId = getAnyString(existingMsg, 'id')
						if (existingId == msgTempId) {
							// 用服务端确认的 realId 和 createTime 替换临时消息
							const updatedMsg = new UTSJSONObject()
							updatedMsg.set('id', msgId)
							updatedMsg.set('senderId', senderIdFinal)
							updatedMsg.set('receiverId', receiverIdFinal)
							updatedMsg.set('type', getAnyString(existingMsg, 'type'))
							updatedMsg.set('messageType', getAnyString(existingMsg, 'messageType'))
							updatedMsg.set('content', getAnyString(existingMsg, 'content'))
							// 🔧 关键：用服务端时间替换本地时间，确保排序正确
							updatedMsg.set('createTime', (serverCreateTime != '') ? serverCreateTime : getAnyString(existingMsg, 'createTime'))
							updatedMsg.set('status', (msgStatus != '') ? msgStatus : 'sent')
							updatedMsg.set('senderAvatar', getAnyString(existingMsg, 'senderAvatar'))
							messageList.value[j] = updatedMsg
							// 保存到本地存储（临时 ID 已替换为正式 ID）
							chatLocalStorageManager.saveMessages(
								currentUserIdVal,
								targetUserIdVal,
								messageList.value
							)
							break
						}
					}
				}
			}
		}

		// 合并接收到的对方消息
		if (currentConversationMessages.length > 0) {
			const mergedMessages = mergeMessagesWithoutDuplicates(currentConversationMessages as Array<any>, messageList.value as Array<any>)
			messageList.value = mergedMessages

			nextTick(() => {
				scrollToBottom()
			})
		}
	})
	
	// ⭐ 直接监听发送确认事件（绕过 onMessageChange 链路，确保 APP 端可靠）
	uni.$on('chat:messageSentConfirmed', (data: any) => {
		try {
			const eventData = JSON.parse(JSON.stringify(data)) as UTSJSONObject
			const tempIdVal = eventData.getString('tempId')
			const realIdVal = eventData.getString('realId')
			const statusVal = eventData.getString('status')
			const createTimeVal = eventData.getString('createTime')
			
			if (tempIdVal == null || tempIdVal == '') return
			
			console.log('✅ [detail] 收到发送确认事件, tempId:', tempIdVal, '-> realId:', realIdVal)
			
			// 在 messageList 中查找临时消息并更新
			for (let j = 0; j < messageList.value.length; j = j + 1) {
				const existingMsg = messageList.value[j]
				const existingId = getAnyString(existingMsg, 'id')
				if (existingId == tempIdVal) {
					const updatedMsg = new UTSJSONObject()
					updatedMsg.set('id', (realIdVal != null && realIdVal != '') ? realIdVal : tempIdVal)
					updatedMsg.set('tempId', tempIdVal)
					updatedMsg.set('senderId', getAnyString(existingMsg, 'senderId'))
					updatedMsg.set('receiverId', getAnyString(existingMsg, 'receiverId'))
					updatedMsg.set('fromUserKid', getAnyString(existingMsg, 'senderId'))
					updatedMsg.set('toUserKid', getAnyString(existingMsg, 'receiverId'))
					updatedMsg.set('type', getAnyString(existingMsg, 'type'))
					updatedMsg.set('messageType', getAnyString(existingMsg, 'messageType'))
					updatedMsg.set('content', getAnyString(existingMsg, 'content'))
					updatedMsg.set('createTime', (createTimeVal != null && createTimeVal != '') ? createTimeVal : getAnyString(existingMsg, 'createTime'))
					updatedMsg.set('status', (statusVal != null && statusVal != '') ? statusVal : 'sent')
					updatedMsg.set('senderAvatar', getAnyString(existingMsg, 'senderAvatar'))
					updatedMsg.set('mediaUrl', getAnyString(existingMsg, 'mediaUrl'))
					updatedMsg.set('thumbUrl', getAnyString(existingMsg, 'thumbUrl'))
					// 触发响应式更新：替换整个数组
					const newList = messageList.value.slice(0)
					newList[j] = updatedMsg
					messageList.value = newList
					break
				}
			}
		} catch (e) {
			console.error('❌ [detail] 处理发送确认事件失败:', e)
		}
	})
	
	// ⭐ 直接监听新消息接收事件
	uni.$on('chat:newMessageReceived', (data: any) => {
		try {
			const eventData = JSON.parse(JSON.stringify(data)) as UTSJSONObject
			const msgSenderId = eventData.getString('senderId')
			const msgReceiverId = eventData.getString('receiverId')
			
			if (msgSenderId == null || msgReceiverId == null) return
			
			const currentUserIdVal = currentUserId.value
			const targetUserIdVal = targetUserId.value
			
			// 只处理当前会话的消息
			const isCurrentConversation =
				(msgSenderId == currentUserIdVal && msgReceiverId == targetUserIdVal) ||
				(msgSenderId == targetUserIdVal && msgReceiverId == currentUserIdVal)
			
			if (isCurrentConversation == false) return
			
			const msgId = eventData.getString('messageId')
			const msgContent = eventData.getString('content')
			const msgCreateTime = eventData.getString('createTime')
			const msgTypeNum = eventData.getNumber('messageType')
			const conversationId = eventData.getString('conversationId')
			
			console.log('📨 [detail] 收到新消息事件, id:', msgId, 'from:', msgSenderId)
			
			// 检查是否已存在（避免重复）
			let alreadyExists = false
			for (let j = 0; j < messageList.value.length; j = j + 1) {
				const existingId = getAnyString(messageList.value[j], 'id')
				if (existingId == msgId) {
					alreadyExists = true
					break
				}
			}
			if (alreadyExists == true) return
			
			// 构造消息对象
			let typeStr = 'text'
			if (msgTypeNum == 2) typeStr = 'image'
			else if (msgTypeNum == 3) typeStr = 'video'
			else if (msgTypeNum == 4) typeStr = 'voice'
			else if (msgTypeNum == 6) typeStr = 'share'
			else if (msgTypeNum == 7) typeStr = 'gift'
			
			const newMsg = new UTSJSONObject()
			newMsg.set('id', msgId != null ? msgId : '')
			newMsg.set('senderId', msgSenderId)
			newMsg.set('receiverId', msgReceiverId != null ? msgReceiverId : '')
			newMsg.set('fromUserKid', msgSenderId)
			newMsg.set('toUserKid', msgReceiverId != null ? msgReceiverId : '')
			newMsg.set('type', typeStr)
			newMsg.set('messageType', msgTypeNum != null ? msgTypeNum : 1)
			newMsg.set('content', msgContent != null ? msgContent : '')
			newMsg.set('createTime', msgCreateTime != null ? msgCreateTime : '')
			newMsg.set('status', 'received')
			newMsg.set('conversationId', conversationId != null ? conversationId : '')
			
			// 追加到消息列表
			const newList = messageList.value.slice(0)
			newList.push(newMsg)
			messageList.value = newList
			
			nextTick(() => {
				scrollToBottom()
			})
		} catch (e) {
			console.error('❌ [detail] 处理新消息事件失败:', e)
		}
	})
}

const cleanupMessageListeners = () => {
	const existingMessageChange = offMessageChange
	if (existingMessageChange != null) {
		existingMessageChange()
		offMessageChange = null
	}
	// 清理 uni.$on 事件监听
	uni.$off('chat:messageSentConfirmed')
	uni.$off('chat:newMessageReceived')
}

// ========== 页面初始化 ==========
const initPageHeight = () => {
	initPageLayoutComposable()
	
	if (pageWindowHeight.value > 0) {
		// H5端不显示自定义导航栏，只有快捷功能栏
		// APP端显示状态栏 + 导航栏 + 快捷功能栏
		let chatHeaderPx = 0
		// #ifndef H5
		const navBarPx = 44
		const actionBarPx = 60
		chatHeaderPx = pageStatusBarHeight.value + navBarPx + actionBarPx
		// #endif
		// #ifdef H5
		const h5ActionBarPx = 60
		chatHeaderPx = h5ActionBarPx
		// #endif
		
		// 输入框基础高度（padding-top 10px + input-wrapper 40px + padding-bottom 18px ≈ 68px）+ 安全区域高度
		const safeAreaBottomPx = getSafeAreaBottom()
		let chatInputPx = 68 + safeAreaBottomPx
		// #ifdef H5
		// iOS 浏览器底部有前进/后退工具栏（Safari约44px、微信约44px），需要额外预留空间
		if (hasIOSBottomToolbar() == true) {
			chatInputPx = chatInputPx + 44
		}
		// #endif
		
		const listHeight = pageWindowHeight.value - chatHeaderPx - chatInputPx
		
		if (listHeight > 200) {
			messageListHeight.value = listHeight
		} else {
			const fallbackHeight = (pageWindowHeight.value * 60) / 100
			messageListHeight.value = fallbackHeight > 300 ? fallbackHeight : 300
		}
	}
	
	if (messageListHeight.value <= 0) {
		messageListHeight.value = 500
	}
}

const updateComposableOptions = () => {
	// 更新消息管理选项
	messagesOptions.currentUserId = currentUserId.value
	messagesOptions.targetUserId = targetUserId.value
	messagesOptions.currentUserAvatar = currentUserAvatar.value
	messagesOptions.scrollTopValue = scrollTopValue
	messagesOptions.scrollWithAnimation = scrollWithAnimation

	// 初始化需要参数的 Composables
	initDynamicComposables()
}

// 自动发送分享消息（使用 function 声明以支持递归调用）
function autoSendShareMessage(): void {
	if (pendingShareMessage.value == null || pendingShareMessage.value == '') {
		return
	}
	
	// 检查连接状态
	if (connectionStatus.value != 'connected') {
		shareMessageRetryCount.value = shareMessageRetryCount.value + 1
		if (shareMessageRetryCount.value < MAX_RETRY_COUNT) {
			setTimeout(function() { autoSendShareMessage() }, 500)
		} else {
			pendingShareMessage.value = ''
			shareMessageRetryCount.value = 0
		}
		return
	}
	
	// 发送分享消息
	sendTextMessage(pendingShareMessage.value, pendingShareMessageType.value)
	pendingShareMessage.value = ''
	shareMessageRetryCount.value = 0
}

// ⭐ 新增：标记会话已读方法
const markConversationAsRead = async () => {
	if (currentUserId.value == '' || targetUserId.value == '') {
		return
	}

	try {
		// UTS 规范：不能使用对象字面量，需使用类实例
		const params = new MarkReadParams()
		params.fromUserId = currentUserId.value
		params.toUserId = targetUserId.value

		await markConversationRead(params)

		// ⭐ 移除：不要调用 updateUnreadCountsDirect({})
		// 因为这会错误地将所有未读数（包括订单未读数）设置为0
		// 订单未读数应该独立管理，不受会话清零影响

		// ⭐ 新增：立即通知消息列表页刷新会话数据
		// 解决用户返回时会话未读数不清零的问题
		uni.$emit('chat:conversationUpdate')

	} catch (error) {
		handleSilentError(error, '标记会话已读')
	}
}

const doInitChatPage = () => {
	// 设置当前用户ID
	chatService.setCurrentUserId(currentUserId.value)

	// 🔧 修复：设置活跃会话，阻止 messageStateManager.persistToStorage 覆盖当前会话的存储
	const convKey = chatLocalStorageManager.getConversationKey(currentUserId.value, targetUserId.value)
	if (convKey != '') {
		messageStateManager.setActiveConversation(convKey)
	}

	// ⭐ 新增：标记会话已读，清零未读数
	markConversationAsRead()

	// ⭐ 清理 messageStateManager 中属于当前会话的旧消息
	// 这样可以避免旧的临时消息被合并到消息列表
	chatService.clearConversationByUsers(currentUserId.value, targetUserId.value)
	
	// 检查 WebSocket 连接状态
	const isConnected = getWebSocketConnectedStatus()
	
	if (isConnected == false) {
		forceReconnectAction(currentUserId.value).then((success: boolean): void => {
			if (success == true) {
				let checkCount = 0
				const maxChecks = 5
				let intervalId: number = 0
				intervalId = setInterval(() => {
					checkCount = checkCount + 1
					const newStatus = getWebSocketConnectedStatus()
					if (newStatus == true) {
						clearInterval(intervalId)
					} else if (checkCount >= maxChecks) {
						clearInterval(intervalId)
					}
				}, 1000)
			}
		}).catch((err: any | null): void => {
			console.error('强制重连失败:', err)
		})
	}
	
	// 设置监听器
	setupConnectionListeners()
	setupPlayListeners()
	setupMessageListeners()
	
	// 加载历史消息
	loadMessages()
	
	// 处理待发送的分享消息
	if (pendingShareMessage.value != null && pendingShareMessage.value != '') {
		setTimeout(() => autoSendShareMessage(), 800)
	}
	
	// 处理待发送的礼物消息
	if (pendingGiftMessage.value != null && pendingGiftMessage.value != '') {
		setTimeout(() => {
			const giftInstance = chatGiftInstanceRef.value
			if (giftInstance != null) {
				giftInstance.sendGiftMessageFromPending(pendingGiftMessage.value)
			}
			pendingGiftMessage.value = ''
		}, 1000)
	}
}

const initChatPage = () => {
	initPageHeight()
	
	if (currentUserId.value == null || currentUserId.value == '') {
		setTimeout(() => {
			if (currentUserId.value != null && currentUserId.value != '') {
				updateComposableOptions()
				doInitChatPage()
			} else {
				uni.showToast({ title: '用户信息加载失败', icon: 'none' })
			}
		}, 500)
		return
	}
	
	updateComposableOptions()
	doInitChatPage()
}

// ========== 联系方式弹窗事件监听 ==========
// 🔧 修复：监听 show-contact-popup 事件，显示联系方式弹窗
const setupContactPopupListener = () => {
	uni.$on('show-contact-popup', (data: UTSJSONObject | null) => {
		console.log('📞 [Detail] 收到 show-contact-popup 事件:', data)
		if (data != null) {
			try {
				const dataObj = data as UTSJSONObject
				
				const userNameVal = dataObj.get('userName')
				const contactInfoVal = dataObj.get('contactInfo')
				
				if (userNameVal != null) {
					contactPopupData.value.userName = userNameVal.toString()
				}
				
				if (contactInfoVal != null) {
					const contactInfoObj = JSON.parse(JSON.stringify(contactInfoVal)) as UTSJSONObject
					
					const realnameVal = contactInfoObj.get('realname')
					const contactPhoneVal = contactInfoObj.get('contactPhone')
					const qqNumberVal = contactInfoObj.get('qqNumber')
					const weixinNumberVal = contactInfoObj.get('weixinNumber')
					
					contactPopupData.value.contactInfo.realname = (realnameVal != null) ? realnameVal.toString() : ''
					contactPopupData.value.contactInfo.contactPhone = (contactPhoneVal != null) ? contactPhoneVal.toString() : ''
					contactPopupData.value.contactInfo.qqNumber = (qqNumberVal != null) ? qqNumberVal.toString() : ''
					contactPopupData.value.contactInfo.weixinNumber = (weixinNumberVal != null) ? weixinNumberVal.toString() : ''
				}
				
				console.log('📞 [Detail] 显示联系方式弹窗, userName:', contactPopupData.value.userName)
				showContactPopup.value = true
			} catch (e) {
				handleSilentError(e, '解析联系方式数据')
			}
		}
	})
}

const cleanupContactPopupListener = () => {
	uni.$off('show-contact-popup')
}

// ========== 生命周期 ==========
onLoad((options: OnLoadOptions) => {
	// 加载功能开关配置
	loadFeatureToggles()
	// 🔧 修复：设置联系方式弹窗事件监听
	setupContactPopupListener()
	
	if (options != null) {
		const optionsStr = JSON.stringify(options)
		const optionsObj = JSON.parse(optionsStr) as UTSJSONObject
		
		const targetUserIdVal = getObjString(optionsObj, 'targetUserId')
		targetUserId.value = (targetUserIdVal != '') ? targetUserIdVal : ''
		
		const conversationIdVal = getObjString(optionsObj, 'conversationId')
		conversationId.value = (conversationIdVal != '') ? conversationIdVal : ''
		
		const targetUserNameVal = getObjString(optionsObj, 'targetUserName')
		if (targetUserNameVal != '') {
			const decodedName = decodeURIComponent(targetUserNameVal)
			if (decodedName != null) {
				targetUserNickname.value = decodedName
			}
		}
		
		const targetUserAvatarVal = getObjString(optionsObj, 'targetUserAvatar')
		if (targetUserAvatarVal != '') {
			const decodedAvatar = decodeURIComponent(targetUserAvatarVal)
			if (decodedAvatar != null) {
				targetUserAvatar.value = decodedAvatar
			}
		}
		
		const shareMessageVal = getObjString(optionsObj, 'shareMessage')
		if (shareMessageVal != '') {
			try {
				const decodedMsg = decodeURIComponent(shareMessageVal)
				if (decodedMsg != null) {
					pendingShareMessage.value = decodedMsg
				}
				const messageTypeVal = getObjString(optionsObj, 'messageType')
				const msgType = (messageTypeVal != '') ? parseInt(messageTypeVal) : 6
				pendingShareMessageType.value = isNaN(msgType) == false ? msgType : 6
			} catch (e: Error) {
				handleSilentError(e, '解析分享消息参数')
			}
		}
	}
	
	// 加载目标用户资料
	loadTargetProfile()
	
	// 初始化聊天页面
	initChatPage()
})

// #ifdef H5
// 🔧 修复：iOS Safari BFCache 导致返回/前进时页面不重新渲染
// Safari 通过返回/前进按钮导航时会从 BFCache 恢复页面，onLoad 不会重新触发
// 监听 pageshow 事件的 persisted 标志来检测 BFCache 恢复，重新计算页面高度
const handlePageShow = (e: any) => {
	try {
		const eStr = JSON.stringify(e)
		const eObj = JSON.parse(eStr) as UTSJSONObject
		const persisted = eObj.get('persisted')
		if (persisted == true) {
			console.log('🔄 [Detail] Safari BFCache 恢复，重新初始化页面高度')
			// 重置布局缓存，确保重新获取窗口尺寸
			resetPageLayout()
			// 延迟执行，确保页面 DOM 完全恢复
			setTimeout(() => {
				initPageHeight()
			}, 100)
		}
	} catch (_e) {
		// 兜底：无论是否 persisted，都尝试重新计算
		resetPageLayout()
		setTimeout(() => {
			initPageHeight()
		}, 100)
	}
}
if (typeof window != 'undefined') {
	window.addEventListener('pageshow', handlePageShow)
}
// #endif

// 🔧 修复：onShow 处理页面重新显示时重新计算高度
// iOS H5 端从其他页面返回时，窗口高度可能因浏览器工具栏变化而不同
onShow(() => {
	// #ifdef H5
	console.log('📱 [Detail] onShow 触发，重新计算页面高度')
	setTimeout(() => {
		initPageHeight()
	}, 50)
	// #endif
})

onUnmounted(() => {
	// 标记需要刷新会话列表
	safeSetStorageSync('shouldRefreshConversations', 'true')
	
	// 🔧 修复：清除活跃会话标记，恢复 messageStateManager 对该会话的持久化能力
	messageStateManager.clearActiveConversation()
	
	// 清理监听器
	cleanupConnectionListeners()
	cleanupPlayListeners()
	cleanupMessageListeners()
	// 🔧 修复：清理联系方式弹窗事件监听
	cleanupContactPopupListener()
	// 🔧 修复：清理 pageshow 事件监听
	// #ifdef H5
	if (typeof window != 'undefined') {
		window.removeEventListener('pageshow', handlePageShow)
	}
	// #endif
})
</script>


<style>
/* APP 端：必须设置 100% 高度和 overflow: hidden */
/* #ifndef H5 */
.chat-page-container {
	flex-direction: column;
	background-color: #f5f5f5;
	width: 750rpx;
	height: 100%;
	overflow: hidden;
}
/* #endif */

/* H5 端：使用 flex: 1 自动填充 */
/* #ifdef H5 */
.chat-page-container {
	flex: 1;
	flex-direction: column;
	background-color: #f5f5f5;
	height: 100%;
	overflow: hidden;
}
/* #endif */

.connection-status {
	background-color: #fff3cd;
	padding-top: 16rpx;
	padding-bottom: 16rpx;
	padding-left: 28rpx;
	padding-right: 28rpx;
	flex-direction: row;
	justify-content: center;
	align-items: center;
	border-bottom-width: 2rpx;
	border-bottom-style: solid;
	border-bottom-color: #ffeaa7;
}

.status-text {
	font-size: 24rpx;
	color: #856404;
}

/* 消息列表外层容器 - 使用 flex: 1 自动填充剩余空间 */
.message-list-wrapper {
	flex: 1;
	flex-direction: column;
	overflow: hidden;
}

/* 消息滚动容器 */
.message-scroll-view {
	flex: 1;
	flex-direction: column;
	width: 750rpx;
	padding-left: 28rpx;
	padding-right: 28rpx;
	background-color: #f5f5f5;
}

.message-list-view {
	flex-direction: column;
	width: 750rpx;
	padding-left: 28rpx;
	padding-right: 28rpx;
	background-color: #f5f5f5;
}

.message-list-item {
	padding-top: 12rpx;
	padding-bottom: 12rpx;
}

.empty-list-item {
	padding-top: 200rpx;
}

.load-more-list-item {
	padding-top: 20rpx;
	padding-bottom: 20rpx;
