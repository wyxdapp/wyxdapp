const handleReserve = () => {
	// 提取纯数字部分，避免中文字符在微信小程序URL参数中编解码异常
	const rawPrice = (targetUserServicePrice.value != '') ? targetUserServicePrice.value : '0'
	let cleanPrice = ''
	let pi = 0
	while (pi < rawPrice.length) {
		const ch = rawPrice.charAt(pi)
		if ((ch >= '0' && ch <= '9') || ch == '.') {
			cleanPrice = cleanPrice + ch
		}
		pi = pi + 1
	}
	const price = (cleanPrice != '') ? cleanPrice : '0'
	let url = '/pagesUser/persionInfo/submitOrder?targetId=' + targetUserId.value
	if (price != '' && price != '0') {
		url = url + '&price=' + encodeURIComponent(price)
	}
	uni.navigateTo({ url: url })
}

