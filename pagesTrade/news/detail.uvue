// ⭐ 删除消息确认（需要在 handleMessageLongPress 之前定义）
const handleDeleteMessageConfirm = (messageId: string) => {
	if (messageId == null || messageId == '') return
	
	uni.showModal({
		title: '提示',
		content: '确定要删除这条消息吗？',
		success: (res: UniShowModalResult) => {
			if (res.confirm == true) {
				const success = deleteLocalMessage(messageId)
				if (success == true) {
					uni.showToast({
						title: '已删除',
						icon: 'success'
					})
				} else {
					uni.showToast({
						title: '删除失败',
						icon: 'none'
					})
				}
			}
		}
	})
}

// ⭐ 消息长按处理 - 显示操作菜单
const handleMessageLongPress = (message: UTSJSONObject, messageType: number) => {
	if (message == null) return
	
	// 获取消息内容
	const msgContent = getAnyString(message, 'content')
	const msgId = getAnyString(message, 'id')
	
	// 根据消息类型显示不同菜单
	// messageType: 1=文本, 2=图片, 3=视频, 4=语音
	if (messageType == 1) {
		// 文本消息：复制、删除
		uni.showActionSheet({
			itemList: ['复制', '删除'],
			success: (res) => {
				if (res == null) return
				const tapIndex = res.tapIndex
				
				if (tapIndex == 0) {
					// 复制消息内容
					copyMessageContent(msgContent)
				} else if (tapIndex == 1) {
					// 删除消息
					handleDeleteMessageConfirm(msgId)
				}
			}
		})
	}
}

