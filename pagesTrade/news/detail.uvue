// ⭐ 保存图片到相册
const handleSaveToAlbum = (imageUrl: string) => {
	if (imageUrl == null || imageUrl == '') {
		uni.showToast({ title: '图片地址无效', icon: 'none' })
		return
	}
	
	uni.showLoading({ title: '保存中...' })
	
	// 先下载图片
	uni.downloadFile({
		url: imageUrl,
		success: (downloadRes) => {
			if (downloadRes == null) {
				uni.hideLoading()
				uni.showToast({ title: '下载失败', icon: 'none' })
				return
			}
			
			const tempFilePath = downloadRes.tempFilePath
			
			if (tempFilePath == null || tempFilePath == '') {
				uni.hideLoading()
				uni.showToast({ title: '下载失败', icon: 'none' })
				return
			}
			
			// 保存到相册
			uni.saveImageToPhotosAlbum({
				filePath: tempFilePath,
				success: () => {
					uni.hideLoading()
					uni.showToast({ title: '已保存到相册', icon: 'success' })
				},
				fail: (err) => {
					uni.hideLoading()
					handleSilentError(err, '保存到相册')
					uni.showToast({ title: '保存失败', icon: 'none' })
				}
			})
		},
		fail: (err) => {
			uni.hideLoading()
			handleSilentError(err, '下载图片')
			uni.showToast({ title: '下载失败', icon: 'none' })
		}
	})
}

