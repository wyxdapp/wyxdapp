// ==================== 跨平台兼容函数 ====================

export function getStoredWxCodeSafe(): string {
	// #ifdef H5
	try {
		// 🔧 修复：使用正确的存储键 wxCode（与登录授权保持一致）
		const code = uni.getStorageSync(SK_WX_CODE)
		if (code != null && code.toString() != '') {
			return code.toString()
		}
	} catch (e) {}
	// #endif
	return ''
}

export function clearWxCodeSafe(): void {
	// #ifdef H5
	try {
		// 🔧 修复：清理正确的存储键
		uni.removeStorageSync(SK_WX_CODE)
		uni.removeStorageSync(SK_WX_CODE_USED)
	} catch (e) {}
	// #endif
}

// ==================== H5 端微信支付（带授权码）====================

// 导入 H5 支付实现
// #ifdef H5
import { 
	doWechatPayWithCode as doWechatPayWithCodeImpl, 
	isWechatBrowser, 
	getWechatAuthCode as getWechatAuthCodeImpl,
	isWxCodeUsed as isWxCodeUsedImpl,
	markWxCodeUsed as markWxCodeUsedImpl,
	getAvailableWxCode as getAvailableWxCodeImpl
} from './wechatPayH5.uts'
// #endif

export function wechatPayH5WithCode(
	params: PaymentParams,
	wxCode: string,
	onSuccess: PaymentSuccessCallback,
	onError: PaymentErrorCallback
): void {
	console.log('💰 [WX-PAY] H5端使用授权码支付')
	
	const currentState = getPaymentState(params.orderId)
	if (currentState == PAYMENT_STATE_PROCESSING) {
		console.warn('⚠️ [WX-PAY] 支付正在处理中，防止重复支付')
		onError('支付正在处理中，请稍候')
		return
	}
	
	// #ifdef H5
	// 检查是否在微信浏览器中
	if (isWechatBrowser() == false) {
		console.error('❌ [WX-PAY] 非微信浏览器环境')
		onError('请在微信浏览器中打开')
		return
	}
	
	// 调用实际的 H5 支付实现
	doWechatPayWithCodeImpl(params, wxCode, onSuccess, onError)
	// #endif
	
	// #ifndef H5
	onError('非H5环境不支持此功能')
	// #endif
}

/**
 * H5 端获取微信授权码（用于支付）
 * 会跳转到微信授权页面，授权成功后回跳到当前页面
 */
export function getWechatPayAuthCode(orderId: string): void {
	// #ifdef H5
	console.log('🔄 [WX-PAY] H5端获取微信支付授权码')
	getWechatAuthCodeImpl(orderId, (code: string) => {
		// 注意：这个回调不会被执行，因为页面会跳转
	}, (error: string) => {
		console.error('❌ [WX-PAY] 获取授权码失败:', error)
	})
	// #endif
	
	// #ifndef H5
	console.log('⚠️ [WX-PAY] 非H5环境，跳过获取授权码')
	// #endif
}

/**
 * 检查是否在微信浏览器中
 */
export function checkIsWechatBrowser(): boolean {
	// #ifdef H5
	return isWechatBrowser()
	// #endif
	
	// #ifndef H5
	return false
	// #endif
}

/**
 * 检查授权码是否已使用
 */
export function checkWxCodeUsed(): boolean {
	// #ifdef H5
