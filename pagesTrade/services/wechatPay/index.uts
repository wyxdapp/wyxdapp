	// #endif
}

// ==================== 小程序端微信支付（带登录码）====================

export function wechatPayMpWithCode(
	params: PaymentParams,
	loginCode: string,
	onSuccess: PaymentSuccessCallback,
	onError: PaymentErrorCallback
): void {
	console.log('💰 [WX-PAY] 小程序端使用登录码支付')
	
	const currentState = getPaymentState(params.orderId)
	if (currentState == PAYMENT_STATE_PROCESSING) {
		console.warn('⚠️ [WX-PAY] 支付正在处理中，防止重复支付')
		onError('支付正在处理中，请稍候')
		return
	}
	
	onError('小程序端支付功能开发中')
}

