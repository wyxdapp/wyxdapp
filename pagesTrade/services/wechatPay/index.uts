// ==================== 平台检测函数 ====================

export function getCurrentPlatform(): string {
	try {
		const systemInfo = uni.getSystemInfoSync()
		const infoStr = JSON.stringify(systemInfo)
		const infoObj = JSON.parse(infoStr) as UTSJSONObject
		const platformVal = infoObj.get('uniPlatform')
		if (platformVal != null) {
			return platformVal.toString()
		}
	} catch (e) {
		console.error('[WX-PAY] 获取平台信息失败:', e)
	}
	return ''
}

export function isAppPlatform(): boolean {
	const platform = getCurrentPlatform()
	return platform == 'app' || platform == 'app-plus' || platform == 'app-android' || platform == 'app-ios' || platform == 'app-harmony'
}

export function isH5Platform(): boolean {
	const platform = getCurrentPlatform()
	return platform == 'web' || platform == 'h5'
}

export function isMpWeixinPlatform(): boolean {
	const platform = getCurrentPlatform()
	return platform == 'mp-weixin'
}

export function getPlatformType(): string {
	if (isAppPlatform()) {
		return 'app'
	} else if (isMpWeixinPlatform()) {
		return 'mp-weixin'
	} else if (isH5Platform()) {
		return 'h5'
	}
	return 'unknown'
}

export function isPaymentAvailable(): boolean {
	const platform = getPlatformType()
	if (platform == 'mp-weixin') {
		return true
	}
	if (platform == 'h5') {
		// #ifdef H5
		try {
			if (typeof window != 'undefined') {
				const ua = (window as any).navigator.userAgent.toLowerCase()
				// 兼容鸿蒙系统微信浏览器
				return ua.indexOf('micromessenger') != -1
					|| (ua.indexOf('hmos') != -1 && ua.indexOf('wechat') != -1)
			}
		} catch (e) {}
		// #endif
		return false
	}
	if (platform == 'app') {
		return true
	}
	return false
}

