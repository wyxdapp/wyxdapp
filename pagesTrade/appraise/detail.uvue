<template>
	<view class="page">
		<!-- 顶部渐变背景 -->
		<view class="hear-bg" :style="headerGradientOuter()"><view class="hear-bg-mask" :style="headerGradientMask()"></view></view>
		<!-- #ifndef H5 -->
		<view class="nav-bar" :style="{ paddingTop: pageStatusBarHeight + 'px' }">
			<view class="nav-content">
				<view class="nav-back" @click="handleBack">
					<UniIcons type="left" :size="22" color="#333333" />
				</view>
				<text class="nav-title">评价详情</text>
				<view class="nav-action"></view>
			</view>
		</view>
		<!-- #endif -->

		<!-- #ifndef H5 -->
		<scroll-view class="scroll-view" scroll-y="true">
		<!-- #endif -->
		<!-- #ifdef H5 -->
		<scroll-view class="scroll-view-h5" scroll-y="true">
		<!-- #endif -->

			<!-- 加载失败 -->
			<view v-if="loadFailed == true" class="fail-container">
				<text class="fail-text">加载失败，请重试</text>
				<view class="retry-btn" @click="retryLoad">
					<text class="retry-text">重试</text>
				</view>
			</view>

			<!-- 评价信息 -->
			<view v-else class="section">
				<view class="user-info">
					<Avatar :url="userAvatar" :customSize="80" clickMode="none" />
					<view class="user-detail">
						<text class="username">{{ userName }}</text>
						<view class="rating-stars">
							<text v-for="i in 5" :key="i" class="star">{{ i <= rating ? '⭐' : '☆' }}</text>
						</view>
					</view>
					<text class="time">{{ createTime }}</text>
				</view>

				<text class="content">{{ appraiseContent }}</text>

				<view v-if="imageList.length > 0" class="images-grid">
					<image
						v-for="(img, index) in imageList"
						:key="index"
						class="grid-image"
						:src="img"
						mode="aspectFill"
						@click="previewImage(index)"
					></image>
				</view>

				<view v-if="tagList.length > 0" class="tags-row">
					<view v-for="(tag, index) in tagList" :key="index" class="tag-item">
						<text class="tag-text">{{ tag }}</text>
					</view>
				</view>
			</view>

			<!-- 底部安全区域 -->
			<view class="safe-bottom"></view>
		</scroll-view>
	</view>
</template>

<script setup lang="uts">
import { ref } from 'vue'
import { onLoad } from '@dcloudio/uni-app'
import UniIcons from '@/components/base/UniIcons.uvue'
import Avatar from '@/components/base/Avatar.uvue'
import { pageStatusBarHeight, initPageLayout } from '@/common/composables/usePageLayout.uts'
import { parseTimeString } from '@/common/utils/dateUtils.uts'
import { COS_BUCKET_ID } from '@/common/config/thirdPartyConfig.uts'
import { handleSilentError } from '@/common/utils/errorHandler.uts'
import { headerGradientOuter, headerGradientMask } from '@/common/utils/themeHelper.uts'

const appraiseId = ref<string>('')
const userAvatar = ref<string>('')
const userName = ref<string>('')
const rating = ref<number>(5)
const appraiseContent = ref<string>('')
const imageList = ref<Array<string>>([])
const tagList = ref<Array<string>>([])
const createTime = ref<string>('')
const orderCover = ref<string>('')
const orderTitle = ref<string>('')
const orderTime = ref<string>('')
const loadFailed = ref<boolean>(false)
const rawDataStr = ref<string>('')

const defaultAvatar = 'https://qyimage-' + COS_BUCKET_ID + '.cos.ap-chengdu.myqcloud.com/iconImages/default_avatar.png'

const handleBack = () => {
	uni.navigateBack({ delta: 1, fail: () => { uni.switchTab({ url: '/pages/index/index' }) } })
}

const getObjString = (obj: UTSJSONObject | null, key: string): string => {
	if (obj == null) return ''
	const val = obj.get(key)
	return (val != null && val.toString() != '') ? val.toString() : ''
}

const getObjNumber = (obj: UTSJSONObject | null, key: string): number => {
	if (obj == null) return 0
	const val = obj.get(key)
	if (val != null) {
		const num = parseInt(val.toString())
		if (isNaN(num) == false) return num
	}
	return 0
}

/**
 * 时间格式化：24小时内显示相对时间，超过显示 M月D日
 */
const formatEvaluateTime = (timeStr: string): string => {
	if (timeStr == '') return ''
	const date = parseTimeString(timeStr)
	if (date == null) return timeStr
	if (isNaN(date.getTime()) == true) return timeStr

	const now = new Date()
	const diff = now.getTime() - date.getTime()

	if (diff < 0) return '刚刚'
	if (diff < 60000) return '刚刚'
	if (diff < 3600000) {
		const minutes = Math.floor(diff / 60000)
		return minutes.toString() + '分钟前'
	}
	if (diff < 86400000) {
		const hours = Math.floor(diff / 3600000)
		return hours.toString() + '小时前'
	}

	const month = date.getMonth() + 1
	const day = date.getDate()
	return month.toString() + '月' + day.toString() + '日'
}

const loadAppraiseDetail = () => {
	loadFailed.value = false
	if (rawDataStr.value == '') {
		loadFailed.value = true
		return
	}
	try {
		const dataObj = JSON.parse(rawDataStr.value) as UTSJSONObject

		const avatar = getObjString(dataObj, 'evaluateUserImage')
		userAvatar.value = (avatar != '') ? avatar : defaultAvatar
		userName.value = getObjString(dataObj, 'evaluateUserNickName')
		rating.value = getObjNumber(dataObj, 'starLevel')
		if (rating.value == 0) rating.value = 5
		appraiseContent.value = getObjString(dataObj, 'commentContent')

		const timeStr = getObjString(dataObj, 'evaluateTime')
		createTime.value = formatEvaluateTime(timeStr)

		// 解析图片列表
		const picListVal = dataObj.get('picUrlList')
		if (picListVal != null && Array.isArray(picListVal) == true) {
			const picArr = picListVal as Array<string | null>
			const imgs: Array<string> = []
			for (let i = 0; i < picArr.length; i = i + 1) {
				const item = picArr[i]
				if (item != null) {
					const url = item.toString()
					if (url != '') {
						imgs.push(url)
					}
				}
			}
			imageList.value = imgs
		}

		loadFailed.value = false
	} catch (e: Error) {
		handleSilentError(e, '解析评价详情数据')
		loadFailed.value = true
	}
}

const retryLoad = () => {
	loadAppraiseDetail()
}

const previewImage = (index: number) => {
	uni.previewImage({ urls: imageList.value, current: index })
}

onLoad((options: OnLoadOptions) => {
	initPageLayout()
	if (options != null) {
		const optionsStr = JSON.stringify(options)
		const optionsObj = JSON.parse(optionsStr) as UTSJSONObject
		const idVal = getObjString(optionsObj, 'id')
		if (idVal != '') {
			appraiseId.value = idVal
		}
		const dataVal = getObjString(optionsObj, 'data')
		if (dataVal != '') {
			const decoded = decodeURIComponent(dataVal)
			if (decoded != null) {
				rawDataStr.value = decoded as string
			}
		}
	}
	loadAppraiseDetail()
})
</script>

<style scoped>
