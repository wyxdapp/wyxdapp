	margin-right: 12rpx;
	margin-bottom: 12rpx;
}

.tags-row {
	flex-direction: row;
	flex-wrap: wrap;
}

.tag-item {
	padding-top: 6rpx;
	padding-bottom: 6rpx;
	padding-left: 16rpx;
	padding-right: 16rpx;
	background-color: #E3F2FD;
	border-radius: 20rpx;
	margin-right: 12rpx;
	margin-bottom: 12rpx;
}

.tag-text {
	font-size: 22rpx;
	color: #37B1F2;
}

.card-title {
	font-size: 30rpx;
	color: #333333;
	font-weight: bold;
	margin-bottom: 20rpx;
}

.order-content {
	flex-direction: row;
}

.order-cover {
	width: 120rpx;
	height: 120rpx;
	border-radius: 8rpx;
	margin-right: 20rpx;
}

.order-info {
	flex: 1;
	flex-direction: column;
	justify-content: center;
}

.order-title {
	font-size: 28rpx;
