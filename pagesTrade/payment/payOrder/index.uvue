// 定时器生命周期管理
let timerHandles: number[] = []

function safeSetTimeout(callback: () => void, ms: number): number {
	const handle = setTimeout(callback, ms)
	timerHandles.push(handle)
	return handle
}

function clearAllTimers(): void {
	for (const handle of timerHandles) {
		clearTimeout(handle)
	}
	timerHandles = []
}

// ==================== 辅助函数（必须在使用前定义）====================

// 内联金额格式化（替代 money.uts）
const formatMoney = (value: number): string => {
	if (isNaN(value)) return '0.00'
	const cents = Math.round(value * 100)
	const absCents = (cents < 0) ? -cents : cents
	const yuan = Math.floor(absCents / 100)
	const fen = absCents % 100
	const fenStr = (fen < 10) ? ('0' + fen.toString()) : fen.toString()
	const result = yuan.toString() + '.' + fenStr
	return (cents < 0) ? ('-' + result) : result
}

// 从对象获取字符串属性
const getObjString = (obj: UTSJSONObject | null, key: string): string => {
	if (obj == null) return ''
	const val = obj.get(key)
	if (val != null && val.toString() != '') {
		return val.toString()
	}
	return ''
}

// 从对象获取数字属性
const getObjNumber = (obj: UTSJSONObject | null, key: string): number => {
	if (obj == null) return 0
	const val = obj.get(key)
	if (val != null) {
		const num = parseFloat(val.toString())
		if (isNaN(num) == false) {
			return num
		}
	}
	return 0
}


// 延迟函数
const delay = (ms: number) => {
	let timer: number = 0
	return new Promise<number>((resolve: (value: number) => void) => {
		timer = safeSetTimeout(() => {
			resolve(timer)
		}, ms)
	})
}

// ==================== URL 参数解析函数（H5 端专用）====================

/**
 * URL 参数解析结果类
 */
class UrlParams {
	orderKid: string = ''
	code: string = ''
	state: string = ''
	
	constructor(orderKid: string, code: string, state: string) {
		this.orderKid = orderKid
		this.code = code
		this.state = state
	}
}

/**
 * 解析 URL 查询参数
 * @param search URL 查询字符串（如 ?orderKid=xxx&code=yyy）
 * @returns 参数对象
 */
const parseQueryParams = (search: string): UTSJSONObject => {
	const result = {} as UTSJSONObject
	if (search == '' || search == null) return result
	
	// 移除开头的 ?
	let queryStr = search
	if (queryStr.charAt(0) == '?') {
		queryStr = queryStr.substring(1)
	}
	
	const pairs = queryStr.split('&')
	for (let i = 0; i < pairs.length; i = i + 1) {
		const pair = pairs[i].split('=')
		if (pair.length >= 2) {
			const key = pair[0]
			const value = safeDecodeURIComponent(pair[1])
			result.set(key, value)
		}
	}
	
	return result
}

/**
 * 解析 Hash 路由参数
 * @param hash URL hash 部分（如 #/page?orderKid=xxx）
 * @returns 参数对象
 */
const parseHashParams = (hash: string): UTSJSONObject => {
	const result = {} as UTSJSONObject
	if (hash == '' || hash == null) return result
	
	// 查找 ? 的位置
	const queryIndex = hash.indexOf('?')
	if (queryIndex == -1) return result
	
	const queryStr = hash.substring(queryIndex + 1)
	return parseQueryParams(queryStr)
}

/**
 * 解析完整 URL 获取所有参数
 * 优先使用 Hash 路由中的参数，其次使用查询参数
 * 
 * @returns UrlParams 解析结果
 */
const parseUrlParams = (): UrlParams => {
	let orderKidVal = ''
	let codeVal = ''
	let stateVal = ''
	
	// #ifdef H5
	try {
		if (typeof window != 'undefined') {
			// 使用安全的 URL 参数解析（自动处理 search 和 hash 参数）
			const safeParams = getUrlParams()
			
			// 获取 orderKid
			const orderKidParam = safeParams.get('orderKid')
			if (orderKidParam != null && orderKidParam != '') {
				orderKidVal = orderKidParam
			}
			
			// 获取 code（微信授权回跳参数）
			const codeParam = safeParams.get('code')
			if (codeParam != null && codeParam != '') {
				codeVal = codeParam
			}
			
			// 获取 state
			const stateParam = safeParams.get('state')
			if (stateParam != null && stateParam != '') {
				stateVal = stateParam
			}
			
			console.log('🔍 [URL-PARSE] 解析结果: orderKid=' + orderKidVal + ', code=' + (codeVal != '' ? '存在' : '不存在') + ', state=' + stateVal)
		}
	} catch (e) {
		handleSilentError(e, '解析URL参数')
	}
	// #endif
	
	return new UrlParams(orderKidVal, codeVal, stateVal)
}

/**
 * 清理 URL 中的授权码参数
 * @param orderKid 订单 ID（保留在 URL 中）
 */
const cleanUrlAuthCode = (orderKid: string): void => {
	// #ifdef H5
	try {
		if (typeof window != 'undefined' && window.location != null && window.history != null) {
			const cleanUrl = window.location.origin + window.location.pathname + '?orderKid=' + orderKid
			window.history.replaceState({}, document.title, cleanUrl)
		}
	} catch (e) {
		handleSilentError(e, '清理URL参数')
	}
	// #endif
}

/**
 * 检查授权码是否已使用
 */
const isWxCodeUsed = (): boolean => {
	try {
		const usedVal = uni.getStorageSync('wxCode_used')
		if (usedVal != null && usedVal.toString() == 'true') {
			return true
		}
	} catch (e) {}
	return false
}

/**
 * 标记授权码为已使用
 */
const markWxCodeUsed = (): void => {
	try {
		uni.setStorageSync('wxCode_used', 'true')
	} catch (e) {}
}

/**
 * 清理授权码相关存储
 */
const clearWxCodeStorage = (): void => {
	try {
		uni.removeStorageSync('wxCode')
		uni.removeStorageSync('wxCode_used')
	} catch (e) {}
}

// ==================== 错误处理函数 ====================

/**
 * 错误类型枚举
 */
const ERROR_TYPE_USER_CANCEL = 'USER_CANCEL'
const ERROR_TYPE_NETWORK = 'NETWORK_ERROR'
const ERROR_TYPE_PARAM = 'PARAM_ERROR'
const ERROR_TYPE_AUTH = 'AUTH_ERROR'
const ERROR_TYPE_BACKEND = 'BACKEND_ERROR'
const ERROR_TYPE_UNKNOWN = 'UNKNOWN_ERROR'

/**
 * 分类错误类型
 * @param error 错误信息
 * @returns 错误类型
 */
const classifyPaymentError = (error: string): string => {
	const errorLower = error.toLowerCase()
	
	// 用户取消
	if (error.indexOf('取消') != -1 || errorLower.indexOf('cancel') != -1) {
		return ERROR_TYPE_USER_CANCEL
	}
	
	// 网络错误
	if (error.indexOf('网络') != -1 || errorLower.indexOf('network') != -1 || 
		errorLower.indexOf('timeout') != -1 || error.indexOf('请求失败') != -1) {
		return ERROR_TYPE_NETWORK
	}
	
	// 参数错误
	if (error.indexOf('参数') != -1 || errorLower.indexOf('param') != -1 || 
		error.indexOf('缺少') != -1 || error.indexOf('无效') != -1) {
		return ERROR_TYPE_PARAM
	}
	
	// 授权错误
	if (error.indexOf('授权') != -1 || errorLower.indexOf('code') != -1 ||
		error.indexOf('openid') != -1) {
		return ERROR_TYPE_AUTH
	}
	
	// 后端错误
	if (error.indexOf('服务') != -1 || error.indexOf('系统') != -1) {
		return ERROR_TYPE_BACKEND
	}
	
	return ERROR_TYPE_UNKNOWN
}

/**
 * 获取用户友好的错误提示
 * @param error 原始错误信息
 * @param errorType 错误类型
 * @returns 用户友好的错误提示
 */
const getUserFriendlyErrorMessage = (error: string, errorType: string): string => {
	if (errorType == ERROR_TYPE_USER_CANCEL) {
		return '已取消支付'
	}
	if (errorType == ERROR_TYPE_NETWORK) {
		return '网络连接失败，请检查网络后重试'
	}
	if (errorType == ERROR_TYPE_PARAM) {
		return '支付参数错误，请重试'
	}
	if (errorType == ERROR_TYPE_AUTH) {
		return '微信授权失败，请重新授权'
	}
	if (errorType == ERROR_TYPE_BACKEND) {
		return '服务暂时不可用，请稍后重试'
	}
	
	// 如果有具体错误信息，显示具体信息
	if (error != '' && error.length < 30) {
		return error
	}
	
	return '支付失败，请重试'
}

// ==================== Store 访问函数（使用 loginHelper 可靠版本）====================

// 获取用户 Token
const getUserToken = (): string => {
