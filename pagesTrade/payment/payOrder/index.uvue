}


// ==================== 响应式数据 ====================
const loading = ref<boolean>(false)
const initDataFlag = ref<boolean>(false)
const orderData = ref<UTSJSONObject | null>(null)
const payMethod = ref<number>(0) // 0余额 1微信 2支付宝
const passwordInputVisity = ref<boolean>(false)
const orderKid = ref<string>('')
const isPaymentProcessing = ref<boolean>(false)
const payPassword = ref<string>('')
const balancePayEnabled = ref<boolean>(false) // 零钱支付资格状态

// 🔧 H5 端自动支付状态（授权回跳后使用）
const pendingAutoPayment = ref<boolean>(false)
const authCodeFromRedirect = ref<string>('')

// 状态栏高度相关
const statusBarHeight = ref<number>(0)

// 初始化状态栏高度
const initStatusBarHeight = () => {
	try {
		const systemInfo = uni.getSystemInfoSync()
		const systemInfoObj = JSON.parse(JSON.stringify(systemInfo)) as UTSJSONObject
		const statusBarVal = systemInfoObj.get('statusBarHeight')
		if (statusBarVal != null) {
			const sbHeight = parseInt(statusBarVal.toString())
			if (isNaN(sbHeight) == false) {
				statusBarHeight.value = sbHeight
			}
		}
	} catch (e) {
		statusBarHeight.value = 44
	}
}

// 返回按钮处理
