	font-size: 26rpx;
	color: #666666;
}

.order-price {
	font-size: 28rpx;
	color: #333333;
}

.order-total {
	flex-direction: row;
	justify-content: flex-end;
	align-items: center;
	padding-top: 24rpx;
	border-top-width: 2rpx;
	border-top-style: solid;
	border-top-color: #f0f0f0;
}

.total-label {
	font-size: 28rpx;
	color: #333333;
	margin-right: 16rpx;
}

.total-value {
	font-size: 36rpx;
	color: #FF6B35;
	font-weight: bold;
}

.section-card {
	background-color: #ffffff;
	padding-top: 24rpx;
	padding-bottom: 24rpx;
	padding-left: 32rpx;
	padding-right: 32rpx;
	margin-bottom: 20rpx;
}

.section-header {
	flex-direction: row;
	align-items: center;
	margin-bottom: 24rpx;
}

.title-indicator {
	width: 6rpx;
	height: 28rpx;
	background-color: #37B1F2;
	border-radius: 3rpx;
	margin-right: 12rpx;
}

.section-title {
	font-size: 32rpx;
	color: #333333;
	font-weight: bold;
}

.textarea {
	width: 100%;
	min-height: 196rpx;
	padding: 20rpx;
	background-color: #f8f9fa;
	border-radius: 8rpx;
	font-size: 26rpx;
	line-height: 1.6;
	border-width: 2rpx;
	border-style: solid;
	border-color: #e0e0e0;
}

.info-list {
	flex-direction: column;
}

.info-item {
	flex-direction: row;
	align-items: center;
	padding: 24rpx 0;
	border-bottom-width: 2rpx;
	border-bottom-style: solid;
	border-bottom-color: #f0f0f0;
}

