	background-color: #ffffff;
	margin-top: 280rpx;
	margin-left: 28rpx;
	margin-right: 28rpx;
	margin-bottom: 20rpx;
	border-radius: 16rpx;
	padding-top: 32rpx;
	padding-bottom: 32rpx;
	padding-left: 24rpx;
	padding-right: 24rpx;
}

.amount-section {
	flex-direction: row;
	align-items: flex-end;
	justify-content: center;
	padding-top: 24rpx;
	padding-bottom: 24rpx;
}

.amount-symbol {
	font-size: 28rpx;
	color: #333333;
	font-weight: bold;
	margin-right: 8rpx;
}

.amount-value {
	font-size: 64rpx;
	color: #333333;
	font-weight: bold;
}

.divider {
	height: 2rpx;
	background-color: #f0f0f0;
	margin-top: 24rpx;
	margin-bottom: 24rpx;
}

.info-section {
	flex-direction: column;
	padding-top: 16rpx;
	padding-bottom: 16rpx;
}

.info-item {
	font-size: 28rpx;
