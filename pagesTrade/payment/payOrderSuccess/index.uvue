<template>
	<view class="success-page">
		<view class="header-bg"></view>
		
		<view class="success-content">
			<view class="success-icon-wrapper">
				<text class="success-icon">✓</text>
			</view>
			<text class="success-title">支付成功！</text>
			<text class="success-subtitle">欢迎再次光临</text>
		</view>
		
		<view class="order-card">
			<view class="amount-section">
				<text class="amount-symbol">¥</text>
				<text class="amount-value">{{ payMoney }}</text>
			</view>
			
			<view class="divider"></view>
			
			<view class="info-section">
				<text class="info-item">订单编号：{{ orderNo }}</text>
				<text class="info-item">下单时间：{{ createTime }}</text>
				<text class="info-item">支付方式：{{ payMethodText }}</text>
			</view>
			
			<view class="divider"></view>
			
			<view class="action-row" @click="goToOrderDetail">
				<text class="action-text">订单详情</text>
				<text class="arrow">›</text>
			</view>
		</view>
		
		<view class="footer-button">
			<view class="primary-btn" @click="goToHome">
				<text class="primary-btn-text">返回首页</text>
			</view>
		</view>
	</view>
</template>

<script setup lang="uts">
import { ref, computed, onUnmounted } from 'vue'
import { onLoad } from '@dcloudio/uni-app'
import { getCurrentTimeString } from '@/common/utils/dateUtils.uts'
import { goToHome } from '@/common/utils/utsSafe.uts'
import { initUserInfoAction, updateUserInfoAction } from '@/stores/user.uts'
import { refreshCurrentUserProfile, invalidateCurrentUserProfile, destroyEventListeners } from '@/common/composables/useCurrentUserProfile.uts'
import { handleSilentError } from '@/common/utils/errorHandler.uts'

// ==================== 响应式数据（拆分为独立 ref）====================
const payMoney = ref<string>('0.00')
const orderNo = ref<string>('')
const createTime = ref<string>('')
const payMethod = ref<number>(0)
const orderId = ref<string>('')
const orderKid = ref<string>('')
const shortKid = ref<string>('')
const orderType = ref<number>(0)

// 支付方式文本（使用独立 ref 而非 computed 访问对象属性）
const payMethodText = computed((): string => {
	const method = payMethod.value
	if (method == 0) {
		return '余额支付'
	} else if (method == 1) {
		return '微信支付'
	} else if (method == 2) {
		return '支付宝'
	}
	return '在线支付'
})

// 跳转订单详情
const goToOrderDetail = () => {
	let targetId = orderKid.value
	if (targetId == '') {
		targetId = orderId.value
	}
	if (targetId != '') {
		uni.redirectTo({
			url: '/pagesTrade/orderDetails/index?orderKid=' + targetId
		})
	} else {
		uni.showToast({ title: '订单信息不完整', icon: 'none' })
	}
}

// 返回首页（使用全局工具函数）
// goToHome 已从 utsSafe.uts 导入

// ==================== 生命周期 ====================
onLoad((options: OnLoadOptions) => {
	if (options != null) {
		const optionsStr = JSON.stringify(options)
		const optionsObj = JSON.parse(optionsStr) as UTSJSONObject
		
		// 支付金额
		const payMoneyVal = optionsObj.get('payMoney')
		if (payMoneyVal != null && payMoneyVal.toString() != '') {
			payMoney.value = payMoneyVal.toString()
		}
		
		// 订单号（优先使用 shortKid）
		const shortKidVal = optionsObj.get('shortKid')
		if (shortKidVal != null && shortKidVal.toString() != '') {
			shortKid.value = shortKidVal.toString()
			orderNo.value = shortKidVal.toString()
		} else {
			const orderNoVal = optionsObj.get('orderNo')
			if (orderNoVal != null && orderNoVal.toString() != '') {
				orderNo.value = orderNoVal.toString()
			}
		}
		
		// 订单 Kid
		const orderKidVal = optionsObj.get('orderKid')
		if (orderKidVal != null && orderKidVal.toString() != '') {
			orderKid.value = orderKidVal.toString()
		}
		
		// 订单 ID（兼容旧参数）
		const orderIdVal = optionsObj.get('orderId')
		if (orderIdVal != null && orderIdVal.toString() != '') {
			orderId.value = orderIdVal.toString()
		}
		
		// 创建时间
		const createTimeVal = optionsObj.get('creatTime')
		if (createTimeVal != null && createTimeVal.toString() != '') {
			createTime.value = createTimeVal.toString()
		} else {
			const createTimeVal2 = optionsObj.get('createTime')
			if (createTimeVal2 != null && createTimeVal2.toString() != '') {
				createTime.value = createTimeVal2.toString()
			} else {
				createTime.value = getCurrentTimeString()
			}
		}
		
		// 支付方式
		const payMethodVal = optionsObj.get('payMethod')
		if (payMethodVal != null && payMethodVal.toString() != '') {
			const methodNum = parseInt(payMethodVal.toString())
			if (isNaN(methodNum) == false) {
				payMethod.value = methodNum
			}
		}

		// 订单类型
		const orderTypeVal = optionsObj.get('orderType')
		if (orderTypeVal != null && orderTypeVal.toString() != '') {
			const typeNum = parseInt(orderTypeVal.toString())
			if (isNaN(typeNum) == false) {
				orderType.value = typeNum
			}
		}
	}

	// 🎯 会员订单支付成功后刷新用户信息
	if (orderType.value == 30) {
		// 🔧 修复：增加延迟时间到2秒，确保后端处理完成
		setTimeout(() => {
			console.log('[PaySuccess] 会员订单支付成功，从服务器刷新用户信息')
			
			// 🔧 新增：先使缓存失效
			invalidateCurrentUserProfile()
			
			// 然后强制刷新
			refreshCurrentUserProfile().then((profile: any | null) => {
				if (profile != null) {
					try {
						const profileStr = JSON.stringify(profile)
						const profileObj = JSON.parse(profileStr) as UTSJSONObject
						// 更新本地存储的用户信息
						updateUserInfoAction(profileObj)
						
						// 🔧 新增：触发用户信息更新事件，通知其他页面刷新VIP状态
						uni.$emit('user_info_update', profileObj)
						
						console.log('[PaySuccess] 会员状态已更新')
					} catch (e) {}
				}
			}).catch((error: any | null): void => {
				handleSilentError(error as any, '刷新用户信息')
				// 降级：尝试从本地存储读取
				initUserInfoAction()
			})
		}, 2000) // 🔧 修复：增加到2秒，确保后端处理完成
	}
})

// 🔧 优化：组件卸载时清理 useCurrentUserProfile 事件监听器，防止内存泄漏
onUnmounted(() => {
	destroyEventListeners()
})
</script>

