// 修改价格（向导端）
const handleModifyPrice = () => {
	const currentPrice = totalMoney.value
	uni.showModal({
		title: '修改订单价格',
		editable: true,
		placeholderText: '当前价格：￥' + currentPrice,
		success: (res: UniShowModalResult) => {
			if (res.confirm == true && res.content != null) {
				const val = res.content.trim()
				if (val == '') {
					uni.showToast({ title: '请输入价格', icon: 'none' })
					return
				}
				const num = parseFloat(val)
				if (isNaN(num) == true || num <= 0) {
					uni.showToast({ title: '价格必须大于0', icon: 'none' })
					return
				}
				doModifyPrice(num)
			}
		}
	})
}

