// ==================== 计算属性（使用独立 ref 替代）====================

// 状态文本
const statusText = ref<string>('状态有误')
// 状态图标
const statusIcon = ref<string>('')

// 更新状态文本
const updateStatusText = () => {
	const os = orderStatu.value
	const rs = refundStatu.value
	const ot = orderType.value
	if (os == 5) {
		statusText.value = '待接单'
	} else if (os == 6) {
		statusText.value = '待接单·已付款'
	} else if (os == 7) {
		statusText.value = '待接单·已退款'
	} else if (os == ORDER_STATUS_PENDING) {
		statusText.value = '待付款'
	} else if (os == ORDER_STATUS_PAID) {
		statusText.value = '付款中'
	} else if (os == ORDER_STATUS_CONFIRMED) {
		// 特殊订单（会员/礼物/抽奖）付款成功即完成（虚拟商品无需服务）
		if (ot == ORDER_TYPE_CUSTOM || ot == ORDER_TYPE_GUIDE || ot == ORDER_TYPE_LINE) {
			statusText.value = '已完成'
		} else {
			// 🔧 修复：如果有退款状态，优先显示退款状态
			if (rs == REFUND_STATUS_PENDING) {
				statusText.value = '退款中'
			} else if (rs == REFUND_STATUS_SUCCESS) {
				statusText.value = '退款成功'
			} else if (rs == REFUND_STATUS_FAILED) {
				statusText.value = '退款失败'
			} else {
				// 普通订单付款成功后等待导游接单
				statusText.value = '待接单'
			}
		}
	} else if (os == ORDER_STATUS_IN_PROGRESS) {
		// 🔧 修复：如果有退款状态，优先显示退款状态
		if (rs == REFUND_STATUS_PENDING) {
			statusText.value = '退款中'
		} else if (rs == REFUND_STATUS_SUCCESS) {
			statusText.value = '退款成功'
		} else if (rs == REFUND_STATUS_FAILED) {
			statusText.value = '退款失败'
		} else {
			statusText.value = '待接单'
		}
	} else if (os == ORDER_STATUS_COMPLETED) {
		// 🔧 修复：如果有退款状态，优先显示退款状态
		if (rs == REFUND_STATUS_PENDING) {
			statusText.value = '退款中'
		} else if (rs == REFUND_STATUS_SUCCESS) {
			statusText.value = '退款成功'
		} else if (rs == REFUND_STATUS_FAILED) {
			statusText.value = '退款失败'
		} else {
			statusText.value = '进行中'
		}
	} else if (os == ORDER_STATUS_CANCELLED) {
		statusText.value = '待评价'
	} else if (os == ORDER_STATUS_REFUNDING) {
		statusText.value = '已评价'
	} else if (os == ORDER_STATUS_REFUNDED && rs == REFUND_STATUS_PENDING) {
		statusText.value = '退款中'
	} else if (os == ORDER_STATUS_REFUNDED && rs == REFUND_STATUS_SUCCESS) {
		statusText.value = '退款成功'
	} else if (os == ORDER_STATUS_REFUNDED && rs == REFUND_STATUS_FAILED) {
		statusText.value = '退款失败'
	} else if (os == ORDER_STATUS_REFUNDED) {
		statusText.value = '订单已取消'
	} else if (os == ORDER_STATUS_CLOSED) {
		statusText.value = '订单已取消'
	} else {
		statusText.value = '状态缺失'
	}
}

// 更新状态图标
const updateStatusIcon = () => {
	const os = orderStatu.value
	const rs = refundStatu.value
	const ts = timestamp.value
	
	// 🔧 修复：任何订单状态下，如果有退款状态，优先显示退款图标
	if (rs == REFUND_STATUS_PENDING || rs == REFUND_STATUS_SUCCESS || rs == REFUND_STATUS_FAILED) {
		statusIcon.value = 'https://qyimage-' + COS_BUCKET_ID + '.cos.ap-chengdu.myqcloud.com/iconImages/order_icon_refund.png'
	} else if (os == ORDER_STATUS_PENDING && ts > 0) {
		statusIcon.value = 'https://qyimage-' + COS_BUCKET_ID + '.cos.ap-chengdu.myqcloud.com/iconImages/order_icon_waitPay.png'
	} else if (os == ORDER_STATUS_PENDING && ts == 0) {
		statusIcon.value = 'https://qyimage-' + COS_BUCKET_ID + '.cos.ap-chengdu.myqcloud.com/iconImages/order_icon_close.png'
	} else if (os == ORDER_STATUS_CONFIRMED && (isSpecialOrderType.value == true)) {
		statusIcon.value = 'https://qyimage-' + COS_BUCKET_ID + '.cos.ap-chengdu.myqcloud.com/iconImages/order_icon_waitSay.png'
	} else if (os == ORDER_STATUS_PAID || os == ORDER_STATUS_IN_PROGRESS || os == ORDER_STATUS_COMPLETED || (os == ORDER_STATUS_CONFIRMED && isSpecialOrderType.value == false)) {
		statusIcon.value = 'https://qyimage-' + COS_BUCKET_ID + '.cos.ap-chengdu.myqcloud.com/iconImages/order_icon_doing.png'
	} else if (os == ORDER_STATUS_CANCELLED || os == ORDER_STATUS_REFUNDING) {
		statusIcon.value = 'https://qyimage-' + COS_BUCKET_ID + '.cos.ap-chengdu.myqcloud.com/iconImages/order_icon_waitSay.png'
	} else if (os == ORDER_STATUS_REFUNDED || os == ORDER_STATUS_CLOSED) {
		statusIcon.value = 'https://qyimage-' + COS_BUCKET_ID + '.cos.ap-chengdu.myqcloud.com/iconImages/order_icon_close.png'
	} else {
		statusIcon.value = ''
	}
}

// 从订单数据更新所有字段
const updateOrderFields = (data: UTSJSONObject | null) => {
	if (data == null) return
	
	orderStatu.value = getObjNumber(data, 'orderStatu')
	refundStatu.value = getObjNumber(data, 'refundStatu')
	orderType.value = getObjNumber(data, 'orderType')
	guideName.value = getObjString(data, 'guideName')
	guideKid.value = getObjString(data, 'guideKid')
	guidePhone.value = getObjString(data, 'guidePhone')
	touristName.value = getObjString(data, 'touristName')
	// 收入订单卡片显示游客昵称：优先使用 userName/userNickname（游客账号昵称）
	// touristName 是下单联系人姓名，在游客信息卡片中单独展示
	touristNickname.value = getObjString(data, 'userName')
	if (touristNickname.value == '') {
		touristNickname.value = getObjString(data, 'userNickname')
	}
	if (touristNickname.value == '') {
		touristNickname.value = touristName.value
	}
	touristKid.value = getObjString(data, 'touristKid')
	touristPhone.value = getObjString(data, 'touristPhone')
	adultNumber.value = getObjNumber(data, 'adultNumber')
	childrenNumber.value = getObjNumber(data, 'childrenNumber')
	touristOrderDetailsPic.value = getObjString(data, 'touristOrderDetailsPic')
	// 兼容后端返回的游客头像字段：优先 touristOrderDetailsPic，其次 userAvatar，最后 userImg
	if (touristOrderDetailsPic.value == '') {
		touristOrderDetailsPic.value = getObjString(data, 'userAvatar')
	}
	if (touristOrderDetailsPic.value == '') {
		touristOrderDetailsPic.value = getObjString(data, 'userImg')
	}
	// 兼容后端返回的向导头像字段：优先 guideAvatar，其次 guideImg
	guideAvatar.value = getObjString(data, 'guideAvatar')
	if (guideAvatar.value == '') {
		guideAvatar.value = getObjString(data, 'guideImg')
	}
	// 不再将 guideAvatar 填充到 touristOrderDetailsPic
	// 向导预约订单的展示图根据 type 决定：
	// - 支出订单（type=1）：显示向导头像（guideAvatar）
	// - 收入订单（type=2）：显示游客头像（touristOrderDetailsPic）
	if (type.value == 1) {
		// 支出订单：展示向导头像
		orderCardDisplayPic.value = guideAvatar.value != '' ? guideAvatar.value : 'https://jiasu.wyxdapp.com/iconimages/default_avatar.png'
	} else {
		// 收入订单：展示游客头像
		orderCardDisplayPic.value = touristOrderDetailsPic.value != '' ? touristOrderDetailsPic.value : 'https://jiasu.wyxdapp.com/iconimages/default_avatar.png'
	}
	orderTitle.value = getObjString(data, 'orderTitle')
	totalMoney.value = getObjString(data, 'totalMoney')
	travelDate.value = getObjString(data, 'travelDate')
	travelTotalTime.value = getObjString(data, 'travelTotalTime')
	shortKid.value = getObjString(data, 'shortKid')
	orderRemarks.value = getObjString(data, 'orderRemarks')
	createTime.value = getObjString(data, 'createTime')
	refundKid.value = getObjString(data, 'refundKid')
	
	// 解析推广订单相关字段
	isPromotionOrder.value = parseIsPromotionOrder(data)
	commissionAmount.value = formatCommission(data)
	
	// 处理 picUrls 数组（如果后端返回了路线图片）
	const picUrlsVal = data.get('picUrls')
	if (picUrlsVal != null && Array.isArray(picUrlsVal) == true) {
		const picUrls = picUrlsVal as Array<any>
		if (picUrls.length > 0) {
			const firstPic = picUrls[0]
			if (firstPic != null) {
				firstPicUrl.value = getAnyString(firstPic, 'picUrl')
			}
		}
	}
	// 如果 picUrls 为空，路线订单不再回退到 guideAvatar（路线订单应显示路线主图）
	// 仅向导预约订单才使用 guideAvatar 作为回退
	if (firstPicUrl.value == '' && guideAvatar.value != '' && orderType.value != 10) {
		firstPicUrl.value = guideAvatar.value
	}
	
	if (orderRemarks.value == '') {
		orderRemarks.value = '无'
	}
	
	// 更新派生数据
	updateIsSpecialOrderType()
	
	// 判断当前用户是否为订单下单者
	const currentUserKid = getUserKid()
	if (currentUserKid != '' && touristKid.value != '') {
		// 优先通过游客ID精确判断
		isOrderOwner.value = (currentUserKid == touristKid.value)
	} else {
		// touristKid 为空时，待接单状态默认非下单者（显示立即接单），其他状态根据 type 推断
		const os = orderStatu.value
		if (os == 5 || os == 6) {
			isOrderOwner.value = false
		} else {
			isOrderOwner.value = (type.value == 1)
		}
	}
	
	// 根据当前用户身份动态修正 type（解决抢单成功后 type 未更新的问题）
	// 当前用户是向导 → 收入订单（type=2）；当前用户是游客 → 支出订单（type=1）
	if (currentUserKid != '') {
		if (guideKid.value != '' && currentUserKid == guideKid.value) {
			type.value = 2
			isCurrentUserGuide.value = true
			// 收入订单：展示游客头像
			orderCardDisplayPic.value = touristOrderDetailsPic.value != '' ? touristOrderDetailsPic.value : 'https://jiasu.wyxdapp.com/iconimages/default_avatar.png'
		} else if (touristKid.value != '' && currentUserKid == touristKid.value) {
			type.value = 1
			isCurrentUserGuide.value = false
			// 支出订单：展示向导头像
			orderCardDisplayPic.value = guideAvatar.value != '' ? guideAvatar.value : 'https://jiasu.wyxdapp.com/iconimages/default_avatar.png'
		}
	}
	
	// 待接单状态且非下单者（第三方向导查看）：订单卡片显示游客头像和昵称
	const isWaitGrab = (orderStatu.value == 5 || orderStatu.value == 6)
	if (isWaitGrab == true && isOrderOwner.value == false) {
		orderCardDisplayPic.value = touristOrderDetailsPic.value != '' ? touristOrderDetailsPic.value : 'https://jiasu.wyxdapp.com/iconimages/default_avatar.png'
	}
	
	// 支出订单待接单状态：向导昵称显示"等待向导接单"
	if (type.value == 1) {
		const os = orderStatu.value
		const isWaitingGuide = (os == ORDER_STATUS_CONFIRMED && isSpecialOrderType.value == false) || os == ORDER_STATUS_IN_PROGRESS
		if (isWaitingGuide == true) {
			guideName.value = '等待向导接单'
		}
	}
	
	updateStatusText()
	updateStatusIcon()
}

// 初始化倒计时
const initDropTime = (val: string): number => {
	if (val == null || val == '') return 0
	const nowTime = Math.floor(Date.now() / 1000)
	const dateStr = val.replace(/-/g, "/")
	const creatTime = Math.floor(new Date(dateStr).getTime() / 1000) + 1800
	if (nowTime >= creatTime) {
		return 0
	}
	return creatTime - nowTime
}

// 标记订单相关通知为已读
const markOrderNotificationsRead = async (targetOrderId: string, targetShortId: string) => {
	try {
		const userId = getUserId()
		if (userId == '') return
		
		const params = new GetNotificationHistoryParams()
		params.userId = userId
		params.page = 1
		params.size = 50
		const history = await getNotificationHistory(params)
		const historyObj = toJsonObj(history)
		if (historyObj == null) return
		
		const code = getObjNumber(historyObj, 'code')
		if (code != 200) return
		
		const dataVal = historyObj.get('data')
		if (dataVal == null) return
		const dataObj = toJsonObj(dataVal)
		if (dataObj == null) return
		
		const entitiesVal = dataObj.get('entities')
		if (entitiesVal == null || Array.isArray(entitiesVal) == false) return
		
		const entities = entitiesVal as Array<any>
		let i = 0
		while (i < entities.length) {
			const item = entities[i]
			const itemObj = toJsonObj(item)
			if (itemObj != null) {
				const isReadVal = itemObj.get('isRead')
				const isRead = (isReadVal != null && isReadVal.toString() == 'true')
				
				if (isRead == false) {
					const itemOrderKid = getObjString(itemObj, 'orderKid')
					const itemShortOrderId = getObjString(itemObj, 'shortOrderId')
					
					const matchOrder = (itemOrderKid != '' && itemOrderKid == targetOrderId)
					const matchShort = (itemShortOrderId != '' && targetShortId != '' && itemShortOrderId == targetShortId)
					
					if (matchOrder == true || matchShort == true) {
						let notifId = getObjString(itemObj, 'kid')
						if (notifId == '') {
							notifId = getObjString(itemObj, 'id')
						}
						if (notifId == '') {
							notifId = getObjString(itemObj, 'notificationId')
						}
						if (notifId != '') {
							try {
								await markNotificationRead(notifId)
							} catch (e) {
								handleSilentError(e, '标记通知已读')
							}
						}
					}
				}
			}
			i = i + 1
		}
		
		// 刷新未读数并更新徽章
		await updateTabBarBadge()
	} catch (e) {
		handleSilentError(e, '标记订单通知已读')
	}
}

// 更新 TabBar 徽章
const updateTabBarBadge = async () => {
	try {
		const userId = getUserId()
		if (userId == '') return
		
		const params = new GetNotificationHistoryParams()
		params.userId = userId
		params.page = 1
		params.size = 1
		const result = await getNotificationHistory(params)
		const resultObj = toJsonObj(result)
		if (resultObj == null) return
		
		const code = getObjNumber(resultObj, 'code')
		if (code != 200) return
		
		const dataVal = resultObj.get('data')
		if (dataVal == null) return
		const dataObj = toJsonObj(dataVal)
		if (dataObj == null) return
		
		const unreadCount = getObjNumber(dataObj, 'count')
		if (unreadCount > 0) {
			let badgeText = unreadCount.toString()
			if (unreadCount > BADGE_COUNT_MAX_DISPLAY) {
				badgeText = BADGE_COUNT_MAX_DISPLAY.toString() + '+'
			}
			uni.setTabBarBadge({ index: 2, text: badgeText })
		} else {
			uni.removeTabBarBadge({ index: 2 })
		}
	} catch (e) {
		handleSilentError(e, '更新徽章')
	}
}

// ========== 保险相关 ==========
// 检查订单的保险状态
const checkInsuranceStatus = () => {
	const kid = orderKid.value
	if (kid == '') return
	const params = new GetInsuranceByTripOrderParams()
	params.tripOrderKid = kid
	getInsuranceByTripOrder(params).then((res: UTSJSONObject | null) => {
		if (res != null) {
			const code = getObjNumber(res, 'code')
			if (code == 200) {
				const dataVal = res.get('data')
				if (dataVal != null) {
					const dataObj = toJsonObj(dataVal)
					if (dataObj != null) {
						const insKid = getObjString(dataObj, 'kid')
						if (insKid != '') {
							insuranceOrderKid.value = insKid
							insuranceBtnText.value = '已投保'
						}
					}
				}
			}
		}
	}).catch((_e: any | null) => {
		// 查询失败静默处理
	})
}

// 点击保险按钮
const handleInsuranceClick = () => {
	if (insuranceOrderKid.value != '') {
		// 已投保，跳转保单详情
		uni.navigateTo({
			url: '/pagesTrade/insurance/InsuranceDetail?orderKid=' + insuranceOrderKid.value
		})
	} else {
		// 未投保，跳转保险信息填写页面
		uni.navigateTo({
			url: '/pagesTrade/insurance/InsuranceEntry?tripOrderKid=' + orderKid.value + '&travelDate=' + travelDate.value + '&serviceDays=' + travelTotalTime.value
		})
	}
}

// 获取订单信息
const getOrderInfo = async (id: string) => {
	loading.value = true
	try {
		const params = { orderKid: id } as UTSJSONObject
		const res = await getGuiderOrderInfo(params)
		const resObj = toJsonObj(res)
		
		if (resObj == null) {
			uni.showToast({ title: '获取订单信息失败', icon: 'error' })
			return
		}
		
		const code = getObjNumber(resObj, 'code')
		const dataVal = resObj.get('data')
		
		if (code == 200 && dataVal != null) {
			const dataObj = toJsonObj(dataVal)
			initData.value = dataObj
			initDataFlag.value = true
			
			// 更新所有字段
			updateOrderFields(dataObj)
			
			// 更新当前用户角色：基于订单类型（type=2 为收入订单，即当前用户是向导）
			isCurrentUserGuide.value = (type.value == 2)
			
			// 初始化倒计时
			timestamp.value = initDropTime(createTime.value)
			updateStatusIcon()
			
			// 标记相关通知为已读
			await markOrderNotificationsRead(id, shortKid.value)
			
			// 进行中订单检查保险状态
			if (orderStatu.value == ORDER_STATUS_COMPLETED && refundStatu.value != REFUND_STATUS_PENDING) {
				checkInsuranceStatus()
			}
		} else {
			const msg = getObjString(resObj, 'msg')
			// 订单不存在或已被删除 — 显示空状态页面
			if (msg.indexOf('不存在') !== -1) {
				orderNotFound.value = true
				return
			}
			let errMsg = '获取订单信息失败'
			if (msg != '') {
				errMsg = msg
			}
			uni.showToast({ title: errMsg, icon: 'none' })
		}
	} catch (error: any) {
		// 检测订单不存在错误
		const errMsg = (error instanceof Error) ? (error as Error).message : ''
		if (errMsg.indexOf('不存在') !== -1) {
			orderNotFound.value = true
			loading.value = false
			return
		}
		if (!isAuthError(error)) {
			handlePageError(error, '获取订单信息', loading)
		} else {
			loading.value = false
		}
	} finally {
		loading.value = false
	}
}

// 刷新订单信息
const refreshOrderInfo = async () => {
	if (orderKid.value != '') {
		await getOrderInfo(orderKid.value)
	}
}

