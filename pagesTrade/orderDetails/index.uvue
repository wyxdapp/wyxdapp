// 更新特殊订单类型判断
const updateIsSpecialOrderType = () => {
	const ot = orderType.value
	if (ot == ORDER_TYPE_CUSTOM || ot == ORDER_TYPE_GUIDE || ot == ORDER_TYPE_LINE) {
		isSpecialOrderType.value = true
	} else {
