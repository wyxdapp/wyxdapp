					<text class="action-text">聊天</text>
				</view>
				<view class="action-btn" @click="callPhone">
					<uni-icons type="phone" :size="20" color="#666666"></uni-icons>
					<text class="action-text">电话</text>
				</view>
			</view>
		</view>
		
		<!-- 底部占位 -->
		<view class="footer-placeholder"></view>
		
		<!-- 底部固定按钮 -->
		<view class="footer-box">
			<!-- 第三方向导查看待接单订单：显示"立即接单"按钮 -->
			<template v-if="(orderStatu == 5 || orderStatu == 6) && isOrderOwner == false">
				<view class="footer-btn footer-btn-primary" @click="handleGrabOrder">
					<text class="footer-btn-text footer-btn-primary-text">立即接单</text>
				</view>
			</template>
			<template v-else-if="type == 1">
				<view class="footer-btn footer-btn-cancel footer-btn-half" v-if="orderStatu == ORDER_STATUS_PENDING || orderStatu == 5" @click="handleCancelOrder">
					<text class="footer-btn-text">取消订单</text>
				</view>
				<view class="footer-btn footer-btn-primary footer-btn-half" v-if="orderStatu == ORDER_STATUS_PENDING || orderStatu == 5" @click="handlePay">
					<text class="footer-btn-text footer-btn-primary-text">去付款</text>
				</view>
				<view class="footer-btn footer-btn-cancel footer-btn-half" v-if="orderStatu == ORDER_STATUS_CANCELLED || orderStatu == ORDER_STATUS_CLOSED || orderStatu == ORDER_STATUS_REFUNDED || orderStatu == 7 || orderStatu == ORDER_STATUS_REFUNDING || (orderStatu == ORDER_STATUS_CONFIRMED && isSpecialOrderType == true)" @click="handleDeleteOrder">
					<text class="footer-btn-text">删除订单</text>
				</view>
				<view class="footer-btn footer-btn-cancel footer-btn-half" v-if="(orderStatu == ORDER_STATUS_IN_PROGRESS || orderStatu == 6 || (orderStatu == ORDER_STATUS_CONFIRMED && isSpecialOrderType == false)) && refundStatu != REFUND_STATUS_PENDING && refundStatu != REFUND_STATUS_SUCCESS" @click="handleApplyRefund">
					<text class="footer-btn-text">申请退款</text>
				</view>
				<view class="footer-btn footer-btn-cancel footer-btn-half" v-if="isInsuranceButtonEnabled() && orderStatu == ORDER_STATUS_COMPLETED && refundStatu != REFUND_STATUS_PENDING && refundStatu != REFUND_STATUS_SUCCESS" @click="handleInsuranceClick">
					<text class="footer-btn-text">{{ insuranceBtnText }}</text>
				</view>
				<view class="footer-btn footer-btn-cancel footer-btn-half" v-if="orderStatu == ORDER_STATUS_COMPLETED && refundStatu != REFUND_STATUS_PENDING && refundStatu != REFUND_STATUS_SUCCESS" @click="handleApplyRefund">
					<text class="footer-btn-text">申请退款</text>
				</view>
				<view class="footer-btn footer-btn-primary footer-btn-half" v-if="orderStatu == ORDER_STATUS_COMPLETED && refundStatu != REFUND_STATUS_PENDING && refundStatu != REFUND_STATUS_SUCCESS" @click="handleCompleteOrder">
					<text class="footer-btn-text footer-btn-primary-text">确认完成</text>
				</view>
				<view class="footer-btn footer-btn-primary footer-btn-half" v-if="orderStatu == ORDER_STATUS_CANCELLED" @click="handleEvaluate">
					<text class="footer-btn-text footer-btn-primary-text">评价</text>
				</view>
				<view class="footer-btn footer-btn-cancel" v-if="refundStatu == REFUND_STATUS_PENDING" @click="handleCancelRefund">
					<text class="footer-btn-text">取消退款</text>
				</view>
				<view class="footer-btn footer-btn-primary" v-if="orderStatu == ORDER_STATUS_REFUNDED && refundStatu == REFUND_STATUS_FAILED" @click="handleReRefund">
					<text class="footer-btn-text footer-btn-primary-text">重新退款</text>
				</view>
			</template>
			<template v-if="type == 2">
				<view class="footer-btn footer-btn-cancel footer-btn-half" v-if="orderStatu == ORDER_STATUS_CANCELLED || orderStatu == ORDER_STATUS_CLOSED || orderStatu == ORDER_STATUS_REFUNDED" @click="handleDeleteOrder">
					<text class="footer-btn-text">删除订单</text>
				</view>
				<view class="footer-btn footer-btn-cancel footer-btn-half" v-if="orderStatu == ORDER_STATUS_PENDING && refundStatu != REFUND_STATUS_PENDING" @click="handleIncomeCancelOrder">
					<text class="footer-btn-text">取消订单</text>
				</view>
				<view class="footer-btn footer-btn-primary footer-btn-half" v-if="orderStatu == ORDER_STATUS_PENDING && refundStatu != REFUND_STATUS_PENDING" @click="handleModifyPrice">
					<text class="footer-btn-text footer-btn-primary-text">改价</text>
				</view>
				<view class="footer-btn footer-btn-cancel footer-btn-half" v-if="(orderStatu == ORDER_STATUS_IN_PROGRESS || (orderStatu == ORDER_STATUS_CONFIRMED && isSpecialOrderType == false)) && refundStatu != REFUND_STATUS_PENDING" @click="handleRejectOrder">
					<text class="footer-btn-text">拒绝</text>
				</view>
				<view class="footer-btn footer-btn-primary footer-btn-half" v-if="(orderStatu == ORDER_STATUS_IN_PROGRESS || (orderStatu == ORDER_STATUS_CONFIRMED && isSpecialOrderType == false)) && refundStatu != REFUND_STATUS_PENDING" @click="handleAcceptOrder">
					<text class="footer-btn-text footer-btn-primary-text">接受</text>
				</view>
				<view class="footer-btn footer-btn-primary footer-btn-half" v-if="orderStatu == ORDER_STATUS_CANCELLED && refundStatu != REFUND_STATUS_PENDING" @click="handleEvaluate">
					<text class="footer-btn-text footer-btn-primary-text">评价</text>
				</view>
				<view class="footer-btn footer-btn-cancel" @click="handleRejectRefund" v-if="refundStatu == REFUND_STATUS_PENDING">
					<text class="footer-btn-text">拒绝退款</text>
				</view>
				<view class="footer-btn footer-btn-primary" @click="handleAcceptRefund" v-if="refundStatu == REFUND_STATUS_PENDING">
					<text class="footer-btn-text footer-btn-primary-text">同意退款</text>
				</view>
			</template>	
		</view>
		<Loading :show="loading" fullscreen />
		<!-- 分享弹窗组件 -->
		<SharePopup
			v-model:visity="showSharePopup"
			:shareData="sharePayload"
			:chatList="shareChatList"
			@share-to-chat="handleShareToChat"
			@wechat-share="handleShareWechat"
			@moments-share="handleShareMoments"
			@copy-link="handleCopyLink"
			@show-qrcode="handleShowQrcode">
		</SharePopup>
	</view>
	
	<!-- 订单不存在空状态页面 -->
	<view class="page-not-found" v-else-if="orderNotFound == true">
		<!-- 背景渐变（与正常页面一致） -->
		<view class="hear-bg" :style="headerGradientOuter()">
			<view class="hear-bg-mask" :style="headerGradientMask()"></view>
		</view>
		<!-- #ifndef H5 -->
		<!-- APP端导航栏 -->
		<view class="nav-bar" :style="{ paddingTop: pageStatusBarHeight + 'px' }">
			<view class="nav-content">
				<view class="nav-back" @click="goBack">
					<uni-icons type="left" size="22" color="#333333"></uni-icons>
				</view>
				<text class="nav-title">订单详情</text>
				<view class="nav-right"></view>
			</view>
		</view>
		<!-- #endif -->
		<!-- 顶部区域（与正常页面一致） -->
		<!-- #ifndef H5 -->
		<view class="page-header">
		<!-- #endif -->
		<!-- #ifdef H5 -->
		<view class="page-header">
			<view class="header-left-btn" @click="goBack">
				<Icon name="back" :size="40" color="#333333" />
			</view>
		<!-- #endif -->
			<view class="header-content">
				<view class="status-row">
					<text class="header-title">订单不存在</text>
				</view>
				<text class="header-subtitle">该订单可能已被取消、删除或状态已变更</text>
			</view>
		</view>
		<!-- 空状态内容区域 -->
		<view class="not-found-body">
			<image class="not-found-icon" src="https://jiasu.wyxdapp.com/iconimages/order_null_list.png" mode="aspectFit" />
			<text class="not-found-desc">您访问的订单信息已不存在</text>
			<view class="not-found-btn" @click="goBack">
				<text class="not-found-btn-text">返回上一页</text>
			</view>
		</view>
	</view>
</template>

<script setup lang="uts">
import { ref, computed, onUnmounted } from 'vue'
import { onLoad } from '@dcloudio/uni-app'
import ImageSelf from '@/components/base/ImageSelf.uvue'
import Loading from '@/components/base/Loading.uvue'
import Avatar from '@/components/base/Avatar.uvue'
import Icon from '@/components/base/Icon.uvue'
import { getGuiderOrderInfo, setOrderCancel, delOrderInfo, setOrderComplete, applyOrderRefound, guiderAcceptOrder, guiderRejectOrder, guiderAcceptRefound, guiderRejectRefound, updateGuiderOrderPrice, cancelRefund, queryRefundDetail, guiderGrabOrder } from '@/common/services/orderService.uts'
import { getNotificationHistory, markNotificationRead } from '@/api/notification.uts'
import { GetNotificationHistoryParams } from '@/api/types/notificationTypes.uts'
import { useUserStore, getUserShortKid, getUserKidDirect, updateUserInfoAction } from '@/stores/user.uts'
import { pageStatusBarHeight, initPageLayout } from '@/common/composables/usePageLayout.uts'
import { headerGradientOuter, headerGradientMask } from '@/common/utils/themeHelper.uts'
import SharePopup from '@/components/common/SharePopup.uvue'
import { 
	getChatList as getChatListFn, 
	getChatListRef,
	handleShareToChat as handleShareToChatFn
} from '@/common/composables/useChatAndShare.uts'
import { 
	handleShareWechat as handleShareWechatFn,
	handleShareMoments as handleShareMomentsFn,
	handleCopyLink as handleCopyLinkFn,
	handleShowQrcode as handleShowQrcodeFn
} from '@/common/composables/useShareUi.uts'

// ==================== 辅助函数（必须在使用前定义）====================
import { toJsonObj } from '@/common/utils/utsSafe.uts'
import { ORDER_STATUS_PENDING, ORDER_STATUS_PAID, ORDER_STATUS_CONFIRMED, ORDER_STATUS_IN_PROGRESS, ORDER_STATUS_COMPLETED, ORDER_STATUS_CANCELLED, ORDER_STATUS_REFUNDING, ORDER_STATUS_REFUNDED, ORDER_STATUS_CLOSED, REFUND_STATUS_PENDING, REFUND_STATUS_SUCCESS, REFUND_STATUS_FAILED, ORDER_TYPE_CUSTOM, ORDER_TYPE_GUIDE, ORDER_TYPE_LINE } from '@/common/config/businessCodes.uts'
import { BADGE_COUNT_MAX_DISPLAY } from '@/common/config/uiConfig.uts'
import { COS_BUCKET_ID } from '@/common/config/thirdPartyConfig.uts'
import { handlePageError, handleSilentError, isAuthError } from '@/common/utils/errorHandler.uts'
import { DEFAULT_SHARE_IMAGE } from '@/common/config/defaultImages.uts'
import { getCachedProfile } from '@/common/composables/useUserProfileCache.uts'
import { getInsuranceByTripOrder, GetInsuranceByTripOrderParams } from '@/api/insurance.uts'
import { isInsuranceButtonEnabled } from '@/common/composables/useFeatureToggles.uts'

// 定时器生命周期管理
let timerHandles: number[] = []

function safeSetTimeout(callback: () => void, ms: number): number {
	const handle = setTimeout(callback, ms)
	timerHandles.push(handle)
	return handle
}

function clearAllTimers(): void {
	for (const handle of timerHandles) {
		clearTimeout(handle)
	}
	timerHandles = []
}

// COS 图片 URL
const cosStartTimeIconUrl = 'https://qyimage-' + COS_BUCKET_ID + '.cos.ap-chengdu.myqcloud.com/iconImages/order_icon_startTime.png'

// 从对象获取字符串属性
const getObjString = (obj: UTSJSONObject | null, key: string): string => {
	if (obj == null) return ''
	const val = obj.get(key)
	if (val != null && val.toString() != '') {
		return val.toString()
	}
	return ''
}

// 从对象获取数字属性
const getObjNumber = (obj: UTSJSONObject | null, key: string): number => {
	if (obj == null) return 0
	const val = obj.get(key)
	if (val != null) {
		const num = parseInt(val.toString())
		if (isNaN(num) == false) {
			return num
		}
	}
	return 0
}

// 从 UTSJSONObject 类型获取字符串属性
const getAnyString = (data: UTSJSONObject | null, key: string): string => {
	const obj = toJsonObj(data)
	return getObjString(obj, key)
}

// 判断是否为推广订单（兼容 boolean/string 类型）
const parseIsPromotionOrder = (data: UTSJSONObject | null): boolean => {
	if (data == null) return false
	const val = data.get('isPromotionOrder')
	if (val == null) return false
	if (val == true) return true
	if (val.toString() == 'true' || val.toString() == '1') return true
	return false
}

// 格式化佣金金额为两位小数字符串
const formatCommission = (data: UTSJSONObject | null): string => {
	if (data == null) return '0.00'
	const val = data.get('commissionAmount')
	if (val == null) return '0.00'
	const num = parseFloat(val.toString())
	if (isNaN(num) == true || num <= 0) return '0.00'
	const cents = Math.round(num * 100)
	const absCents = (cents < 0) ? -cents : cents
	const yuan = Math.floor(absCents / 100)
	const fen = absCents % 100
	const fenStr = (fen < 10) ? ('0' + fen.toString()) : fen.toString()
	return yuan.toString() + '.' + fenStr
}

