// 抢单（第三方向导抢待接单订单）
const doGrabOrder = async () => {
	loading.value = true
	try {
		const currentUserKid = getUserKid()
		if (currentUserKid == '') {
			uni.showToast({ title: '用户信息不存在，请重新登录', icon: 'error' })
			loading.value = false
			return
		}
		const params = { guideKid: currentUserKid, orderKid: orderKid.value } as UTSJSONObject
		const res = await guiderGrabOrder(params)
		const resObj = toJsonObj(res)
		const code = getObjNumber(resObj, 'code')
		if (code == 200) {
			uni.showToast({ title: '抢单成功', icon: 'success' })
			// 抢单成功后刷新订单信息
			safeSetTimeout(() => {
				refreshOrderInfo()
			}, 1500)
		} else {
			const msg = getObjString(resObj, 'msg')
			uni.showToast({ title: msg != '' ? msg : '抢单失败', icon: 'error' })
		}
	} catch (error: any) {
		if (!isAuthError(error)) {
			handlePageError(error, '抢单', loading)
		} else {
			loading.value = false
		}
	} finally {
		loading.value = false
	}
}

const handleGrabOrder = () => {
	uni.showModal({
		title: '提示',
		content: '确认抢单？抢单成功后将由您为游客提供服务',
		success: (res: UniShowModalResult) => {
			if (res.confirm == true) {
				doGrabOrder()
			}
		}
	})
}

// 同意退款（实现函数必须在调用前定义）
const doAcceptRefund = async () => {
	loading.value = true
	try {
		const params = { refundKid: refundKid.value } as UTSJSONObject
		await guiderAcceptRefound(params)
		uni.showToast({ title: '已同意', icon: 'success' })
		orderStatu.value = 80
		refundStatu.value = 20
		updateStatusText()
		updateStatusIcon()
	} catch (error: any) {
		if (!isAuthError(error)) {
			handlePageError(error, '同意退款', loading)
		} else {
			loading.value = false
		}
	} finally {
		loading.value = false
	}
}

// 同意退款（向导端）
const handleAcceptRefund = () => {
	uni.showModal({
		title: '提示',
		content: '是否同意该订单退款?',
		success: (res: UniShowModalResult) => {
			if (res.confirm == true) {
				doAcceptRefund()
			}
		}
	})
}

// 拒绝退款（实现函数必须在调用前定义）
const doRejectRefund = async () => {
	loading.value = true
	try {
		const params = { refundKid: refundKid.value } as UTSJSONObject
		await guiderRejectRefound(params)
		uni.showToast({ title: '已拒绝', icon: 'success' })
		orderStatu.value = 80
		refundStatu.value = 30
		updateStatusText()
		updateStatusIcon()
	} catch (error: any) {
		if (!isAuthError(error)) {
			handlePageError(error, '拒绝退款', loading)
		} else {
			loading.value = false
		}
	} finally {
		loading.value = false
	}
}

// 拒绝退款（向导端）
const handleRejectRefund = () => {
	uni.showModal({
		title: '提示',
		content: '是否拒绝该订单退款?',
		success: (res: UniShowModalResult) => {
			if (res.confirm == true) {
				doRejectRefund()
			}
		}
	})
}

// ==================== 生命周期 ====================
onLoad((options: OnLoadOptions) => {
	// 初始化页面布局（获取状态栏高度）
	initPageLayout()
	
	if (options == null) {
		uni.showToast({ title: '订单id出错', icon: 'error' })
		return
	}
	
	const optionsStr = JSON.stringify(options)
	const optionsObj = JSON.parse(optionsStr) as UTSJSONObject
	
	const orderKidVal = optionsObj.get('orderKid')
	if (orderKidVal == null || orderKidVal.toString() == '') {
		uni.showToast({ title: '订单id出错', icon: 'error' })
		return
	}
	
	const typeVal = optionsObj.get('type')
	if (typeVal != null && typeVal.toString() != '') {
		const typeNum = parseInt(typeVal.toString())
		if (isNaN(typeNum) == false) {
			type.value = typeNum
		}
	}
	
	orderKid.value = orderKidVal.toString()
	getOrderInfo(orderKid.value)
})

onUnmounted(() => {
	clearAllTimers()
})
</script>

