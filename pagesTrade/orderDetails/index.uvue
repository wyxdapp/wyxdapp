// 获取用户 Kid（优先从响应式ref取值，避免快照时序问题）
const getUserKid = (): string => {
	// 优先使用直接从响应式ref取值的方式
	const directKid = getUserKidDirect()
	if (directKid != '') return directKid
	// fallback：从快照 userStore 取值
	try {
		const storeObj = toJsonObj(userStore)
		if (storeObj == null) return ''
		const userInfoVal = storeObj.get('userInfo')
		if (userInfoVal == null) return ''
		const userInfoObj = toJsonObj(userInfoVal)
		if (userInfoObj == null) return ''
		const kidVal = userInfoObj.get('kid')
		if (kidVal != null && kidVal.toString() != '') {
			return kidVal.toString()
		}
		return ''
	} catch (e) {
		return ''
	}
}

// 获取用户 ID
const getUserId = (): string => {
	try {
		const storeObj = toJsonObj(userStore)
		if (storeObj == null) return ''
		const userIdVal = storeObj.get('userId')
		if (userIdVal != null && userIdVal.toString() != '') {
			return userIdVal.toString()
		}
		return ''
	} catch (e) {
		return ''
	}
}

