// 打电话（基于订单类型：支出拨打向导电话，收入拨打游客预留电话）
const callPhone = () => {
	let phone = ''
	if (type.value == 2) {
		// 收入订单：拨打游客预留电话
		phone = touristPhone.value
	} else {
		// 支出订单：拨打向导电话
		phone = guidePhone.value
	}
	if (phone != '') {
		uni.makePhoneCall({ phoneNumber: phone })
	}
}

// 跳转到聊天（基于订单类型：支出联系向导，收入联系游客，待接单联系客服）
const goToChat = () => {
	let targetUserId = ''
	if (type.value == 1) {
		// 支出订单：待接单状态跳转到 admin 客服
		const os = orderStatu.value
		const isWaitingGuide = (os == ORDER_STATUS_CONFIRMED && isSpecialOrderType.value == false) || os == ORDER_STATUS_IN_PROGRESS
		if (isWaitingGuide == true) {
			targetUserId = 'admin'
		} else {
			targetUserId = guideKid.value
		}
	} else {
		// 收入订单：联系游客
		targetUserId = touristKid.value
	}
	if (targetUserId != '') {
		uni.navigateTo({ url: '/pagesTrade/news/detail?targetUserId=' + targetUserId })
	}
}

