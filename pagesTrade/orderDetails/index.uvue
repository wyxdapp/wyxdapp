// 分享订单
const handleShare = async () => {
	console.log('[OrderDetails] handleShare called')
	
	try {
		// 构建分享标题
		const status = statusText.value
		const title = orderTitle.value
		const shareTitle = status + '：' + title
		
		// 构建分享描述
		const orderNoVal = shortKid.value
		const priceVal = totalMoney.value
		const timeVal = travelDate.value
		const shareDesc = '订单编号：' + orderNoVal + '\n价格：¥' + priceVal + '\n出发时间：' + timeVal
		
		// 构建分享链接
		const kid = orderKid.value
		let shareLink = 'https://m.wyxdapp.com/#/pagesTrade/orderDetails/index?orderKid=' + kid
		
		// 获取推广短号
		let referrerShortKid = ''
		try {
			// 🔧 修复：优先使用 getUserShortKid()，再 fallback 到 store 和缓存 profile
			referrerShortKid = getUserShortKid()
			if (referrerShortKid == '') {
				const storeObj = toJsonObj(userStore)
				if (storeObj != null) {
					const userInfoVal = storeObj.get('userInfo')
					if (userInfoVal != null) {
						const userInfoJson = JSON.stringify(userInfoVal)
						if (userInfoJson != null && userInfoJson != '') {
							const userInfoObj = JSON.parse(userInfoJson) as UTSJSONObject
							const shortKidVal = userInfoObj.get('shortKid')
							if (shortKidVal != null && shortKidVal.toString() != '') {
								referrerShortKid = shortKidVal.toString()
							}
						}
					}
				}
			}
			// 🔧 修复APP端：从缓存的当前用户 profile 中获取 shortKid
			if (referrerShortKid == '') {
				const currentUserKidForRef = getUserKid()
				if (currentUserKidForRef != '') {
					try {
						const cachedMyProfile = getCachedProfile(currentUserKidForRef, currentUserKidForRef)
						if (cachedMyProfile != null) {
							const cachedShortKidVal = cachedMyProfile.get('shortKid')
							if (cachedShortKidVal != null && cachedShortKidVal.toString() != '') {
								referrerShortKid = cachedShortKidVal.toString()
								console.log('[handleShare] 从缓存profile获取推广短号:', referrerShortKid)
								updateUserInfoAction({ shortKid: referrerShortKid } as UTSJSONObject)
							}
						}
					} catch (e2) {}
				}
			}
			if (referrerShortKid != '') {
				shareLink = shareLink + '&ref=' + referrerShortKid
			}
		} catch (e) {
			handleSilentError(e, '获取推广短号')
		}
		
		// 获取分享图片
		let imageUrl = DEFAULT_SHARE_IMAGE
		if (touristOrderDetailsPic.value != '') {
			imageUrl = touristOrderDetailsPic.value
		} else if (firstPicUrl.value != '') {
			imageUrl = firstPicUrl.value
		}
		
		// 构建分享数据
		const newPayload: UTSJSONObject = {
			title: shareTitle,
			summary: shareDesc,
			desc: shareDesc,
			link: shareLink,
			url: shareLink,
			imageUrl: imageUrl,
			userId: '',
			referrerShortKid: referrerShortKid
		}
		
		sharePayload.value = newPayload
		
		console.log('[handleShare] 分享数据构建完成')
	} catch (e) {
		handleSilentError(e, '构建分享数据')
		sharePayload.value = {
			title: '订单详情',
			summary: '查看订单详情',
			desc: '查看订单详情',
			link: 'https://m.wyxdapp.com',
			url: 'https://m.wyxdapp.com',
			imageUrl: DEFAULT_SHARE_IMAGE,
			userId: '',
			referrerShortKid: ''
		}
	}
	
	// 获取会话列表
	try {
		const result = await getChatListFn(userStore)
		if (result != null && Array.isArray(result) == true) {
			shareChatList.value = result as Array<UTSJSONObject>
		} else {
			shareChatList.value = []
		}
	} catch (e) {
		handleSilentError(e, '获取会话列表')
		shareChatList.value = []
	}
	
	showSharePopup.value = true
}

// 分享到聊天
const handleShareToChat = (data: UTSJSONObject) => {
	console.log('[OrderDetails] handleShareToChat called')
	
	// 从 data 中提取 chatItem
	let chatItem: UTSJSONObject = {} as UTSJSONObject
	try {
		const dataObj = JSON.parse(JSON.stringify(data)) as UTSJSONObject
		const chatItemVal = dataObj.get('chatItem')
		if (chatItemVal != null) {
			chatItem = chatItemVal as UTSJSONObject
		}
	} catch (e) {
		handleSilentError(e, '解析分享数据')
	}
	
	if (chatItem == null) {
		uni.showToast({
			title: '分享失败，会话信息不完整',
			icon: 'none'
		})
		return
	}
	
	// 构建订单信息对象
	const orderInfo = {
		kid: orderKid.value,
		orderNo: shortKid.value,
		orderTitle: orderTitle.value,
		totalMoney: totalMoney.value,
		travelDate: travelDate.value,
		touristName: touristName.value,
		touristAvatar: touristOrderDetailsPic.value != '' ? touristOrderDetailsPic.value : firstPicUrl.value
	}
	
	console.log('[OrderDetails] handleShareToChat - orderInfo:', JSON.stringify(orderInfo))
	
	const shareData = {
		chatItem: chatItem
	} as UTSJSONObject
	
	handleShareToChatFn(shareData, orderInfo)
}

