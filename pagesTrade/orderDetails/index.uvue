// 订单卡片展示的用户ID（待接单且非下单者时显示游客）
const cardDisplayUserId = computed((): string => {
	const isWaitGrab = (orderStatu.value == 5 || orderStatu.value == 6)
	if (isWaitGrab == true && isOrderOwner.value == false) {
		return touristKid.value
	}
	return type.value == 1 ? guideKid.value : touristKid.value
})

// 订单卡片展示的昵称（待接单且非下单者时显示游客昵称）
const cardDisplayName = computed((): string => {
	const isWaitGrab = (orderStatu.value == 5 || orderStatu.value == 6)
	if (isWaitGrab == true && isOrderOwner.value == false) {
		return touristNickname.value
	}
	return type.value == 1 ? guideName.value : touristNickname.value
})

// 订单卡片头像点击（待接单且非下单者时跳转游客主页）
const handleCardAvatarClick = () => {
	const isWaitGrab = (orderStatu.value == 5 || orderStatu.value == 6)
	if (isWaitGrab == true && isOrderOwner.value == false) {
		goToTouristInfo()
	} else if (type.value == 1) {
		goToGuideInfo()
	} else {
		goToTouristInfo()
	}
}

// 取消订单（实现函数必须在调用前定义）
const doCancelOrder = async () => {
	loading.value = true
	try {
		const userKid = getUserKid()
		if (userKid == '') {
			uni.showToast({ title: '用户信息不存在，请重新登录', icon: 'error' })
			loading.value = false
			return
		}
		const params = { orderKid: orderKid.value, userKid: userKid } as UTSJSONObject
		await setOrderCancel(params)
		uni.showToast({ title: '取消成功', icon: 'success' })
		safeSetTimeout(() => {
			uni.navigateBack()
		}, 1500)
	} catch (error: any) {
		if (!isAuthError(error)) {
			handlePageError(error, '取消订单', loading)
		} else {
			loading.value = false
		}
	} finally {
		loading.value = false
	}
}

