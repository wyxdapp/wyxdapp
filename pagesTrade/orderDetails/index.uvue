<template>
	<view class="page" v-if="initDataFlag == true">
		<!-- 背景渐变 -->
		<view class="hear-bg" :style="headerGradientOuter()">
			<view class="hear-bg-mask" :style="headerGradientMask()"></view>
		</view>
		<!-- #ifndef H5 -->
		<!-- APP端导航栏 -->
		<view class="nav-bar" :style="{ paddingTop: pageStatusBarHeight + 'px' }">
			<view class="nav-content">
				<view class="nav-back" @click="goBack">
					<uni-icons type="left" size="22" color="#333333"></uni-icons>
				</view>
				<text class="nav-title">订单详情</text>
				<view class="nav-right" @click="handleShare">
					<uni-icons type="redo" size="22" color="#333333"></uni-icons>
				</view>
			</view>
		</view>
		<!-- #endif -->
		
		<!-- 顶部背景区域 -->
		<!-- #ifndef H5 -->
		<view class="page-header">
		<!-- #endif -->
		<!-- #ifdef H5 -->
		<view class="page-header">
			<!-- H5端保留返回和分享按钮 -->
			<view class="header-left-btn" @click="goBack">
				<Icon name="back" :size="40" color="#333333" />
			</view>
			<view class="header-right-btn" @click="handleShare">
				<Icon name="share" :size="40" color="#333333" />
			</view>
		<!-- #endif -->
			<!-- 状态标题 -->
			<view class="header-content">
				<view class="status-row">
					<image 
						v-if="statusIcon != ''" 
						class="status-icon" 
						:src="statusIcon" 
						mode="aspectFit" 
					/>
					<text class="header-title">{{statusText}}</text>
				</view>
				<!-- 超时提示或其他状态信息 -->
				<template v-if="type == 1">
					<template v-if="refundStatu == REFUND_STATUS_PENDING">
						<text class="header-subtitle">退款中，等待向导确认退款</text>
					</template>
					<template v-else-if="refundStatu == REFUND_STATUS_SUCCESS">
						<text class="header-subtitle">订单已取消，退款已原路退回</text>
					</template>
					<template v-else-if="refundStatu == REFUND_STATUS_FAILED">
						<text class="header-subtitle">退款被拒绝</text>
					</template>
					<template v-else-if="orderStatu == ORDER_STATUS_PENDING && isSpecialOrderType == false">
						<text class="header-subtitle">请支付订单费用</text>
					</template>
					<template v-else-if="orderStatu == ORDER_STATUS_CONFIRMED && isSpecialOrderType == false">
						<text class="header-subtitle">等待向导接单</text>
					</template>
					<text v-else-if="orderStatu == ORDER_STATUS_IN_PROGRESS" class="header-subtitle">已付款</text>
					<text v-else-if="orderStatu == ORDER_STATUS_CANCELLED" class="header-subtitle">交易已完成，期待您的评价</text>
					<text v-else-if="orderStatu == ORDER_STATUS_REFUNDING" class="header-subtitle">感谢您本次购买，期待您再次光临</text>
					<text v-else-if="orderStatu == ORDER_STATUS_CLOSED" class="header-subtitle">订单已取消</text>
					<text v-else-if="orderStatu == ORDER_STATUS_REFUNDED && refundStatu != REFUND_STATUS_PENDING && refundStatu != REFUND_STATUS_SUCCESS && refundStatu != REFUND_STATUS_FAILED" class="header-subtitle">订单已取消</text>
				</template>
			</view>
		</view>
		<!-- 主内容区 -->
		<view class="content-body">
			<!-- 订单信息卡片 -->
			<view class="order-card">
				<view class="order-main">
					<!-- 导游预约 -->
					<template v-if="orderType == 20 || orderType == ORDER_TYPE_CUSTOM">
						<view class="order-avatar" @click="handleCardAvatarClick">
							<Avatar
								:url="orderCardDisplayPic"
								:userId="cardDisplayUserId"
								:customSize="120"
								clickMode="none"
							/>
						</view>
						<view class="order-info">
							<view class="order-name-row">
								<text class="order-name">{{cardDisplayName}}</text>
								<!-- 推广订单标签 -->
								<view v-if="isPromotionOrder == true" class="promotion-badge">
									<text class="promotion-badge-text">推广</text>
								</view>
							</view>
							<text class="order-title">{{orderTitle}}</text>
							<view class="order-time">
								<image class="time-icon" :src="cosStartTimeIconUrl" mode="aspectFill" />
								<text class="time-text">出发时间：{{travelDate}}</text>
							</view>
						</view>
					</template>
					<!-- 定制预约 -->
					<template v-if="orderType == 10">
						<view class="order-avatar">
							<ImageSelf :width="120" :height="120" borderRadius="16rpx" :preView="false" :url="firstPicUrl"></ImageSelf>
						</view>
						<view class="order-info">
							<view class="order-name-row">
								<text class="order-title order-title-custom">{{orderTitle}}</text>
								<!-- 推广订单标签 -->
								<view v-if="isPromotionOrder == true" class="promotion-badge">
									<text class="promotion-badge-text">推广</text>
								</view>
							</view>
							<view class="order-time">
								<image class="time-icon" :src="cosStartTimeIconUrl" mode="aspectFill" />
								<text class="time-text">出发时间：{{travelDate}}</text>
							</view>
						</view>
					</template>
				</view>
				<!-- 底部价格行 -->
				<view class="order-footer">
					<text class="footer-text" v-if="orderType == 20">购买天数：{{travelTotalTime}}</text>
					<text class="footer-text footer-pay-label">需付款：</text>
					<text class="footer-pay-price">¥{{totalMoney}}</text>
				</view>
				<!-- 推广订单佣金显示 -->
				<view v-if="isPromotionOrder == true" class="commission-row">
					<text class="footer-text">预计佣金</text>
					<text class="commission-text">¥{{commissionAmount}}</text>
				</view>
			</view>
			<!-- 推广订单向导信息卡片（推广收入订单时显示） -->
			<view class="info-card" v-if="isPromotionOrder == true && guideName != '' && guideKid != ''">
				<view class="info-card-header">
					<view class="card-title-line"></view>
					<text class="card-title">向导信息</text>
				</view>
				<view class="promotion-guide-row" @click="goToGuideInfo">
					<Avatar
						:url="guideAvatar != '' ? guideAvatar : 'https://jiasu.wyxdapp.com/iconimages/default_avatar.png'"
						:userId="guideKid"
						:customSize="80"
						clickMode="none"
					/>
					<text class="promotion-guide-name">{{guideName}}</text>
					<view class="promotion-badge">
						<text class="promotion-badge-text">推广</text>
					</view>
				</view>
			</view>
			<!-- 联系人信息卡片 - 游客信息（收入订单 type=2 时显示） -->
			<view class="info-card" v-if="type == 2">
				<view class="info-card-header">
					<view class="card-title-line"></view>
					<text class="card-title">游客信息</text>
				</view>
				<view class="info-row">
					<text class="info-label">姓名</text>
					<text class="info-value">{{touristName}}</text>
				</view>
				<view class="info-row">
					<text class="info-label">电话</text>
					<text class="info-value">{{touristPhone}}</text>
					<view class="copy-btn" @click="copyTouristPhone">
						<text class="copy-text">复制</text>
					</view>
				</view>
			</view>
			<!-- 联系人信息卡片 - 游客信息（支出订单 type=1 且待接单状态时显示） -->
			<view class="info-card" v-if="type == 1 && (orderStatu == 5 || orderStatu == 6 || orderStatu == 7)">
				<view class="info-card-header">
					<view class="card-title-line"></view>
					<text class="card-title">游客信息</text>
				</view>
				<view class="info-row">
					<text class="info-label">姓名</text>
					<text class="info-value">{{touristName}}</text>
				</view>
				<view class="info-row">
					<text class="info-label">电话</text>
					<text class="info-value">{{touristPhone}}</text>
					<view class="copy-btn" @click="copyTouristPhone">
						<text class="copy-text">复制</text>
					</view>
				</view>
				<view class="info-row" v-if="adultNumber > 0 || childrenNumber > 0">
					<text class="info-label">出行人数</text>
					<text class="info-value">成人 {{adultNumber}} 人 / 儿童 {{childrenNumber}} 人</text>
				</view>
			</view>
			<!-- 联系人信息卡片 - 向导信息（支出订单 type=1 时显示，待接单时不显示） -->
			<view class="info-card" v-if="type == 1 && orderStatu != 5 && orderStatu != 6 && orderStatu != 7 && guideName != '' && guideName != '等待向导接单'">
				<view class="info-card-header">
					<view class="card-title-line"></view>
					<text class="card-title">向导信息</text>
				</view>
				<view class="info-row">
					<text class="info-label">姓名</text>
					<text class="info-value">{{guideName}}</text>
				</view>
				<view class="info-row">
					<text class="info-label">电话</text>
					<text class="info-value">{{guidePhone}}</text>
					<view class="copy-btn" @click="copyGuidePhone">
						<text class="copy-text">复制</text>
					</view>
				</view>
			</view>
			<!-- 订单信息卡片 -->
			<view class="info-card">
				<view class="info-card-header">
					<view class="card-title-line"></view>
					<text class="card-title">订单信息</text>
				</view>
				<view class="info-row">
					<text class="info-label">订单编号</text>
					<text class="info-value">{{shortKid}}</text>
				</view>
				<view class="info-row">
					<text class="info-label">订单备注</text>
					<text class="info-value">{{orderRemarks}}</text>
				</view>
				<view class="info-row">
					<text class="info-label">创建时间</text>
					<text class="info-value">{{createTime}}</text>
				</view>
			</view>
			<!-- 横向操作按钮 -->
			<view class="action-btns" v-if="orderStatu != 5">
				<view class="action-btn" @click="goToChat">
