	flex-direction: column;
	width: 750rpx;
	background-color: #f5f5f5;
}

.hear-bg {
	position: absolute;
	top: 0;
	left: 0;
	width: 750rpx;
	height: 392rpx;
	z-index: 0;
}

.hear-bg-mask {
	position: absolute;
	top: 0;
	left: 0;
	width: 750rpx;
	height: 392rpx;
	z-index: 0;
}

/* 导航栏 */
/* #ifndef H5 */
.nav-bar {
	position: relative;
	z-index: 10;
}
/* #endif */

.nav-content {
	flex-direction: row;
	align-items: center;
	justify-content: space-between;
	height: 88rpx;
	padding-left: 24rpx;
	padding-right: 24rpx;
}

.back-btn {
	width: 60rpx;
	height: 60rpx;
	flex-direction: row;
	align-items: center;
	justify-content: center;
}

.nav-title {
	font-size: 36rpx;
	font-weight: bold;
	color: #333333;
}

.nav-placeholder {
	width: 60rpx;
}

/* 滚动内容 */
.scroll-content {
	flex: 1;
	flex-direction: column;
}

/* 加载状态 */
.loading-box {
	flex-direction: row;
	align-items: center;
	justify-content: center;
	padding-top: 120rpx;
}

.loading-text {
	font-size: 28rpx;
	color: #999999;
}

.error-text {
	font-size: 28rpx;
	color: #ff4d4f;
}

/* 状态卡片 */
.status-card {
	margin-left: 24rpx;
	margin-right: 24rpx;
	margin-top: 24rpx;
	border-radius: 16rpx;
	padding-left: 32rpx;
	padding-right: 32rpx;
	padding-top: 32rpx;
	padding-bottom: 32rpx;
	flex-direction: column;
	align-items: center;
}

.status-text {
	font-size: 36rpx;
	font-weight: bold;
	color: #ffffff;
}

.audit-text {
	font-size: 26rpx;
	color: rgba(255, 255, 255, 0.85);
	margin-top: 8rpx;
}

/* 卡片 */
.card {
	background-color: #ffffff;
	border-radius: 16rpx;
	margin-left: 24rpx;
	margin-right: 24rpx;
	margin-top: 24rpx;
	padding-left: 28rpx;
	padding-right: 28rpx;
	padding-top: 24rpx;
	padding-bottom: 24rpx;
}

.card-header {
	flex-direction: row;
	align-items: center;
	margin-bottom: 16rpx;
}

.card-title-line {
	width: 6rpx;
	height: 32rpx;
	background-color: #2EAEF2;
	border-radius: 3rpx;
	margin-right: 12rpx;
}

.card-title-line-warn {
	background-color: #ff4d4f;
}

.card-title {
	font-size: 32rpx;
	font-weight: bold;
	color: #333333;
}

/* 信息行 */
.info-row {
	flex-direction: row;
	align-items: flex-start;
	padding-top: 16rpx;
	padding-bottom: 16rpx;
	border-bottom-width: 1rpx;
	border-bottom-color: #f5f5f5;
	border-bottom-style: solid;
}

.info-label {
	width: 180rpx;
	font-size: 28rpx;
	color: #999999;
}

.info-value {
	flex: 1;
	font-size: 28rpx;
	color: #333333;
	text-align: right;
}

.premium-amount {
	color: #ff4d4f;
	font-weight: bold;
}

.warn-text {
	color: #ff4d4f;
}

/* 被保人块 */
.insured-block {
	margin-top: 12rpx;
	padding-top: 12rpx;
	border-top-width: 2rpx;
	border-top-color: #f0f0f0;
	border-top-style: solid;
}

.insured-header {
	flex-direction: row;
	align-items: center;
	margin-bottom: 4rpx;
}

.insured-title {
	font-size: 28rpx;
	font-weight: bold;
	color: #333333;
}

/* 空提示 */
.empty-tip {
	flex-direction: row;
	align-items: center;
	justify-content: center;
	padding-top: 32rpx;
	padding-bottom: 32rpx;
}

.empty-text {
	font-size: 26rpx;
	color: #999999;
}

/* 底部占位 */
.bottom-placeholder {
	height: 60rpx;
}
</style>
