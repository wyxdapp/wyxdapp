.video-feed-page {
	height: 100vh;
	overflow: hidden;
}
/* #endif */

/* 顶部栏 */
.top-bar {
	position: fixed;
	top: 0;
	left: 0;
	width: 750rpx;
	z-index: 100;
	flex-direction: row;
	align-items: center;
	padding-left: 24rpx;
	padding-right: 24rpx;
	padding-bottom: 20rpx;
}

.back-btn {
	width: 72rpx;
	height: 72rpx;
	flex-direction: row;
	align-items: center;
	justify-content: center;
}

.back-icon {
	width: 48rpx;
	height: 48rpx;
}

/* 视频 Swiper */
.video-swiper {
	width: 750rpx;
}

/* H5 优化：远离当前视频的占位元素，极简 DOM */
.video-placeholder {
	width: 750rpx;
	height: 100%;
	background-color: #000000;
}

/* 右滑返回指示器 */
.swipe-back-indicator {
	position: fixed;
	left: 0;
	top: 0;
	bottom: 0;
	width: 80rpx;
	z-index: 200;
	flex-direction: column;
	align-items: center;
	justify-content: center;
	background-color: rgba(0, 0, 0, 0.3);
}

.swipe-back-arrow {
	width: 60rpx;
	height: 60rpx;
	border-radius: 30rpx;
	background-color: rgba(255, 255, 255, 0.9);
	flex-direction: row;
	align-items: center;
	justify-content: center;
}

.swipe-back-arrow-icon {
	width: 32rpx;
	height: 32rpx;
}
</style>
