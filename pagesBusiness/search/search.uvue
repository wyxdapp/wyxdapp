	padding-top: 24rpx;
	padding-bottom: 24rpx;
}

.mb-24 {
	margin-bottom: 24rpx;
}

.mt-128 {
	margin-top: 128rpx;
}

.flex-row {
	flex-direction: row;
}

.align-center {
	align-items: center;
}

.flex-center {
	justify-content: center;
}

.space-between {
	justify-content: space-between;
}

