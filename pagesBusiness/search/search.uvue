	align-items: center;
	padding-top: 16rpx;
	padding-bottom: 16rpx;
	padding-left: 24rpx;
	padding-right: 24rpx;
	/* #ifdef MP-WEIXIN */
	box-sizing: border-box;
	/* #endif */
}

