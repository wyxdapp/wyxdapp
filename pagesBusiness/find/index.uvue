// 视频播放
const onVideoPlay = (videoId: string) => {
	// 暂停其他视频
	if (currentPlayingVideoId.value != '' && currentPlayingVideoId.value != videoId) {
		try {
			const videoContext = uni.createVideoContext('video-' + currentPlayingVideoId.value)
			if (videoContext != null) {
				videoContext.pause()
			}
		} catch (e) {}
	}
	currentPlayingVideoId.value = videoId
}

// 视频点击 - 跳转到全屏视频播放页
const handleVideoClick = (item: UTSJSONObject) => {
	// 筛选出视频类型的动态（insertType == 3）
	const videoItems: Array<any> = []
	let clickedIndex = 0
	const list = trendsList.value
	
	for (let i = 0; i < list.length; i = i + 1) {
		const listItem = list[i]
		const insertType = getItemNumberProp(listItem, 'insertType')
		if (insertType == 3) {
			const mediaName = getItemStringProp(listItem, 'mediaName')
			if (mediaName != '') {
				// 检查是否是当前点击的视频
				const itemKid = getItemStringProp(item, 'kid')
				const listItemKid = getItemStringProp(listItem, 'kid')
				if (itemKid == listItemKid) {
					clickedIndex = videoItems.length
				}
				videoItems.push(listItem)
			}
		}
	}
	
	if (videoItems.length > 0) {
		// 设置视频数据到 Store
		setVideoFeedData(videoItems, clickedIndex)
		
		// 跳转到视频播放页
		uni.navigateTo({
			url: '/pagesBusiness/videoFeed/index'
		})
	} else {
		uni.showToast({
			title: '视频不可用',
			icon: 'none'
		})
	}
}

// 点赞
const onLike = async (item: UTSJSONObject) => {
	const isLogin = checkIsLogin()
	if (isLogin == false) {
		uni.navigateTo({
			url: '/pagesUser/login/index'
		})
		return
	}
	
	const userKid = getUserKidFromStore()
	const discoverKid = getItemStringProp(item, 'kid')
	
	if (userKid == '' || discoverKid == '') return
	
	try {
		await toggleLike(userKid, discoverKid)
		
		// 更新列表中的点赞状态
		const list = trendsList.value
		for (let i = 0; i < list.length; i = i + 1) {
			const listItem = list[i]
			const itemKid = getItemStringProp(listItem, 'kid')
			if (itemKid == discoverKid) {
				const isLikedNow = isLiked(discoverKid)
				const likeCount = getLikeCount(discoverKid)
				
				// 更新 item
				const itemStr = JSON.stringify(listItem)
				const itemObj = JSON.parse(itemStr) as UTSJSONObject
				itemObj.set('isLike', isLikedNow == true ? 10 : 0)
				itemObj.set('likeNum', likeCount)
				list[i] = itemObj as UTSJSONObject
				break
			}
		}
		trendsList.value = list
	} catch (error: Error) {
		handleSilentError(error, '点赞失败')
	}
}

// 评论点击
const handleCommentClick = (item: UTSJSONObject) => {
	const kid = getItemStringProp(item, 'kid')
	if (kid != '') {
		uni.navigateTo({
			url: '/pagesBusiness/commend/index?kid=' + kid + '&focusComment=1'
		})
	}
}

// 更多操作 - 改为分享功能
const handleMoreOptions = async (item: UTSJSONObject) => {
	console.log('[Find] handleMoreOptions called - 分享动态')
	currentShareItem.value = item
	
	try {
		// 构建分享标题
		const nickName = getItemStringProp(item, 'nickName')
		const shareTitle = nickName != '' ? `${nickName}的动态` : '网约向导趣游玩'
		
		// 构建分享描述
		let shareDesc = '发现精彩动态，一起来看看吧！'
		const content = getItemStringProp(item, 'discoverContent')
		if (content != '') {
			// 截取前50个字符作为描述
			shareDesc = content.length > 50 ? content.substring(0, 50) + '...' : content
		}
		
		// 获取分享图片
		let imageStr = 'https://jiasu.wyxdapp.com/iconimages/share_default.png'
		const insertType = getItemNumberProp(item, 'insertType')
		
		if (insertType == 1) {
			// 图片类型 - 使用第一张图片
			const picList = getItemArrayProp(item, 'picList')
			if (picList.length > 0) {
				const firstPic = picList[0]
				if (firstPic != null) {
					// 🔧 修复：安全地获取图片 URL，添加错误处理
					try {
						// 先尝试作为字符串处理
						const picStr = firstPic.toString()
						if (picStr != '' && picStr.indexOf('http') >= 0) {
							// 已经是 URL 字符串
							imageStr = picStr
						} else {
							// 尝试作为对象处理
							const picUrl = getItemStringProp(firstPic, 'picUrl')
							if (picUrl != '') {
								imageStr = picUrl
							}
						}
					} catch (e) {
						handleSilentError(e, '获取图片URL')
						// 使用默认图片
					}
				}
			}
		} else if (insertType == 3) {
			// 视频类型 - 使用视频封面
			const videoPic = getItemStringProp(item, 'videoPic')
			if (videoPic != '') {
				imageStr = videoPic
			}
		}
		
		// 构建分享链接
		const kid = getItemStringProp(item, 'kid')
		let shareLink = 'https://m.wyxdapp.com/#/pagesBusiness/commend/index?kid=' + kid
		
		// 获取当前用户的推广短号
		let referrerShortKid = ''
		try {
			// 🔧 修复：优先使用 getUserShortKid()，再 fallback 到 store 和缓存 profile
			referrerShortKid = getUserShortKid()
			if (referrerShortKid == '') {
				// 使用 toJsonObj 安全访问 store
				const userStoreObj = toJsonObj(userStore)
				if (userStoreObj != null) {
					const userInfoVal = userStoreObj.get('userInfo')
					if (userInfoVal != null) {
						const userInfoJson = JSON.stringify(userInfoVal)
						if (userInfoJson != null && userInfoJson != '') {
							const userInfoObj = JSON.parse(userInfoJson) as UTSJSONObject
							const shortKidVal = userInfoObj.get('shortKid')
							if (shortKidVal != null && shortKidVal.toString() != '') {
								referrerShortKid = shortKidVal.toString()
							}
						}
					}
				}
			}
			// 🔧 修复APP端：从缓存的当前用户 profile 中获取 shortKid
			if (referrerShortKid == '') {
				const currentUserKidForRef = getUserKidFromStore()
				if (currentUserKidForRef != '') {
					try {
						const cachedMyProfile = getCachedProfile(currentUserKidForRef, currentUserKidForRef)
						if (cachedMyProfile != null) {
							const cachedShortKidVal = cachedMyProfile.get('shortKid')
							if (cachedShortKidVal != null && cachedShortKidVal.toString() != '') {
								referrerShortKid = cachedShortKidVal.toString()
								console.log('[handleShare] 从缓存profile获取推广短号:', referrerShortKid)
								updateUserInfoAction({ shortKid: referrerShortKid } as UTSJSONObject)
							}
						}
					} catch (e2) {}
				}
			}
			if (referrerShortKid != '') {
				// 添加推广参数到链接
				if (shareLink.indexOf('?') >= 0) {
					shareLink = shareLink + '&ref=' + referrerShortKid
				} else {
					shareLink = shareLink + '?ref=' + referrerShortKid
				}
			}
		} catch (e) {
			handleSilentError(e, '获取推广短号')
		}
		
		// 构建分享数据
		// 🔧 修复：添加 discoverKid 字段，用于举报功能
		const newPayload = {
			title: shareTitle,
			summary: shareDesc,
			desc: shareDesc,
			link: shareLink,
			url: shareLink,
			imageUrl: imageStr,
			userId: '',
			referrerShortKid: referrerShortKid,
			discoverKid: kid  // ✅ 添加动态KID，用于举报
		}
		
		sharePayload.value = newPayload
		
		console.log('[handleMoreOptions] 分享数据构建完成:')
		console.log('[handleMoreOptions] - title:', shareTitle)
		console.log('[handleMoreOptions] - desc:', shareDesc)
		console.log('[handleMoreOptions] - imageUrl:', imageStr)
		console.log('[handleMoreOptions] - link:', shareLink)
	} catch (e) {
		handleSilentError(e, '构建分享数据')
		// 使用默认值
		sharePayload.value = {
			title: '网约向导趣游玩',
			summary: '发现精彩动态，一起来看看吧！',
			desc: '发现精彩动态，一起来看看吧！',
			link: 'https://m.wyxdapp.com',
			url: 'https://m.wyxdapp.com',
			imageUrl: 'https://jiasu.wyxdapp.com/iconimages/share_default.png',
			userId: '',
			referrerShortKid: ''
		}
	}
	
	// 获取会话列表
	try {
		const result = await getChatListFn(userStore)
		console.log('[Find] getChatListFn result:', JSON.stringify(result))
		try {
			if (result != null && Array.isArray(result) == true) {
				shareChatList.value = result as Array<UTSJSONObject>
				console.log('[Find] assigned result to shareChatList, new length:', shareChatList.value.length)
			} else {
				// fallback: 安全解析模块级 chatList
				try {
					let fallbackArr: Array<UTSJSONObject> = []
					try {
						const chatList = getChatListRef()
						const rawParsed = JSON.parse(JSON.stringify(chatList))
						if (Array.isArray(rawParsed) == true) {
							fallbackArr = rawParsed as Array<UTSJSONObject>
						}
					} catch (e) {}
					
					if (fallbackArr.length == 0) {
						try {
							const chatList = getChatListRef()
							const chatListObj = JSON.parse(JSON.stringify(chatList)) as UTSJSONObject
							if (chatListObj != null) {
								try {
									const v = chatListObj.get('value')
									if (v != null) {
										try {
											const parsedV = JSON.parse(JSON.stringify(v))
											if (Array.isArray(parsedV) == true) {
												fallbackArr = parsedV as Array<UTSJSONObject>
											}
										} catch (e) {}
									}
								} catch (e) {}
							}
						} catch (e) {}
					}
					shareChatList.value = (fallbackArr.length > 0) ? fallbackArr : []
					console.log('[Find] used fallback chatList, length:', shareChatList.value.length)
				} catch (e) {
					shareChatList.value = []
				}
			}
		} catch (e) {
			handleSilentError(e, '解析会话列表')
		}
	} catch (e) {
		handleSilentError(e, '获取会话列表')
		shareChatList.value = []
	}

	showSharePopup.value = true
}

// 分享事件处理函数
const handleShareToChat = (data: UTSJSONObject) => {
	console.log('[Find] handleShareToChat called with data:', JSON.stringify(data))
	
	if (currentShareItem.value == null) {
		uni.showToast({
			title: '分享失败，请重试',
			icon: 'none'
		})
		return
	}
	
	// 🔧 修复：从 data 中提取 chatItem（SharePopup 传递的是 { chatItem, shareData }）
	let chatItem: UTSJSONObject = {} as UTSJSONObject
	try {
		const dataObj = JSON.parse(JSON.stringify(data)) as UTSJSONObject
		const chatItemVal = dataObj.get('chatItem')
		if (chatItemVal != null) {
			chatItem = chatItemVal as UTSJSONObject
			console.log('[Find] 成功提取 chatItem:', JSON.stringify(chatItem))
		} else {
			console.error('[Find] ❌ data 中没有 chatItem 字段')
		}
	} catch (e) {
		handleSilentError(e, '解析分享数据')
	}
	
	if (chatItem == null) {
		uni.showToast({
			title: '分享失败，会话信息不完整',
			icon: 'none'
		})
		return
	}
	
	// 🔧 判断分享内容类型：检查是否为订单
	const orderNo = getItemStringProp(currentShareItem.value, 'orderNo')
	const shortKid = getItemStringProp(currentShareItem.value, 'shortKid')
	const orderPrice = getItemNumberProp(currentShareItem.value, 'orderPrice')
	const totalMoney = getItemNumberProp(currentShareItem.value, 'totalMoney')
	
	const hasOrderNo = (orderNo != '' || shortKid != '')
	const hasPrice = (orderPrice > 0 || totalMoney > 0)
	
	if (hasOrderNo == true || hasPrice == true) {
		// 订单分享
		console.log('[Find] 检测到订单分享')
		
		// 构建订单信息对象用于分享
		const orderInfo = {
			kid: getItemStringProp(currentShareItem.value, 'kid'),
			orderNo: getGrabOrderNo(currentShareItem.value),
			orderTitle: getGrabOrderTitle(currentShareItem.value),
			totalMoney: getGrabOrderPrice(currentShareItem.value),
			travelDate: getGrabOrderTime(currentShareItem.value),
			touristName: getGrabOrderUserName(currentShareItem.value),
			touristAvatar: getGrabOrderAvatar(currentShareItem.value)
		}
		
		console.log('[Find] handleShareToChat - orderInfo:', JSON.stringify(orderInfo))
		
		// 传递包含 chatItem 的对象作为第一个参数
		const shareData = {
			chatItem: chatItem
		} as UTSJSONObject
		
		handleShareToChatFn(shareData, orderInfo)
	} else {
		// 动态分享（原有逻辑）
		console.log('[Find] 检测到动态分享')
		
		// 构建动态信息对象用于分享（使用动态卡片格式）
		// 🔧 确保字段完整，便于 useChatAndShare.uts 正确识别为动态内容
		const contentText = getItemStringProp(currentShareItem.value, 'discoverContent')
		const titleText = contentText != '' ? contentText : '精彩动态分享'
		
		const dynamicInfo = {
			kid: getItemStringProp(currentShareItem.value, 'kid'),
			id: getItemStringProp(currentShareItem.value, 'kid'),
			title: titleText.length > TEXT_PREVIEW_LENGTH ? titleText.substring(0, TEXT_PREVIEW_LENGTH) + '...' : titleText,
			content: contentText,
			text: contentText,
			description: contentText,  // 🔧 添加 description 字段
			image: '',
			coverImage: '',
			// 🔧 添加用户信息字段，用于卡片显示
			userKid: getItemStringProp(currentShareItem.value, 'userKid'),
			nickName: getItemStringProp(currentShareItem.value, 'nickName'),
			userImage: getItemStringProp(currentShareItem.value, 'userImage')
		}
		
		// 获取封面图片
		const insertType = getItemNumberProp(currentShareItem.value, 'insertType')
		if (insertType == 1) {
			// 图片类型 - 使用第一张图片
			const picList = getItemArrayProp(currentShareItem.value, 'picList')
			if (picList.length > 0) {
				const firstPic = picList[0]
				if (firstPic != null) {
					// 🔧 修复：安全地获取图片 URL
					// firstPic 可能是字符串或对象，需要分别处理
					let picUrl = ''
					try {
						// 先尝试作为字符串处理
						const picStr = firstPic.toString()
						if (picStr != '' && picStr.indexOf('http') >= 0) {
							// 已经是 URL 字符串
							picUrl = picStr
						} else {
							// 尝试作为对象处理
							const picUrlFromObj = getItemStringProp(firstPic, 'picUrl')
							if (picUrlFromObj != '') {
								picUrl = picUrlFromObj
							}
						}
					} catch (e) {
						handleSilentError(e, '获取分享图片URL')
					}
					
					if (picUrl != '') {
						dynamicInfo.image = picUrl
						dynamicInfo.coverImage = picUrl
					}
				}
			}
		} else if (insertType == 3) {
			// 视频类型 - 使用视频封面
			const videoPic = getItemStringProp(currentShareItem.value, 'videoPic')
			if (videoPic != '') {
				dynamicInfo.image = videoPic
				dynamicInfo.coverImage = videoPic
			}
		}
		
		// 🔧 如果没有图片，使用默认动态图片
		if (dynamicInfo.image == '') {
			dynamicInfo.image = 'https://jiasu.wyxdapp.com/iconimages/default_dynamic.png'
			dynamicInfo.coverImage = 'https://jiasu.wyxdapp.com/iconimages/default_dynamic.png'
		}
		
		console.log('[Find] handleShareToChat - dynamicInfo:', JSON.stringify(dynamicInfo))
		console.log('[Find] - 动态ID:', dynamicInfo.kid)
		console.log('[Find] - 标题:', dynamicInfo.title)
		console.log('[Find] - 内容:', dynamicInfo.content)
		console.log('[Find] - 图片:', dynamicInfo.image)
		
		// 🔧 修复：传递包含 chatItem 的对象作为第一个参数
		const shareData = {
			chatItem: chatItem
		} as UTSJSONObject
		
		handleShareToChatFn(shareData, dynamicInfo)
	}
}

// 抢单分享按钮点击
const handleGrabOrderShare = async (item: UTSJSONObject) => {
	console.log('[Find] handleGrabOrderShare called')
	currentShareItem.value = item
	
	try {
		// 构建分享标题
		const orderTitle = getGrabOrderTitle(item)
		const shareTitle = '待抢订单：' + orderTitle
		
		// 构建分享描述
		const orderNo = getGrabOrderNo(item)
		const price = getGrabOrderPrice(item)
		const time = getGrabOrderTime(item)
		const shareDesc = '订单编号：' + orderNo + '\n价格：¥' + price + '\n出发时间：' + time
		
		// 构建分享链接
		const kid = getItemStringProp(item, 'kid')
		let shareLink = 'https://m.wyxdapp.com/#/pagesTrade/orderDetails/index?orderKid=' + kid
		
		// 获取推广短号
		let referrerShortKid = ''
		try {
			// 使用 toJsonObj 安全访问 store
			const userStoreObj = toJsonObj(userStore)
			if (userStoreObj != null) {
				const userInfoVal = userStoreObj.get('userInfo')
				if (userInfoVal != null) {
					const userInfoJson = JSON.stringify(userInfoVal)
					if (userInfoJson != null && userInfoJson != '') {
						const userInfoObj = JSON.parse(userInfoJson) as UTSJSONObject
						const shortKidVal = userInfoObj.get('shortKid')
						if (shortKidVal != null && shortKidVal.toString() != '') {
							referrerShortKid = shortKidVal.toString()
							shareLink = shareLink + '&ref=' + referrerShortKid
						}
					}
				}
			}
		} catch (e) {
			handleSilentError(e, '获取推广短号')
		}
		
		// 构建分享数据
		// 🔧 修复：添加订单KID字段，用于举报功能
		const newPayload = {
			title: shareTitle,
			summary: shareDesc,
			desc: shareDesc,
			link: shareLink,
			url: shareLink,
			imageUrl: 'https://jiasu.wyxdapp.com/iconimages/order_default.png',
			userId: '',
			referrerShortKid: referrerShortKid,
			orderKid: kid  // ✅ 添加订单KID（注意：后端可能需要支持订单举报类型）
		}
		
		sharePayload.value = newPayload
		
		console.log('[handleGrabOrderShare] 分享数据构建完成')
	} catch (e) {
		handleSilentError(e, '构建抢单分享数据')
		sharePayload.value = {
			title: '待抢订单',
			summary: '精彩订单，等你来抢！',
			desc: '精彩订单，等你来抢！',
			link: 'https://m.wyxdapp.com',
			url: 'https://m.wyxdapp.com',
			imageUrl: 'https://jiasu.wyxdapp.com/iconimages/order_default.png',
			userId: '',
			referrerShortKid: ''
		}
	}
	
	// 获取会话列表
	try {
		const result = await getChatListFn(userStore)
		if (result != null && Array.isArray(result) == true) {
			shareChatList.value = result as Array<UTSJSONObject>
		} else {
			shareChatList.value = []
		}
	} catch (e) {
		handleSilentError(e, '获取抢单会话列表')
		shareChatList.value = []
	}
	
	showSharePopup.value = true
}

const handleShareWechat = () => {
	handleShareWechatFn(sharePayload.value)
}

const handleShareMoments = () => {
	handleShareMomentsFn(sharePayload.value)
}

const handleCopyLink = () => {
	handleCopyLinkFn(sharePayload.value)
}

const handleShowQrcode = () => {
	handleShowQrcodeFn(sharePayload.value)
}

// 抢单点击
const handleGrabOrderClick = (item: UTSJSONObject) => {
	const orderKid = getItemStringProp(item, 'kid')
	if (orderKid != '') {
		uni.navigateTo({
			url: '/pagesTrade/orderDetails/index?orderKid=' + orderKid
		})
	}
}

// 抢单用户头像/昵称点击 - 跳转个人主页
const handleGrabOrderUserClick = (item: UTSJSONObject) => {
	// 尝试多个可能的用户ID字段
	let userKid = getItemStringProp(item, 'touristKid')
	if (userKid == '') userKid = getItemStringProp(item, 'userKid')
	if (userKid == '') userKid = getItemStringProp(item, 'userId')
	
	if (userKid != '') {
		uni.navigateTo({
			url: '/pagesUser/persionInfo/index?id=' + userKid
		})
	}
}

// 抢单操作
const handleGrabOrder = async (item: UTSJSONObject) => {
	const isLogin = checkIsLogin()
	if (isLogin == false) {
		uni.navigateTo({
			url: '/pagesUser/login/index'
		})
		return
	}
	
	const userKid = getUserKidFromStore()
	const orderKid = getItemStringProp(item, 'kid')
	
	if (userKid == '' || orderKid == '') return
	
	try {
		const params = {
			orderKid: orderKid,
			guideKid: userKid
		} as UTSJSONObject
		
		await request.post('/order/guide/grabOrder', params, true)
		
		uni.showToast({
			title: '抢单成功',
			icon: 'success'
		})
		
		// 刷新列表
		fetchGrabOrderList(true)
	} catch (error: Error) {
		if (!isAuthError(error)) {
			handlePageError(error, '抢单', null)
		}
	}
}

// ==================== 初始化函数 ====================

// 获取用户位置
const fetchUserLocation = async () => {
	try {
		const locationResult = await getLocationInfo()
		if (locationResult != null) {
			userLatitude.value = locationResult.latitude
			userLongitude.value = locationResult.longitude
			console.log('用户位置获取成功:', userLatitude.value, userLongitude.value)
		}
	} catch (e) {
		handleSilentError(e, '获取用户位置')
	}
}

const initPageData = async () => {
	// 使用 composable 初始化布局
	initPageLayoutComposable()
	
	// 计算头部高度
	// #ifndef H5
	// APP端：状态栏 + 导航栏44 + Tab栏约45px
	headerHeight.value = pageStatusBarHeight.value + 44 + 45
	// #endif
	// #ifdef H5
	// H5端：状态栏 + Tab栏约45px（无导航栏）
	headerHeight.value = pageStatusBarHeight.value + 45
	// #endif
	
	// 计算内容区域高度（窗口高度 - 头部高度）
	if (pageWindowHeight.value > 0) {
		contentHeight.value = pageWindowHeight.value - headerHeight.value
		
		// 确保内容高度有效
		if (contentHeight.value < 200) {
			contentHeight.value = pageWindowHeight.value - 100
		}
	}
	
	console.log('状态栏高度:', pageStatusBarHeight.value, '头部高度:', headerHeight.value, '内容高度:', contentHeight.value)
	
	// 如果内容高度仍然无效，设置默认值
	if (contentHeight.value <= 0) {
		contentHeight.value = 600
	}
	
	// 先获取用户位置，再加载列表
	await fetchUserLocation()
	await fetchTrendsList(true)
}

// ==================== 生命周期 ====================

onMounted(() => {
	// 🔧 修复：主动调用 initUserInfoAction 确保用户信息被初始化
	// 因为 App.uvue 的初始化是延迟的，页面可能在初始化完成前就加载了
	initUserInfoAction()
	
	// 使用 waitForLoginStatus 等待 Store 初始化完成
	waitForLoginStatus(2000).then((result: number) => {
		console.log('[Find] Store 初始化完成，登录状态:', result == 1)
		// 初始化页面数据
		initPageData()
	}).catch((error) => {
		if (error != null) {
			handleSilentError(error, '等待登录状态初始化')
		}
	})
})

onShow(() => {
	const isLogin = checkUserLoginReliable()
	console.log('[Find] onShow 登录状态:', isLogin)
})
</script>

