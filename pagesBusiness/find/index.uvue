<template>
	<view class="page">
		<!-- 背景图片 -->
		<view 
			class="bg-index-header" 
			:style="headerGradientOuter()"
		>
			<view class="bg-index-header-mask" :style="headerGradientMask()"></view>
		</view>
		
		<!-- #ifndef H5 -->
		<!-- APP端导航栏 -->
		<view class="nav-bar" :style="{ paddingTop: pageStatusBarHeight + 'px' }">
			<view class="nav-content">
				<view class="nav-back" @click="handleBack">
					<uni-icons type="left" size="22" color="#333333"></uni-icons>
				</view>
				<text class="nav-title">发现</text>
				<view class="nav-placeholder"></view>
			</view>
		</view>
		<!-- #endif -->
		
		<!-- 顶部 Tab -->
		<!-- #ifndef H5 -->
		<view class="header" :style="{ marginTop: (pageStatusBarHeight + 44) + 'px' }">
		<!-- #endif -->
		<!-- #ifdef H5 -->
		<view class="header" :style="{ paddingTop: pageStatusBarHeight + 'px' }">
		<!-- #endif -->
			<!-- Tab 切换 - 直接实现，不使用组件 -->
			<view class="tabs-row">
				<view class="tab-item" @click="switchTabIndex(0)">
					<text class="tab-text" :class="{ 'tab-text-active': currentTab == 0 }">动态</text>
					<view v-if="currentTab == 0" class="tab-underline"></view>
				</view>
				<view class="tab-item" @click="switchTabIndex(1)">
					<text class="tab-text" :class="{ 'tab-text-active': currentTab == 1 }">抢单</text>
					<view v-if="currentTab == 1" class="tab-underline"></view>
				</view>
				<view class="publish-btn" @click="goToPublish">
					<image src="https://jiasu.wyxdapp.com/iconimages/n_index_send.png" mode="aspectFit" class="publish-icon"></image>
					<text class="publish-text">发布</text>
				</view>
			</view>
		</view>
		
		<!-- 内容区域 -->
		<swiper 
			class="swiper-container"
			:style="{ marginTop: headerHeight + 'px', height: contentHeight + 'px' }"
			:current="currentTab"
			@change="onSwiperChange"
		>
			<!-- 动态 Tab -->
			<swiper-item>
				<scroll-view 
					class="scroll-view"
					:style="{ height: contentHeight + 'px' }"
					scroll-y="true"
					:show-scrollbar="false"
					refresher-enabled="true"
					:refresher-triggered="trendsRefreshing"
					@refresherrefresh="onRefreshTrends"
					@scrolltolower="loadMoreTrends"
				>
					<view v-if="trendsLoading == true && trendsListLength == 0" class="loading">
						<text class="loading-text">加载中...</text>
					</view>
					
					<ListStatus 
						v-else-if="trendsListLength == 0" 
						status="empty" 
						emptyText="暂无动态"
					/>
					
					<view v-else class="list">
						<DynamicItem 
							v-for="(item, index) in trendsList" 
							:key="getTrendsItemKey(item, index)"
							:item="item"
							@user-click="handleUserClick"
							@content-click="handleContentClick"
							@play="onVideoPlay"
							@like="onLike"
							@comment="handleCommentClick"
							@more-click="handleMoreOptions"
							@video-click="handleVideoClick"
						/>
					</view>

					<!-- 加载更多 -->
					<view v-if="trendsListLength > 0" class="load-status">
						<text v-if="trendsLoadStatus == 'loading'" class="status-text">加载中...</text>
						<text v-else-if="trendsLoadStatus == 'nomore'" class="status-text">没有更多了</text>
						<text v-else class="status-text-more">上拉加载更多</text>
					</view>
				</scroll-view>
			</swiper-item>
			
			<!-- 抢单 Tab -->
			<swiper-item>
				<scroll-view 
					class="scroll-view"
					:style="{ height: contentHeight + 'px' }"
					scroll-y="true"
					:show-scrollbar="false"
					refresher-enabled="true"
					:refresher-triggered="grabOrderRefreshing"
					@refresherrefresh="onRefreshGrabOrder"
					@scrolltolower="loadMoreGrabOrders"
				>
					<view v-if="grabOrderLoading == true && grabOrderListLength == 0" class="loading">
						<text class="loading-text">加载中...</text>
					</view>
					
					<ListStatus 
						v-else-if="grabOrderListLength == 0" 
						status="empty" 
						emptyText="暂无抢单"
					/>
					
					<view v-else class="list grab-order-list">
						<view 
							v-for="(item, index) in grabOrderList" 
							:key="getGrabOrderItemKey(item, index)"
							class="order-card"
							@click="handleGrabOrderClick(item)"
						>
							<!-- 头部：头像 + 用户名 + 分享按钮 -->
							<view class="order-card-header">
								<view class="order-card-user" @click.stop="handleGrabOrderUserClick(item)">
									<Avatar
										:url="getGrabOrderAvatar(item)"
										:userId="getGrabOrderUserKid(item)"
										size="small"
										clickMode="none"
									/>
									<text class="order-username">{{ getGrabOrderUserName(item) }}</text>
								</view>
								<view class="order-share-btn" @click.stop="handleGrabOrderShare(item)">
									<uni-icons type="redo" :size="24" color="#999999"></uni-icons>
								</view>
							</view>
							<!-- 分割线 -->
							<view class="order-divider"></view>
							<!-- 订单编号 -->
							<view class="order-info-row">
								<text class="order-info-label">订单编号：</text>
								<text class="order-info-value">{{ getGrabOrderNo(item) }}</text>
							</view>
							<!-- 订单描述 -->
							<view class="order-desc-row">
								<text class="order-desc-text">{{ getGrabOrderTitle(item) }}</text>
							</view>
							<!-- 出发时间 -->
							<view class="order-time-row">
								<image
									class="order-time-icon"
									src="https://jiasu.wyxdapp.com/iconimages/order_icon_startTime.png"
									mode="aspectFill"
								/>
								<text class="order-time-label">出发时间：</text>
								<text class="order-time-value">{{ getGrabOrderTime(item) }}</text>
							</view>
							<!-- 操作按钮行：预算 + 抢单按钮 -->
							<view class="order-btn-row" @click.stop>
								<view class="order-budget-box">
									<text class="order-budget-label">预算：</text>
									<text class="order-price-symbol">¥</text>
									<text class="order-price-value">{{ getGrabOrderPrice(item) }}</text>
								</view>
								<view class="order-btn order-btn-primary" @click="handleGrabOrder(item)">
									<text class="order-btn-primary-text">立即抢单</text>
								</view>
							</view>
						</view>
					</view>
					
					<!-- 加载更多 -->
					<view v-if="grabOrderListLength > 0" class="load-status">
						<text v-if="grabOrderLoadStatus == 'loading'" class="status-text">加载中...</text>
						<text v-else-if="grabOrderLoadStatus == 'nomore'" class="status-text">没有更多了</text>
						<text v-else class="status-text-more">上拉加载更多</text>
					</view>
				</scroll-view>
			</swiper-item>

		</swiper>
		
		<!-- 分享弹窗组件 -->
		<SharePopup
			v-model:visity="showSharePopup"
			:shareData="sharePayload"
			:chatList="shareChatList"
			@share-to-chat="handleShareToChat"
			@wechat-share="handleShareWechat"
			@moments-share="handleShareMoments"
			@copy-link="handleCopyLink"
			@show-qrcode="handleShowQrcode">
		</SharePopup>
	</view>
</template>

<script setup lang="uts">
import { ref, computed, onMounted } from 'vue'
import { onShow } from '@dcloudio/uni-app'
import { headerGradientOuter, headerGradientMask } from '@/common/utils/themeHelper.uts'
import { calculateAndFormatDistance, getFloatProp, toJsonObj } from '@/common/utils/utsSafe.uts'
import { DEFAULT_AVATAR_LOCAL } from '@/common/config/defaultImages.uts'
import { 
	pageStatusBarHeight, 
	pageWindowHeight,
	initPageLayout as initPageLayoutComposable 
} from '@/common/composables/usePageLayout.uts'
import { 
	checkUserLoginReliable, 
	waitForLoginStatus, 
	getCurrentUserIdReliable 
} from '@/common/utils/loginHelper.uts'
import { initUserInfoAction } from '@/stores/user.uts'
import { batchSetLikeStatus, toggleLike, isLiked, getLikeCount } from '@/stores/like.uts'
import { setVideoFeedData } from '@/stores/videoFeed.uts'
import DynamicItem from '@/components/business/DynamicItem.uvue'
import Avatar from '@/components/base/Avatar.uvue'
import SharePopup from '@/components/common/SharePopup.uvue'
import request from '@/utils/request'
import { getLocationInfo } from '@/common/utils/location.uts'
import { isSharedDataDisplayEnabled, isFeatureTogglesLoaded } from '@/common/composables/useFeatureToggles.uts'
import ListStatus from '@/components/base/ListStatus.uvue'
import { 
	getChatList as getChatListFn, 
	getChatListRef,
	handleShareToChat as handleShareToChatFn
} from '@/common/composables/useChatAndShare.uts'
import { 
	handleShareWechat as handleShareWechatFn,
	handleShareMoments as handleShareMomentsFn,
	handleCopyLink as handleCopyLinkFn,
	handleShowQrcode as handleShowQrcodeFn
} from '@/common/composables/useShareUi.uts'
import { useUserStore, getUserShortKid, updateUserInfoAction } from '@/stores/user.uts'
import { TEXT_PREVIEW_LENGTH } from '@/common/config/uiConfig.uts'
import { handlePageError, handleSilentError, isAuthError } from '@/common/utils/errorHandler.uts'
import { getCachedProfile } from '@/common/composables/useUserProfileCache.uts'

// ==================== 类定义 ====================
class PageListData {
	pageNumber: number = 1
	pageSize: number = 10
	status: string = 'loadmore'
	total: number = 0
}

// ==================== 用户位置 ====================
const userLatitude = ref<number>(0)
const userLongitude = ref<number>(0)

// ==================== 辅助函数（必须在使用前定义）====================

// 获取字符串属性
const getItemStringProp = (item: UTSJSONObject, key: string): string => {
	if (item == null) return ''
	try {
		const itemObj = JSON.parse(JSON.stringify(item)) as UTSJSONObject
		const val = itemObj.get(key)
		return (val != null && val.toString() != '') ? val.toString() : ''
	} catch (e) {
		return ''
	}
}

// 获取数字属性
const getItemNumberProp = (item: UTSJSONObject, key: string): number => {
	if (item == null) return 0
	try {
		const itemObj = JSON.parse(JSON.stringify(item)) as UTSJSONObject
		const val = itemObj.get(key)
		if (val != null) {
			const num = parseInt(val.toString())
			if (isNaN(num) == false) return num
		}
	} catch (e) {}
	return 0
}

// 内联金额格式化（替代 money.uts）
const formatMoney = (value: number): string => {
	if (isNaN(value)) return '0.00'
	const cents = Math.round(value * 100)
	const absCents = (cents < 0) ? -cents : cents
	const yuan = Math.floor(absCents / 100)
	const fen = absCents % 100
	const fenStr = (fen < 10) ? ('0' + fen.toString()) : fen.toString()
	const result = yuan.toString() + '.' + fenStr
	return (cents < 0) ? ('-' + result) : result
}

// 获取数组属性
const getItemArrayProp = (item: UTSJSONObject, key: string): Array<UTSJSONObject> => {
	if (item == null) return []
	try {
		const itemObj = JSON.parse(JSON.stringify(item)) as UTSJSONObject
		const val = itemObj.get(key)
		if (val == null) return []
		if (Array.isArray(val) == true) {
			return val as Array<UTSJSONObject>
		}
		return []
	} catch (e) {
		return []
	}
}

// 从 loginHelper 获取用户 Kid（可靠版本）
const getUserKidFromStore = (): string => {
	return getCurrentUserIdReliable()
}

// 检查是否已登录（可靠版本）
const checkIsLogin = (): boolean => {
	return checkUserLoginReliable()
}

// ==================== 响应式状态 ====================

// 返回按钮处理
const handleBack = () => {
	uni.navigateBack({
		delta: 1,
		fail: () => {
			uni.switchTab({ url: '/pages/index/index' })
		}
	})
}

// 头部高度
const headerHeight = ref<number>(0)
// 内容区域高度
const contentHeight = ref<number>(0)

// Tab 相关
const currentTab = ref<number>(0)

// 动态列表
const trendsList = ref<Array<UTSJSONObject>>([])
const trendsLoading = ref<boolean>(false)
const trendsRefreshing = ref<boolean>(false)
const trendsPageData = ref<PageListData>(new PageListData())

// 抢单列表
const grabOrderList = ref<Array<UTSJSONObject>>([])
const grabOrderLoading = ref<boolean>(false)
const grabOrderRefreshing = ref<boolean>(false)
const grabOrderPageData = ref<PageListData>(new PageListData())

// 当前播放的视频 ID
const currentPlayingVideoId = ref<string>('')

// 分享相关状态
const showSharePopup = ref(false)
const sharePayload = ref<UTSJSONObject>({
	title: '',
	desc: '',
	summary: '',
	link: '',
	url: '',
	imageUrl: '',
	userId: '',
	referrerShortKid: ''
} as UTSJSONObject)
const shareChatList = ref<Array<UTSJSONObject>>([])
const userStore = useUserStore()
const currentShareItem = ref({} as UTSJSONObject)

// ==================== 计算属性 ====================

const trendsListLength = computed((): number => {
	try {
		const list = trendsList.value
		if (list != null && Array.isArray(list) == true) {
			return (list as Array<UTSJSONObject>).length
		}
	} catch (e) {}
	return 0
})

const trendsLoadStatus = computed((): string => {
	try {
		return trendsPageData.value.status
	} catch (e) {}
	return 'loadmore'
})

const grabOrderListLength = computed((): number => {
	try {
		const list = grabOrderList.value
		if (list != null && Array.isArray(list) == true) {
			return (list as Array<UTSJSONObject>).length
		}
	} catch (e) {}
	return 0
})

const grabOrderLoadStatus = computed((): string => {
	try {
		return grabOrderPageData.value.status
	} catch (e) {}
	return 'loadmore'
})

// ==================== 模板辅助函数 ====================

// 动态列表 key
const getTrendsItemKey = (item: UTSJSONObject, index: number): string => {
	const kid = getItemStringProp(item, 'kid')
	return (kid != '') ? kid : index.toString()
}

// 抢单列表 key
const getGrabOrderItemKey = (item: UTSJSONObject, index: number): string => {
	const kid = getItemStringProp(item, 'kid')
	return (kid != '') ? kid : index.toString()
}

// 抢单属性获取
const getGrabOrderTitle = (item: UTSJSONObject): string => {
	let title = getItemStringProp(item, 'orderDescribe')
	if (title == '') title = getItemStringProp(item, 'orderTitle')
	return (title != '') ? title : '待抢订单'
}

const getGrabOrderPrice = (item: UTSJSONObject): string => {
	let price = getItemNumberProp(item, 'orderPrice')
	if (price == 0) price = getItemNumberProp(item, 'totalMoney')
	return formatMoney(price)
}

const getGrabOrderTime = (item: UTSJSONObject): string => {
	let time = getItemStringProp(item, 'startTime')
	if (time == '') time = getItemStringProp(item, 'serviceTime')
	if (time == '') time = getItemStringProp(item, 'travelDate')
	return (time != '') ? time : '-'
}

const getGrabOrderNo = (item: UTSJSONObject): string => {
	let orderNo = getItemStringProp(item, 'orderNo')
	if (orderNo == '') orderNo = getItemStringProp(item, 'shortKid')
	return (orderNo != '') ? orderNo : '-'
}

const getGrabOrderAvatar = (item: UTSJSONObject): string => {
	let avatar = getItemStringProp(item, 'touristAvatar')
	if (avatar == '') avatar = getItemStringProp(item, 'userImg')
	if (avatar == '') avatar = getItemStringProp(item, 'avatar')
	return (avatar != '') ? avatar : DEFAULT_AVATAR_LOCAL
}

const getGrabOrderUserName = (item: UTSJSONObject): string => {
	let name = getItemStringProp(item, 'touristName')
	if (name == '') name = getItemStringProp(item, 'userNickname')
	if (name == '') name = getItemStringProp(item, 'nickname')
	return (name != '') ? name : '游客'
}

// 获取抢单用户 ID
const getGrabOrderUserKid = (item: UTSJSONObject): string => {
	let userKid = getItemStringProp(item, 'touristKid')
	if (userKid == '') userKid = getItemStringProp(item, 'userKid')
	return userKid
}

// ==================== API 调用函数 ====================

// 获取动态列表
const fetchTrendsList = async (isRefresh: boolean) => {
	try {
		if (isRefresh == true) {
			trendsPageData.value.pageNumber = 1
			trendsPageData.value.status = 'loadmore'
		}
		
		if (trendsPageData.value.status == 'nomore') return
		
		trendsLoading.value = true
		trendsPageData.value.status = 'loading'
		
		const userKid = getUserKidFromStore()
		const params = {
			pageNumber: trendsPageData.value.pageNumber,
			pageSize: trendsPageData.value.pageSize,
			userKid: userKid
		} as UTSJSONObject
		// 功能开关已加载时才传递 sharedDataEnabled，否则让后端从数据库查询商户配置
		if (isFeatureTogglesLoaded() == true) {
			params['sharedDataEnabled'] = isSharedDataDisplayEnabled()
		}
		
		const res = await request.post('/dynamic/v1/queryAllDynamic', params, false)
		
		console.log('动态列表响应:', JSON.stringify(res))
		
		if (res != null) {
			const resStr = JSON.stringify(res)
			const resObj = JSON.parse(resStr) as UTSJSONObject
			
			// 先获取 data 字段
			const dataVal = resObj.get('data')
			let dataObj: UTSJSONObject | null = null
			if (dataVal != null) {
				const dataStr = JSON.stringify(dataVal)
				dataObj = JSON.parse(dataStr) as UTSJSONObject
			}
			
			// 从 data 中获取 entities 和 count
			let entities: Array<UTSJSONObject> = []
			let count = 0
			
			if (dataObj != null) {
				const entitiesVal = dataObj.get('entities')
				const countVal = dataObj.get('count')
				
				if (entitiesVal != null && Array.isArray(entitiesVal) == true) {
					entities = entitiesVal as Array<UTSJSONObject>
				}
				
				if (countVal != null) {
					const num = parseInt(countVal.toString())
					if (isNaN(num) == false) count = num
				}
			}
			
			console.log('动态列表数据 - entities数量:', entities.length, 'count:', count)
			
			// 为每个项目计算距离
			const userLat = userLatitude.value
			const userLng = userLongitude.value
			if (userLat != 0 && userLng != 0) {
				for (let i = 0; i < entities.length; i = i + 1) {
					const entity = entities[i]
					const itemLat = getFloatProp(entity, 'latitude')
					const itemLng = getFloatProp(entity, 'longitude')
					
					if (itemLat != 0 && itemLng != 0) {
						const distanceStr = calculateAndFormatDistance(userLat, userLng, itemLat, itemLng)
						if (distanceStr != '') {
							// 更新 entity 的 distance 字段
							const entityStr = JSON.stringify(entity)
							const entityObj = JSON.parse(entityStr) as UTSJSONObject
							entityObj.set('distance', distanceStr)
							entities[i] = entityObj as UTSJSONObject
						}
					}
				}
			}
			
			// 批量设置点赞状态
			if (entities.length > 0) {
				const likeItems: Array<any> = []
				for (let i = 0; i < entities.length; i = i + 1) {
					const entity = entities[i]
					const kid = getItemStringProp(entity, 'kid')
					const isLikeVal = getItemNumberProp(entity, 'isLike')
					const likeNumVal = getItemNumberProp(entity, 'likeNum')
					if (kid != '') {
						const likeItem = {
							kid: kid,
							isLike: isLikeVal,
							likeNum: likeNumVal
						} as UTSJSONObject
						likeItems.push(likeItem)
					}
				}
				if (likeItems.length > 0) {
					batchSetLikeStatus(likeItems)
				}
			}
			
			if (isRefresh == true) {
				trendsList.value = entities
			} else {
				const currentList = trendsList.value
				for (let i = 0; i < entities.length; i = i + 1) {
					currentList.push(entities[i])
				}
				trendsList.value = currentList
			}
			
			trendsPageData.value.total = count
			
			const currentLength = trendsList.value.length
			if (currentLength >= count || entities.length < trendsPageData.value.pageSize) {
				trendsPageData.value.status = 'nomore'
			} else {
				trendsPageData.value.status = 'loadmore'
				trendsPageData.value.pageNumber = trendsPageData.value.pageNumber + 1
			}
		}
	} catch (error: Error) {
		if (!isAuthError(error)) {
			handlePageError(error, '获取动态列表', null)
		}
		trendsPageData.value.status = 'loadmore'
	} finally {
		trendsLoading.value = false
	}
}

// 获取抢单列表
const fetchGrabOrderList = async (isRefresh: boolean) => {
	try {
		if (isRefresh == true) {
			grabOrderPageData.value.pageNumber = 1
			grabOrderPageData.value.status = 'loadmore'
		}
		
		if (grabOrderPageData.value.status == 'nomore') return
		
		grabOrderLoading.value = true
		grabOrderPageData.value.status = 'loading'
		
		const params = {
			pageNumber: grabOrderPageData.value.pageNumber,
			pageSize: grabOrderPageData.value.pageSize
		} as UTSJSONObject
		
		const res = await request.post('/order/guide/queryGrabOrder', params, false)
		
		if (res != null) {
			const resStr = JSON.stringify(res)
			const resObj = JSON.parse(resStr) as UTSJSONObject
			
			// 先获取 data 字段
			const dataVal = resObj.get('data')
			let dataObj: UTSJSONObject | null = null
			if (dataVal != null) {
				const dataStr = JSON.stringify(dataVal)
				dataObj = JSON.parse(dataStr) as UTSJSONObject
			}
			
			// 从 data 中获取 entities 和 count
			let entities: Array<UTSJSONObject> = []
			let count = 0
			
			if (dataObj != null) {
				const entitiesVal = dataObj.get('entities')
				const countVal = dataObj.get('count')
				
				if (entitiesVal != null && Array.isArray(entitiesVal) == true) {
					entities = entitiesVal as Array<UTSJSONObject>
				}
				
				if (countVal != null) {
					const num = parseInt(countVal.toString())
					if (isNaN(num) == false) count = num
				}
			}
			
			if (isRefresh == true) {
				grabOrderList.value = entities
			} else {
				const currentList = grabOrderList.value
				for (let i = 0; i < entities.length; i = i + 1) {
					currentList.push(entities[i])
				}
				grabOrderList.value = currentList
			}
			
			grabOrderPageData.value.total = count
			
			const currentLength = grabOrderList.value.length
			if (currentLength >= count || entities.length < grabOrderPageData.value.pageSize) {
				grabOrderPageData.value.status = 'nomore'
			} else {
				grabOrderPageData.value.status = 'loadmore'
				grabOrderPageData.value.pageNumber = grabOrderPageData.value.pageNumber + 1
			}
		}
	} catch (error: Error) {
		if (!isAuthError(error)) {
			handlePageError(error, '获取抢单列表', null)
		}
		grabOrderPageData.value.status = 'loadmore'
	} finally {
		grabOrderLoading.value = false
	}
}

// ==================== 事件处理函数 ====================

// Tab 切换 - 直接点击 Tab 项
const switchTabIndex = (index: number) => {
	if (currentTab.value != index) {
		currentTab.value = index
	}
	
	// 首次切换时加载数据
	if (index == 1 && grabOrderListLength.value == 0) {
		fetchGrabOrderList(true)
	}
}

// Swiper 切换
const onSwiperChange = (e: UTSJSONObject) => {
	if (e != null) {
		const eStr = JSON.stringify(e)
		const eObj = JSON.parse(eStr) as UTSJSONObject
		const detailVal = eObj.get('detail')
		if (detailVal != null) {
			const detailStr = JSON.stringify(detailVal)
			const detailObj = JSON.parse(detailStr) as UTSJSONObject
			const currentVal = detailObj.get('current')
			if (currentVal != null) {
				const current = parseInt(currentVal.toString())
				if (isNaN(current) == false) {
					currentTab.value = current
					
					// 首次切换时加载数据
					if (current == 1 && grabOrderListLength.value == 0) {
						fetchGrabOrderList(true)
					}
				}
			}
		}
	}
}

// 跳转发布 - 根据当前Tab决定跳转目标
const goToPublish = () => {
	if (currentTab.value == 0) {
		// 动态Tab - 跳转到发布动态页面
		uni.navigateTo({ url: '/pages/index/components/addTrends' })
	} else if (currentTab.value == 1) {
		// 抢单Tab - 跳转到提交订单页面
		uni.navigateTo({ url: '/pagesUser/submitOrder/index' })
	}
}

// 下拉刷新 - 动态
const onRefreshTrends = async () => {
	trendsRefreshing.value = true
	await fetchTrendsList(true)
	trendsRefreshing.value = false
}

// 下拉刷新 - 抢单
const onRefreshGrabOrder = async () => {
	grabOrderRefreshing.value = true
	await fetchGrabOrderList(true)
	grabOrderRefreshing.value = false
}

// 加载更多 - 动态
const loadMoreTrends = () => {
