	if (userKid != '') {
		uni.navigateTo({
			url: '/pagesUser/persionInfo/index?id=' + userKid
		})
	}
}

// 内容点击 - 跳转详情
const handleContentClick = (item: UTSJSONObject) => {
	const kid = getItemStringProp(item, 'kid')
	if (kid != '') {
		uni.navigateTo({
			url: '/pagesBusiness/commend/index?kid=' + kid
		})
