	font-size: 28rpx;
	color: #FF6B6B;
	font-weight: bold;
}

.form-item {
	flex-direction: row;
	justify-content: space-between;
	align-items: center;
	padding-top: 24rpx;
	padding-bottom: 24rpx;
	border-bottom-width: 2rpx;
	border-bottom-style: solid;
	border-bottom-color: #f0f0f0;
}

