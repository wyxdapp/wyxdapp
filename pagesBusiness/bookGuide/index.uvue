	padding-left: 28rpx;
	padding-right: 28rpx;
	flex-direction: row;
	align-items: center;
	box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.footer-bar .footer-price + .submit-btn,
.footer-bar .submit-btn + .footer-price {
