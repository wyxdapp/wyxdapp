	font-size: 28rpx;
	color: #333333;
	line-height: 1.8;
	margin-bottom: 20rpx;
}

.images-grid {
	flex-direction: row;
	flex-wrap: wrap;
	margin-bottom: 20rpx;
}


.image-item {
	width: 220rpx;
	height: 220rpx;
	border-radius: 8rpx;
}

