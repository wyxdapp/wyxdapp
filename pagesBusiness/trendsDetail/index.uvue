	margin-bottom: 20rpx;
}


.action-bar {
	flex-direction: row;
	padding-top: 20rpx;
	border-top-width: 2rpx;
	border-top-style: solid;
	border-top-color: #f0f0f0;
}

.action-item {
	flex: 1;
	flex-direction: row;
	align-items: center;
	justify-content: center;
}

.action-icon {
	font-size: 36rpx;
}

.action-text {
	font-size: 24rpx;
	color: #666666;
}

.comment-section {
	background-color: #ffffff;
	padding: 28rpx;
}

.section-title {
	font-size: 30rpx;
	color: #333333;
	font-weight: bold;
	margin-bottom: 24rpx;
}

.empty {
	padding: 80rpx 0;
	text-align: center;
}


.comment-list {
	flex-direction: column;
}

.comment-item {
	flex-direction: row;
	padding-top: 24rpx;
	padding-bottom: 24rpx;
	border-bottom-width: 2rpx;
	border-bottom-style: solid;
	border-bottom-color: #f0f0f0;
}

.comment-item:last-child {
	border-bottom: none;
}

.comment-avatar {
	width: 60rpx;
	height: 60rpx;
	border-radius: 30rpx;
	margin-right: 16rpx;
}

.comment-content {
	flex: 1;
	flex-direction: column;
}

.comment-username {
	font-size: 26rpx;
	color: #333333;
	margin-bottom: 8rpx;
}

.comment-text {
	font-size: 26rpx;
	color: #666666;
	line-height: 1.6;
	margin-bottom: 12rpx;
}

.comment-footer {
	flex-direction: row;
	justify-content: space-between;
	align-items: center;
}

.comment-time {
	font-size: 22rpx;
	color: #999999;
}

.comment-like {
	font-size: 22rpx;
	color: #666666;
}

.comment-input-bar {
	background-color: #ffffff;
	padding-top: 20rpx;
	padding-bottom: 20rpx;
	padding-left: 28rpx;
	padding-right: 28rpx;
	flex-direction: row;
	align-items: center;
	border-top-width: 2rpx;
	border-top-style: solid;
	border-top-color: #e0e0e0;
}


.comment-input {
	flex: 1;
	height: 64rpx;
	background-color: #f5f5f5;
	border-radius: 32rpx;
	padding: 0 24rpx;
	font-size: 26rpx;
}

.send-btn {
	padding-top: 12rpx;
	padding-bottom: 12rpx;
	padding-left: 32rpx;
	padding-right: 32rpx;
	background-color: #e0e0e0;
	border-radius: 32rpx;
}

.send-btn.active {
	background-color: #37B1F2;
}

.send-btn text {
	font-size: 26rpx;
	color: #ffffff;
}
