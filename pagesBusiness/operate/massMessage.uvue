	flex-direction: row;
	justify-content: center;
	padding-bottom: 20rpx;
	border-bottom-width: 1rpx;
	border-bottom-style: solid;
	border-bottom-color: #eeeeee;
}

.tab-item {
	flex-direction: column;
	align-items: center;
	margin-left: 40rpx;
	margin-right: 40rpx;
}

