}

.user-item {
	flex-direction: row;
	align-items: center;
	padding-top: 20rpx;
	padding-bottom: 20rpx;
	border-bottom-width: 1rpx;
	border-bottom-style: solid;
	border-bottom-color: #f5f5f5;
}

.checkbox-box {
	margin-right: 20rpx;
}

.checkbox {
	width: 40rpx;
