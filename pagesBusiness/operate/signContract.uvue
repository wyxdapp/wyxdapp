.page {
	flex-direction: column;
	width: 750rpx;
	height: 100%;
	background-color: #F5F5F5;
}

/* ==================== 背景图片 ==================== */
.hear-bg {
	position: absolute;
	top: 0;
	left: 0;
	width: 750rpx;
	height: 450rpx;
}

.hear-bg-mask {
	position: absolute;
	top: 0;
	left: 0;
	width: 750rpx;
	height: 450rpx;
}

/* #ifndef H5 */
/* APP端导航栏样式 */
.nav-bar {
	position: fixed;
	top: 0;
	left: 0;
	right: 0;
	background-color: #ffffff;
	z-index: 100;
	flex-direction: column;
}

.nav-content {
	flex-direction: row;
	align-items: center;
	justify-content: space-between;
	height: 88rpx;
	padding-left: 20rpx;
	padding-right: 20rpx;
}

.nav-back {
	width: 80rpx;
	height: 88rpx;
	flex-direction: row;
	align-items: center;
	justify-content: flex-start;
}

.nav-title {
	font-size: 34rpx;
	color: #333333;
	font-weight: bold;
}

.nav-placeholder {
	width: 80rpx;
}
/* #endif */

/* ==================== 顶部固定区域 ==================== */
.header {
	position: fixed;
	top: 0;
	left: 0;
	width: 750rpx;
	padding-left: 28rpx;
	padding-right: 28rpx;
	padding-bottom: 0;
	z-index: 100;
}

/* ==================== 搜索栏 ==================== */
.search-bar {
	flex-direction: row;
	align-items: center;
	width: 694rpx;
	height: 84rpx;
}

.location {
	flex-direction: row;
	align-items: center;
	margin-right: 16rpx;
}

.location-icon {
	width: 44rpx;
	height: 44rpx;
	margin-right: 4rpx;
}

.location-text {
	font-size: 32rpx;
	color: #333333;
	font-weight: bold;
}

.arrow {
	font-size: 20rpx;
	color: #333333;
	margin-left: 6rpx;
}

.search-input {
	flex: 1;
	height: 64rpx;
	background-color: #FFFFFF;
	border-radius: 32rpx;
	flex-direction: row;
	align-items: center;
	justify-content: flex-start;
	padding-left: 26rpx;
	padding-right: 26rpx;
	padding-top: 0;
	padding-bottom: 0;
	margin-left: 24rpx;
	margin-right: 32rpx;
}

.search-icon {
	width: 30rpx;
	height: 30rpx;
	margin-right: 22rpx;
}

.search-placeholder {
	font-size: 28rpx;
	color: #999999;
}

.publish-btn {
	flex-direction: column;
	align-items: center;
	justify-content: center;
}

.publish-icon {
	width: 30rpx;
	height: 30rpx;
	margin-bottom: 6rpx;
}

.publish-text {
	font-size: 22rpx;
	color: #333333;
}

/* ==================== Tab 栏 ==================== */
.tabs-row {
	flex-direction: row;
	align-items: center;
	width: 694rpx;
	height: 90rpx;
	background-color: transparent;
}

.tab-item {
	flex-direction: column;
	align-items: center;
	justify-content: center;
	margin-right: 48rpx;
	height: 90rpx;
}

.tab-text {
	font-size: 28rpx;
	color: #666666;
	line-height: 40rpx;
}

.tab-text-active {
	font-size: 32rpx;
	color: #333333;
	font-weight: bold;
}

.tab-underline {
	width: 40rpx;
	height: 6rpx;
	background-color: #37B1F2;
	border-radius: 3rpx;
	margin-top: 8rpx;
}

.filter-btn {
	flex-direction: row;
	align-items: center;
	justify-content: center;
