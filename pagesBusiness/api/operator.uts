/**
 * 运营中心相关 API
 * 对应Vue2: http.api.js 中的运营中心模块
 */

import request from '@/utils/request'

// ============ 接口定义（仅作文档参考，不用于函数参数类型） ============

// 向导签约信息接口
export interface GuideSignInfo {
	kid: string
	guideKid: string
	guideName: string
	guideAvatar?: string
	signStatus: number
	signRate: number
	signTime?: string
	auditTime?: string
	auditStatus?: number
}

// 推广统计接口
export interface PromotionStats {
	totalInvites: number
	totalRevenue: number
	monthInvites: number
	monthRevenue: number
}

// 运营统计接口
export interface OperateStats {
	signedGuides: number
	totalRevenue: number
	monthRevenue: number
	pendingAudit: number
}

// ============ API 函数 ============

/**
 * 添加运营（用户绑定）- 用于推广落地页绑定用户到导师
 * POST /support/tutor/addExtend
 * @param params { tutorKid: string, userKid: string, tutorNumber?: string }
 */
export const addExtend = (params: UTSJSONObject): Promise<UTSJSONObject> => {
	return request.post('/support/tutor/addExtend', params, true)
}

/**
 * 查询向导签约列表 - 用于用户管理页面显示向导列表和运营中心首页统计数据
 * POST /support/tutor/queryGuideSignList
 * @param params { tutorKid: string, signStatus?: number, pageNumber?: number, pageSize?: number }
 */
export const getOperatorGuides = (params: UTSJSONObject): Promise<UTSJSONObject> => {
	return request.post('/support/tutor/queryGuideSignList', params, true)
}

/**
 * 签约向导 - 用于用户管理页面签约向导操作
 * POST /support/tutor/addSign
 * @param params { tutorKid: string, guideKid: string, signRate: number }
 */
export const signGuide = (params: UTSJSONObject): Promise<UTSJSONObject> => {
	return request.post('/support/tutor/addSign', params, true)
}

/**
 * 修改签约 - 用于签约记录页面修改签约费率
 * POST /support/tutor/updateSign
 * @param params { kid: string, signRate: number }
 */
export const updateSignGuide = (params: UTSJSONObject): Promise<UTSJSONObject> => {
	return request.post('/support/tutor/updateSign', params, true)
}

/**
 * 审核签约（后台管理系统）- 后台使用，前端不直接调用
 * POST /support/tutor/auditSign
 * @param params { kid: string, auditStatus: number, auditReason?: string }
 */
export const auditSign = (params: UTSJSONObject): Promise<UTSJSONObject> => {
	return request.post('/support/tutor/auditSign', params, true)
}

/**
 * 获取推广统计数据 - 用于用户推广页面显示推广统计
 * GET /support/tutor/queryPromotionStats
 */
export const getPromotionStats = (userKid: string): Promise<UTSJSONObject> => {
	return request.get('/support/tutor/queryPromotionStats?userKid=' + userKid, null, false)
}


/**
 * 获取邀请记录 - 用于用户推广页面显示邀请历史
 * GET /support/tutor/queryInviteHistory
 * @param params { userKid: string, pageSize?: number }
 */
export const getInviteHistory = (params: UTSJSONObject): Promise<UTSJSONObject> => {
	// 使用 JSON 序列化模式获取参数
	const paramsStr = JSON.stringify(params)
	const paramsObj = JSON.parse(paramsStr) as UTSJSONObject
	const userKidVal = paramsObj.get('userKid')
	const userKid = (userKidVal != null) ? userKidVal.toString() : ''
	const pageSizeVal = paramsObj.get('pageSize')
	let pageSize = 10
	if (pageSizeVal != null) {
		const ps = parseInt(pageSizeVal.toString())
		if (isNaN(ps) == false) {
			pageSize = ps
		}
	}
	return request.get('/support/tutor/queryInviteHistory?userKid=' + userKid + '&pageSize=' + pageSize.toString(), null, false)
}

/**
 * 根据导师号获取邀请人信息 - 用于推广落地页显示邀请人信息
 * GET /support/tutor/queryInviterInfo
