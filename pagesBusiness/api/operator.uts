/**
 * 审核签约申请 - 用于运营端审核向导的签约申请
 * POST /support/tutor/auditSign
 * @param params { kid: string, auditStatus: number, auditReason?: string }
 * auditStatus: 30=审核通过, 40=审核不通过
 */
export const auditSignRequest = (params: UTSJSONObject): Promise<UTSJSONObject> => {
	return request.post('/support/tutor/auditSign', params, true)
}

/**
 * 查询待审核签约列表 - 用于运营端查看待审核的签约申请
 * POST /support/tutor/queryPendingSignList
 * @param params { tutorKid: string, pageNumber?: number, pageSize?: number }
 */
export const queryPendingSignList = (params: UTSJSONObject): Promise<UTSJSONObject> => {
	// 使用 JSON 序列化模式获取参数
	const paramsStr = JSON.stringify(params)
	const paramsObj = JSON.parse(paramsStr) as UTSJSONObject
	const tutorKidVal = paramsObj.get('tutorKid')
	const tutorKid = (tutorKidVal != null) ? tutorKidVal.toString() : ''
	const pageNumberVal = paramsObj.get('pageNumber')
	let pageNumber = 1
	if (pageNumberVal != null) {
		const pn = parseInt(pageNumberVal.toString())
		if (isNaN(pn) == false) {
			pageNumber = pn
		}
	}
	const pageSizeVal = paramsObj.get('pageSize')
	let pageSize = 10
	if (pageSizeVal != null) {
		const ps = parseInt(pageSizeVal.toString())
		if (isNaN(ps) == false) {
			pageSize = ps
		}
	}
	// 查询 signStatus=20 的签约申请
	const queryParams = {
		tutorKid: tutorKid,
		signStatus: 20,
		pageNumber: pageNumber,
		pageSize: pageSize
	} as UTSJSONObject
	return request.post('/support/tutor/queryGuideSignList', queryParams, true)
}
