/**
 * 获取群发消息历史 - 用于群发消息页面显示发送历史
 * GET /support/tutor/queryMassMessageHistory
 * @param params { userKid: string, pageSize?: number }
 */
export const getMassMessageHistory = (params: UTSJSONObject): Promise<UTSJSONObject> => {
	// 使用 JSON 序列化模式获取参数
	const paramsStr = JSON.stringify(params)
	const paramsObj = JSON.parse(paramsStr) as UTSJSONObject
	const userKidVal = paramsObj.get('userKid')
	const userKid = (userKidVal != null) ? userKidVal.toString() : ''
	const pageSizeVal = paramsObj.get('pageSize')
	let pageSize = 5
	if (pageSizeVal != null) {
		const ps = parseInt(pageSizeVal.toString())
		if (isNaN(ps) == false) {
			pageSize = ps
		}
	}
	return request.get('/support/tutor/queryMassMessageHistory?userKid=' + userKid + '&pageSize=' + pageSize.toString(), null, false)
}

