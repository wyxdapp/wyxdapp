/**
 * 获取向导签约信息 - 用于签约记录页面显示向导详细信息
 * GET /support/tutor/queryGuideSignInfo
 * @param params { guideId: string, userKid: string }
 */
export const getGuideSignInfo = (params: UTSJSONObject): Promise<UTSJSONObject> => {
	// 使用 JSON 序列化模式获取参数
	const paramsStr = JSON.stringify(params)
	const paramsObj = JSON.parse(paramsStr) as UTSJSONObject
	const guideIdVal = paramsObj.get('guideId')
	const guideId = (guideIdVal != null) ? guideIdVal.toString() : ''
	const userKidVal = paramsObj.get('userKid')
	const userKid = (userKidVal != null) ? userKidVal.toString() : ''
	return request.get('/support/tutor/queryGuideSignInfo?guideId=' + guideId + '&userKid=' + userKid, null, false)
}

