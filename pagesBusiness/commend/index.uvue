const previewCommentImage = (item: UTSJSONObject, index: number) => {
	const picList = getItemArrayProp(item, 'picUrlList')
	let urls: Array<string> = []
	for (let i = 0; i < picList.length; i++) {
		const p = picList[i]
		const picUrl = getItemStringProp(p, 'picUrl')
		if (picUrl != '') {
			urls.push(picUrl)
		} else if (p != null) {
			urls.push(p.toString())
		}
	}
	uni.previewImage({
		urls: urls,
		current: index
	})
}

const viewAllReplies = async (item: UTSJSONObject) => {
	let commentKid = getItemStringProp(item, 'commentKid')
	if (commentKid == '') {
		commentKid = getItemStringProp(item, 'kid')
	}
	if (commentKid == '') return
	
	try {
		const params = new GetReplyListParams()
		params.commentKid = commentKid
		params.pageNumber = 1
		params.pageSize = 50
		const res = await getReplyList(params)
		
		if (res != null) {
			const resStr = JSON.stringify(res)
			const resObj = JSON.parse(resStr) as UTSJSONObject
			const dataVal = resObj.get('data')
			if (dataVal != null) {
				const dataStr = JSON.stringify(dataVal)
				const dataObj = JSON.parse(dataStr) as UTSJSONObject
				const entitiesVal = dataObj.get('entities')
				if (entitiesVal != null && Array.isArray(entitiesVal) == true) {
					const itemStr = JSON.stringify(item)
					const itemObj = JSON.parse(itemStr) as UTSJSONObject
					itemObj.set('replyList', entitiesVal)
					
					const countVal = dataObj.get('count')
					if (countVal != null) {
						const count = parseInt(countVal.toString())
						if (isNaN(count) == false) {
							itemObj.set('replyCount', count)
						}
					} else {
						itemObj.set('replyCount', (entitiesVal as Array<UTSJSONObject>).length)
					}
				}
			}
		}
	} catch (error) {
		handleSilentError(error, '获取回复列表')
	}
}

const getCommendList = async () => {
	if (pageList.value.status == 'loading' || pageList.value.status == 'nomore') {
		return
	}
	
	// 检查 contentKid 是否有效
	const contentKidVal = pageList.value.contentKid
	if (contentKidVal == null || contentKidVal == '') {
		console.error('获取评论列表失败: contentKid为空')
		pageList.value.status = 'loadmore'
		return
	}
	
	try {
		pageList.value.status = 'loading'
		
		const params = new GetCommentListParams()
		params.discoverKid = contentKidVal
		params.pageNumber = pageList.value.pageNumber
		params.pageSize = pageList.value.pageSize
		params.commentModule = commendTemp.value.commentModule
		const res = await getCommentList(params)
		
		let entities: Array<UTSJSONObject> = []
		if (res != null) {
			const resStr = JSON.stringify(res)
			const resObj = JSON.parse(resStr) as UTSJSONObject
			const dataVal = resObj.get('data')
			if (dataVal != null) {
				const dataStr = JSON.stringify(dataVal)
				const dataObj = JSON.parse(dataStr) as UTSJSONObject
				
				const entitiesVal = dataObj.get('entities')
				if (entitiesVal != null && Array.isArray(entitiesVal) == true) {
					entities = entitiesVal as Array<UTSJSONObject>
				} else if (Array.isArray(dataVal) == true) {
					entities = dataVal as Array<UTSJSONObject>
				}
				
				// 同步评论总数
				const countVal = dataObj.get('count')
				if (countVal != null) {
					const count = parseInt(countVal.toString())
					if (isNaN(count) == false) {
						info.value.commentNum = count
						uni.setNavigationBarTitle({
							title: `评论(${count})`
						})
					}
				}
			}
		}
		
		// 处理每条评论，如果有回复列表则加载前2条
		if (entities.length > 0) {
			for (let i = 0; i < entities.length; i++) {
				const item = entities[i]
				const replyCount = getItemNumberProp(item, 'replyCount')
				const replyList = getItemArrayProp(item, 'replyList')
				
				if (replyCount > 0 && replyList.length == 0) {
					try {
						let commentKid = getItemStringProp(item, 'commentKid')
						if (commentKid == '') {
							commentKid = getItemStringProp(item, 'kid')
						}
						
						const replyParams = new GetReplyListParams()
						replyParams.commentKid = commentKid
						replyParams.pageNumber = 1
						replyParams.pageSize = 2
						const replyRes = await getReplyList(replyParams)
						
						if (replyRes != null) {
							const replyResStr = JSON.stringify(replyRes)
							const replyResObj = JSON.parse(replyResStr) as UTSJSONObject
							const replyDataVal = replyResObj.get('data')
							if (replyDataVal != null) {
								const replyDataStr = JSON.stringify(replyDataVal)
								const replyDataObj = JSON.parse(replyDataStr) as UTSJSONObject
								const replyEntitiesVal = replyDataObj.get('entities')
								if (replyEntitiesVal != null && Array.isArray(replyEntitiesVal) == true) {
									const itemObj = JSON.parse(JSON.stringify(item)) as UTSJSONObject
									itemObj.set('replyList', replyEntitiesVal)
									
									const replyCountVal = replyDataObj.get('count')
									if (replyCountVal != null) {
										const rc = parseInt(replyCountVal.toString())
										if (isNaN(rc) == false) {
											itemObj.set('replyCount', rc)
										}
									}
									entities[i] = itemObj
								}
							}
						}
					} catch (e) {
						handleSilentError(e, '加载回复')
					}
				}
			}
			
			const currentList = commendList.value
			for (let j = 0; j < entities.length; j++) {
				currentList.push(entities[j])
			}
			commendList.value = currentList
			pageList.value.status = 'loadmore'
		} else {
			pageList.value.status = 'nomore'
		}
	} catch (error) {
		handleSilentError(error, '获取评论列表')
		pageList.value.status = 'loadmore'
		// 显示用户友好的错误提示
		let errorMsg = '获取评论列表失败'
		if (error != null) {
			const errorStr = error.toString()
			if (errorStr.indexOf('网络') >= 0 || errorStr.indexOf('network') >= 0) {
				errorMsg = '网络连接失败，请检查网络'
			} else if (errorStr.indexOf('timeout') >= 0 || errorStr.indexOf('超时') >= 0) {
				errorMsg = '请求超时，请稍后重试'
			}
		}
		uni.showToast({
			title: errorMsg,
			icon: 'none'
		})
	}
}

const loadMoreComments = () => {
	if (pageList.value.status == 'loadmore') {
		pageList.value.pageNumber++
		getCommendList()
	}
}

const send = async () => {
	checkLogin()
	if (isUserLoggedIn() == false) return
	
	const content = commentContentStr.value.trim()
	if (content == '') {
		uni.showToast({
			title: '请输入评论内容',
			icon: 'none'
		})
		return
	}
	
	if (flag.value == false) return
	flag.value = false
	
	try {
		const currentUserKid = getUserKidFromStore()
		
		// 回复评论
		if (replyMode.value == true && hasReplyTarget.value == true && replyTarget.value.commentKid != '') {
			const payload = new AddReplyParams()
			payload.userKid = currentUserKid
			payload.commentKid = replyTarget.value.commentKid
			payload.replyContent = content
			payload.idempotencyKey = `${currentUserKid}-${replyTarget.value.commentKid}-${Date.now()}`
			
			await addReply(payload)
			
			uni.showToast({
				title: '回复成功',
				icon: 'success'
			})
			
			replyMode.value = false
			hasReplyTarget.value = false
			replyTarget.value = new ReplyTargetData()
			commentContentStr.value = ''
			commendTemp.value.commentContent = ''
			flag.value = true
			
			// 刷新评论列表
			pageList.value.pageNumber = 1
			pageList.value.status = 'loadmore'
			commendList.value = []
			getCommendList()
			return
		}
		
		// 新增评论
		const commentPayload = new AddCommentParams()
		commentPayload.userKid = currentUserKid
		commentPayload.contentKid = commendTemp.value.contentKid
		commentPayload.commentContent = content
		commentPayload.commentModule = commendTemp.value.commentModule
		await addComment(commentPayload)
		
		commentContentStr.value = ''
		commendTemp.value.commentContent = ''
		flag.value = true
		
		// 更新评论数
		info.value.commentNum = info.value.commentNum + 1
		uni.setNavigationBarTitle({
			title: `评论(${info.value.commentNum})`
		})
		
		// 刷新评论列表
		safeSetTimeout(() => {
			pageList.value.pageNumber = 1
			pageList.value.status = 'loadmore'
			commendList.value = []
			getCommendList()
		}, 650)
		
		uni.showToast({
			title: '评论成功',
			icon: 'success'
		})
	} catch (error) {
		if (!isAuthError(error)) {
			handlePageError(error, '评论', null)
		}
		flag.value = true
	}
}

const getData = async (data: GetTrendDetailParams) => {
	try {
		loading.value = true
		const res = await getTrendDetail(data)
		
		if (res != null) {
			const resStr = JSON.stringify(res)
			const resObj = JSON.parse(resStr) as UTSJSONObject
			const dataVal = resObj.get('data')
			
			if (dataVal != null) {
				const detailStr = JSON.stringify(dataVal)
				const detail = JSON.parse(detailStr) as UTSJSONObject
				
				// 解析详情数据
				let kid = ''
				const kidVal = detail.get('kid')
				const dynamicKidVal = detail.get('dynamicKid')
				if (kidVal != null && kidVal.toString() != '') {
					kid = kidVal.toString()
				} else if (dynamicKidVal != null && dynamicKidVal.toString() != '') {
					kid = dynamicKidVal.toString()
				}
				
				const userKidVal = detail.get('userKid')
				const userKid = (userKidVal != null) ? userKidVal.toString() : ''
				
				let nickName = ''
				const nicknameVal = detail.get('nickname')
				const nickNameVal = detail.get('nickName')
				if (nicknameVal != null && nicknameVal.toString() != '') {
					nickName = nicknameVal.toString()
				} else if (nickNameVal != null && nickNameVal.toString() != '') {
					nickName = nickNameVal.toString()
				}
				
				let userImage = defaultAvatar
				const avatarVal = detail.get('avatar')
				const userImageVal = detail.get('userImage')
				if (avatarVal != null && avatarVal.toString() != '') {
					userImage = avatarVal.toString()
				} else if (userImageVal != null && userImageVal.toString() != '') {
					userImage = userImageVal.toString()
				}
				
				const sexVal = detail.get('sex')
				const sex = (sexVal != null) ? sexVal.toString() : ''
				
				const ageVal = detail.get('age')
				const age = (ageVal != null) ? ageVal.toString() : ''
				
				let publishTime = ''
				const publishTimeVal = detail.get('publishTime')
				const createTimeVal = detail.get('createTime')
				if (publishTimeVal != null && publishTimeVal.toString() != '') {
					publishTime = publishTimeVal.toString()
				} else if (createTimeVal != null && createTimeVal.toString() != '') {
					publishTime = createTimeVal.toString()
				}
				
				let discoverContent = ''
				const contentVal = detail.get('content')
				const discoverContentVal = detail.get('discoverContent')
				if (contentVal != null && contentVal.toString() != '') {
					discoverContent = contentVal.toString()
				} else if (discoverContentVal != null && discoverContentVal.toString() != '') {
					discoverContent = discoverContentVal.toString()
				}
				
				let insertType = 0
				const insertTypeVal = detail.get('insertType')
				if (insertTypeVal != null) {
					const it = parseInt(insertTypeVal.toString())
					if (isNaN(it) == false) insertType = it
				}
				
				let picList: Array<any> = []
				const imagesVal = detail.get('images')
				const picListVal = detail.get('picList')
				if (imagesVal != null && Array.isArray(imagesVal) == true) {
					picList = imagesVal as Array<any>
				} else if (picListVal != null && Array.isArray(picListVal) == true) {
					picList = picListVal as Array<any>
				}
				
				let mediaName = ''
				const mediaNameVal = detail.get('mediaName')
				const videoVal = detail.get('video')
				if (mediaNameVal != null && mediaNameVal.toString() != '') {
					mediaName = mediaNameVal.toString()
				} else if (videoVal != null && videoVal.toString() != '') {
					mediaName = videoVal.toString()
				}
				
				const videoPicVal = detail.get('videoPic')
				const videoPic = (videoPicVal != null) ? videoPicVal.toString() : ''
				
				const lineVal = detail.get('line')
				let line: UTSJSONObject | null = null
				if (lineVal != null) {
					line = lineVal as UTSJSONObject
				}
				
				let discoverAddress = ''
				const locationVal = detail.get('location')
				const discoverAddressVal = detail.get('discoverAddress')
				if (locationVal != null && locationVal.toString() != '') {
					discoverAddress = locationVal.toString()
				} else if (discoverAddressVal != null && discoverAddressVal.toString() != '') {
					discoverAddress = discoverAddressVal.toString()
				}
				
				const distanceVal = detail.get('distance')
				const distance = (distanceVal != null) ? distanceVal.toString() : ''
				
				let likeNum = 0
				const likeCountVal = detail.get('likeCount')
				const likeNumVal = detail.get('likeNum')
				if (likeCountVal != null) {
					const lc = parseInt(likeCountVal.toString())
					if (isNaN(lc) == false) likeNum = lc
				} else if (likeNumVal != null) {
					const ln = parseInt(likeNumVal.toString())
					if (isNaN(ln) == false) likeNum = ln
				}
				
				let commentNum = 0
				const commentCountVal = detail.get('commentCount')
				const commentNumVal = detail.get('commentNum')
				if (commentCountVal != null) {
					const cc = parseInt(commentCountVal.toString())
					if (isNaN(cc) == false) commentNum = cc
				} else if (commentNumVal != null) {
					const cn = parseInt(commentNumVal.toString())
					if (isNaN(cn) == false) commentNum = cn
				}
				
				const isLikeVal = detail.get('isLike')
				const isLike = (isLikeVal == true || isLikeVal == 10) ? 10 : 20
				
				const levelVal = detail.get('level')
				let level: UTSJSONObject | null = null
				if (levelVal != null) {
					level = levelVal as UTSJSONObject
				}
				
				const badgeVal = detail.get('badge')
				let badge: UTSJSONObject | null = null
				if (badgeVal != null) {
					badge = badgeVal as UTSJSONObject
				}
				
				let auditStatus = 0
				const auditStatusVal = detail.get('auditStatus')
				if (auditStatusVal != null) {
					const as2 = parseInt(auditStatusVal.toString())
					if (isNaN(as2) == false) auditStatus = as2
				}
				
				// 设置 info 数据
				info.value.kid = kid
				info.value.userKid = userKid
				info.value.nickName = nickName
				info.value.userImage = userImage
				info.value.sex = sex
				info.value.age = age
				info.value.publishTime = publishTime
				info.value.discoverContent = discoverContent
				info.value.insertType = insertType
				info.value.picList = picList
				info.value.mediaName = mediaName
				info.value.videoPic = videoPic
				info.value.line = line
				info.value.discoverAddress = discoverAddress
				info.value.distance = distance
				info.value.likeNum = likeNum
				info.value.commentNum = commentNum
				info.value.isLike = isLike
				info.value.level = level
				info.value.badge = badge
				info.value.auditStatus = auditStatus
				hasInfoData.value = true
				
				// 同步点赞状态到全局 store
				if (kid != '') {
					const likeDataItem = {
						kid: kid,
						isLike: isLike,
						likeNum: likeNum
					} as UTSJSONObject
					const likeData: Array<any> = [likeDataItem]
					batchSetLikeStatus(likeData)
				}
				
				// 设置导航栏标题
				if (commentNum > 0) {
					uni.setNavigationBarTitle({
						title: `评论(${commentNum})`
					})
				}
				
				pageList.value.contentKid = kid
				commendTemp.value.contentKid = kid
				
				// 记录访客
				recordVisitor()
				
				// 获取评论列表
				const currentUserKid = getUserKidFromStore()
				if (currentUserKid != '') {
					commendTemp.value.userKid = currentUserKid
				}
				getCommendList()
			}
		}
		
		initFinish.value = true
	} catch (error) {
		if (!isAuthError(error)) {
			handlePageError(error, '获取动态详情', loading)
		}
	} finally {
		loading.value = false
	}
}

// ==================== 生命周期 ====================
onLoad((options: OnLoadOptions) => {
	// 初始化页面布局（状态栏高度等）
	initPageLayoutComposable()
	
	// 🔧 修复：主动调用 initUserInfoAction 确保用户信息被初始化
	// 因为 App.uvue 的初始化是延迟的，页面可能在初始化完成前就加载了
	initUserInfoAction()
	
	if (options == null) {
		uni.showToast({
			title: '动态id出错1',
			icon: 'none'
		})
		return
	}
	
	const optionsStr = JSON.stringify(options)
	const optionsObj = JSON.parse(optionsStr) as UTSJSONObject
	
	// 兼容两种参数名：id 和 kid
	let dynamicId = ''
	const idVal = optionsObj.get('id')
	const kidVal = optionsObj.get('kid')
	
	if (idVal != null && idVal.toString() != '') {
		dynamicId = idVal.toString()
	} else if (kidVal != null && kidVal.toString() != '') {
		dynamicId = kidVal.toString()
	}
	
	if (dynamicId == '') {
		uni.showToast({
			title: '动态id出错2',
			icon: 'none'
		})
		return
	}
	
	// 获取位置信息
	getLocation()
	
	// 构建请求数据
	const dataObj = new GetTrendDetailParams()
	dataObj.kid = dynamicId
	
	const currentUserKid = getUserKidFromStore()
	if (currentUserKid != '') {
		dataObj.userKid = currentUserKid
	}
	
	// 传递位置信息
	if (latitude.value > 0 && longitude.value > 0) {
		dataObj.latitude = latitude.value
		dataObj.longitude = longitude.value
	}
	
	getData(dataObj)
})

onReachBottom(() => {
	checkLogin()
	if (pageList.value.status == 'loadmore') {
		pageList.value.status = 'loading'
		pageList.value.pageNumber++
		getCommendList()
	}
})

// ==================== Watch ====================
watch(commentContentStr, (newVal: string, oldVal: string) => {
	commendTemp.value.commentContent = newVal
})

onUnmounted(() => {
	clearAllTimers()
})
</script>

