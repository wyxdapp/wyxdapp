const handleBook = () => {
	// 检查登录状态
	const isLoggedIn = checkUserLoginReliable()
	if (isLoggedIn == false) {
		uni.showToast({
			title: '请先登录',
			icon: 'none'
		})
		safeSetTimeout(() => {
			uni.navigateTo({
				url: '/pagesUser/login/index'
			})
		}, 1500)
		return
	}
	
	// 跳转到路线预约页面
	const lineKidVal = routeInfoId.value
	const priceVal = routeInfoPrice.value
	const guideKidVal = guideInfoUserKid.value
	const lineTitleVal = routeInfoTitle.value
	
	if (lineKidVal == '') {
		uni.showToast({
			title: '路线信息不存在',
			icon: 'none'
		})
		return
	}
	
	// 验证向导信息
	if (guideKidVal == '') {
		uni.showToast({
			title: '路线向导信息不完整',
			icon: 'none'
		})
		return
	}
	
	// 构建跳转URL（包含向导ID和路线标题）
	let url = '/pagesBusiness/routeInfo/submitOrder?lineKid=' + lineKidVal + '&guideKid=' + guideKidVal
	if (priceVal > 0) {
		url = url + '&price=' + priceVal.toString()
	}
	if (lineTitleVal != '') {
		// URL编码路线标题,避免特殊字符问题
		url = url + '&lineTitle=' + encodeURIComponent(lineTitleVal)
	}
	
	uni.navigateTo({
		url: url
	})
}

// 辅助函数：检查用户是否登录
const checkUserLogin = (): boolean => {
	return checkUserLoginUtil()
}

// 点赞处理
const handleLike = () => {
	const isLoggedIn = checkUserLoginReliable()
	if (isLoggedIn == false) {
		uni.showToast({
			title: '请先登录',
			icon: 'none'
		})
		safeSetTimeout(() => {
			uni.navigateTo({
				url: '/pagesUser/login/index'
			})
		}, 1500)
		return
	}
	
	isLiked.value = (isLiked.value == true) ? false : true
	if (isLiked.value == true) {
		likeCount.value = likeCount.value + 1
		uni.showToast({
			title: '已点赞',
			icon: 'success',
			duration: 1000
		})
	} else {
		const newCount = likeCount.value - 1
		likeCount.value = (newCount > 0) ? newCount : 0
	}
	
	// TODO: 调用点赞API
	// await likeRoute(routeId.value, isLiked.value)
}

onUnmounted(() => {
	clearAllTimers()
})
</script>

