		image: routeInfoImages.value.length > 0 ? routeInfoImages.value[0] : '',
		coverImage: routeInfoImages.value.length > 0 ? routeInfoImages.value[0] : ''
	}
	
	console.log('[RouteInfo] handleShareToChat - routeInfo:', JSON.stringify(routeInfo))
	handleShareToChatFn(data, routeInfo)
}

