		return
	}
	uni.navigateTo({
		url: `/pagesUser/persionInfo/index?id=${guideInfoUserKid.value}`
	})
}

const handleApp = () => {
	// #ifdef H5
	try {
		// 使用缓存工具获取环境信息
		if (isPC()) {
			safeRedirect('https://jiasu.wyxdapp.com/down.html')
			return
		}
		
		if (isWechatBrowser()) {
			uni.showToast({
				title: '请点击右上角按钮, 点击使用浏览器打开',
				icon: 'none'
			})
			return
		}
		
		// 判断是否为Android或iOS
		const isAndroidDevice = isAndroid()
		const isIOSDevice = isIOS()
		const lineKidCheckVal = routeInfoId.value
		const lineKid = ((lineKidCheckVal != null) && (lineKidCheckVal != '')) ? lineKidCheckVal : routeId.value
		const userKid = getCurrentUserKid()
		if (isAndroidDevice) {
			safeRedirect(`qy://app/route?password=${lineKid}&kid=${userKid}`)
			safeSetTimeout(() => {
				safeRedirect('https://cos.wyxdapp.com/down/wyxdapp.apk')
			}, 1000)
		} else if (isIOSDevice) {
			safeRedirect(`qylv://routeid=${lineKid}&kid=${userKid}`)
			safeSetTimeout(() => {
				safeRedirect('itms-apps://itunes.apple.com/cn/app/id1470361392?mt=8')
			}, 1000)
		}
	} catch (error) {
		handleSilentError(error, 'handleApp')
	}
	// #endif
}

const handleBack = () => uni.navigateBack()

// 分享按钮点击 - 构建分享数据并显示分享弹窗
const handleShare = async () => {
	console.log('[RouteInfo] handleShare called')
	
	try {
		// 构建分享标题
		const shareTitle = routeInfoTitle.value != '' ? routeInfoTitle.value : '网约向导趣游玩'
		
		// 构建分享描述
		let shareDesc = '发现专业向导，定制专属行程'
		if (routeInfoDestination.value != '') {
			shareDesc = `${routeInfoDestination.value} ${routeInfoDays.value}天${routeInfoNights.value}晚 ¥${routeInfoPrice.value}/人起`
		}
		
		// 获取分享图片
		let imageStr = 'https://jiasu.wyxdapp.com/iconimages/share_default.png'
		if (routeInfoImages.value.length > 0) {
			imageStr = routeInfoImages.value[0]
		}
		
		// 构建分享链接
		let shareLink = 'https://m.wyxdapp.com/#/pagesBusiness/routeInfo/index?lineKid=' + routeId.value
		
		// 获取当前用户的推广短号
		let referrerShortKid = ''
		try {
			// 🔧 修复：优先使用 getUserShortKid()，再 fallback 到 store 和缓存 profile
			referrerShortKid = getUserShortKid()
			if (referrerShortKid == '') {
				const storeObj = toJsonObj(userStore)
				if (storeObj != null) {
					const userInfoVal = storeObj.get('userInfo')
					if (userInfoVal != null) {
						const userInfoJson = JSON.stringify(userInfoVal)
						const userInfoParsed = JSON.parse(userInfoJson) as UTSJSONObject
						if (userInfoParsed != null) {
							const userInfoObj = userInfoParsed as UTSJSONObject
							const shortKidVal = userInfoObj.get('shortKid')
							if (shortKidVal != null && shortKidVal.toString() != '') {
								referrerShortKid = shortKidVal.toString()
							}
						}
					}
				}
			}
			// 🔧 修复APP端：从缓存的当前用户 profile 中获取 shortKid
			if (referrerShortKid == '') {
				const currentUserKidForRef = getCurrentUserKid()
				if (currentUserKidForRef != '') {
					try {
						const cachedMyProfile = getCachedProfile(currentUserKidForRef, currentUserKidForRef)
						if (cachedMyProfile != null) {
							const cachedShortKidVal = cachedMyProfile.get('shortKid')
							if (cachedShortKidVal != null && cachedShortKidVal.toString() != '') {
								referrerShortKid = cachedShortKidVal.toString()
								console.log('[handleShare] 从缓存profile获取推广短号:', referrerShortKid)
								updateUserInfoAction({ shortKid: referrerShortKid } as UTSJSONObject)
							}
						}
					} catch (e2) {}
				}
			}
			if (referrerShortKid != '') {
				// 添加推广参数到链接
				if (shareLink.indexOf('?') >= 0) {
					shareLink = shareLink + '&ref=' + referrerShortKid
				} else {
					shareLink = shareLink + '?ref=' + referrerShortKid
				}
			}
		} catch (e) {
			handleSilentError(e, '获取推广短号')
		}
		
		// 构建分享数据
		const newPayload = {
			title: shareTitle,
			summary: shareDesc,
			desc: shareDesc,
			link: shareLink,
			url: shareLink,
			imageUrl: imageStr,
			userId: guideInfoUserKid.value,
			referrerShortKid: referrerShortKid
		}
		
		sharePayload.value = newPayload
		
		console.log('[handleShare] 分享数据构建完成:')
		console.log('[handleShare] - title:', shareTitle)
		console.log('[handleShare] - desc:', shareDesc)
		console.log('[handleShare] - imageUrl:', imageStr)
		console.log('[handleShare] - link:', shareLink)
		console.log('[handleShare] - userId:', guideInfoUserKid.value)
	} catch (e) {
		handleSilentError(e, '构建分享数据')
		// 使用默认值
		sharePayload.value = {
			title: '网约向导趣游玩',
			summary: '发现专业向导，定制专属行程',
			desc: '发现专业向导，定制专属行程',
			link: 'https://m.wyxdapp.com/',
			url: 'https://m.wyxdapp.com/',
			imageUrl: 'https://jiasu.wyxdapp.com/iconimages/share_default.png',
			userId: '',
			referrerShortKid: ''
		}
	}

	// 获取会话列表（异步请求） - 允许失败但仍显示弹窗
	try {
		const result = await getChatListFn(userStore)
		console.log('[RouteInfo] getChatListFn result:', JSON.stringify(result))
		try {
			if (result != null && Array.isArray(result) == true) {
				shareChatList.value = result as Array<UTSJSONObject>
				console.log('[RouteInfo] assigned result to shareChatList, new length:', shareChatList.value.length)
			} else {
				// fallback: 安全解析模块级 chatList
				try {
					let fallbackArr: Array<UTSJSONObject> = []
					try {
						const chatList = getChatListRef()
						const rawParsed = JSON.parse(JSON.stringify(chatList))
						if (Array.isArray(rawParsed) == true) {
							fallbackArr = rawParsed as Array<UTSJSONObject>
						}
					} catch (e) {}
					
					if (fallbackArr.length == 0) {
						try {
							const chatList = getChatListRef()
							const chatListObj = toJsonObj(chatList)
							if (chatListObj != null) {
								try {
									const v = chatListObj.get('value')
									if (v != null) {
										try {
											const parsedV = JSON.parse(JSON.stringify(v))
											if (Array.isArray(parsedV) == true) {
												fallbackArr = parsedV as Array<UTSJSONObject>
											}
										} catch (e) {}
									}
								} catch (e) {}
							}
						} catch (e) {}
					}
					shareChatList.value = (fallbackArr.length > 0) ? fallbackArr : []
					console.log('[RouteInfo] used fallback chatList, length:', shareChatList.value.length)
				} catch (e) {
					shareChatList.value = []
				}
			}
		} catch (e) {
			handleSilentError(e, '解析会话列表')
		}
	} catch (e) {
		handleSilentError(e, '获取会话列表')
		shareChatList.value = []
	}

	showSharePopup.value = true
}

// 分享事件处理函数
const handleShareToChat = (data: UTSJSONObject) => {
	// 构建路线信息对象用于分享（使用定制卡片格式）
	const routeInfo = {
