/**
 * 添加账户详情
 * POST /user/userWallet/addUserWalletInfo
 */
export const addWalletInfo = (params: AddWalletInfoParams): Promise<UTSJSONObject> => {
	const payload = {
		userKid: params.userKid,
		transactionType: params.transactionType,
		transactionAmount: params.transactionAmount,
		transactionDescribe: params.transactionDescribe,
		orderKid: params.orderKid
	} as UTSJSONObject
	return request.post('/user/userWallet/addUserWalletInfo', payload, true)
}

/**
 * 查询交易明细列表
 * GET /user/userWallet/queryWalletInfoList
 */
export const getWalletList = (params: GetWalletListParams): Promise<UTSJSONObject> => {
	// 🔧 APP端修复：直接从 params 对象获取属性，避免 JSON 序列化问题
	const userKid = params.userKid
	const transactionType = params.transactionType
	const pageNumber = params.pageNumber
	const pageSize = params.pageSize
	
	let queryParts: Array<string> = []
	if (userKid != null && userKid != '') {
		queryParts.push(`userKid=${encodeURIComponent(userKid)}`)
	}
	if (transactionType != 0) {
		queryParts.push(`transactionType=${encodeURIComponent(transactionType.toString())}`)
	}
	if (pageNumber != null) {
		queryParts.push(`pageNumber=${encodeURIComponent(pageNumber.toString())}`)
	}
	if (pageSize != null) {
		queryParts.push(`pageSize=${encodeURIComponent(pageSize.toString())}`)
	}
	
	const query = queryParts.join('&')
	return request.get(`/user/userWallet/queryWalletInfoList?${query}`, null, false)
}

/**
 * 查询交易明细详情
 * GET /user/userWallet/queryWalletInfo
 * 注意：后端接口需要 userKid 参数（用户ID），而非交易记录 kid
 */
export const getWalletDetail = (userKid: string): Promise<UTSJSONObject> => {
	return request.get(`/user/userWallet/queryWalletInfo?userKid=${userKid}`, null, false)
}

