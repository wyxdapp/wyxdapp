/**
 * 申请提现
 * POST /user/userWallet/withdraw
 */
export const applyWithdraw = (params: ApplyWithdrawParams): Promise<UTSJSONObject> => {
	const payload = {
		userKid: params.userKid,
		withdrawAmount: params.withdrawAmount,
		withdrawType: params.withdrawType,
		withdrawAccount: params.withdrawAccount,
		withdrawName: params.withdrawName,
		payPassword: params.payPassword
	} as UTSJSONObject
	return request.post('/user/userWallet/withdraw', payload, true)
}

