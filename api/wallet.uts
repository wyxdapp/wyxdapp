/**
 * 用户提现（微信/支付宝）
 * POST /support/cashout/userCashout
 */
export const userCashout = (params: UserCashoutParams): Promise<UTSJSONObject> => {
	let cashoutMoney = params.cashoutMoney
	
	// 使用整数运算（分）避免浮点精度问题
	const cashoutFen = Math.round(cashoutMoney * 100)
	const serviceFeeFen = Math.round(cashoutFen * 2 / 100)
	const actualMoneyFen = cashoutFen - serviceFeeFen
	
	let actualMoney = actualMoneyFen / 100
	if (params.actualMoney != 0) {
		actualMoney = params.actualMoney
	}
	
	let serviceFee = serviceFeeFen / 100
	if (params.serviceFee != 0) {
		serviceFee = params.serviceFee
	}
	
	let feeRate = 2.0
	if (params.feeRate != 2.0) {
		feeRate = params.feeRate
	}
	
	const payload = {
		userKid: params.userKid,
		cashoutType: params.cashoutType,
		cashoutMoney: cashoutMoney,
		actualMoney: actualMoney,
		serviceFee: serviceFee,
		feeRate: feeRate,
		payPwd: params.payPwd
	} as UTSJSONObject
	
	return request.post('/support/cashout/userCashout', payload, true)
}

