/**
 * 首页相关 API
 * 对应Vue2: http.api.js 中的首页接口
 */

import request from '@/utils/request'
import { SEARCH_TYPE_USER, SEARCH_TYPE_CUSTOM, SEARCH_TYPE_TREND } from '@/common/config/businessCodes.uts'
import {
	GetGuideListParams,
	GetTravelLineListParams,
	GetUserHomePageParams,
	QueryUserByKidParams,
	GetGuideInfoDetailParams,
	GetUserTrendsParams,
	GetUserLinesParams,
	SearchIndexParams as SearchIndexParamsType,
	SearchByTypeParams as SearchByTypeParamsType
} from './types/homeTypes.uts'

/**
 * 获取首页向导列表
 * POST /support/member/queryGuideInfoList
 */
export const getGuideList = (params: GetGuideListParams) => {
	const payload = {
		pageNumber: params.pageNumber,
		pageSize: params.pageSize,
		userKid: params.userKid,
		cityName: params.cityName,
		sortType: params.sortType
	} as UTSJSONObject
	return request.post('/support/member/queryGuideInfoList', payload, false)
}

