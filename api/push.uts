/**
 * 更新小程序通知开关
 * PUT /chat/push/miniprogram/enabled
 * @param enabled 是否开启
 */
export const updateMiniProgramNotificationEnabled = (enabled: boolean): Promise<UTSJSONObject> => {
	const userKid = getCurrentUserIdReliable()
	if (userKid == null || userKid == '') {
		return new Promise<UTSJSONObject>((resolve: (value: UTSJSONObject) => void, reject: (reason: UTSJSONObject) => void) => {
			reject({ message: '用户未登录' } as UTSJSONObject)
		})
	}
	const params = {
		userId: userKid,
		enabled: enabled
