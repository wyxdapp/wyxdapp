/**
 * 查询所有标签和语言
 * POST /user/speciality/queryAllSpeciality
 * UTS 规范：API 函数参数使用类型定义，避免 Android ClassCastException
 */
export const queryAllSpeciality = (params: QueryAllSpecialityParamsType) => {
	const payload = {
		userKid: params.userKid
	} as UTSJSONObject
	return request.post('/user/speciality/queryAllSpeciality', payload, true)
