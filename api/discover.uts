 * 查询所有擅长
 * POST /user/userForte/queryAllForte
 */
export const queryAllForte = (params: QueryAllForteParams | null = null) => {
	const payload = {} as UTSJSONObject
	return request.post('/user/userForte/queryAllForte', payload, true)
}

/**
