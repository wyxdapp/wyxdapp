/**
 * 获取订单详情
 * POST /order/tourist/queryOrderDetails
 */
export const getGuiderOrderInfo = (params: OrderDetailsParams): Promise<UTSJSONObject> => {
	// 🔧 APP端修复：将自定义类型转换为普通对象，避免 uni.request 报 "请求数据格式错误"
