/**
 * 评价
 * POST /behavior/evaluate/addEvaluate
 */
export const addEvaluate = (params: AddEvaluateParams): Promise<UTSJSONObject> => {
	const payload = {
		userKid: params.userKid,
		evaluatedKid: params.evaluatedKid,
		orderKid: params.orderKid,
		evaluateContent: params.evaluateContent,
		evaluateScore: params.evaluateScore,
		evaluateImages: params.evaluateImages
	} as UTSJSONObject
	return request.post('/behavior/evaluate/addEvaluate', payload, true)
}

/**
 * 同意退款
 * POST /order/refund/agreeTouristRefund
 */
export const guiderAcceptRefund = (params: GuiderAcceptRefundParams): Promise<UTSJSONObject> => {
	const payload = {
		refundKid: params.refundKid
	} as UTSJSONObject
	return request.post(`/order/refund/agreeTouristRefund?refundKid=${params.refundKid}`, payload, true)
}

/**
 * 拒绝退款
 * POST /order/refund/guideRefuseApplyRefund
 */
export const guiderRejectRefund = (params: GuiderRejectRefundParams): Promise<UTSJSONObject> => {
	const reason = params.refuseReason != null ? params.refuseReason : ''
	const payload = {
		refundKid: params.refundKid,
		refuseReason: reason
	} as UTSJSONObject
	return request.post(`/order/refund/guideRefuseApplyRefund?refundKid=${params.refundKid}&reason=${reason}`, payload, true)
}

/**
 * 修改订单价格
 * POST /order/guide/updateOrderPrice
 * 
 * 注意：参数名称需要与后端接口保持一致
 * 旧项目使用：vm.$u.post('/order/guide/updateOrderPrice', data)
 * data包含：orderKid, orderPrice 或 orderAmount
 */
export const updateGuiderOrderPrice = (params: UpdateOrderPriceParams): Promise<UTSJSONObject> => {
	let orderPrice = params.orderPrice
	let orderAmount = params.orderAmount
	
	// 如果 orderPrice 为 0，使用 orderAmount
	if (orderPrice == 0 && orderAmount != 0) {
		orderPrice = orderAmount
	}
	
	const body = {
		orderKid: params.orderKid,
		orderPrice: orderPrice,
		orderAmount: orderAmount
	} as UTSJSONObject
	
	return request.post('/order/guide/updateOrderPrice', body, true)
}

