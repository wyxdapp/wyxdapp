/**
 * 创建向导订单
 * POST /order/tourist/createFreeTravelOrder
 * 
 * 注意：
 * - 已移除 serviceHours 参数，使用 travelTotalTime 代替
 * - 已移除 cityName 参数，后端不支持
 */
