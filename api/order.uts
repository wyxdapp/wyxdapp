/**
 * 取消订单（支出）
 * POST /order/tourist/cancelOrder
 * 
 * 注意：后端接口需要body中包含orderKid和userKid（必需）
 * 如果未传递userKid，需要在调用时从userStore获取
 */
export const cancelOrder = (params: CancelOrderParams): Promise<UTSJSONObject> => {
	// 构建body
	let cancelReason = ''
	if (params.cancelReason != null && params.cancelReason != '') {
		cancelReason = params.cancelReason
	} else if (params.reason != null && params.reason != '') {
		cancelReason = params.reason
	}
	
	const body = {
		orderKid: params.orderKid,
		userKid: params.userKid,
		cancelReason: cancelReason
	} as UTSJSONObject
	
	return request.post('/order/tourist/cancelOrder?orderKid=' + params.orderKid, body, true)
}

