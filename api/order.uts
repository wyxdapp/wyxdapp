/**
 * 发布向导需求（创建抢单订单）
 * POST /order/tourist/createGrabOrder
 */
export const createGrabOrder = (params: CreateGrabOrderParams): Promise<UTSJSONObject> => {
	// 🔧 APP端修复：将自定义类型转换为普通对象，避免 uni.request 报 "请求数据格式错误"
	const payload = {
		userKid: params.userKid,
		guideKid: params.guideKid,
		travelDate: params.travelDate,
		serviceHours: params.serviceHours,
		realname: params.realname,
		phone: params.phone,
		totalMoney: params.totalMoney,
		orderRemarks: params.orderRemarks,
		orderLocation: params.orderLocation,
		orderSource: params.orderSource,
		merchantKid: params.merchantKid,
		adultNumber: params.adultNumber,
		childrenNumber: params.childrenNumber,
		idempotencyKey: params.idempotencyKey,
		guideComment: params.guideComment
	} as UTSJSONObject
	return request.post('/order/tourist/createGrabOrder', payload, true)
}

/**
 * 修改抢单
 * POST /order/tourist/updateGrabOrder
 */
export const updateGrabOrder = (params: UpdateGrabOrderParams): Promise<UTSJSONObject> => {
	// 🔧 APP端修复：将自定义类型转换为普通对象，避免 uni.request 报 "请求数据格式错误"
	const payload = {
		kid: params.kid,
		orderTitle: params.orderTitle,
		orderDescribe: params.orderDescribe,
		startTime: params.startTime,
		endTime: params.endTime,
		peopleNum: params.peopleNum,
		budget: params.budget,
		destination: params.destination,
		userKid: params.userKid,
		travelDate: params.travelDate,
		serviceHours: params.serviceHours,
		realname: params.realname,
		phone: params.phone,
		totalMoney: params.totalMoney,
		orderRemarks: params.orderRemarks,
		orderLocation: params.orderLocation,
		orderSource: params.orderSource
	} as UTSJSONObject
	return request.post('/order/tourist/updateGrabOrder', payload, true)
}

