/**
 * 获取联系信息列表
 * POST /user/userTraveller/queryTraveller
 */
export const getContactList = (params: GetContactListParams): Promise<UTSJSONObject> => {
	// 🔧 APP端修复：将自定义类型转换为普通对象，避免 uni.request 报 "请求数据格式错误"
	const payload = {
		userKid: params.userKid
	} as UTSJSONObject
	return request.post('/user/userTraveller/queryTraveller', payload, true)
}

/**
 * 添加联系人
 * POST /user/userTraveller/addTraveller
 */
export const addTravelUser = (params: AddTravelUserParams): Promise<UTSJSONObject> => {
	// 🔧 APP端修复：将自定义类型转换为普通对象，避免 uni.request 报 "请求数据格式错误"
	const payload = {
		userKid: params.userKid,
		name: params.name,
		phone: params.phone,
		idcard: params.idcard,
		is_default: params.is_default
	} as UTSJSONObject
	return request.post('/user/userTraveller/addTraveller', payload, true)
}

