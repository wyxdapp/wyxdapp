	// 🔧 APP端修复：将自定义类型转换为普通对象，避免 uni.request 报 "请求数据格式错误"
	const payload = {
		userKid: params.userKid,
		guideKid: params.guideKid,
		orderTitle: params.orderTitle,
		travelDate: params.travelDate,
		travelTotalTime: params.travelTotalTime,
		orderRemarks: params.orderRemarks,
		totalMoney: params.totalMoney,
		phone: params.phone,
		realname: params.realname,
		orderSource: params.orderSource,
		orderAddr: params.orderAddr,
		idempotencyKey: params.idempotencyKey,
		merchantKid: params.merchantKid,
		adultNumber: params.adultNumber,
		childrenNumber: params.childrenNumber
	} as UTSJSONObject
	return request.post('/order/tourist/createFreeTravelOrder', payload, true)
}

