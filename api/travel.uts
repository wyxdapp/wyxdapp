// 发布向导信息参数接口
export interface PublishGuideInfoParams {
	userKid: string
	servicePrice: string
	accessiblePlace: string
	serviceFeature?: string
	userFortes?: string[]
}

/**
 * 向导发布
 * POST /support/member/addFreeTravelGuideInfo
 * @param params { userKid: string, servicePrice: string, accessiblePlace: string, serviceFeature?, userFortes? }
 */
export const publishGuideInfo = (params: PublishGuideInfoParams): Promise<UTSJSONObject> => {
	const payload = {
		userKid: params.userKid,
		servicePrice: params.servicePrice,
		accessiblePlace: params.accessiblePlace
	} as UTSJSONObject
	if (params.serviceFeature != null) { payload['serviceFeature'] = params.serviceFeature }
	if (params.userFortes != null) { payload['userFortes'] = params.userFortes }
	return request.post('/support/member/addFreeTravelGuideInfo', payload, true)
}

// 更新基本信息参数接口
export interface UpdateBaseInfoParams {
	kid: string
	nickname?: string
	sex?: string
	birthDate?: string
	birthPlace?: string
	liveCity?: string
	signature?: string
	image?: string
	background?: string
}

/**
 * 修改个人基本信息
 * POST /user/baseInfo/updateBaseInfo
 * @param params { kid: string, nickname?, sex?, birthDate?, birthPlace?, liveCity?, signature?, image?, background? }
 */
export const updateBaseInfo = (params: UpdateBaseInfoParams): Promise<UTSJSONObject> => {
	const payload = {
		kid: params.kid
	} as UTSJSONObject
	if (params.nickname != null) { payload['nickname'] = params.nickname }
	if (params.sex != null) { payload['sex'] = params.sex }
	if (params.birthDate != null) { payload['birthDate'] = params.birthDate }
	if (params.birthPlace != null) { payload['birthPlace'] = params.birthPlace }
	if (params.liveCity != null) { payload['liveCity'] = params.liveCity }
	if (params.signature != null) { payload['signature'] = params.signature }
	if (params.image != null) { payload['image'] = params.image }
	if (params.background != null) { payload['background'] = params.background }
	return request.post('/user/baseInfo/updateBaseInfo', payload, true)
}

