/**
 * 定制/向导相关 API
 * 对应Vue2: http.api.js 中的定制模块
 */

import request from '@/utils/request'

// 日程详情接口（用于 PublishTravelInfoParams）
export interface ScheduleItem {
	day: number
	title: string
	content: string
	images?: string[]
}

// 获取定制详情参数类
export class GetTravelDetailParams {
	kid: string = ''
	userKid: string = ''
}

// 辅助函数：从 UTSJSONObject 获取字符串属性
const getParamString = (obj: UTSJSONObject | null, key: string): string => {
	if (obj == null) return ''
	const val = obj.get(key)
	if (val != null && val.toString() != '') {
		return val.toString()
	}
	return ''
}

/**
 * 获取定制详情
 * GET /line/newLine/querySchedule
 */
export const getTravelDetail = (params: GetTravelDetailParams) => {
	// 直接访问 class 属性（避免 JSON.stringify 在 Android 上对 class 实例序列化不完整）
	const kid = (params.kid != null && params.kid != '') ? params.kid : ''
	const userKid = (params.userKid != null && params.userKid != '') ? params.userKid : ''
	
	let queryParts: Array<string> = []
	if (kid != '') {
		queryParts.push(`kid=${encodeURIComponent(kid)}`)
	}
	if (userKid != '') {
		queryParts.push(`userKid=${encodeURIComponent(userKid)}`)
	}
	
	const query = queryParts.join('&')
	return request.get(`/line/newLine/querySchedule?${query}`, null, false)
}

// 创建定制参数接口
export interface CreateTrendInfoParams {
	userKid: string
	lineTitle: string
	lineDescribe?: string
	linePrice?: string
	lineDays?: number
	lineCity?: string
	lineImage?: string
}

/**
 * 创建定制
 * POST /line/newLine/createEditLine
 * @param params { userKid: string, lineTitle: string, lineDescribe?, linePrice?, lineDays?, lineCity?, lineImage? }
 */
export const createTrendInfo = (params: CreateTrendInfoParams): Promise<UTSJSONObject> => {
	const payload = {
		userKid: params.userKid,
		lineTitle: params.lineTitle
	} as UTSJSONObject
	if (params.lineDescribe != null) { payload['lineDescribe'] = params.lineDescribe }
	if (params.linePrice != null) { payload['linePrice'] = params.linePrice }
	if (params.lineDays != null) { payload['lineDays'] = params.lineDays }
	if (params.lineCity != null) { payload['lineCity'] = params.lineCity }
	if (params.lineImage != null) { payload['lineImage'] = params.lineImage }
	return request.post('/line/newLine/createEditLine', payload, true)
}

// 发布定制参数接口
export interface PublishTravelInfoParams {
	userKid: string
	lineTitle: string
	lineDescribe?: string
	linePrice?: string
	lineDays?: number
	lineCity?: string
	lineImage?: string
	schedules?: ScheduleItem[]
}

/**
 * 发布定制
 * POST /line/newLine/v1/createLine
 * @param params { userKid: string, lineTitle: string, lineDescribe?, linePrice?, lineDays?, lineCity?, lineImage?, schedules? }
 */
export const publishTravelInfo = (params: PublishTravelInfoParams): Promise<UTSJSONObject> => {
	const payload = {
		userKid: params.userKid,
		lineTitle: params.lineTitle
	} as UTSJSONObject
	if (params.lineDescribe != null) { payload['lineDescribe'] = params.lineDescribe }
	if (params.linePrice != null) { payload['linePrice'] = params.linePrice }
	if (params.lineDays != null) { payload['lineDays'] = params.lineDays }
	if (params.lineCity != null) { payload['lineCity'] = params.lineCity }
	if (params.lineImage != null) { payload['lineImage'] = params.lineImage }
	if (params.schedules != null) { payload['schedules'] = params.schedules }
	return request.post('/line/newLine/v1/createLine', payload, true)
}

