// 个人认证参数接口
export interface IdentityUserParams {
	userKid: string
	realname: string
	idNumber: string
	idcardFrontImage: string
	idcardBackImage: string
}

/**
 * 个人认证
 * POST /user/baseInfo/identityUser
 * @param params { userKid: string, realname: string, idNumber: string, idcardFrontImage: string, idcardBackImage: string }
 */
export const identityUser = (params: IdentityUserParams): Promise<UTSJSONObject> => {
	// 🔧 安全提取参数：兼容 interface 实例和 UTSJSONObject
	const paramsObj = JSON.parse(JSON.stringify(params)) as UTSJSONObject
	const payload = {
		userKid: getParamString(paramsObj, 'userKid'),
		realname: getParamString(paramsObj, 'realname'),
		idNumber: getParamString(paramsObj, 'idNumber'),
		idcardFrontImage: getParamString(paramsObj, 'idcardFrontImage'),
		idcardBackImage: getParamString(paramsObj, 'idcardBackImage')
	} as UTSJSONObject
	return request.post('/user/baseInfo/identityUser', payload, true)
}

