// 查询认证信息参数接口
export interface QueryAuthInfoParams {
	userKid: string
}

/**
 * 查询认证信息
 * POST /user/baseInfo/v1/queryAuthInfo
 * @param params { userKid: string }
 */
export const queryAuthInfo = (params: QueryAuthInfoParams): Promise<UTSJSONObject> => {
	// 🔧 安全提取参数：兼容 interface 实例和 UTSJSONObject
	const paramsObj = JSON.parse(JSON.stringify(params)) as UTSJSONObject
	const userKid = getParamString(paramsObj, 'userKid')
	const payload = {
		userKid: userKid
	} as UTSJSONObject
	return request.post('/user/baseInfo/v1/queryAuthInfo', payload, false)
}

// 导游认证参数接口
export interface GuideAuthParams {
	userKid: string
	guideAuthenticatImage: string
	guideCertificateNo?: string
}

/**
 * 导游认证
 * POST /user/baseInfo/guideAuth
 * @param params { userKid: string, guideAuthenticatImage: string, guideCertificateNo?: string }
 */
export const guideAuth = (params: GuideAuthParams): Promise<UTSJSONObject> => {
	// 🔧 安全提取参数：兼容 interface 实例和 UTSJSONObject
	const paramsObj = JSON.parse(JSON.stringify(params)) as UTSJSONObject
	const payload = {
		userKid: getParamString(paramsObj, 'userKid'),
		guideAuthenticatImage: getParamString(paramsObj, 'guideAuthenticatImage')
	} as UTSJSONObject
	const certNo = getParamString(paramsObj, 'guideCertificateNo')
	if (certNo != '') { payload['guideCertificateNo'] = certNo }
	return request.post('/user/baseInfo/guideAuth', payload, true)
}

