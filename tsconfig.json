{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@/utils/*": ["./utils/*"],
      "@/common/*": ["./common/*"],
      "@/pagesUser/*": ["./pagesUser/*"],
      "@/pagesBusiness/*": ["./pagesBusiness/*"],
      "@/pagesTrade/*": ["./pagesTrade/*"],
      "@/stores/*": ["./stores/*"],
      "@/api/*": ["./api/*"]
    },
    "types": ["@dcloudio/types"],
    "resolveJsonModule": true
  },
  "include": [
    "**/*.ts",
    "**/*.d.ts",
    "**/*.tsx", 
    "**/*.vue",
    "**/*.uvue",
    "**/*.uts"
  ],
  "exclude": [
    "node_modules",
    "unpackage",
    "dist"
  ]
}
