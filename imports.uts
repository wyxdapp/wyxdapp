/**
 * 显式引用主包模块以消除微信小程序编译器警告
 * 
 * 背景：
 * 微信小程序编译器报告这些文件为"主包未使用"，但实际上它们都被分包引用。
 * 编译器的静态分析未能正确识别跨分包引用，导致误报。
 * 
 * 解决方案：
 * 在主包入口显式引用这些模块，让编译器识别它们被使用。
 * 这些 import 语句不会被实际执行，只是为了满足编译器的静态分析。
 * 
 * 实际使用情况：
 * 所有这些模块都被分包中的页面、组件或 composables 使用。
 * 详细的使用情况分析见：.kiro/specs/wechat-miniprogram-optimization/file-usage-analysis.md
 * 
 * 创建时间：2026-02-04
 */

// ============ API 模块 ============

/**
 * api/app.uts
 * 实际使用：被 common/services/updateService.uts 使用（版本检查）
 * 引用位置：pagesUser/my/setting/index.uvue
 */
import '@/api/app.uts'

/**
 * api/behavior.uts
 * 实际使用：被 5+ 个分包页面使用（访客记录）
 * 引用位置：
 * - pagesBusiness/videoFeed/index.uvue
 * - pagesBusiness/trendsDetail/index.uvue
 * - pagesBusiness/routeInfo/index.uvue
 * - pagesBusiness/commend/index.uvue
 * - pagesTrade/composables/useVisitor.uts
 */
import '@/api/behavior.uts'

/**
 * api/travel.uts
 * 实际使用：被 6+ 个分包页面使用（路线、认证、会员）
 * 引用位置：
 * - pagesBusiness/routeInfo/submitOrder.uvue
 * - pagesBusiness/routeInfo/index.uvue
 * - pagesBusiness/composables/useChatActions.uts
 * - pagesUser/my/proveDetails/realNameAuth.uvue
 * - pagesUser/my/proveDetails/guide.uvue
 * - pagesUser/my/proveDetails/driver.uvue
 */
import '@/api/travel.uts'

/**
 * api/user.uts
 * 实际使用：被 4 个位置使用（用户信息）
 * 引用位置：
 * - pagesBusiness/composables/useChatActions.uts
 * - pagesBusiness/operate/userPromotionManage.uvue
 * - pagesBusiness/operate/userPromotion.uvue
 * - common/utils/promotionTracker.uts
 */
import '@/api/user.uts'

