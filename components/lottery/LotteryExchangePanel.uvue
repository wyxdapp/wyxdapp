<template>
	<view class="exchange-panel">
		<view class="panel-header">
			<text class="header-title">幸运值兑换</text>
			<text class="header-subtitle">满50/100/200/300/500/800点可兑换</text>
		</view>
		
		<view class="exchange-buttons">
			<view 
				v-for="(config, index) in exchangeConfigs" 
				:key="index"
				class="exchange-btn"
				:class="{ 
					'disabled': props.luckyPoints < getConfigPoints(config),
					'available': props.luckyPoints >= getConfigPoints(config)
				}"
				@click="handleExchange(config)"
			>
				<text class="exchange-point">{{ getConfigPoints(config) }}点</text>
				<text class="exchange-label">{{ getConfigLabel(config) }}</text>
			</view>
		</view>
		
		<!-- 兑换弹窗 -->
		<view v-if="showExchangeModal == true" class="exchange-modal-overlay" @click="closeModal">
			<view class="exchange-modal" @click.stop>
				<view class="exchange-modal-header">
					<text class="exchange-modal-title">幸运值兑换</text>
					<view class="exchange-modal-close" @click="closeModal">
						<text class="close-icon">✕</text>
					</view>
				</view>
				<view class="exchange-modal-content">
					<text class="exchange-modal-desc">使用 {{ selectedPoints }} 点幸运值兑换奖励</text>
					<text class="exchange-modal-value">可兑换价值 {{ selectedValue }} 元的奖励</text>
					<view class="exchange-options">
						<view class="exchange-option" @click="handleExchangeReward('gift')">
							<UniIcons type="gift" :size="36" color="#FF6B6B" />
							<text class="option-label">虚拟礼物</text>
						</view>
						<view class="exchange-option" @click="handleExchangeReward('cash')">
							<UniIcons type="wallet" :size="36" color="#FFB800" />
							<text class="option-label">现金红包</text>
						</view>
					</view>
				</view>
			</view>
		</view>
	</view>
</template>

<script setup lang="uts">
import { ref, computed } from 'vue'
import { exchangeLuckyPoints } from '@/common/services/lotteryService.uts'
import UniIcons from '@/components/base/UniIcons.uvue'

// Props 定义
const props = defineProps({
	userKid: { type: String, required: true },
	luckyPoints: { type: Number, default: 0 }
})

// Emits 定义
const emit = defineEmits(['refresh', 'exchangeSuccess'])

// 响应式数据
const showExchangeModal = ref<boolean>(false)
const selectedPoints = ref<number>(0)
const selectedValue = ref<number>(0)
const loading = ref<boolean>(false)

// 兑换档位配置（使用 any 数组）
const exchangeConfigs = ref<Array<any>>([
	{ points: 50, value: 5, label: '兑换' },
	{ points: 100, value: 10, label: '兑换' },
	{ points: 200, value: 20, label: '兑换' },
	{ points: 300, value: 30, label: '兑换' },
	{ points: 500, value: 50, label: '兑换' },
	{ points: 800, value: 188, label: '188元' }
])

// 获取配置的点数
const getConfigPoints = (config: any): number => {
	try {
		const json = JSON.stringify(config)
		if (json == null || json == '') return 0
		const parsed = JSON.parse(json) as UTSJSONObject
		if (parsed == null) return 0
		const v = parsed.get('points')
		return (v != null) ? parseInt(v.toString()) : 0
	} catch (e) {}
	return 0
}

// 获取配置的标签
const getConfigLabel = (config: any): string => {
	const points = getConfigPoints(config)
	if (points == 800) {
		return '188元'
	}
	return '兑换'
}

// 获取配置的价值
const getConfigValue = (config: any): number => {
	try {
		const json = JSON.stringify(config)
		if (json == null || json == '') return 0
		const parsed = JSON.parse(json) as UTSJSONObject
		if (parsed == null) return 0
		const v = parsed.get('value')
		return (v != null) ? parseInt(v.toString()) : 0
	} catch (e) {}
	return 0
}

// 关闭弹窗
const closeModal = () => {
	showExchangeModal.value = false
}

// 点击兑换按钮
const handleExchange = (config: any) => {
	const points = getConfigPoints(config)
	const value = getConfigValue(config)
	
	if (props.luckyPoints < points) {
		uni.showToast({
			title: '幸运值不足，需要' + points.toString() + '点',
			icon: 'none'
		})
		return
	}
	
	selectedPoints.value = points
	selectedValue.value = value
	showExchangeModal.value = true
}

// 执行兑换
const handleExchangeReward = async (rewardType: string) => {
	if (loading.value == true) return
	
	const userKidValue = props.userKid
	if (userKidValue == null || userKidValue == '') {
		uni.showToast({
			title: '请先登录',
			icon: 'none'
		})
		return
	}
	
	loading.value = true
	
	try {
		uni.showLoading({ title: '兑换中...' })
		
		const params = {
			userKid: userKidValue,
			points: selectedPoints.value,
			rewardType: rewardType == 'gift' ? 10 : 20
		} as UTSJSONObject
		
		const result = await exchangeLuckyPoints(params)
		
		// 解析响应
		let resultCode = 0
		let resultMsg = '兑换失败'
		if (result != null) {
			try {
				const resultJson = JSON.stringify(result)
				if (resultJson != null && resultJson != '') {
					const resultObj = JSON.parse(resultJson) as UTSJSONObject
					if (resultObj != null) {
						const codeVal = resultObj.get('code')
						resultCode = (codeVal != null) ? parseInt(codeVal.toString()) : 0
						const msgVal = resultObj.get('msg')
						if (msgVal != null && msgVal.toString() != '') {
							resultMsg = msgVal.toString()
						}
						const messageVal = resultObj.get('message')
						if (messageVal != null && messageVal.toString() != '') {
							resultMsg = messageVal.toString()
						}
					}
				}
			} catch (e) {
				console.error('解析兑换响应失败:', e)
			}
		}
		
		if (resultCode == 200) {
			uni.showToast({ title: '兑换成功', icon: 'success' })
			showExchangeModal.value = false
			emit('refresh')
			emit('exchangeSuccess')
		} else {
			uni.showToast({ title: resultMsg, icon: 'none' })
		}
	} catch (error: any) {
		console.error('兑换失败:', error)
		uni.showToast({
			title: '兑换失败，请重试',
			icon: 'none'
		})
	} finally {
		loading.value = false
		uni.hideLoading()
	}
}

// 暴露刷新方法
defineExpose({
	refresh: () => {
		// 组件刷新逻辑（如果需要）
	}
})
</script>

