	width: 200rpx;
	padding: 24rpx 16rpx;
	background-color: #F5F5F5;
	border-radius: 16rpx;
	flex-direction: column;
	align-items: center;
	justify-content: center;
	margin-bottom: 16rpx;
}

.exchange-btn.available {
	background-color: #9C27B0;
}

.exchange-btn.disabled {
	opacity: 0.5;
}

.exchange-point {
	font-size: 28rpx;
	font-weight: bold;
	color: #333333;
	margin-bottom: 8rpx;
}

.exchange-btn.available .exchange-point {
	color: #FFFFFF;
}

.exchange-label {
	font-size: 24rpx;
	color: #666666;
}

.exchange-btn.available .exchange-label {
	color: rgba(255, 255, 255, 0.9);
}

/* 兑换弹窗 */
.exchange-modal-overlay {
	position: fixed;
	top: 0;
	left: 0;
	right: 0;
	bottom: 0;
	background-color: rgba(0, 0, 0, 0.6);
	z-index: 10000;
	flex-direction: row;
	align-items: center;
	justify-content: center;
}

.exchange-modal {
	width: 600rpx;
	background-color: #FFFFFF;
	border-radius: 32rpx;
	padding: 48rpx;
	flex-direction: column;
}

.exchange-modal-header {
	flex-direction: row;
	align-items: center;
	justify-content: space-between;
	margin-bottom: 32rpx;
}

.exchange-modal-title {
	font-size: 36rpx;
	font-weight: bold;
	color: #333333;
}

.exchange-modal-close {
	width: 60rpx;
	height: 60rpx;
	flex-direction: row;
	align-items: center;
	justify-content: center;
}

.close-icon {
	font-size: 40rpx;
	color: #999999;
}

.exchange-modal-content {
	flex-direction: column;
	align-items: center;
}

.exchange-modal-desc {
	font-size: 28rpx;
	color: #666666;
	margin-bottom: 16rpx;
	text-align: center;
}

.exchange-modal-value {
	font-size: 32rpx;
	color: #9C27B0;
	font-weight: bold;
	margin-bottom: 32rpx;
	text-align: center;
}

.exchange-options {
	flex-direction: row;
	align-items: center;
	justify-content: space-around;
	width: 100%;
}

.exchange-option {
	width: 200rpx;
	padding: 32rpx;
	background-color: #F5F5F5;
	border-radius: 16rpx;
	flex-direction: column;
	align-items: center;
	justify-content: center;
}

.option-icon {
	font-size: 80rpx;
	margin-bottom: 16rpx;
}

.option-label {
	font-size: 28rpx;
	color: #333333;
}
</style>
