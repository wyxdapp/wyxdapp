	font-size: 28rpx;
	margin-right: 16rpx;
}

.search-input {
	flex: 1;
	font-size: 28rpx;
	color: #333333;
}

/* 滚动区域 */
.scroll-area {
	flex: 1;
	padding-right: 60rpx;
}

.section {
	padding: 0 28rpx;
}

.section-title {
	font-size: 28rpx;
	color: #999999;
	padding: 24rpx 0 16rpx;
}

.letter-title {
	font-size: 32rpx;
	color: #333333;
	font-weight: bold;
	background-color: #F5F5F5;
	margin: 0 -28rpx;
	padding: 16rpx 28rpx;
}

/* 城市网格 */
.city-grid {
	display: flex;
	flex-direction: row;
	flex-wrap: wrap;
	margin-bottom: 16rpx;
}

.city-item {
	min-width: 136rpx;
	height: 64rpx;
	background-color: #F5F5F5;
	border-radius: 32rpx;
	display: flex;
	align-items: center;
	justify-content: center;
	margin-right: 20rpx;
	margin-bottom: 20rpx;
	padding: 0 24rpx;
}

.city-item.active {
	background-color: #E8F4FF;
	border-width: 2rpx;
	border-style: solid;
	border-color: #2EAEF2;
}

.city-text {
	font-size: 28rpx;
	color: #333333;
}

.city-item.active .city-text {
	color: #2EAEF2;
	font-weight: bold;
}

/* 城市列表 */
.city-list {
	display: flex;
	flex-direction: column;
}

.city-list-item {
	height: 88rpx;
	display: flex;
	align-items: center;
	border-bottom: 1rpx solid #EEEEEE;
}

.city-list-item.active {
	background-color: #F5F5F5;
}

.city-list-text {
	font-size: 30rpx;
	color: #333333;
}

