	display: flex;
	flex-direction: column;
}

.empty-state {
	padding: 80rpx 0;
	text-align: center;
}

.empty-state text {
	font-size: 28rpx;
	color: #999999;
}

.order-item {
	background-color: #ffffff;
	border-radius: 12rpx;
	padding: 24rpx;
	margin-bottom: 20rpx;
}

.order-header {
	display: flex;
	justify-content: space-between;
	padding-bottom: 16rpx;
	border-bottom: 2rpx solid #f0f0f0;
	margin-bottom: 16rpx;
}

.order-no {
	font-size: 24rpx;
	color: #666666;
}

.order-status {
	font-size: 24rpx;
	color: #FF9800;
}

.order-content {
	display: flex;
	margin-bottom: 16rpx;
}

.order-image {
	width: 160rpx;
	height: 160rpx;
	border-radius: 8rpx;
	margin-right: 16rpx;
}

.content-info {
	flex: 1;
	display: flex;
	flex-direction: column;
}

.order-title {
	font-size: 28rpx;
	color: #333333;
	font-weight: bold;
	margin-bottom: 12rpx;
}

.order-time,
.order-location {
	font-size: 24rpx;
	color: #666666;
	margin-bottom: 8rpx;
}

.order-footer {
	display: flex;
	justify-content: space-between;
	align-items: center;
}

.price {
	font-size: 32rpx;
	color: #FF6B6B;
	font-weight: bold;
}

.actions {
	display: flex;
}

.btn {
	padding-top: 12rpx;
	padding-bottom: 12rpx;
	padding-left: 32rpx;
	padding-right: 32rpx;
	border-radius: 40rpx;
	border-width: 2rpx;
	border-style: solid;
	border-color: #e0e0e0;
	margin-left: 16rpx;
}

.btn {
	font-size: 26rpx;
	color: #666666;
}

.btn.primary {
	background-color: #2EAEF2;
	border-color: #2EAEF2;
}
</style>
