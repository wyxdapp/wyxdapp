<template>
	<view class="order-list">
		<view v-if="list.length === 0" class="empty-state">
			<text>{{ nullText }}</text>
		</view>
		
		<view v-else class="list">
			<view 
				v-for="(item, index) in list" 
				:key="item.id || index"
				class="order-item"
				@click="$emit('itemClick', item)"
			>
				<view class="order-header">
					<text class="order-no">订单号：{{ item.orderNo }}</text>
					<text class="order-status">{{ item.statusText }}</text>
				</view>
				
				<view class="order-content">
					<image v-if="item.coverImage" class="order-image" :src="item.coverImage" mode="aspectFill"></image>
					<view class="content-info">
						<text class="order-title">{{ item.title }}</text>
						<text class="order-time">{{ item.serviceTime }}</text>
						<text class="order-location">{{ item.location }}</text>
					</view>
				</view>
				
				<view class="order-footer">
					<text class="price">¥{{ item.price }}</text>
					<view class="actions">
						<view v-if="item.status === 'unpaid'" class="btn primary" @click.stop="$emit('pay', item)">
							<text>去支付</text>
						</view>
						<view v-if="item.status === 'completed'" class="btn" @click.stop="$emit('evaluate', item)">
							<text>评价</text>
						</view>
					</view>
				</view>
			</view>
		</view>
	</view>
</template>

<script setup lang="uts">
interface OrderItem {
	id: string
	orderNo: string
	title: string
	coverImage?: string
	serviceTime: string
	location: string
	price: number
	status: string
	statusText: string
}

// 使用运行时 prop 声明避免编译器问题
const props = defineProps({
	list: { type: Array, default: () => [] },
	nullText: { type: String, default: '暂无订单' }
})

defineEmits<{
	itemClick: [item: OrderItem]
	pay: [item: OrderItem]
	evaluate: [item: OrderItem]
}>()
</script>

