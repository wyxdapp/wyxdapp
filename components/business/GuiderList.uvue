	flex-direction: row;
	padding: 28rpx;
	margin-bottom: 20rpx;
	border-radius: 12rpx;
	background-color: #ffffff;
}

.bg-white {
	background-color: #ffffff;
}

.guider-avatar-wrapper {
	margin-right: 20rpx;
}

.guider-info {
	flex: 1;
	flex-direction: column;
	margin-right: 20rpx;
}

.info-top {
	flex-direction: row;
	justify-content: space-between;
	align-items: center;
	margin-bottom: 12rpx;
}

.name-row {
	flex-direction: row;
	align-items: center;
}

.nickname {
	font-size: 30rpx;
	color: #333333;
	font-weight: bold;
	margin-right: 8rpx;
}

.gender-badge {
	width: 32rpx;
	height: 32rpx;
	border-radius: 16rpx;
	flex-direction: row;
	align-items: center;
	justify-content: center;
}

.gender-badge.male {
	background-color: #2196F3;
}

.gender-badge.female {
	background-color: #E91E63;
}

.gender-badge text {
	font-size: 20rpx;
	color: #ffffff;
}

.rating {
	flex-direction: row;
	align-items: center;
}

.star {
	font-size: 24rpx;
	margin-right: 4rpx;
}

.score {
	font-size: 24rpx;
	color: #FF9800;
	font-weight: bold;
}

.info-middle {
	flex-direction: row;
	align-items: center;
	margin-bottom: 12rpx;
}

.location {
	font-size: 24rpx;
	color: #666666;
	margin-right: 20rpx;
}

.age {
	font-size: 24rpx;
	color: #666666;
}

.info-tags {
	flex-direction: row;
	flex-wrap: wrap;
	margin-bottom: 12rpx;
}

.tag {
	padding: 4rpx 12rpx;
	background-color: #E3F2FD;
	border-radius: 8rpx;
	margin-right: 8rpx;
	margin-bottom: 8rpx;
}

.info-bottom {
	flex-direction: row;
}

.signature {
	font-size: 24rpx;
	color: #999999;
	overflow: hidden;
	text-overflow: ellipsis;
	lines: 1;
}

.guider-price {
	flex-direction: column;
	align-items: flex-end;
	justify-content: center;
}

.price-label {
	font-size: 22rpx;
	color: #999999;
	margin-bottom: 8rpx;
}

.price-value {
	font-size: 32rpx;
	color: #FF6B6B;
	font-weight: bold;
}

.price-unit {
	font-size: 22rpx;
	color: #999999;
}
</style>
