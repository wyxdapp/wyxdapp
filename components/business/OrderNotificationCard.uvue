<template>
	<view 
		class="notification-card"
		:class="{ unread: !props.read }"
		@click="$emit('click')"
	>
		<view class="card-icon-wrapper">
			<UniIcons type="shop" :size="48" color="#37B1F2" />
			<view v-if="!props.read" class="unread-dot"></view>
		</view>
		
		<view class="card-content">
			<view class="card-header">
				<text class="card-title">{{ props.title }}</text>
				<text class="card-time">{{ props.time }}</text>
			</view>
			
			<text class="card-text">{{ props.content }}</text>
			
			<view class="order-info">
				<text class="order-no">订单号: {{ props.orderNo }}</text>
				<text v-if="props.amount" class="order-amount">¥{{ formattedAmount }}</text>
			</view>
		</view>
		
		<text class="delete-btn" @click.stop="$emit('delete')">✕</text>
	</view>
</template>

<script setup lang="uts">
import { computed } from 'vue'
import UniIcons from '@/components/base/UniIcons.uvue'
import { fen2yuan } from '@/utils/money.uts'

const props = defineProps({
	title: { type: String, required: true },
	content: { type: String, required: true },
	time: { type: String, required: true },
	orderNo: { type: String, required: true },
	amount: { type: Number, default: 0 },
	read: { type: Boolean, default: false }
})

const emit = defineEmits<{
	click: []
	delete: []
}>()

// 将分转换为元并格式化（保留两位小数）
const formattedAmount = computed((): string => {
	if (props.amount <= 0) return '0.00'
	return fen2yuan(props.amount)
})
</script>

<style scoped>
