	display: flex;
	background-color: #ffffff;
	border-radius: 16rpx;
	padding: 24rpx;
	margin-bottom: 20rpx;
	box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
	position: relative;
}

.notification-card.unread {
	background-color: #F0F9FF;
}

.card-icon-wrapper {
	position: relative;
	width: 80rpx;
	height: 80rpx;
	display: flex;
	align-items: center;
	justify-content: center;
	margin-right: 20rpx;
	flex-shrink: 0;
}

.card-icon {
	font-size: 48rpx;
}

.unread-dot {
	position: absolute;
	top: 0;
	right: 0;
	width: 16rpx;
	height: 16rpx;
	background-color: #FF5252;
	border-radius: 8rpx;
}

.card-content {
	flex: 1;
	display: flex;
	flex-direction: column;
}

.card-header {
	display: flex;
	justify-content: space-between;
	align-items: center;
	margin-bottom: 12rpx;
}

.card-title {
	font-size: 28rpx;
	color: #333333;
	font-weight: bold;
}

.card-time {
	font-size: 22rpx;
	color: #999999;
}

.card-text {
	font-size: 26rpx;
	color: #666666;
	line-height: 1.6;
	margin-bottom: 16rpx;
}

.order-info {
	display: flex;
	justify-content: space-between;
	align-items: center;
	padding: 12rpx;
	background-color: #F8F9FA;
	border-radius: 8rpx;
}

.order-no {
	font-size: 24rpx;
	color: #2EAEF2;
}

.order-amount {
	font-size: 28rpx;
	color: #FF6B6B;
	font-weight: bold;
}

.delete-btn {
	position: absolute;
	top: 24rpx;
	right: 24rpx;
	font-size: 30rpx;
	color: #cccccc;
	padding: 4rpx 8rpx;
}

.delete-btn:active {
	color: #ff5252;
}
</style>
