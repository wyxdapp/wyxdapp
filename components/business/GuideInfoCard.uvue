	position: relative;
	margin-top: 24rpx;
	margin-right: 32rpx;
	margin-bottom: 24rpx;
	margin-left: 32rpx;
	padding: 32rpx;
	border-radius: 24rpx;
	box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

