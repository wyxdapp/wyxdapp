	margin-bottom: 24rpx;
}

.card-content {
	display: flex;
	flex-direction: column;
}

.guide-basic {
	display: flex;
	align-items: center;
}

.guide-avatar {
	width: 96rpx;
	height: 96rpx;
	border-radius: 48rpx;
	margin-right: 24rpx;
}

.guide-info {
	flex: 1;
}

