	padding: 4rpx 12rpx;
	background-color: #e6f7ff;
	color: #37B1F2;
	border-radius: 8rpx;
}

.service-info {
	padding: 24rpx;
	background-color: #f8f8f8;
	border-radius: 16rpx;
}

.info-item {
	display: flex;
	justify-content: space-between;
	align-items: center;
}

.card-arrow {
	position: absolute;
	right: 32rpx;
	top: 50%;
	transform: translateY(-50%);
}

.arrow-icon {
	font-size: 48rpx;
	color: #999999;
}

.mt-xs {
	margin-top: 8rpx;
}

.mt-sm {
	margin-top: 16rpx;
}

.mt-md {
	margin-top: 24rpx;
}

