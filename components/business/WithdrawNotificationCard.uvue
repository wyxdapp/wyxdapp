	flex-direction: row;
	background-color: #ffffff;
	border-radius: 16rpx;
	padding: 24rpx;
	margin-bottom: 20rpx;
	position: relative;
}

.notification-card.unread {
	background-color: #FFF8E6;
}

.card-icon-wrapper {
	position: relative;
	width: 80rpx;
	height: 80rpx;
	flex-direction: row;
	align-items: center;
	justify-content: center;
	margin-right: 20rpx;
}

.card-icon {
	font-size: 48rpx;
}

.unread-dot {
	position: absolute;
	top: 0;
	right: 0;
	width: 16rpx;
	height: 16rpx;
	background-color: #FF5252;
	border-radius: 8rpx;
}

.card-content {
	flex: 1;
	flex-direction: column;
}

.card-header {
	flex-direction: row;
	justify-content: space-between;
	align-items: flex-start;
	margin-bottom: 12rpx;
}

.title-row {
	flex-direction: row;
	align-items: center;
	flex: 1;
}

.card-title {
	font-size: 28rpx;
	color: #333333;
	font-weight: bold;
	margin-right: 12rpx;
}

.status-badge {
	padding: 4rpx 12rpx;
	border-radius: 8rpx;
}

.status-success {
	background-color: #E8F5E9;
}

.status-rejected {
	background-color: #FFEBEE;
}

.status-failed {
	background-color: #FFEBEE;
}

.badge-text {
	font-size: 20rpx;
	color: #333333;
}

.status-success .badge-text {
	color: #4CAF50;
}

.status-rejected .badge-text {
	color: #F44336;
}

.status-failed .badge-text {
	color: #F44336;
}

.card-time {
	font-size: 22rpx;
	color: #999999;
}

.card-text {
	font-size: 26rpx;
	color: #666666;
	margin-bottom: 16rpx;
}

.card-info {
	flex-direction: column;
	background-color: #F5F5F5;
	border-radius: 8rpx;
	padding: 16rpx;
}

.info-row {
	flex-direction: row;
	align-items: center;
	margin-bottom: 8rpx;
}

.info-row:last-child {
	margin-bottom: 0;
}

.reason-row {
	margin-top: 8rpx;
}

.info-label {
	font-size: 24rpx;
	color: #999999;
}

.info-value {
	font-size: 24rpx;
	color: #333333;
}

.info-value.amount {
	color: #FF6B35;
	font-weight: bold;
}

.info-value.reason {
	color: #F44336;
	flex: 1;
}

.delete-btn {
	position: absolute;
	top: 24rpx;
	right: 24rpx;
	font-size: 30rpx;
	color: #cccccc;
	padding: 4rpx 8rpx;
}
</style>
