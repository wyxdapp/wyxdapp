.route-card {
	width: 338rpx;
	margin-bottom: 20rpx;
	background-color: #ffffff;
	border-radius: 16rpx;
	overflow: hidden;
	flex-direction: column;
}

.image-box {
	position: relative;
	width: 338rpx;
	height: 338rpx;
}

.cover-image {
	width: 338rpx;
	height: 338rpx;
	background-color: #f0f0f0;
}

.bottom-mask {
	position: absolute;
	bottom: 0;
	left: 0;
	right: 0;
	padding-top: 10rpx;
	padding-bottom: 10rpx;
	padding-left: 16rpx;
	padding-right: 16rpx;
	background-color: rgba(0, 0, 0, 0.4);
	flex-direction: row;
	align-items: center;
}

.stat-item {
	flex-direction: row;
	align-items: center;
}

.stat-item-margin {
	margin-left: 24rpx;
}

.stat-number {
	font-size: 22rpx;
	color: #ffffff;
	margin-left: 6rpx;
}

.info-box {
	padding-top: 16rpx;
	padding-bottom: 16rpx;
	padding-left: 16rpx;
	padding-right: 16rpx;
	flex-direction: column;
}

.title {
	font-size: 28rpx;
	color: #333333;
	font-weight: bold;
	lines: 2;
}

.tags {
	flex-direction: row;
	margin-top: 12rpx;
}

.price-row {
	flex-direction: row;
	align-items: center;
	margin-top: 12rpx;
}

.price {
	font-size: 32rpx;
	color: #FF9800;
	font-weight: bold;
}

.price-unit {
	font-size: 20rpx;
	color: #FF9800;
	margin-left: 4rpx;
}
</style>
