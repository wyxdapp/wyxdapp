// 辅助函数：添加推广人短号参数（必须在 shareUrl 之前定义）
const appendReferrerParam = (url: string): string => {
	const referrerShortKid = getShareDataProp('referrerShortKid')
	if (referrerShortKid == '') {
		return url
	}
	// 检查URL是否已包含ref参数（避免重复添加）
	if (url.indexOf('ref=') >= 0) {
		return url
	}
	// 检查URL是否已有参数
	if (url.indexOf('?') >= 0) {
		return url + '&ref=' + referrerShortKid
	} else {
		return url + '?ref=' + referrerShortKid
	}
}

const shareUrl = computed((): string => {
	// 优先使用 link，其次使用 url，最后构建
	const link = getShareDataProp('link')
	if (link != '') {
		return appendReferrerParam(link)
	}
	const url = getShareDataProp('url')
	if (url != '') {
		return appendReferrerParam(url)
	}
	
	// 构建向导详情页链接
	const guideKid = getShareDataProp('guideKid')
	if (guideKid != '') {
		const baseUrl = 'https://m.wyxdapp.com/#/pagesBusiness/guideDetail/index'
		let fullUrl = `${baseUrl}?kid=${guideKid}`
		return appendReferrerParam(fullUrl)
	}
	
	// 构建用户主页链接
	const baseUrl = 'https://m.wyxdapp.com/#/pagesUser/persionInfo/index'
	const userId = getShareDataProp('userId')
	if (userId != '') {
		let fullUrl = `${baseUrl}?id=${userId}`
		return appendReferrerParam(fullUrl)
	}
	return baseUrl
})

const shareDesc = computed((): string => {
	const desc = getShareDataProp('desc')
	const summary = getShareDataProp('summary')
	if (desc != '') return desc
	if (summary != '') return summary
	return '发现专业向导，定制专属行程'
})

// 统一分享标题和图片的安全获取函数
const getShareTitle = (): string => {
	const title = getShareDataProp('title')
	if (title != '') {
		return title
	}
	return '网约向导趣游玩'
}

const getShareImage = (): string => {
	const imageUrl = getShareDataProp('imageUrl')
	if (imageUrl != '') {
		return imageUrl
	}
	// 🔧 修复：使用确定存在的默认头像作为分享图片
	return 'https://jiasu.wyxdapp.com/iconimages/default_avatar.png'
}

// 监听器（已移除二维码加载状态监听）

// 🔧 辅助函数：处理分享错误（必须在 doWeChatShare 之前定义）
const handleShareError = (error: any) => {
	let errorMsg = '分享失败'
	try {
		const errStr = JSON.stringify(error)
		const errObj = JSON.parse(errStr) as UTSJSONObject
		const errMsgVal = errObj.get('errMsg')
		if (errMsgVal != null && errMsgVal.toString() != '') {
			errorMsg = errMsgVal.toString()
		}
	} catch (e) {}
	uni.showToast({
		title: errorMsg,
		icon: 'none'
	})
}

// 🔧 辅助函数：压缩图片用于分享（必须在 downloadImageToLocal 之前定义）
const compressImageForShare = (imagePath: string, callback: (localPath: string) => void) => {
	// 使用 uni.compressImage 压缩图片（微信缩略图要求不超过32KB）
	// 🔧 同时限制尺寸为 200x200，确保压缩后不超过 32KB
	uni.compressImage({
		src: imagePath,
		quality: 20, // 压缩质量 20%（微信缩略图要求极小，不超过32KB）
		compressedWidth: 200,
		compressedHeight: 200,
		success: (compressRes: any) => {
			try {
				const compressResObj = JSON.parse(JSON.stringify(compressRes)) as UTSJSONObject
				const tempFilePathVal = compressResObj.get('tempFilePath')
				
				if (tempFilePathVal != null && tempFilePathVal.toString() != '') {
					console.log('[SharePopup] 图片压缩成功:', tempFilePathVal.toString())
					callback(tempFilePathVal.toString())
				} else {
					console.warn('[SharePopup] 图片压缩结果无效，使用原图')
					callback(imagePath) // 压缩结果无效，使用原图
				}
			} catch (e) {
				console.warn('[SharePopup] 图片压缩解析失败:', e)
				callback(imagePath) // 解析失败，使用原图
			}
		},
		fail: (err: any) => {
			console.warn('[SharePopup] 图片压缩失败:', err, '使用原图')
			callback(imagePath) // 压缩失败，使用原图
		}
	})
}

// 🔧 辅助函数：下载网络图片到本地并压缩（微信SDK要求图片必须是本地路径，缩略图不超过32KB）
const downloadImageToLocal = (imageUrl: string, callback: (localPath: string) => void) => {
	// 如果已经是本地路径，直接返回
	if (imageUrl.indexOf('http') != 0) {
		callback(imageUrl)
		return
	}
	
	// 🔧 检查源URL是否为webp格式，如果是则标记需要格式转换
	const isWebpSource = imageUrl.toLowerCase().indexOf('.webp') >= 0
	
	uni.downloadFile({
		url: imageUrl,
		success: (res: any) => {
			try {
				const resObj = JSON.parse(JSON.stringify(res)) as UTSJSONObject
				const statusCodeVal = resObj.get('statusCode')
				const tempFilePathVal = resObj.get('tempFilePath')
				
				const statusCode = (statusCodeVal != null) ? parseInt(statusCodeVal.toString()) : 0
				const tempFilePath = (tempFilePathVal != null) ? tempFilePathVal.toString() : ''
				
				if (statusCode == 200 && tempFilePath != '') {
					// 下载成功，压缩图片（同时将webp转换为jpg）
					console.log('[SharePopup] 图片下载成功, isWebp:', isWebpSource, 'tempPath:', tempFilePath)
					compressImageForShare(tempFilePath, callback)
				} else {
					console.warn('[SharePopup] 图片下载状态异常, statusCode:', statusCode)
					callback('') // 下载失败，返回空
				}
			} catch (e) {
				console.error('[SharePopup] 图片下载解析失败:', e)
				callback('')
			}
		},
		fail: (err: any) => {
			console.error('[SharePopup] 图片下载失败:', err)
			callback('') // 下载失败，返回空
		}
	})
}

// 🔧 执行微信分享的最终调用（抽取公共逻辑，必须在 doWeChatShare 之前定义）
const executeWeChatShare = (weChatInstance: wxsdk.TTWeChatSDK, scene: number, shareTitle: string, shareDescValue: string, shareUrlValue: string, imagePath: string) => {
	console.log('[SharePopup] executeWeChatShare - scene:', scene, 'title:', shareTitle, 'image:', imagePath)
	console.log('[SharePopup] executeWeChatShare - desc:', shareDescValue, 'href:', shareUrlValue)
	console.log('[SharePopup] executeWeChatShare - weChatInstance:', weChatInstance)
	
	try {
		if (imagePath != '') {
			// 有有效图片，使用带缩略图分享
			console.log('[SharePopup] 调用 weChatInstance.share (有图)...')
			weChatInstance.share({
				type: 3, // 网页分享
				scene: scene,
				title: shareTitle,
				desc: shareDescValue,
				href: shareUrlValue,
				thumbImageUrl: imagePath, // 缩略图（本地路径，不超过32KB）
				success: () => {
					console.log('[SharePopup] ✅ 微信分享成功 scene:', scene)
					uni.showToast({
						title: '分享成功',
						icon: 'success'
					})
				},
				fail: (error: any) => {
					console.error('[SharePopup] ❌ 微信分享失败 scene:', scene, 'error:', error)
					handleShareError(error)
				}
			} as wxsdk.TTWeChatShareOptions)
			console.log('[SharePopup] weChatInstance.share 调用完成(有图)，等待回调...')
		} else {
			// 无有效图片，使用无图分享
			console.log('[SharePopup] 调用 weChatInstance.share (无图)...')
			weChatInstance.share({
				type: 3, // 网页分享
				scene: scene,
				title: shareTitle,
				desc: shareDescValue,
				href: shareUrlValue,
				success: () => {
					console.log('[SharePopup] ✅ 微信分享成功(无图) scene:', scene)
					uni.showToast({
						title: '分享成功',
						icon: 'success'
					})
				},
				fail: (error: any) => {
					console.error('[SharePopup] ❌ 微信分享失败(无图) scene:', scene, 'error:', error)
					handleShareError(error)
				}
			} as wxsdk.TTWeChatShareOptions)
			console.log('[SharePopup] weChatInstance.share 调用完成(无图)，等待回调...')
		}
	} catch (e) {
		console.error('[SharePopup] ❌ executeWeChatShare 同步异常:', e)
		uni.showToast({
			title: '分享调用失败',
			icon: 'none'
		})
	}
}

// 🔧 执行微信分享的内部函数（图片已下载到本地）
const doWeChatShare = (scene: number, localImagePath: string) => {
	const shareTitle = getShareTitle()
	const shareDescValue = shareDesc.value
	const shareUrlValue = shareUrl.value
	
	// 使用临时变量避免 smart cast 问题
	const weChatInstance = weChat.value
	if (weChatInstance == null) {
		uni.showToast({
			title: '微信SDK未初始化',
			icon: 'none'
		})
		return
	}
	
	// 检查图片路径是否有效，以及是否是 webp 格式
	// 微信 SDK 不支持 webp 格式的缩略图，需要转换为 jpg
	if (localImagePath != '') {
		const isWebp = localImagePath.toLowerCase().indexOf('.webp') >= 0
		if (isWebp == true) {
			// webp 格式：通过 compressImage 转换为 jpg 后再分享
			console.log('[SharePopup] 检测到 webp 图片，转换为 jpg:', localImagePath)
			uni.compressImage({
				src: localImagePath,
				quality: 20,
				compressedWidth: 200,
				compressedHeight: 200,
				success: (compressRes: any) => {
					try {
						const compressResObj = JSON.parse(JSON.stringify(compressRes)) as UTSJSONObject
						const tempFilePathVal = compressResObj.get('tempFilePath')
						if (tempFilePathVal != null && tempFilePathVal.toString() != '') {
							console.log('[SharePopup] webp 转换成功:', tempFilePathVal.toString())
							executeWeChatShare(weChatInstance, scene, shareTitle, shareDescValue, shareUrlValue, tempFilePathVal.toString())
						} else {
							console.warn('[SharePopup] webp 转换结果无效，使用无图分享')
							executeWeChatShare(weChatInstance, scene, shareTitle, shareDescValue, shareUrlValue, '')
						}
					} catch (e) {
						console.warn('[SharePopup] webp 转换解析失败，使用无图分享')
						executeWeChatShare(weChatInstance, scene, shareTitle, shareDescValue, shareUrlValue, '')
					}
				},
				fail: (err: any) => {
					console.warn('[SharePopup] webp 转换失败:', err, '使用无图分享')
					executeWeChatShare(weChatInstance, scene, shareTitle, shareDescValue, shareUrlValue, '')
				}
			})
			return
		}
		// 非 webp 格式，直接使用
		executeWeChatShare(weChatInstance, scene, shareTitle, shareDescValue, shareUrlValue, localImagePath)
	} else {
		// 无图片
		executeWeChatShare(weChatInstance, scene, shareTitle, shareDescValue, shareUrlValue, '')
	}
}

// 方法 - 按调用顺序定义，被调用的函数先定义

// 关闭弹窗（前置定义，供后续方法调用）
function handleClose(): void {
	emit('update:visity', false)
}

// 🔧 H5 端复制链接并提示（用于微信/朋友圈分享的 fallback）
// 重构：使用 async/await + delay() 替代嵌套 setTimeout 回调
const copyLinkWithTip = async () => {
	const url = shareUrl.value
	console.log('[SharePopup] copyLinkWithTip called, url:', url)
	try {
		uni.setClipboardData({
			data: url,
			success: () => {
				console.log('[SharePopup] copyLinkWithTip success')
				handleClose()
				delay(200).then(() => {
					uni.showToast({
						title: '链接已复制，请打开微信粘贴分享',
						icon: 'none',
						duration: 2500
					})
				})
			},
			fail: (err: any) => {
				console.error('[SharePopup] copyLinkWithTip fail:', err)
				delay(200).then(() => {
					uni.showToast({
						title: '复制失败',
						icon: 'none'
					})
				})
			}
		})
	} catch (e) {
		console.error('[SharePopup] copyLinkWithTip exception:', e)
		uni.showToast({
			title: '复制失败',
			icon: 'none'
		})
	}
}

// 🔧 H5 端尝试调用 Web Share API
const tryWebShare = () => {
	// Web Share API 仅在 H5 端可用，通过运行时判断
	// 由于 UTS 编译限制，navigator 在 APP 端不可用，直接 fallback
	if (isH5Platform() == false) {
		copyLinkWithTip()
		return
	}
	// #ifdef H5
	try {
		if (typeof navigator !== 'undefined' && navigator.share != null) {
			const shareTitle = getShareTitle()
			const shareDescValue = shareDesc.value
			const shareUrlValue = shareUrl.value
			navigator.share({
				title: shareTitle,
				text: shareDescValue,
				url: shareUrlValue
			}).then(() => {
				console.log('[SharePopup] Web Share API 分享成功')
			}).catch((_err: any | null): void => {
				console.log('[SharePopup] Web Share API 失败或取消，fallback 到复制链接')
				copyLinkWithTip()
			})
			return
		}
	} catch (e) {
		console.error('[SharePopup] tryWebShare error:', e)
	}
	// #endif
	// Web Share API 不支持，fallback 到复制链接
	copyLinkWithTip()
}

// 🔧 H5 端微信/朋友圈分享统一入口
const handleH5WechatShare = () => {
	if (isWeChatBrowser() == true) {
		// 微信内置浏览器：显示引导蒙层
		console.log('[SharePopup] 微信浏览器，显示引导蒙层')
		showWechatGuide.value = true
	} else {
		// 非微信浏览器：尝试 Web Share API
		console.log('[SharePopup] 非微信浏览器，尝试 Web Share API')
		tryWebShare()
	}
}

// 🔧 通用微信分享入口函数（减少代码重复）
const doShareToWeChat = (scene: number, sceneName: string) => {
	console.log('[SharePopup] doShareToWeChat - scene:', scene, 'sceneName:', sceneName)
	// 🔧 H5 平台：使用 H5 专用分享逻辑
	if (isH5Platform() == true) {
		handleH5WechatShare()
		return
	}

	// 检查是否为APP平台
	if (isAppPlatform() == false) {
		uni.showToast({
			title: '请在APP中使用微信分享功能',
			icon: 'none'
		})
		return
	}

	// 检查微信SDK是否初始化
	if (weChat.value == null) {
		console.error('[SharePopup] ❌ 微信SDK未初始化')
		uni.showToast({
			title: '微信SDK未初始化',
			icon: 'none'
		})
		return
	}

	// 检查微信是否安装
	if (checkWeChatInstalled() == false) {
		return
	}

	// 获取分享图片URL并下载到本地后分享
	const shareImageUrl = getShareImage()
	console.log('[SharePopup] 分享图片URL:', shareImageUrl)
	downloadImageToLocal(shareImageUrl, (localPath: string) => {
		console.log('[SharePopup] 图片下载完成, localPath:', localPath)
		doWeChatShare(scene, localPath)
	})
}

const shareToWeChat = () => {
	doShareToWeChat(0, '好友') // scene=0 分享到好友
}

const shareToWeChatMoments = () => {
	doShareToWeChat(1, '朋友圈') // scene=1 分享到朋友圈
}


const copyLink = () => {
	const url = shareUrl.value
	console.log('[SharePopup] copyLink called, url:', url)
	try {
		uni.setClipboardData({
			data: url,
			success: () => {
				console.log('[SharePopup] copyLink success')
				handleClose()
			},
			fail: (err: any) => {
				console.error('[SharePopup] copyLink uni.setClipboardData fail:', err)
				uni.showToast({
					title: '复制失败',
					icon: 'none'
				})
			}
		})
	} catch (e) {
		console.error('[SharePopup] copyLink exception:', e)
		uni.showToast({
			title: '复制失败',
			icon: 'none'
		})
	}
}

const handleShowQrcode = () => {
	// 显示二维码弹窗
	showQrcodePopup.value = true
}

// 举报相关方法
// 获取投诉类型（根据分享数据判断）
const getComplaintType = (): number => {
	const lineKid = getShareDataProp('lineKid')
	const discoverKid = getShareDataProp('discoverKid')
	const guideKid = getShareDataProp('guideKid')
	const orderKid = getShareDataProp('orderKid')
	
	console.log('[SharePopup] getComplaintType - lineKid:', lineKid, 'discoverKid:', discoverKid, 'guideKid:', guideKid, 'orderKid:', orderKid)
	
	if (lineKid != '') {
		console.log('[SharePopup] 举报类型: 路线举报 (20)')
		return 20 // 路线举报
	} else if (orderKid != '') {
		console.log('[SharePopup] 举报类型: 订单举报 (10)')
		return 10 // 订单举报
	} else if (discoverKid != '') {
		console.log('[SharePopup] 举报类型: 发现举报 (40)')
		return 40 // 发现举报
	} else if (guideKid != '') {
		console.log('[SharePopup] 举报类型: 向导举报 (40)')
		return 40 // 向导举报（使用发现举报表）
	}
	
	console.log('[SharePopup] 举报类型: 默认发现举报 (40)')
	return 40 // 默认使用发现举报
}

// 获取被举报对象的KID
const getTargetKid = (): string => {
	const lineKid = getShareDataProp('lineKid')
	const discoverKid = getShareDataProp('discoverKid')
	const guideKid = getShareDataProp('guideKid')
	const orderKid = getShareDataProp('orderKid')
	const userId = getShareDataProp('userId')
	
	console.log('[SharePopup] getTargetKid - lineKid:', lineKid, 'discoverKid:', discoverKid, 'guideKid:', guideKid, 'orderKid:', orderKid, 'userId:', userId)
	
	if (lineKid != '') {
		console.log('[SharePopup] 使用 lineKid:', lineKid)
		return lineKid
	} else if (discoverKid != '') {
		console.log('[SharePopup] 使用 discoverKid:', discoverKid)
		return discoverKid
	} else if (guideKid != '') {
		console.log('[SharePopup] 使用 guideKid:', guideKid)
		return guideKid
	} else if (orderKid != '') {
		console.log('[SharePopup] 使用 orderKid:', orderKid)
		return orderKid
	} else if (userId != '') {
		console.log('[SharePopup] 使用 userId:', userId)
		return userId
	}
	
	console.warn('[SharePopup] ⚠️ 无法获取任何有效的KID')
	return ''
}

const handleShowComplaint = () => {
	console.log('[SharePopup] 🚨 handleShowComplaint called')
	console.log('[SharePopup] 📋 shareData:', JSON.stringify(props.shareData))
	
	// 获取举报类型和目标KID
	complaintType.value = getComplaintType()
	complaintTargetKid.value = getTargetKid()
	
	console.log('[SharePopup] 举报类型:', complaintType.value)
	console.log('[SharePopup] 举报目标KID:', complaintTargetKid.value)
	
	// 验证目标KID
	if (complaintTargetKid.value == '') {
		console.warn('[SharePopup] ⚠️ 无法获取举报对象，shareData可能为空或缺少必要字段')
		uni.showToast({
			title: '无法获取举报对象，请从详情页进行举报',
			icon: 'none',
			duration: 2000
		})
		return
	}
	
	showComplaintPopup.value = true
}

const handleComplaintSuccess = () => {
	console.log('[SharePopup] ✅ 举报成功')
	// 举报成功后关闭分享弹窗
	handleClose()
}

const handleComplaintClose = () => {
	console.log('[SharePopup] 关闭举报弹窗')
	showComplaintPopup.value = false
}

const handleShare = (platform: string) => {
	if (platform == '') return
	switch (platform) {
		case 'wechat':
			shareToWeChat()
			break
		case 'wechat_moments':
			shareToWeChatMoments()
			break
		case 'copy':
			copyLink()
			break
		case 'qrcode':
			handleShowQrcode()
			break
		case 'complaint':
			handleShowComplaint()
			break
		default:
			console.warn('不支持的分享平台:', platform)
	}

	emit('share', platform)
}

const handleShareToChat = (chatItem: any) => {
	emit('share-to-chat', {
		chatItem,
		shareData: props.shareData
	})
	handleClose()
}

const handleShareOption = (option: any, optionIndex: number) => {
	console.log('[SharePopup] 点击分享选项:', option, '索引:', optionIndex)
	try {
		if (optionIndex >= 0 && optionIndex < SHARE_OPTION_KEYS.length) {
			const key = SHARE_OPTION_KEYS[optionIndex]
			console.log('[SharePopup] 执行分享:', key)
			handleShare(key)
		}
	} catch (e) {
		console.error('[SharePopup] 分享选项处理错误:', e)
	}
}


// 二维码弹窗相关方法
const handleCloseQrcode = () => {
	showQrcodePopup.value = false
}

const handleSaveQrcode = () => {
	// 保存二维码图片到相册
	const qrcodeUrl = 'https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=' + encodeURIComponent(shareUrl.value)
	uni.downloadFile({
		url: qrcodeUrl,
		success: (res) => {
			if (res.statusCode == 200) {
				uni.saveImageToPhotosAlbum({
					filePath: res.tempFilePath,
					success: () => {
						uni.showToast({
							title: '二维码已保存到相册',
							icon: 'success'
						})
					},
					fail: (error) => {
						console.error('保存二维码失败:', error)
						uni.showToast({
							title: '保存失败',
							icon: 'none'
						})
					}
				})
			} else {
				uni.showToast({
					title: '生成二维码失败',
					icon: 'none'
				})
			}
		},
		fail: (error) => {
			console.error('下载二维码失败:', error)
			uni.showToast({
				title: '生成二维码失败',
				icon: 'none'
			})
		}
	})
}

const handleCopyQrcodeLink = () => {
	uni.setClipboardData({
		data: shareUrl.value,
		success: () => {
			uni.showToast({
				title: '链接已复制',
				icon: 'success'
			})
		},
		fail: () => {
			uni.showToast({
				title: '复制失败',
				icon: 'none'
			})
		}
	})
}

onUnmounted(() => {
	clearAllTimers()
})

</script>

