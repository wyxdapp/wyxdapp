<template>
	<view class="share-popup-container" v-if="visity == true">
		<view class="modal-overlay" @click="handleClose"></view>
		<view class="share-popup-modal">
			<!-- 关闭按钮 - 右上角 -->
			<view class="close-btn" @click="handleClose">
				<text class="close-icon">✕</text>
			</view>
			
			<view class="modal-header">
				<text class="modal-title">分享</text>
			</view>
			
			<view class="modal-content">
				<!-- 聊天会话列表 -->
				<view class="share-chat-section" v-if="chatListCount > 0 || chatListLoading">
					<text class="section-title">分享到聊天</text>
					<!-- 加载状态 -->
					<view v-if="chatListLoading" class="chat-loading">
						<text class="loading-text">加载中...</text>
					</view>
					<!-- 聊天列表 -->
					<scroll-view v-if="chatListLoading == false && chatListCount > 0" scroll-x="true" class="share-chat-list" :show-scrollbar="false">
						<view class="share-chat-list-container">
							<view
								class="share-chat-item"
								v-for="(item, index) in effectiveChatList"
								:key="'chat_' + index"
								@click="handleShareToChat(item)">
								<view class="chat-avatar-box">
									<Avatar
										:url="getChatAvatar(item)"
										:customSize="96"
										clickMode="none"
									/>
								</view>
								<text class="chat-name u-line-1">{{ getChatName(item) }}</text>
							</view>
						</view>
					</scroll-view>
				</view>
				
				<!-- 分享方式 -->
				<view class="share-methods-section">
					<text class="section-title">分享方式</text>
					<view class="share-options">
						<!-- 分享选项列表 -->
						<view
							v-for="(option, optionIndex) in shareOptions"
							:key="'share_option_' + optionIndex"
							class="share-option"
							@click="handleShareOption(option, optionIndex)"
						>
							<view class="option-icon">
								<!-- uni-icon 类型图标 -->
								<uni-icons
									v-if="getOptionIconType(option) == 'uni-icon'"
									:type="getOptionIconName(option)"
									:color="getOptionIconColor(option)"
									:size="getOptionIconSize(option)"
								/>
								<!-- 图片类型图标 -->
								<image
									v-else
									class="option-icon-image"
									:src="getOptionIcon(option, optionIndex)"
									mode="aspectFit"
									@error="(e: any) => { console.warn('share icon load failed', e, getOptionIcon(option, optionIndex)) }"
								/>
							</view>
							<text class="option-text">{{ getOptionName(option, optionIndex) }}</text>
						</view>
					</view>
				</view>
				
			</view>
			
			<view class="modal-footer">
				<view class="cancel-btn" @click="handleClose">
					<text class="cancel-text">取消</text>
				</view>
			</view>
		</view>

		<!-- 二维码分享弹窗 -->
		<view class="qrcode-popup-container" v-if="showQrcodePopup == true">
			<view class="modal-overlay" @click="handleCloseQrcode"></view>
			<view class="qrcode-popup-modal">
				<!-- 关闭按钮 -->
				<view class="close-btn" @click="handleCloseQrcode">
					<text class="close-icon">✕</text>
				</view>

				<view class="modal-header">
					<text class="modal-title">分享二维码</text>
				</view>

				<view class="modal-content">
					<!-- 二维码图片 -->
					<view class="qrcode-container">
						<image
							class="qrcode-image"
							:src="'https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=' + encodeURIComponent(shareUrl)"
							mode="aspectFit">
						</image>
					</view>

					<!-- 分享标题 -->
					<view class="qrcode-title">
						<text class="title-text">{{ getShareTitle() }}</text>
					</view>

					<!-- 分享描述 -->
					<view class="qrcode-desc">
						<text class="desc-text">{{ shareDesc }}</text>
					</view>

					<!-- 链接文本 -->
					<view class="qrcode-link">
						<text class="link-text">{{ shareUrl }}</text>
					</view>
				</view>

				<view class="modal-footer">
					<view class="action-btn action-save" @click="handleSaveQrcode">
						<text class="action-text">保存二维码</text>
					</view>
					<view class="action-btn action-copy" @click="handleCopyQrcodeLink">
						<text class="action-text">复制链接</text>
					</view>
				</view>
			</view>
		</view>

		<!-- 举报弹窗组件 -->
		<ComplaintPopup
			:visible="showComplaintPopup"
			:complaintType="complaintType"
			:targetKid="complaintTargetKid"
			@update:visible="(val: boolean) => { showComplaintPopup = val }"
			@success="handleComplaintSuccess"
			@close="handleComplaintClose"
		/>

		<!-- H5 微信分享引导蒙层 -->
		<view class="wechat-share-guide-overlay" v-if="showWechatGuide == true" @click="showWechatGuide = false">
			<view class="guide-content" @click.stop="">
				<!-- 右上角箭头指示 -->
				<view class="guide-arrow-area">
					<image 
						class="guide-arrow-icon" 
						src="https://jiasu.wyxdapp.com/iconimages/wechat_guide_arrow.png" 
						mode="aspectFit"
					></image>
				</view>
				<!-- 提示文字 -->
				<view class="guide-text-area">
					<text class="guide-text-main">请点击右上角 ··· 进行分享</text>
				</view>
				<!-- 关闭按钮 -->
				<view class="guide-close-btn" @click="showWechatGuide = false">
					<text class="guide-close-text">我知道了</text>
				</view>
			</view>
		</view>
	</view>
</template>

<script setup lang="uts">
import { ref, computed, onMounted, onUnmounted, watch } from 'vue'
import { currentTheme } from '@/stores/theme.uts'
import Avatar from '@/components/base/Avatar.uvue'
import ComplaintPopup from '@/components/common/ComplaintPopup.uvue'
import * as wxsdk from '@/uni_modules/tt-wechat-pro'
import { getChatList, getChatListRef } from '@/common/composables/useChatAndShare.uts'
import { toJsonObj, countArrayItems, isAppPlatform, isH5Platform } from '@/common/utils/utsSafe.uts'
import { useUserStore, initUserInfoAction } from '@/stores/user.uts'
import { COMPLAINT_TYPE_DEFAULT } from '@/common/config/businessCodes.uts'
import { DEFAULT_SHARE_IMAGE } from '@/common/config/defaultImages.uts'
import { delay } from '@/common/utils/delay.uts'

// 定时器生命周期管理
let timerHandles: number[] = []

function safeSetTimeout(callback: () => void, ms: number): number {
	const handle = setTimeout(callback, ms)
	timerHandles.push(handle)
	return handle
}

function clearAllTimers(): void {
	for (const handle of timerHandles) {
		clearTimeout(handle)
	}
	timerHandles = []
}

// Props定义
interface ShareData {
	title?: string
	desc?: string
	summary?: string
	imageUrl?: string
	url?: string
	link?: string
	userId?: string
	// 推广相关字段
	referrerShortKid?: string  // 推广人短号（8位）
	guideKid?: string          // 向导KID
	guideName?: string         // 向导昵称
	guideAvatar?: string       // 向导头像
	servicePrice?: number      // 服务价格
	commissionRate?: number    // 佣金费率
}

interface ChatListItem {
	targetUserId?: string
	targetUserName?: string
	avatar?: string
	lastMessage?: string
	lastMessageTime?: string
}

// 使用运行时 prop 声明避免编译器问题
const props = defineProps({
	visity: { type: Boolean, default: false },
	shareData: { 
		type: Object, 
		default: () => ({
			title: '网约向导趣游玩',
			desc: '发现专业向导，定制专属行程',
			summary: '发现专业向导，定制专属行程',
			imageUrl: DEFAULT_SHARE_IMAGE,
			url: '',
			link: '',
			userId: ''
		})
	},
	chatList: { type: [Array, Object], default: () => [] }
})
// Emits定义
const emit = defineEmits([
	'update:visity',
	'share',
	'share-to-chat',
	'wechat-share',
	'moments-share',
	'copy-link',
	'show-qrcode'
])

// 响应式数据
const weChat = ref<wxsdk.TTWeChatSDK | null>(null)
const showQrcodePopup = ref<boolean>(false)
const userStore = useUserStore()

// 聊天列表相关状态
const chatListLoading = ref<boolean>(false)
const chatListError = ref<string>('')
const loadAttemptCount = ref<number>(0) // 防止无限重试

// 举报弹窗相关状态
const showComplaintPopup = ref<boolean>(false)
const complaintType = ref<number>(COMPLAINT_TYPE_DEFAULT) // 10=订单, 20=路线, 30=聊天, 40=发现
const complaintTargetKid = ref<string>('')

// H5 微信分享引导蒙层状态
const showWechatGuide = ref<boolean>(false)

// 检测是否在微信内置浏览器中（仅 H5 端有效）
const isWeChatBrowser = (): boolean => {
	// #ifdef H5
	try {
		const ua = navigator.userAgent.toLowerCase()
		return ua.indexOf('micromessenger') >= 0
	} catch (e) {
		console.error('[SharePopup] isWeChatBrowser error:', e)
	}
	// #endif
	return false
}

// 分享选项 - APP端显示所有分享选项
const shareOptions = ref<Array<any>>([
	{
		key: 'wechat',
		name: '微信',
		iconUrl: 'https://jiasu.wyxdapp.com/iconimages/share_wechat.png',
		iconType: 'image'
	},
	{
		key: 'wechat_moments',
		name: '朋友圈',
		iconUrl: 'https://jiasu.wyxdapp.com/iconimages/share_moments.png',
		iconType: 'image'
	},
	{
		key: 'copy',
		name: '复制链接',
		iconUrl: 'https://jiasu.wyxdapp.com/iconimages/share_link.png',
		iconType: 'image'
	},
	{
		key: 'qrcode',
		name: '二维码',
		iconUrl: 'https://jiasu.wyxdapp.com/iconimages/share_qrcode.png',
		iconType: 'image'
	},
	{
		key: 'complaint',
		name: '举报',
		iconType: 'uni-icon',
		iconName: 'hand-down-filled',
		iconColor: currentTheme.accentColor,
		iconSize: 40
	}
])

// 投诉原因列表
const complaintReasons = ref<Array<any>>([
	{ code: 10, name: '色情低俗' },
	{ code: 20, name: '暴力血腥' },
	{ code: 30, name: '诈骗信息' },
	{ code: 40, name: '侵权内容' },
	{ code: 50, name: '广告骚扰' },
	{ code: 60, name: '其他' }
])

// 检查微信是否安装
const checkWeChatInstalled = (): boolean => {
	try {
		if (weChat.value == null) {
			console.warn('微信SDK未初始化')
			return false
		}
		const isInstalled = weChat.value.isInstall()
		if (isInstalled == false) {
			uni.showToast({
				title: '请先安装微信客户端',
				icon: 'none'
			})
			return false
		}
		return true
	} catch (e) {
		console.error('检查微信安装状态失败:', e)
		return false
	}
}

// 微信开放平台 APP 端配置（与 wechatLoginApp.uts 保持一致）
const WECHAT_APP_ID = 'wx4a9aa1fbc92e1054'
const WECHAT_UNIVERSAL_LINK = 'https://www.wyxdapp.com/app/'

// 初始化微信SDK
const initWeChatSDK = () => {
	// 只在APP平台初始化微信SDK，H5平台不支持微信SDK
	if (isAppPlatform() == false) {
		console.log('ℹ️ [SharePopup] H5平台不支持微信SDK，跳过初始化')
		return
	}

	try {
		weChat.value = wxsdk.getTTWeChatSDK()
		if (weChat.value != null) {
			console.log('📱 [SharePopup] 开始注册微信SDK，appid:', WECHAT_APP_ID)
			// 注册微信SDK - 使用正确的微信开放平台配置
			weChat.value.register({
				appid: WECHAT_APP_ID,
				universalLink: WECHAT_UNIVERSAL_LINK,
				success: () => {
				},
				fail: (error: any) => {
					console.error('❌ [SharePopup] 微信SDK注册失败:', error)
				}
			} as wxsdk.TTWeChatRegisterOptions)
		} else {
			console.error('❌ [SharePopup] 获取微信SDK实例失败')
		}
	} catch (e) {
		console.error('❌ [SharePopup] 初始化微信SDK失败:', e)
	}
}

// 主动加载聊天列表（在组件挂载时调用，不阻塞弹窗显示）
const loadChatList = async () => {
	try {
		chatListLoading.value = true
		chatListError.value = ''

		console.log('[SharePopup] ===== 开始主动获取聊天列表 =====')

		// 简化逻辑：直接调用getChatList，依赖页面级别的userStore初始化
		// 如果页面级别初始化失败，这里会重试一次
		const result = await getChatList(userStore)
		console.log('[SharePopup] 主动获取聊天列表成功，长度:', countArrayItems(result))

		// 安全检查数组长度并输出样例数据
		const resultLength = countArrayItems(result)
		let sampleData = 'empty'
		if (resultLength > 0) {
			try {
				sampleData = JSON.stringify(result[0])
			} catch (e) {
				sampleData = 'parse error'
			}
		}
		console.log('[SharePopup] 聊天列表数据样例:', sampleData)

		// 检查内部数据是否正确设置
		const internalData = getChatListRef()
		console.log('[SharePopup] 内部chatListRef数据长度:', countArrayItems(internalData))
		console.log('[SharePopup] ===== 聊天列表获取完成 =====')

		// 结果已经通过 getChatList 函数设置到模块级 chatListRef 中
		// effectiveChatList 计算属性会自动更新
	} catch (error) {
		console.error('[SharePopup] 获取聊天列表失败:', error)
		chatListError.value = '获取聊天列表失败'
	} finally {
		chatListLoading.value = false
	}
}

// 在组件挂载时初始化微信SDK和用户数据
onMounted(() => {
	console.log('[SharePopup] onMounted called')
	initWeChatSDK()

	// 🔧 修复：组件挂载时初始化用户数据，确保userStore可用
	try {
		console.log('[SharePopup] 初始化用户数据...')
		initUserInfoAction()
	} catch (e) {
		console.error('[SharePopup] 初始化用户数据失败:', e)
	}

})

// 聊天列表数据源：优先使用 props.chatList，次优先使用内部主动获取的数据
const chatListArr = computed((): Array<any> => {
	try {
		const raw = props.chatList
		// 尝试解析多种可能的包裹结构（直接数组 / ref 对象 { value: [...] } / 包装对象 { list: [...] } / UTSJSONObject）
		// 1) 直接是数组
		try {
			const parsedRaw = JSON.parse(JSON.stringify(raw))
			if (Array.isArray(parsedRaw) == true) return parsedRaw as Array<any>
		} catch (e) {}

		// 2) 如果是对象包装，尝试通过 UTSJSONObject 安全访问 value 或 list
		const rawObj = toJsonObj(raw)
		if (rawObj != null) {
			try {
				const val = rawObj.get('value')
				if (val != null) {
					try {
						const parsedVal = JSON.parse(JSON.stringify(val))
						if (Array.isArray(parsedVal) == true) return parsedVal as Array<any>
					} catch (e) {}
				}
			} catch (e) {}
			try {
				const listVal = rawObj.get('list')
				if (listVal != null) {
					try {
						const parsedList = JSON.parse(JSON.stringify(listVal))
						if (Array.isArray(parsedList) == true) return parsedList as Array<any>
					} catch (e) {}
				}
			} catch (e) {}
		}
	} catch (e) {}
	return []
})

// 从模块级 chatListRef 获取的数据（作为内部主动获取的后备）
const chatListInternalArr = computed((): Array<any> => {
	try {
		const refList = getChatListRef()
		// 使用 toJsonObj 安全读取 ref 对象或包装对象
		const refObj = toJsonObj(refList)
		let raw: any = ''
		if (refObj != null) {
			try {
				const val = refObj.get('value')
				if (val != null) raw = val as any
			} catch (e) {}
			try {
				if (raw == '') {
					const listVal = refObj.get('list')
					if (listVal != null) raw = listVal as any
				}
			} catch (e) {}
		}
		// fallback to JSON.stringify(refList)
		if (raw == '') {
			try {
				const str = JSON.stringify(refList)
				if (str != '') raw = JSON.parse(str) as any
			} catch (e) {}
		}
		if (raw == '') return []
		const parsed = raw as any
		if (Array.isArray(parsed) == true) return parsed as Array<any>
	} catch (e) {}
	return []
})

// 最终使用的聊天列表：优先级 props.chatList > 内部获取的数据
const effectiveChatList = computed((): Array<any> => {
	try {
		const propsCount = countArrayItems(chatListArr.value)
		const internalCount = countArrayItems(chatListInternalArr.value)

		console.log('[SharePopup] effectiveChatList计算 - props数据长度:', propsCount, '内部数据长度:', internalCount)

		// 优先使用 props 传递的数据
		if (propsCount > 0) {
			console.log('[SharePopup] 使用props传递的数据，第一个项目:', JSON.stringify(chatListArr.value[0]))
			return chatListArr.value
		}
		// 次优先使用内部主动获取的数据
		if (internalCount > 0) {
			console.log('[SharePopup] 使用内部获取的数据，第一个项目:', JSON.stringify(chatListInternalArr.value[0]))
			return chatListInternalArr.value
		}

		console.log('[SharePopup] 没有可用的聊天列表数据')
	} catch (e) {
		console.error('[SharePopup] effectiveChatList计算出错:', e)
	}
	return []
})

const shareOptionsCount = computed((): number => {
	try {
		return shareOptions.value.length
	} catch (e) {}
	return 0
})

// 🔧 新增：聊天列表数量计算属性
const chatListCount = computed((): number => {
	try {
		return countArrayItems(effectiveChatList.value)
	} catch (e) {}
	return 0
})

// 调试函数：打印 chatList 状态（放在 computed 之后以避免 UTS 编译 error18）
const logChatListStatus = (prefix: string) => {
	try {
		console.log(prefix + ' props.chatList (raw):', props.chatList)
		try {
			console.log(prefix + ' shareOptions length:', shareOptions.value.length)
		} catch (e) {}
		try {
			console.log(prefix + ' shareData:', JSON.stringify(props.shareData))
		} catch (e) {}
		// 尝试输出解析后的数组（如果可用），使用安全的 JSON.parse 检查长度
		try {
			const arrJson = JSON.stringify(chatListArr.value)
			const parsed = JSON.parse(arrJson)
			if (Array.isArray(parsed) == true) {
				console.log(prefix + ' parsed chatListArr length:', countArrayItems(parsed))
			}
		} catch (e) {}
		try {
			const efJson = JSON.stringify(effectiveChatList.value)
			const parsedEf = JSON.parse(efJson)
			if (Array.isArray(parsedEf) == true) {
				console.log(prefix + ' effectiveChatList length:', countArrayItems(parsedEf))
			}
		} catch (e) {}
	} catch (e) {}
}

// 监听 props.chatList 变化（放在 computed 之后，safe JSON 解析长度）
// 使用 computed wrapper as watch source to satisfy UTS function typing
const _chatListSource = computed((): any => props.chatList)
watch(_chatListSource, (newList: any, oldList: any) => {
	try {
		let newLen = 0
		let oldLen = 0
		try {
			const nj = JSON.stringify(newList)
			const parsedNew = JSON.parse(nj)
			if (Array.isArray(parsedNew) == true) newLen = countArrayItems(parsedNew)
		} catch (e) {}
		try {
			const oj = JSON.stringify(oldList)
			const parsedOld = JSON.parse(oj)
			if (Array.isArray(parsedOld) == true) oldLen = countArrayItems(parsedOld)
		} catch (e) {}
		console.log('[SharePopup] props.chatList changed, new length:', newLen, 'old length:', oldLen)
		logChatListStatus('[SharePopup] after chatList change')
	} catch (e) {}
}, { immediate: true, deep: true })

// 🔧 修复：监听组件显示状态，当显示时主动加载聊天列表
const MAX_LOAD_ATTEMPTS = 3

// 使用 computed 包装 props.visity 避免 UTS 编译器类型问题
const visityComputed = computed((): boolean => {
	return props.visity
})

// 🔧 修复：将 tryLoadChatList 提取为独立函数，避免 UTS 函数提升问题
// 使用 function 声明而非箭头函数，因为需要默认参数
function doTryLoadChatList(attempt: number): void {
	console.log('[SharePopup] 尝试加载聊天列表 (第', attempt, '次)')

	loadChatList().then(() => {
		// 加载完成后检查是否有数据
		const loadedData = getChatListRef()
		const dataCount = countArrayItems(loadedData)
		console.log('[SharePopup] 加载完成，数据长度:', dataCount)

		// 如果没有加载到数据，且还没达到最大尝试次数
		if (dataCount == 0 && chatListError.value == '' && loadAttemptCount.value < MAX_LOAD_ATTEMPTS) {
			const delay = attempt * 500 // 递增延迟：500ms, 1000ms, 1500ms...
			console.log('[SharePopup] 没有加载到数据，', delay, 'ms后重试')
			safeSetTimeout(() => {
				if (props.visity == true && chatListLoading.value == false && loadAttemptCount.value < MAX_LOAD_ATTEMPTS) {
					loadAttemptCount.value = loadAttemptCount.value + 1
					doTryLoadChatList(attempt + 1)
				}
			}, delay)
		}
	}).catch((error: any | null): void => {
		console.error('[SharePopup] 加载聊天列表失败:', error)
		// 如果是网络错误或其他错误，也尝试重试
		if (loadAttemptCount.value < MAX_LOAD_ATTEMPTS) {
			const delay = attempt * 500
			console.log('[SharePopup] 加载失败，', delay, 'ms后重试')
			safeSetTimeout(() => {
				if (props.visity == true && chatListLoading.value == false && loadAttemptCount.value < MAX_LOAD_ATTEMPTS) {
					loadAttemptCount.value = loadAttemptCount.value + 1
					doTryLoadChatList(attempt + 1)
				}
			}, delay)
		}
	})
}

watch(visityComputed, (newVisity: boolean) => {
	try {
		console.log('[SharePopup] visity changed to:', newVisity)
		if (newVisity == true) {
			// 🔧 调试：打印分享数据
			try {
				const shareDataJson = JSON.stringify(props.shareData)
				console.log('[SharePopup] 📋 shareData:', shareDataJson)
			} catch (e) {
				console.error('[SharePopup] 打印shareData失败:', e)
			}
			
			// 组件显示时，检查是否需要加载聊天列表
			const hasPropsData = countArrayItems(chatListArr.value) > 0
			const hasInternalData = countArrayItems(chatListInternalArr.value) > 0

			if (hasPropsData == false && hasInternalData == false && chatListLoading.value == false && loadAttemptCount.value < MAX_LOAD_ATTEMPTS) {
				console.log('[SharePopup] 组件显示但没有聊天数据，主动加载 (尝试次数:', loadAttemptCount.value + 1, ')')
				loadAttemptCount.value = loadAttemptCount.value + 1

				// 调用独立函数
				doTryLoadChatList(1)
			}
		} else {
			// 组件隐藏时重置尝试次数
			loadAttemptCount.value = 0
		}
	} catch (e) {
		console.error('[SharePopup] watch visity error:', e)
	}
}, { immediate: true })

// 监听内部聊天列表变化
watch(effectiveChatList, (newList: any, oldList: any) => {
	try {
		const newLen = countArrayItems(newList)
		const oldLen = countArrayItems(oldList)
		console.log('[SharePopup] effectiveChatList changed, new length:', newLen, 'old length:', oldLen)
		if (newLen > 0 && oldLen == 0) {
			console.log('[SharePopup] 聊天列表加载完成，可以显示聊天会话列表了')
		}
	} catch (e) {}
}, { immediate: false, deep: true })

// 注意：移除有问题的watch监听器
// 聊天列表数据通过props.chatList从页面传递，不需要在组件内部主动获取

// 辅助方法：安全获取分享数据属性
// 定义分享数据接口
interface ShareDataInfo {
	link?: string | null
	url?: string | null
	userId?: string | null
	desc?: string | null
	summary?: string | null
	title?: string | null
	imageUrl?: string | null
	// 推广相关字段
	referrerShortKid?: string | null
	guideKid?: string | null
	guideName?: string | null
	guideAvatar?: string | null
	servicePrice?: number | null
	commissionRate?: number | null
}

// 定义聊天项接口（与消息列表页保持一致）
interface ChatItemInfo {
	targetUserId?: string | null
	targetUserName?: string | null
	targetUserAvatar?: string | null
	avatar?: string | null  // 兼容性字段
}

// 定义选项接口
interface ShareOptionInfo {
	iconUrl?: string | null
	name?: string | null
	key?: string | null
	iconType?: string | null
	iconName?: string | null
	iconColor?: string | null
	iconSize?: number | null
}

// 获取选项的 iconType
const getOptionIconType = (option: any): string => {
	try {
		// 使用 JSON 序列化方式安全访问
		const optionStr = JSON.stringify(option)
		const optionObj = JSON.parse(optionStr) as UTSJSONObject
		const iconTypeVal = optionObj.get('iconType')
		if (iconTypeVal != null && iconTypeVal.toString() != '') {
			return iconTypeVal.toString()
		}
	} catch (e) {
		console.error('[SharePopup] getOptionIconType error:', e)
	}
	return 'image'
}

// 获取选项的 iconName
const getOptionIconName = (option: any): string => {
	try {
		// 使用 JSON 序列化方式安全访问
		const optionStr = JSON.stringify(option)
		const optionObj = JSON.parse(optionStr) as UTSJSONObject
		const iconNameVal = optionObj.get('iconName')
		if (iconNameVal != null && iconNameVal.toString() != '') {
			return iconNameVal.toString()
		}
	} catch (e) {
		console.error('[SharePopup] getOptionIconName error:', e)
	}
	return ''
}

// 获取选项的 iconColor
const getOptionIconColor = (option: any): string => {
	try {
		// 使用 JSON 序列化方式安全访问
		const optionStr = JSON.stringify(option)
		const optionObj = JSON.parse(optionStr) as UTSJSONObject
		const iconColorVal = optionObj.get('iconColor')
		if (iconColorVal != null && iconColorVal.toString() != '') {
			return iconColorVal.toString()
		}
	} catch (e) {
		console.error('[SharePopup] getOptionIconColor error:', e)
	}
	return '#333333'
}

// 获取选项的 iconSize
const getOptionIconSize = (option: any): number => {
	try {
		// 使用 JSON 序列化方式安全访问
		const optionStr = JSON.stringify(option)
		if (optionStr != '') {
			const optionObj = JSON.parse(optionStr) as UTSJSONObject
			const iconSizeVal = optionObj.get('iconSize')
			if (iconSizeVal != null) {
				const size = parseInt(iconSizeVal.toString())
				if (isNaN(size) == false && size > 0) {
					return size
				}
			}
		}
	} catch (e) {
		console.error('[SharePopup] getOptionIconSize error:', e)
	}
	return 48
}

// 辅助方法：安全获取分享数据属性（使用JSON序列化方式，兼容Android）
const getShareDataProp = (key: string): string => {
	const data = props.shareData
	try {
		// 🔧 修复：使用JSON序列化方式安全访问属性，避免Android端ClassCastException
		const dataJson = JSON.stringify(data)
		if (dataJson == '' || dataJson == '{}') {
			console.log('[SharePopup] getShareDataProp: shareData is empty, key:', key)
			return ''
		}
		const dataObj = JSON.parse(dataJson) as UTSJSONObject
		
		const val = dataObj.get(key)
		if (val != null && val.toString() != '') {
			const result = val.toString()
			console.log('[SharePopup] getShareDataProp:', key, '=', result)
			return result
		}
		console.log('[SharePopup] getShareDataProp:', key, '= (empty)')
		return ''
	} catch (e) {
		console.error('[SharePopup] getShareDataProp error:', e, 'key:', key)
	}
	return ''
}

// 🔧 修复：头像获取逻辑，使用 UTSJSONObject.get() 安全访问属性（避免 ClassCastException）
const getChatAvatar = (item: any): string => {
	console.log('[SharePopup] getChatAvatar called with item:', item)
	try {
		// 🔧 修复：item 已经是 UTSJSONObject 类型，直接转换使用，不需要再次序列化
		const itemObj = item as UTSJSONObject
		console.log('[SharePopup] getChatAvatar: itemObj keys check')

		// 🔧 优先级：targetUserAvatar > avatar（与消息列表页一致）
		const targetUserAvatarVal = itemObj.get('targetUserAvatar')
		console.log('[SharePopup] getChatAvatar: targetUserAvatarVal:', targetUserAvatarVal)
		if (targetUserAvatarVal != null && targetUserAvatarVal.toString() != '') {
			console.log('[SharePopup] getChatAvatar: found targetUserAvatar:', targetUserAvatarVal.toString())
			return targetUserAvatarVal.toString()
		}

		const avatarVal = itemObj.get('avatar')
		console.log('[SharePopup] getChatAvatar: avatarVal:', avatarVal)
		if (avatarVal != null && avatarVal.toString() != '') {
			console.log('[SharePopup] getChatAvatar: found avatar:', avatarVal.toString())
			return avatarVal.toString()
		}

		console.log('[SharePopup] getChatAvatar: no avatar found, using default')
	} catch (e) {
		console.error('[SharePopup] getChatAvatar error:', e)
	}
	return 'https://jiasu.wyxdapp.com/iconimages/default_avatar.png'
}

// 🔧 修复：昵称获取逻辑，使用 UTSJSONObject.get() 安全访问属性（避免 ClassCastException）
const getChatName = (item: any): string => {
	console.log('[SharePopup] getChatName called with item:', item)
	try {
		// 🔧 修复：item 已经是普通对象，直接转换为 UTSJSONObject 使用
		const itemObj = item as UTSJSONObject
		console.log('[SharePopup] getChatName: itemObj keys check')

		// 🔧 获取用户ID用于默认昵称生成（与消息列表页一致）
		const targetUserIdVal = itemObj.get('targetUserId')
		const userIdStr = (targetUserIdVal != null && targetUserIdVal.toString() != '') ? targetUserIdVal.toString() : ''
		console.log('[SharePopup] getChatName: targetUserId:', targetUserIdVal, 'userIdStr:', userIdStr)

		// 🔧 获取昵称
		const targetUserNameVal = itemObj.get('targetUserName')
		if (targetUserNameVal != null && targetUserNameVal.toString() != '' && targetUserNameVal.toString() != '用户') {
			console.log('[SharePopup] getChatName: found targetUserName:', targetUserNameVal.toString())
			return targetUserNameVal.toString()
		}

		// 🔧 默认昵称生成逻辑（与消息列表页一致）
		if (userIdStr.length >= 6) {
			const defaultName = '用户' + userIdStr.substring(userIdStr.length - 6)
			console.log('[SharePopup] getChatName: using default name:', defaultName)
			return defaultName
		}

		console.log('[SharePopup] getChatName: using fallback name "用户"')
	} catch (e) {
		console.error('[SharePopup] getChatName error:', e)
	}
	return '用户'
}

