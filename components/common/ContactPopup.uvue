.popup-header {
	background-color: #37B1F2;
	padding-top: 40rpx;
	padding-bottom: 32rpx;
	padding-left: 32rpx;
	padding-right: 32rpx;
	border-top-left-radius: 24rpx;
	border-top-right-radius: 24rpx;
	flex-direction: column;
	align-items: center;
}

.popup-title {
	font-size: 32rpx;
	font-weight: bold;
	color: #FFFFFF;
	margin-bottom: 8rpx;
}

.popup-subtitle {
	font-size: 24rpx;
	color: rgba(255, 255, 255, 0.8);
}

/* 联系方式列表 */
.contact-list {
	flex-direction: column;
	padding-left: 32rpx;
	padding-right: 32rpx;
	padding-top: 16rpx;
}

/* 联系方式项 */
.contact-item {
	flex-direction: row;
	padding-top: 24rpx;
	padding-bottom: 24rpx;
	border-bottom-width: 1rpx;
	border-bottom-style: solid;
	border-bottom-color: #EEEEEE;
}

.contact-item-last {
	border-bottom-width: 0;
}

/* 图标容器 */
.contact-icon-box {
	width: 72rpx;
	height: 72rpx;
	border-radius: 16rpx;
	flex-direction: row;
	align-items: center;
	justify-content: center;
	margin-right: 24rpx;
}

.contact-icon-name {
	background-color: #E8F4FD;
}

.contact-icon-phone {
	background-color: #FFF0E6;
}

.contact-icon-qq {
	background-color: #E6F7FF;
}

.contact-icon-wechat {
	background-color: #E6F9F0;
}

.contact-icon-email {
	background-color: #F0E6FF;
}

.contact-icon-text {
	font-size: 28rpx;
	font-weight: bold;
	color: #37B1F2;
}

.contact-icon-name .contact-icon-text {
	color: #37B1F2;
}

.contact-icon-phone .contact-icon-text {
	color: #FF6B35;
}

.contact-icon-qq .contact-icon-text {
	color: #12B7F5;
}

.contact-icon-wechat .contact-icon-text {
	color: #22AA76;
}

.contact-icon-email .contact-icon-text {
	color: #9B59B6;
}

/* 联系信息 */
.contact-info {
	flex: 1;
	flex-direction: column;
}

.contact-label {
	font-size: 24rpx;
	color: #999999;
	margin-bottom: 8rpx;
}

/* 值行 */
.contact-value-row {
	flex-direction: row;
	align-items: center;
	justify-content: space-between;
	background-color: #F5F5F5;
	padding-top: 12rpx;
	padding-bottom: 12rpx;
	padding-left: 16rpx;
	padding-right: 16rpx;
	border-radius: 8rpx;
}

.contact-value {
	font-size: 28rpx;
	font-weight: bold;
	color: #333333;
	flex: 1;
}

.contact-value-empty {
	font-size: 28rpx;
	color: #999999;
}

/* 复制按钮 */
.copy-btn {
	padding-left: 16rpx;
	padding-right: 16rpx;
	padding-top: 6rpx;
	padding-bottom: 6rpx;
	background-color: #37B1F2;
	border-radius: 6rpx;
}

.copy-text {
	font-size: 22rpx;
	color: #FFFFFF;
}

/* 操作按钮行 */
.action-row {
	flex-direction: row;
	margin-top: 16rpx;
}

.action-btn {
	flex: 1;
	padding-top: 14rpx;
	padding-bottom: 14rpx;
	border-radius: 8rpx;
	flex-direction: row;
	align-items: center;
	justify-content: center;
	margin-right: 16rpx;
}

.action-btn:last-child {
	margin-right: 0;
}

.action-btn-primary {
	background-color: #37B1F2;
}

.action-btn-secondary {
	background-color: #F5F5F5;
}

.action-btn-success {
	background-color: #22AA76;
}

.action-btn-text {
	font-size: 24rpx;
	color: #FFFFFF;
}

.action-btn-text-secondary {
	font-size: 24rpx;
	color: #666666;
}

/* 提示信息 */
.note-box {
	flex-direction: row;
	align-items: center;
	justify-content: center;
	padding-top: 20rpx;
	padding-bottom: 20rpx;
	margin-left: 32rpx;
	margin-right: 32rpx;
	background-color: #FFF9E6;
	border-radius: 8rpx;
}

.note-text {
	font-size: 22rpx;
	color: #996600;
}

/* 底部按钮 */
.footer-btn {
	margin-top: 24rpx;
	margin-bottom: 32rpx;
	margin-left: 32rpx;
	margin-right: 32rpx;
	padding-top: 24rpx;
	padding-bottom: 24rpx;
	background-color: #37B1F2;
	border-radius: 44rpx;
	flex-direction: row;
	align-items: center;
	justify-content: center;
}

.footer-btn-text {
	font-size: 30rpx;
	font-weight: bold;
	color: #FFFFFF;
}
</style>
