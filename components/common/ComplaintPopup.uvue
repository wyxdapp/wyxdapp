	font-size: 36rpx;
	font-weight: bold;
	color: #333333;
}

.modal-content {
	flex: 1;
	flex-direction: column;
	padding-top: 32rpx;
	padding-bottom: 32rpx;
	padding-left: 0;
	padding-right: 0;
}

