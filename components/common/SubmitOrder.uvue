	if (hasUserKid == false) {
		uni.showToast({
			title: '请先登录',
			icon: 'none'
		})
		return
	}
	
	// 验证（使用 JSON.parse + 接口类型安全访问 addFormData.value 的属性）
	const addFormDataJson = JSON.stringify(addFormData.value)
	const addFormDataParsed = (addFormDataJson != '') 
		? (JSON.parse(addFormDataJson) as any) as AddFormDataValue
		: null
	
	const nameVal = (addFormDataParsed != null && addFormDataParsed.name != null) 
		? addFormDataParsed.name.toString() 
		: ''
	const nameValTrimmed = (nameVal != '') ? nameVal.trim() : ''
	if (nameValTrimmed == '') {
		uni.showToast({
			title: '请输入姓名',
			icon: 'none'
		})
		return
	}
	
	const phoneVal = (addFormDataParsed != null && addFormDataParsed.phone != null) 
		? addFormDataParsed.phone.toString() 
		: ''
	const phoneValTrimmed = (phoneVal != null && phoneVal != '') ? phoneVal.trim() : ''
	if (phoneValTrimmed == '') {
		uni.showToast({
			title: '请输入手机号',
			icon: 'none'
		})
		return
	}
	
	const phoneReg = /^1[3-9]\d{9}$/
	if (phoneReg.test(phoneValTrimmed) == false) {
		uni.showToast({
			title: '手机号码不正确',
			icon: 'none'
		})
		return
	}
	
	try {
		// 使用 getUserKid 函数，避免括号访问（String.get 错误）
		const userKid = getUserKid()
		if (userKid == '') {
			uni.showToast({
				title: '请先登录',
				icon: 'none'
			})
			return
		}
		
		// 使用 JSON.parse + 接口类型传递参数，避免匿名对象类型错误
		const addParamsJson = JSON.stringify({
			userKid: userKid,
			name: nameValTrimmed,
			phone: phoneValTrimmed
		})
		const addParamsParsed = JSON.parse(addParamsJson) as any
		const addParams = addParamsParsed as AddTravelUserParams
		await addTravelUser(addParams)
		
		uni.showToast({
			title: '添加成功',
			icon: 'success'
		})
		Get_contact_list()
		addFormData.value = {
			name: '',
			phone: ''
		}
	} catch (error) {
		console.error('添加联系人失败:', error)
		uni.showToast({
			title: '添加失败',
			icon: 'none'
		})
	}
}

// 删除联系人
const handleDelContact = async () => {
	if (contactId.value == null || contactId.value == '') {
		uni.showToast({
			title: '请先选择联系人',
			icon: 'none'
		})
		return
	}
	
	// 使用 store 导出的函数获取用户信息（避免直接访问 userStore.userInfo）
	const loginInfo = getUserInfoFromStore()
	let hasKid = false
	if (loginInfo != null) {
		try {
			const kidVal = loginInfo.get('kid')
			hasKid = (kidVal != null && kidVal.toString() != '')
		} catch (e) {}
	}
	if (hasKid == false) {
		uni.showToast({
			title: '请先登录',
			icon: 'none'
		})
		return
	}
	
	const confirmDelete = async () => {
		try {
			// 使用 getUserKid 函数，避免括号访问（String.get 错误）
			const userKidInner = getUserKid()
			if (userKidInner == '') {
				uni.showToast({
					title: '请先登录',
					icon: 'none'
				})
				return
			}
			
			// 使用 JSON.parse + 接口类型传递参数，避免匿名对象类型错误
			const delParamsJson = JSON.stringify({ 
				kid: contactId.value, 
				userKid: userKidInner 
			})
			const delParamsParsed = JSON.parse(delParamsJson) as any
			const delParams = delParamsParsed as DelTravelUserParams
			const result = await delTravelUser(delParams)
			const handleSuccess = () => {
					setFormDataValue({
						phone: '',
						realname: ''
					})
				let filteredList: Array<any> = []
				if (contactList.value != null && Array.isArray(contactList.value) == true) {
					const contactListArr = contactList.value as Array<any>
					const filteredListTemp: Array<any> = []
					
					// 使用 for 循环替代 filter，避免括号访问（String.get 错误）
					for (let i = 0; i < contactListArr.length; i++) {
						const s = contactListArr[i]
						if (s != null) {
							// 使用 JSON.parse + 接口类型 + 点访问，避免括号访问
							try {
								const sJson = JSON.stringify(s)
								if (sJson != '') {
									const sParsed = JSON.parse(sJson) as any
									const sData = sParsed as SubmitOrderContactItem
									const sKid = (sData.kid != null) ? sData.kid.toString() : ''
									if (sKid != contactId.value) {
										filteredListTemp.push(s)
									}
								}
							} catch (e) {}
						}
					}
					filteredList = filteredListTemp
				}
				contactList.value = filteredList
				contactId.value = ''
					
				if (filteredList != null && Array.isArray(filteredList) == true && filteredList.length > 0) {
					const first = filteredList[0]
					if (first != null) {
						// 使用 JSON.parse + 接口类型 + 点访问，避免括号访问（String.get 错误）
						try {
							const firstJson = JSON.stringify(first)
							if (firstJson != '') {
								const firstParsed = JSON.parse(firstJson) as any
								const firstData = firstParsed as SubmitOrderContactItem
								const firstName = (firstData.name != null) ? firstData.name.toString() : ''
								const firstPhone = (firstData.phone != null) ? firstData.phone.toString() : ''
								const firstKid = (firstData.kid != null) ? firstData.kid.toString() : ''
								setFormDataValue({
									realname: firstName,
									phone: firstPhone
								})
								contactId.value = firstKid
							}
						} catch (e) {}
					}
				}
					
					uni.showToast({
						title: '删除成功',
						icon: 'success'
					})
			}
			const handleFail = (error: any) => {
				console.error('删除联系人失败:', error)
				uni.showToast({
					title: '删除失败',
					icon: 'none'
				})
			}
			// delTravelUser 返回 Promise，直接使用 await 处理
			try {
				await result
				handleSuccess()
			} catch (error) {
				handleFail(error)
			}
				} catch (error) {
					console.error('删除联系人失败:', error)
					uni.showToast({
						title: '删除失败',
						icon: 'none'
					})
				}
	}
	
	uni.showModal({
		title: '提示',
		content: '确定要删除该联系人吗？',
		success: (res: any) => {
			// 使用 JSON.parse + 接口类型安全访问 res 的属性，避免直接属性访问错误
			try {
				const resJson = JSON.stringify(res)
				if (resJson != '') {
					const resParsed = JSON.parse(resJson) as any
					const resData = resParsed as ShowModalResult
					if (resData.confirm == true) {
						confirmDelete()
					}
				}
			} catch (e) {}
		}
	})
}

// 路线订单提交（必须在 handleSubmitOrder 之前定义）
const handleRouteOrderSubmit = async () => {
	// 获取用户ID
	const userKid = getUserKid()
	if (userKid == '') {
		uni.showToast({
			title: '请先登录',
			icon: 'none'
		})
		return
	}
	
	// 获取表单数据
	const formDataValueRaw = getFormDataValue()
	const formDataValue = formDataValueRaw as FormDataValue
	
	// 验证联系人信息
	if (formDataValue.phone == null || formDataValue.phone == '') {
		uni.showToast({
			title: '请选择联系人',
			icon: 'none'
		})
		return
	}
	
	if (formDataValue.realname == null || formDataValue.realname == '') {
		uni.showToast({
			title: '请输入联系人姓名',
			icon: 'none'
		})
		return
	}
	
	// 验证日期
	if (chooseDate.value == '') {
		uni.showToast({
			title: '请选择出行日期',
			icon: 'none'
		})
		return
	}
	
	// 构建订单参数
	const orderParamsJson = JSON.stringify({
		userKid: userKid,
		lineKid: props.lineKid,
		orderTitle: props.lineTitle != '' ? props.lineTitle : '路线订单',
		travelDate: chooseDate.value,
		serviceHours: formDataValue.serviceHours,
		phone: formDataValue.phone,
		realname: formDataValue.realname,
		totalMoney: formDataValue.totalMoney,
		orderRemarks: formDataValue.orderRemarks
	})
	const orderParamsParsed = JSON.parse(orderParamsJson) as any
	const orderParams = orderParamsParsed as CreateRouteOrderParams
	
	// 显示加载提示
	uni.showLoading({
		title: '创建订单中...'
	})
	
	try {
		// 调用创建路线订单API
		const res = await createRouteOrder(orderParams)
		
		// 解析响应
		const resObj = JSON.parse(JSON.stringify(res)) as UTSJSONObject
		const code = resObj.get('code')
		
		if (code != null && parseInt(code.toString()) == 200) {
			// 获取订单ID
			const dataVal = resObj.get('data')
			let orderKid = ''
			
			if (dataVal != null) {
				const dataObj = JSON.parse(JSON.stringify(dataVal)) as UTSJSONObject
				const orderKidVal = dataObj.get('orderKid')
				if (orderKidVal == null) {
					const kidVal = dataObj.get('kid')
					if (kidVal != null) {
						orderKid = kidVal.toString()
					}
				} else {
					orderKid = orderKidVal.toString()
				}
			}
			
			if (orderKid == '') {
				uni.showToast({
					title: '订单创建成功，但未获取到订单ID',
					icon: 'none'
				})
				return
			}
			
			// 跳转到支付页面
			uni.hideLoading()
			uni.showToast({
				title: '订单创建成功',
				icon: 'success'
			})
			
			safeSetTimeout(() => {
				// 关闭预订弹窗
				close()
				
				// 跳转到支付页面（orderType=10表示路线订单）
				uni.navigateTo({
					url: '/pagesTrade/payment/payOrder/index?orderKid=' + orderKid + '&orderType=10'
				})
			}, 500)
		} else {
			// 获取错误信息
			const msgVal = resObj.get('msg')
			const errorMsg = (msgVal != null && msgVal.toString() != '') 
				? msgVal.toString() 
				: '订单创建失败'
			
			uni.hideLoading()
			uni.showToast({
				title: errorMsg,
				icon: 'none'
			})
		}
	} catch (error: any) {
		// 错误处理
		uni.hideLoading()
		
		let errorMsg = '订单创建失败'
		if (error != null) {
			try {
				const errorObj = JSON.parse(JSON.stringify(error)) as UTSJSONObject
				const msgVal = errorObj.get('message')
				if (msgVal != null && msgVal.toString() != '') {
					errorMsg = msgVal.toString()
				}
			} catch (e) {
				// 使用默认错误消息
			}
		}
		
		uni.showToast({
			title: errorMsg,
			icon: 'none'
		})
	}
}

// 确认下单
const handleSubmitOrder = async () => {
	// 验证向导信息
	if ((props.guiderKid == null) || (props.guiderKid == '')) {
		if ((props.lineKid == null) || (props.lineKid == '')) {
		uni.showToast({
				title: '缺少必要参数',
			icon: 'none'
		})
		return
		} else {
			// 路线订单创建逻辑
			await handleRouteOrderSubmit()
		return
	}
	}
	
	// 获取用户ID（使用 getUserKid 函数，避免括号访问（String.get 错误））
	const userKid = getUserKid()
	if (userKid == '') {
		return // useOrderSubmission 会处理登录验证
	}
	
	// 构建订单数据（使用 JSON.parse + 接口类型传递参数，避免匿名对象类型错误）
	const formDataValueRaw = getFormDataValue()
	const formDataValue = formDataValueRaw as FormDataValue
	
	const orderParamsJson = JSON.stringify({
		userKid: userKid,
		guideKid: props.guiderKid,
		travelDate: chooseDate.value,
		serviceHours: formDataValue.serviceHours,
		phone: formDataValue.phone,
		realname: formDataValue.realname,
		totalMoney: formDataValue.totalMoney,
		orderRemarks: formDataValue.orderRemarks,
		cityName: formDataValue.cityName
	})
	const orderParamsParsed = JSON.parse(orderParamsJson) as any
	const orderParams = orderParamsParsed as GuiderOrderParams
	const orderData = buildGuiderOrderData(orderParams)
	
	// 提交订单（使用辅助函数调用，避免 error18 和 invoke 错误）
	// 注意：直接调用 any 类型的函数会触发 invoke 错误，需要使用辅助函数包装
	await callSubmitOrder(orderData, {
		validateContact: true,
		phone: formDataValue.phone,
		realname: formDataValue.realname
	})
	
	// 关闭弹窗
	close()
}

// 监听显示状态（使用 computed 包装，避免 watch 返回类型不匹配）
const showValue = computed((): boolean => props.show)
watch(showValue, (newVal: boolean) => {
	if (newVal == true) {
		// 检查登录状态（使用 loginHelper 可靠版本）
		const isLoggedIn = checkUserLoginReliable()
		if (isLoggedIn == false) {
			uni.showToast({
				title: '请先登录',
				icon: 'none'
			})
			safeSetTimeout(() => {
				uni.navigateTo({
					url: '/pagesUser/login/index'
				})
			}, 1500)
			close()
			return
		}
		
		// 初始化价格和日期
		let priceNum = 0 as number
		try {
			if (typeof props.price === 'string') {
				const priceStr = (props.price != null) ? props.price.toString() : '0'
				const parsedPrice = parseFloat(priceStr.replace(/[^\d.]/g, ''))
				priceNum = (parsedPrice > 0) ? parsedPrice : 0
			} else {
				priceNum = (props.price != null) ? (props.price as number) : 0
			}
		} catch (e) {}
		serverPrice.value = priceNum
		setFormDataValue({
			totalMoney: serverPrice.value
		})
		
		// 获取联系人列表
		Get_contact_list()
	}
})

// 监听添加联系人弹窗状态（使用 computed 包装，避免 watch 返回类型不匹配）
const addContactVisityValue = computed((): boolean => addContactVisity.value)
watch(addContactVisityValue, (newVal: boolean) => {
	if (newVal == true) {
		addFormData.value = {
			name: '',
			phone: ''
		}
	}
})

// 初始化日期
onMounted(() => {
	initMinDate()
})

onUnmounted(() => {
	clearAllTimers()
})
</script>

