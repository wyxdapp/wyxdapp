	close()
}

// 选择联系人
const handlePhone = (row: any) => {
	const phoneVal = getContactPhone(row)
	const realnameVal = getContactName(row)
	setFormDataValue({
		phone: phoneVal,
		realname: realnameVal
	})
	const kid = getItemProp(row, 'kid')
	if (kid != null) {
		contactId.value = kid.toString()
	} else {
		contactId.value = ''
	}
}

// 设为默认
const handleSetDefault = async () => {
	if (contactId.value == null || contactId.value == '') {
		uni.showToast({
			title: '请先选择联系人',
			icon: 'none'
		})
		return
	}
	
	// 使用 store 导出的函数获取用户信息（避免直接访问 userStore.userInfo）
	const loginInfo = getUserInfoFromStore()
	let hasKid = false
	if (loginInfo != null) {
		try {
			const kidVal = loginInfo.get('kid')
			hasKid = (kidVal != null && kidVal.toString() != '')
		} catch (e) {}
	}
	if (hasKid == false) {
		uni.showToast({
			title: '请先登录',
			icon: 'none'
		})
		return
	}
	
	try {
		// 使用 getUserKid 函数，避免括号访问（String.get 错误）
		const userKid = getUserKid()
		if (userKid == '') {
			uni.showToast({
				title: '请先登录',
				icon: 'none'
			})
			return
		}
		// 使用 JSON.parse + 接口类型传递参数，避免匿名对象类型错误
		const paramsJson = JSON.stringify({ kid: contactId.value, userKid: userKid })
		const paramsParsed = JSON.parse(paramsJson) as any
		const params = paramsParsed as SetDefaultTravelUserParams
		await setDefaultTravelUser(params)
		uni.showToast({
			title: '设置成功',
			icon: 'success'
		})
		Get_contact_list()
	} catch (error) {
		console.error('设置默认联系人失败:', error)
		uni.showToast({
			title: '设置失败',
			icon: 'none'
		})
	}
}

// 打开编辑
const openEditContact = () => {
	if (contactId.value == null || contactId.value == '') {
		uni.showToast({
			title: '请先选择联系人',
			icon: 'none'
		})
		return
	}
	
	const formDataValueRaw = getFormDataValue()
	const formDataValue = formDataValueRaw as FormDataValue
	const realnameVal = (formDataValue.realname != null && formDataValue.realname != '') ? formDataValue.realname.toString() : ''
	const phoneVal = (formDataValue.phone != null && formDataValue.phone != '') ? formDataValue.phone.toString() : ''
	editFormData.value = {
		name: realnameVal,
		phone: phoneVal
	}
	editContactVisity.value = true
}

// 提交编辑
const handleUpdateContact = async () => {
	const contactIdVal = contactId.value
	if (contactIdVal == null || contactIdVal == '') {
		uni.showToast({
			title: '请先选择联系人',
			icon: 'none'
		})
		return
	}
	
	// 使用 store 导出的函数获取用户信息（避免直接访问 userStore.userInfo）
	const userInfo = getUserInfoFromStore()
	let hasUserKid = false
	if (userInfo != null) {
		try {
			const kidVal = userInfo.get('kid')
			hasUserKid = (kidVal != null && kidVal.toString() != '')
		} catch (e) {}
	}
	if (hasUserKid == false) {
		uni.showToast({
			title: '请先登录',
			icon: 'none'
		})
		return
	}
	
	// 验证（使用 JSON.parse + 接口类型安全访问 editFormData.value 的属性）
	const editFormDataJson = JSON.stringify(editFormData.value)
	const editFormDataParsed = (editFormDataJson != '') 
		? (JSON.parse(editFormDataJson) as any) as EditFormDataValue
		: null
	
	const nameVal = (editFormDataParsed != null && editFormDataParsed.name != null) 
		? editFormDataParsed.name.toString() 
		: ''
	const nameValTrimmed = (nameVal != '') ? nameVal.trim() : ''
	if (nameValTrimmed == '') {
		uni.showToast({
			title: '请输入姓名',
			icon: 'none'
		})
		return
	}
	
	const phoneVal = (editFormDataParsed != null && editFormDataParsed.phone != null) 
		? editFormDataParsed.phone.toString() 
		: ''
	const phoneValTrimmed = (phoneVal != null && phoneVal != '') ? phoneVal.trim() : ''
	if (phoneValTrimmed == '') {
		uni.showToast({
			title: '请输入手机号',
			icon: 'none'
		})
		return
	}
	
	const phoneReg = /^1[3-9]\d{9}$/
	if (phoneReg.test(phoneValTrimmed) == false) {
		uni.showToast({
			title: '手机号码不正确',
			icon: 'none'
		})
		return
	}
	
	try {
		// 使用 JSON.parse + 接口类型传递参数，避免匿名对象类型错误
		const kidVal = contactIdVal.toString()
		const updateParamsJson = JSON.stringify({
			kid: kidVal,
			name: nameValTrimmed,
			phone: phoneValTrimmed
		})
		const updateParamsParsed = JSON.parse(updateParamsJson) as any
		const updateParams = updateParamsParsed as UpdateTravelUserParams
		await updateTravelUser(updateParams)
		
		editContactVisity.value = false
		uni.showToast({
			title: '保存成功',
			icon: 'success'
		})
		Get_contact_list()
	} catch (error) {
		console.error('更新联系人失败:', error)
		uni.showToast({
			title: '保存失败',
			icon: 'none'
		})
	}
}

