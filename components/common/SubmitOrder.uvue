<template>
	<view v-if="show == true" class="submit-order-mask" @click="handleMaskClick">
		<view class="submit-order-popup" @click.stop>
			<view class="city-box relative">
				<view class="page-back flex-row align-center flex-center" @click="close">
					<UniIcons type="back" :size="44" class="back-icon-img" />
				</view>
				<view class="flex-row align-center top-tab flex-center bg-white">
					<text class="fs-xl color-title font-bold">预约</text>
				</view>
				<scroll-view :enable-back-to-top="true" class="scroll-view bg-base" :scroll-y="true" :scroll-with-animation="true">
					<view class="border-radius-26 bg-white plr-24 mlr-24 mt-24 pt-40 pb-22">
						<view class="flex-row align-center space-between">
							<text class="color-title fs-lg font-bold">预约日期</text>
							</view>
						<view class="mt-30">
							<DatePicker 
								v-model="chooseDate"
								:minDate="minDate"
								:maxDate="maxDate"
								@change="handleDateChange"
							/>
						</view>
					</view>
					<view class="border-radius-26 bg-white plr-24 mlr-24 mt-24 pt-40 pb-40">
						<view class="flex-row align-center space-between">
							<text class="color-title fs-lg font-bold">预约天数</text>
						</view>
						<view class="mt-30 flex-row align-center">
							<view class="number-btn" @click="decreaseDays">
								<text>-</text>
							</view>
							<view class="number-value">
								<text>{{formDataServiceHours}}</text>
							</view>
							<view class="number-btn" @click="increaseDays">
								<text>+</text>
							</view>
						</view>
					</view>
					<view class="border-radius-26 bg-white plr-24 mlr-24 mt-24 pt-40 pb-40">
						<view class="flex-row align-center space-between">
							<text class="color-title fs-lg font-bold">联系信息</text>
							<view class="flex-row align-center flex-center more-btn" @click="addContactVisity = true">
								<text class="fs-sm light-blue mr-10">新增更多</text>
								<text class="arrow-icon">→</text>
							</view>
						</view>
						<template v-if="contactList != null && Array.isArray(contactList) == true && (contactList as Array<any>).length > 0">
							<view class="mt-30 flex-row align-start flex-start flex-wrap">
								<view 
									@click="handlePhone(item)" 
									:class="{'active': isContactActive(item)}" 
									class="contact-block flex-row flex-center align-center fs-md mb-20 mr-20" 
									v-for="(item,index) in (contactList as Array<any>)" 
									:key="getContactKey(item, index)">
									<text>{{ getContactName(item) }}</text>
									<text v-if="isContactDefault(item) === true" class="default-tag ml-8">默认</text>
								</view>
							</view>
							<view class="ptb-32 flex-row align-center space-between">
								<view class="flex-row align-center">
									<text class="fs-md color-title">游客</text>
									<text class="fs-md color-title ml-40">{{ formDataRealname }} {{ formDataPhone }}</text>
								</view>
								<view class="flex-row align-center ops">
									<text class="fs-md light-blue mr-24" @click="handleSetDefault">设为默认</text>
									<text class="fs-md light-blue mr-24" @click="openEditContact">编辑</text>
									<text class="fs-md red" @click="handleDelContact">删除</text>
								</view>
							</view>
						</template>
						<view class="mt-20">
							<textarea 
								placeholder="请输入对向导的性别、擅长、服务等需求" 
								maxlength="120" 
								v-model="formDataOrderRemarks" 
								class="textarea-input"
								:auto-height="true" />
						</view>
					</view>
				</scroll-view>
			</view>
			<view class="flex-row plr-32 align-center space-between footer-box bg-white">
				<view class="flex-row align-center">
					<text class="fs-md color-title">费用合计: </text>
					<text class="color-price fs-xl">￥{{formattedTotalMoney}}</text>
				</view>
				<view class="submit-btn flex-row align-center flex-center white fs-lg" @click="handleSubmitOrder">确定下单</view>
			</view>
			
			<!-- 新增联系人弹窗 -->
			<view v-if="addContactVisity" class="popup-mask" @click="addContactVisity = false">
				<view class="popup-content" @click.stop>
					<view class="popup-header">
						<text class="popup-title">新增联系人</text>
						<text class="popup-close" @click="addContactVisity = false">×</text>
					</view>
					<view class="popup-body">
						<view class="form-item">
							<text class="form-label">姓名</text>
							<input 
								class="form-input" 
								v-model="addFormDataName" 
								placeholder="请输入姓名"
								placeholder-class="placeholder" />
						</view>
						<view class="form-item">
							<text class="form-label">电话</text>
							<input 
								class="form-input" 
								v-model="addFormDataPhone" 
								type="number"
								maxlength="11"
								placeholder="请输入手机号"
								placeholder-class="placeholder" />
						</view>
					</view>
					<view class="popup-footer">
						<view class="add-submit flex-row align-center flex-center white fs-lg" @click="handleAddContact">确定</view>
					</view>
				</view>
			</view>

			<!-- 编辑联系人弹窗 -->
			<view v-if="editContactVisity" class="popup-mask" @click="editContactVisity = false">
				<view class="popup-content" @click.stop>
					<view class="popup-header">
						<text class="popup-title">编辑联系人</text>
						<text class="popup-close" @click="editContactVisity = false">×</text>
					</view>
					<view class="popup-body">
						<view class="form-item">
							<text class="form-label">姓名</text>
							<input 
								class="form-input" 
								v-model="editFormDataName" 
								placeholder="请输入姓名"
								placeholder-class="placeholder" />
						</view>
						<view class="form-item">
							<text class="form-label">电话</text>
							<input 
								class="form-input" 
								v-model="editFormDataPhone" 
								type="number"
								maxlength="11"
								placeholder="请输入手机号"
								placeholder-class="placeholder" />
						</view>
					</view>
					<view class="popup-footer">
						<view class="add-submit flex-row align-center flex-center white fs-lg" @click="handleUpdateContact">保存</view>
					</view>
				</view>
			</view>
		</view>
	</view>
</template>

<script setup lang="uts">
import { ref, computed, watch, onMounted, onUnmounted } from 'vue'
import UniIcons from '@/components/base/UniIcons.uvue'
import DatePicker from '@/components/business/DatePicker.uvue'
import { 
	getContactList, 
	addTravelUser, 
	delTravelUser, 
	updateTravelUser, 
	setDefaultTravelUser,
	createGuiderOrder,
	CreateGuiderOrderParams,
	createRouteOrder,
	type CreateRouteOrderParams,
	type GetContactListParams,
	type SetDefaultTravelUserParams,
	type UpdateTravelUserParams,
	type AddTravelUserParams,
	type DelTravelUserParams
} from '@/api/order.uts'
import { useOrderSubmission, SubmissionConfigImpl } from '@/common/composables/useOrderSubmission.uts'
import { buildGuiderOrderData, type GuiderOrderParams } from '@/common/utils/orderBuilder.uts'
import { 
	checkUserLoginReliable, 
	getCurrentUserIdReliable
} from '@/common/utils/loginHelper.uts'

// 定义接口（必须在顶层，不能在函数内部）- UTS110111166
interface ItemData {
	kid?: string | null
	id?: string | null
	name?: string | null
	realname?: string | null
	realName?: string | null
	travellerName?: string | null
	phone?: string | null
	phoneNumber?: string | null
	travellerPhone?: string | null
	mobile?: string | null
	is_default?: string | number | boolean | null
	isDefault?: string | number | boolean | null
	defaultFlag?: string | number | boolean | null
	defaultStatus?: string | number | boolean | null
}

// FormData 值接口（用于安全访问 formData.value 的属性）
interface FormDataValue {
	realname?: string | null
	phone?: string | null
	serviceHours?: number | null
	orderRemarks?: string | null
	totalMoney?: number | null
	cityName?: number | null
}

// UserInfo 接口（用于安全访问 userInfo 的属性）
// 注意：UTS 不支持索引签名 [key: string]: any，只能明确定义需要的字段
// 重命名避免重复声明
interface SubmitOrderUserInfoData {
	kid?: string | number | null
	// 如果需要访问其他字段，需要在此明确定义，不能使用索引签名
}

// ContactItem 接口（用于安全访问联系人项的属性）
// 重命名避免重复声明
interface SubmitOrderContactItem {
	kid?: string | null
	name?: string | null
	phone?: string | null
	is_default?: string | number | boolean | null
}

// EditFormData 接口（用于安全访问 editFormData.value 的属性）
interface EditFormDataValue {
	name?: string | null
	phone?: string | null
}

// AddFormData 接口（用于安全访问 addFormData.value 的属性）
interface AddFormDataValue {
	name?: string | null
	phone?: string | null
}

// ShowModalResult 接口（用于安全访问 uni.showModal 返回值的属性）
interface ShowModalResult {
	confirm?: boolean | null
	cancel?: boolean | null
}

// Props - 运行时声明
const props = defineProps({
	show: { type: Boolean, required: true },
	price: { type: [String, Number], default: 0 },
	guiderKid: { type: String, required: true },
	lineKid: { type: String, default: '' },
	lineTitle: { type: String, default: '' }
})

// Emits
const emit = defineEmits<{
	'update:show': [value: boolean]
	submit: [data: any]
}>()

// 用户存储 - 使用真实的用户状态
import { useUserStore } from '@/stores/user.uts'
// 导入 store 导出的函数（避免直接访问 userStore.userInfo）
import { getUserId as getUserIdFromStore, getUserInfoFromStore } from '@/stores/user.uts'

// 定时器生命周期管理
let timerHandles: number[] = []

function safeSetTimeout(callback: () => void, ms: number): number {
	const handle = setTimeout(callback, ms)
	timerHandles.push(handle)
	return handle
}

function clearAllTimers(): void {
	for (const handle of timerHandles) {
		clearTimeout(handle)
	}
	timerHandles = []
}

// 获取用户 store 实例
const userStore = useUserStore()

// 数据
const chooseDate = ref('')
const maxDate = ref('2050-01-01')
const minDate = ref('2022-01-01')

const formData = ref({
	serviceHours: 1,
	orderRemarks: '',
	phone: '',
	realname: '',
	totalMoney: 0,
	cityName: 0
})

const contactList = ref([] as Array<any>)

const addContactVisity = ref(false)
const editContactVisity = ref(false)

const addFormData = ref({
	name: '',
	phone: ''
})

const editFormData = ref({
	name: '',
	phone: ''
})

const serverPrice = ref(0)
const contactId = ref('')

// 使用订单提交 composable（避免解构赋值，直接获取整个对象）
const orderSubmissionConfig = new SubmissionConfigImpl()
orderSubmissionConfig.successMessage = '下单成功'
orderSubmissionConfig.shouldNavigateToPayment = true
orderSubmissionConfig.shouldNavigateBack = false

// 将 createGuiderOrder 包装为符合 OrderApiFunction 类型的函数
// UTS 规范：直接使用 as any（不能用 as any as Interface，Android 会报 ClassCastException）
const createGuiderOrderWrapper = async (params: any): Promise<any> => {
	// 调用 createGuiderOrder，需要将 params 转换为 CreateGuiderOrderParams
	const orderParams = params as CreateGuiderOrderParams
	const result = await createGuiderOrder(orderParams)
	return result as any
}

const orderSubmissionResult = useOrderSubmission(
	createGuiderOrderWrapper,
	userStore as any,
	orderSubmissionConfig
)

// 定义返回对象接口，使用点访问（避免括号访问）
interface OrderSubmissionResult {
	isSubmitting: any
	submitOrder: (orderData: any, options: any) => Promise<any>
	resetSubmission?: () => void
	validateLogin?: () => boolean
	validateContact?: (phone: string | null, realname: string | null) => boolean
}

// 直接使用类型断言 + 点访问（避免括号访问）
// 根据 UTS 规范，脚本中禁止括号访问，使用接口类型 + 点访问
const orderSubmissionResultTyped = orderSubmissionResult as OrderSubmissionResult

const isSubmit = orderSubmissionResultTyped.isSubmitting
const submitOrder = orderSubmissionResultTyped.submitOrder

// 辅助函数：获取 submitOrder 函数（用于在函数内部调用，避免 error18 和 invoke 错误）
// 注意：返回具体函数类型，而不是 any，避免 any 类型函数调用触发 invoke 问题
const getSubmitOrder = (): (orderData: any, options: any) => Promise<any> => {
	const orderSubmissionResultTypedInner = orderSubmissionResult as OrderSubmissionResult
	return orderSubmissionResultTypedInner.submitOrder
}

// 辅助函数：调用 submitOrder（用于在函数内部调用）
// 注意：在函数内部，即使是顶层定义的变量也可能找不到（error18），需要使用辅助函数获取
// 注意：在函数内部定义的变量可能找不到（error18），需要直接调用函数返回值，不使用中间变量
const callSubmitOrder = async (orderData: any, options: any): Promise<any> => {
	// 使用 getSubmitOrder() 函数获取 submitOrder，避免在函数内部直接访问顶层变量触发 error18
	// 解决方案：直接调用 getSubmitOrder() 的返回值，此时为具体函数类型，不再是 any
	try {
		// 直接调用 getSubmitOrder() 的返回值，返回类型为 (orderData: any, options: any) => Promise<any>
		const submitFn = getSubmitOrder()
		return await submitFn(orderData, options)
	} catch (e) {}
	return null
}

// 辅助方法：安全访问对象属性（返回空字符串而不是 null，避免 Any 类型不能为 null）
// 根据 UTS 规范，脚本中完全禁止括号访问，使用 JSON.parse + 接口类型 + 点访问
const getItemProp = (item: any, key: string): string => {
	try {
		// 使用 JSON 序列化/反序列化来创建新对象，然后使用接口类型访问
		const itemJson = JSON.stringify(item)
		if (itemJson == '') return ''
		
		const parsed = JSON.parse(itemJson) as any
		
		const itemData = parsed as ItemData
		// 不能使用 null 初始化 any 类型，使用空字符串
		let value: any = ''
		
		// 使用显式字段分支 + 点访问（避免括号访问）
		// 将 String? 转换为 any，避免类型不匹配
		if (key === 'kid') {
			const kidVal = itemData.kid
			value = (kidVal != null) ? kidVal as any : ''
		} else if (key === 'id') {
			const idVal = itemData.id
			value = (idVal != null) ? idVal as any : ''
		} else if (key === 'name') {
			const nameVal = itemData.name
			value = (nameVal != null) ? nameVal as any : ''
		} else if (key === 'realname') {
			const realnameVal = itemData.realname
			value = (realnameVal != null) ? realnameVal as any : ''
		} else if (key === 'realName') {
			const realNameVal = itemData.realName
			value = (realNameVal != null) ? realNameVal as any : ''
		} else if (key === 'travellerName') {
			const travellerNameVal = itemData.travellerName
			value = (travellerNameVal != null) ? travellerNameVal as any : ''
		} else if (key === 'phone') {
			const phoneVal = itemData.phone
			value = (phoneVal != null) ? phoneVal as any : ''
		} else if (key === 'phoneNumber') {
			const phoneNumberVal = itemData.phoneNumber
			value = (phoneNumberVal != null) ? phoneNumberVal as any : ''
		} else if (key === 'travellerPhone') {
			const travellerPhoneVal = itemData.travellerPhone
			value = (travellerPhoneVal != null) ? travellerPhoneVal as any : ''
		} else if (key === 'mobile') {
			const mobileVal = itemData.mobile
			value = (mobileVal != null) ? mobileVal as any : ''
		} else if (key === 'is_default') {
			const isDefaultVal = itemData.is_default
			value = (isDefaultVal != null) ? isDefaultVal as any : ''
		} else if (key === 'isDefault') {
			const isDefaultVal = itemData.isDefault
			value = (isDefaultVal != null) ? isDefaultVal as any : ''
		} else if (key === 'defaultFlag') {
			const defaultFlagVal = itemData.defaultFlag
			value = (defaultFlagVal != null) ? defaultFlagVal as any : ''
		} else if (key === 'defaultStatus') {
			const defaultStatusVal = itemData.defaultStatus
			value = (defaultStatusVal != null) ? defaultStatusVal as any : ''
		}
		
		if (value != '') {
			return value.toString()
		}
	} catch (e) {}
	return ''
}

// 日期变化处理
const handleDateChange = (date: string) => {
	chooseDate.value = date
}

// 联系人相关辅助方法
const getContactKey = (item: any, index: number): string => {
	const kid = getItemProp(item, 'kid')
	if (kid != '') return kid
	return index.toString()
}

const getContactName = (item: any): string => {
	const nameVal = getItemProp(item, 'name')
	const realnameVal = getItemProp(item, 'realname')
	const name = (nameVal != '') ? nameVal : realnameVal
	return name
}

const getContactPhone = (item: any): string => {
	const phone = getItemProp(item, 'phone')
	return phone
}

const isContactActive = (item: any): boolean => {
	const name = getContactName(item)
	const phone = getContactPhone(item)
	
	// 安全访问 formData.value 的属性（使用 JSON.parse + 接口类型 + 点访问，避免括号访问）
	// 根据 UTS 规范，脚本中禁止括号访问，使用 JSON.parse + 接口类型 + 点访问
	try {
		const formDataJson = JSON.stringify(formData.value)
		if (formDataJson == '') return false
		
		const formDataParsed = JSON.parse(formDataJson) as any
		
		const formDataValue = formDataParsed as FormDataValue
		const realnameValue = (formDataValue.realname != null) ? formDataValue.realname.toString() : ''
		const phoneValue = (formDataValue.phone != null) ? formDataValue.phone.toString() : ''
		
		// 确保都是字符串类型再比较
		const nameStr = (name != '') ? name : ''
		const phoneStr = (phone != '') ? phone : ''
		
		return realnameValue === nameStr && phoneValue === phoneStr
	} catch (e) {
		return false
	}
}

const isContactDefault = (item: any): boolean => {
	const isDefaultVal = getItemProp(item, 'is_default')
	const isDefaultVal2 = getItemProp(item, 'isDefault')
	const isDefault = (isDefaultVal != '') ? isDefaultVal : isDefaultVal2
	
	// 确保类型一致再比较（String 和 Int 不能直接比较）
	// UTS 中 Number 不能作为构造函数使用，使用 parseInt 或直接与字符串比较
	if (isDefault == '') return false
	
	// 尝试转换为数字比较（使用 parseInt，避免 Number 构造函数）
	try {
		const isDefaultStr = isDefault.toString()
		const isDefaultNum = parseInt(isDefaultStr)
		if (isDefaultNum == 10) return true
	} catch (e) {}
	
	// 或者与字符串比较
	if (isDefault.toString() == '10') return true
	
	return false
}

// 安全获取当前用户kid（使用 loginHelper 可靠版本）
const getUserKid = (): string => {
	// 优先使用 loginHelper 的可靠版本
	const reliableUserId = getCurrentUserIdReliable()
	if (reliableUserId != '') {
		return reliableUserId
	}
	
	// 降级使用 store 导出的函数（避免直接访问 userStore.userInfo）
	const userId = getUserIdFromStore()
	if (userId != '') {
		return userId
	}
	
	return ''
}

// 安全获取 formData.value 的属性（使用 JSON.parse + 接口类型 + 点访问）
// 注意：函数返回类型不能直接使用接口类型（UTS110111163），返回 any 类型
const getFormDataValue = (): any => {
	try {
		const formDataJson = JSON.stringify(formData.value)
		if (formDataJson != '') {
			const formDataParsed = JSON.parse(formDataJson) as any
			return formDataParsed as FormDataValue
		}
	} catch (e) {}
	// 返回默认值（使用 as any 再转接口类型，避免 UTS110111163）
	const defaultRaw = {
		realname: '',
		phone: '',
		serviceHours: 1,
		orderRemarks: '',
		totalMoney: 0,
		cityName: 0
	} as any
	return defaultRaw as FormDataValue
}

// 安全设置 formData.value 的属性（通过整体赋值）
// 注意：UTS 不支持 Partial 工具类型，使用 any 类型，通过 JSON.parse + 接口类型安全访问
const setFormDataValue = (updates: any) => {
	try {
		const currentRaw = getFormDataValue()
		const current = currentRaw as FormDataValue
		
		// 使用 JSON.parse + 接口类型安全访问 updates 的属性（避免直接属性访问错误）
		const updatesJson = JSON.stringify(updates)
		const updatesParsed = (updatesJson != '') 
			? (JSON.parse(updatesJson) as any) as FormDataValue
			: null
		
		// 构建更新后的对象（直接赋值，不使用 as any，避免类型不匹配）
		const updatedRaw = {
			realname: (updatesParsed != null && updatesParsed.realname != null) 
				? updatesParsed.realname 
				: current.realname,
			phone: (updatesParsed != null && updatesParsed.phone != null) 
				? updatesParsed.phone 
				: current.phone,
			serviceHours: (updatesParsed != null && updatesParsed.serviceHours != null) 
				? updatesParsed.serviceHours 
				: current.serviceHours,
			orderRemarks: (updatesParsed != null && updatesParsed.orderRemarks != null) 
				? updatesParsed.orderRemarks 
				: current.orderRemarks,
			totalMoney: (updatesParsed != null && updatesParsed.totalMoney != null) 
				? updatesParsed.totalMoney 
				: current.totalMoney,
			cityName: (updatesParsed != null && updatesParsed.cityName != null) 
				? updatesParsed.cityName 
				: current.cityName
		}
		formData.value = updatedRaw
	} catch (e) {}
}

// 计算属性（需要显式类型参数）
const show = computed<boolean>({
	get: (): boolean => props.show,
	set: (val: boolean) => {
		emit('update:show', val)
	}
})

// 为模板提供 formData 属性的 computed 属性（避免模板中直接访问 formData.value 的属性）
// 格式化后的总金额（供模板使用）
const formattedTotalMoney = computed((): string => {
	try {
		const formDataValueRaw = getFormDataValue()
		const formDataValue = formDataValueRaw as FormDataValue
		const value = (formDataValue.totalMoney != null) ? (formDataValue.totalMoney as number) : 0
		if (isNaN(value)) return '0.00'
		const cents = Math.round(value * 100)
		const absCents = (cents < 0) ? -cents : cents
		const yuan = Math.floor(absCents / 100)
		const fen = absCents % 100
		const fenStr = (fen < 10) ? ('0' + fen.toString()) : fen.toString()
		const result = yuan.toString() + '.' + fenStr
		return (cents < 0) ? ('-' + result) : result
	} catch (e) {
		return '0.00'
	}
})

