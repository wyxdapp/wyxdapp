// 初始化最小日期（4天后）
const initMinDate = () => {
	const nowDate = new Date()
	nowDate.setDate(nowDate.getDate() + 4)
	const nowMonthNum = nowDate.getMonth() + 1
	const nowMon = nowMonthNum < 10 ? ('0' + nowMonthNum.toString()) : nowMonthNum.toString()
	const nowDayNum = nowDate.getDate()
	const nowDay = nowDayNum < 10 ? ('0' + nowDayNum.toString()) : nowDayNum.toString()
	minDate.value = nowDate.getFullYear() + '-' + nowMon + '-' + nowDay
}

// 获取联系人列表
const Get_contact_list = async () => {
	const userKid = getUserKid()
	if (userKid == '') {
		uni.showToast({
			title: '请先登录',
			icon: 'none'
		})
		return
	}
	
	try {
		// 使用 JSON.parse + 接口类型传递参数，避免匿名对象类型错误
		const paramsJson = JSON.stringify({ userKid: userKid })
		const paramsParsed = JSON.parse(paramsJson) as any
		const params = paramsParsed as GetContactListParams
		
		const res = await getContactList(params)
		contactList.value = []
		
		let entitiesSource: Array<any> = []

		// 使用 UTSJSONObject.get() 方法访问属性
		try {
			const resJson = JSON.stringify(res)
			if (resJson != '') {
				const resParsed = JSON.parse(resJson) as UTSJSONObject
				
				// 优先使用 res.data.entities（ContactListData 类型）
				const dataValue = resParsed.get('data')
				if (dataValue != null) {
					const dataObj = dataValue as UTSJSONObject
					const entitiesValue = dataObj.get('entities')
					if (entitiesValue != null && Array.isArray(entitiesValue) == true) {
						const entitiesArr = entitiesValue as Array<any>
						entitiesSource = entitiesArr
					}
				}
				
				// 如果没有 data.entities，使用 res.entities
				if (entitiesSource.length == 0) {
					const entitiesValue = resParsed.get('entities')
					if (entitiesValue != null && Array.isArray(entitiesValue) == true) {
						const entitiesArr = entitiesValue as Array<any>
						entitiesSource = entitiesArr
					}
				}
			}
		} catch (e) {}

		// 确保 entitiesSource 是数组
		if (Array.isArray(entitiesSource) != true) {
			entitiesSource = []
		}
		
		const resultList: Array<any> = []

		for (let i = 0; i < (entitiesSource as Array<any>).length; i++) {
			const item = (entitiesSource as Array<any>)[i]

			const kidValue = (getItemProp(item, 'kid') != null && getItemProp(item, 'kid') != '') 
				? getItemProp(item, 'kid') 
				: getItemProp(item, 'id')
			const nameValueTemp = getItemProp(item, 'name')
			const realnameValue = getItemProp(item, 'realname')
			const realNameValue = getItemProp(item, 'realName')
			const travellerNameValue = getItemProp(item, 'travellerName')

			let nameValue: string = ''
			if (nameValueTemp != null && nameValueTemp != '') {
				nameValue = nameValueTemp
			} else if (realnameValue != null && realnameValue != '') {
				nameValue = realnameValue
			} else if (realNameValue != null && realNameValue != '') {
				nameValue = realNameValue
			} else if (travellerNameValue != null && travellerNameValue != '') {
				nameValue = travellerNameValue
			}

			const phoneValueTemp = getItemProp(item, 'phone')
			const phoneNumberValue = getItemProp(item, 'phoneNumber')
			const travellerPhoneValue = getItemProp(item, 'travellerPhone')
			const mobileValue = getItemProp(item, 'mobile')

			let phoneValue: string = ''
			if (phoneValueTemp != null && phoneValueTemp != '') {
				phoneValue = phoneValueTemp
			} else if (phoneNumberValue != null && phoneNumberValue != '') {
				phoneValue = phoneNumberValue
			} else if (travellerPhoneValue != null && travellerPhoneValue != '') {
				phoneValue = travellerPhoneValue
			} else if (mobileValue != null && mobileValue != '') {
				phoneValue = mobileValue
			}

			const isDefaultRaw1 = getItemProp(item, 'is_default')
			const isDefaultRaw2 = getItemProp(item, 'isDefault')
			const isDefaultRaw3 = getItemProp(item, 'defaultFlag')
			const isDefaultRaw4 = getItemProp(item, 'defaultStatus')

			let flag: string = ''
			if (isDefaultRaw1 != null && isDefaultRaw1 != '') {
				flag = isDefaultRaw1
			} else if (isDefaultRaw2 != null && isDefaultRaw2 != '') {
				flag = isDefaultRaw2
			} else if (isDefaultRaw3 != null && isDefaultRaw3 != '') {
				flag = isDefaultRaw3
			} else if (isDefaultRaw4 != null && isDefaultRaw4 != '') {
				flag = isDefaultRaw4
			}

			const isDefaultNum = (flag != null && flag.toString() == '10') ? 10 : 0

			if (kidValue != null && kidValue.toString() != '' && nameValue != null && nameValue.toString() != '' && phoneValue != null && phoneValue.toString() != '') {
				resultList.push({
					kid: kidValue.toString(),
					name: nameValue.toString(),
					phone: phoneValue.toString(),
					is_default: isDefaultNum
				})
			}
		}

		// 默认联系人排前（使用 JSON.parse + 接口类型 + 点访问，避免括号访问）
		const sortedList: Array<any> = []
		
		// 先添加默认联系人（is_default === 10）
		for (let i = 0; i < resultList.length; i++) {
			const item = resultList[i]
			if (item != null) {
				try {
					// 使用 JSON.parse + 接口类型 + 点访问，避免括号访问（String.get 错误）
					const itemJson = JSON.stringify(item)
					if (itemJson != '') {
						const itemParsed = JSON.parse(itemJson) as any
						const itemData = itemParsed as SubmitOrderContactItem
						const isDefault = itemData.is_default
						
						// 确保类型一致再比较（String/Number 和 Int 不能直接比较）
						if (isDefault != null) {
							// 尝试转换为数字比较
							try {
								const isDefaultStr = isDefault.toString()
								const isDefaultNum = parseInt(isDefaultStr)
								if (isDefaultNum == 10) {
									sortedList.push(item)
								}
							} catch (e) {
								// 或者与字符串比较
								if (isDefault.toString() == '10') {
									sortedList.push(item)
								}
							}
						}
					}
				} catch (e) {}
			}
		}
		
		// 再添加非默认联系人
		for (let i = 0; i < resultList.length; i++) {
			const item = resultList[i]
			if (item != null) {
				try {
					// 使用 JSON.parse + 接口类型 + 点访问，避免括号访问（String.get 错误）
					const itemJson = JSON.stringify(item)
					if (itemJson != '') {
						const itemParsed = JSON.parse(itemJson) as any
						const itemData = itemParsed as SubmitOrderContactItem
						const isDefault = itemData.is_default
						
						// 确保类型一致再比较
						let isDefaultValue = false
						if (isDefault != null) {
							try {
								const isDefaultStr = isDefault.toString()
								const isDefaultNum = parseInt(isDefaultStr)
								if (isDefaultNum == 10) {
									isDefaultValue = true
								}
							} catch (e) {
								if (isDefault.toString() == '10') {
									isDefaultValue = true
								}
							}
						}
						
						// 如果不是默认联系人，添加到列表
						if (isDefaultValue == false) {
							sortedList.push(item)
						}
					}
				} catch (e) {}
			}
		}

		contactList.value = sortedList as any[]
		
		if (contactList.value != null && Array.isArray(contactList.value) == true && (contactList.value as Array<any>).length > 0) {
			const first = (contactList.value as Array<any>)[0]
			const realnameVal = getContactName(first)
			const phoneVal = getContactPhone(first)
			setFormDataValue({
				realname: realnameVal,
				phone: phoneVal
			})
			const kidVal = getItemProp(first, 'kid')
			if (kidVal != null && kidVal.toString() != '') {
				contactId.value = kidVal.toString()
			} else {
				contactId.value = ''
			}
		}
		
		addContactVisity.value = false
	} catch (error) {
		console.error('获取联系人列表失败:', error)
		uni.showToast({
			title: '获取联系人列表失败',
			icon: 'none'
		})
	}
}

// 选择天数变化
const serviceHoursChange = () => {
	const formDataValueRaw = getFormDataValue()
	const formDataValue = formDataValueRaw as FormDataValue
	const hoursVal = formDataValue.serviceHours
	const hoursNum = (hoursVal != null) ? (hoursVal as number) : 0
	const priceNum = serverPrice.value != null ? (serverPrice.value as number) : 0
	setFormDataValue({
		totalMoney: (hoursNum * priceNum) as number
	})
}

// 减少天数
const decreaseDays = () => {
	const formDataValueRaw = getFormDataValue()
	const formDataValue = formDataValueRaw as FormDataValue
	const hoursVal = formDataValue.serviceHours
	const hoursNum = (hoursVal != null) ? (hoursVal as number) : 0
	if (hoursNum > 1) {
		setFormDataValue({
			serviceHours: (hoursNum - 1) as number
		})
		serviceHoursChange()
	}
}

// 增加天数
const increaseDays = () => {
	const formDataValueRaw = getFormDataValue()
	const formDataValue = formDataValueRaw as FormDataValue
	const hoursVal = formDataValue.serviceHours
	const hoursNum = (hoursVal != null) ? (hoursVal as number) : 0
	if (hoursNum < 30) {
		setFormDataValue({
			serviceHours: (hoursNum + 1) as number
		})
		serviceHoursChange()
	}
}

