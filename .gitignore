# uni-app x 项目 .gitignore

# 依赖目录
node_modules/
unpackage/
dist/

# 编译产物
*.class
*.log
*.pyc
*.swp
.DS_Store
*.bak
*.tmp
*.temp

# IDE 配置
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 系统文件
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# 日志文件
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# 环境变量
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# 编辑器目录和文件
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 测试覆盖率
coverage/
*.lcov
.nyc_output

# 缓存文件
.cache/
.temp/
.tmp/

# 构建产物
build/
dist/
out/

# uni-app 特定
unpackage/
.hbuilderx/
.edgeone/
.trae/

# 空测试目录
common/tests/

# 微信小程序
project.config.json
project.private.config.json

# 其他
*.zip
*.rar
*.7z
*.tar
*.gz
