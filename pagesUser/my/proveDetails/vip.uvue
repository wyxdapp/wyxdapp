// 提现
// 🔧 修复 APP 端问题：使用 .then() 处理 Promise
const handleWithdraw = (recordKid: string, method: number) => {
	// #ifdef MP-WEIXIN
	// 微信小程序端不支持提现功能
	uni.showToast({
		title: '微信小程序暂不支持提现功能',
		icon: 'none'
	})
	return
	// #endif
	
	// #ifndef MP-WEIXIN
	// 使用安全方法读取 userKid
	const userKidSafe = getUserKid()
	if (userKidSafe == null || userKidSafe == '') {
		uni.showToast({ title: '请先登录', icon: 'none' })
		return
	}
	
	// 构造参数并显式断言为 HandleCashRewardParams，避免匿名对象类型
	const paramsJson = JSON.stringify({
		userKid: userKidSafe,
		lotteryRecordKid: recordKid,
		actionType: 10,
		withdrawMethod: method
	})
	let paramsParsed: any = ''
	try {
		paramsParsed = (paramsJson != null && paramsJson != '') ? JSON.parse(paramsJson) as any : ''
	} catch (e) {
		console.error('提现参数解析失败:', e)
		uni.showToast({ title: '提现失败，请重试', icon: 'none' })
		return
	}
	if (paramsParsed == null || paramsParsed == '') {
		uni.showToast({ title: '提现失败，请重试', icon: 'none' })
		return
	}
	const params = paramsParsed as UTSJSONObject
	
	handleCashReward(params).then((resultRaw: any) => {
		// 使用 UTSJSONObject 安全读取返回值
		let resObj: UTSJSONObject | null = null
		try {
			const resJson = JSON.stringify(resultRaw)
			if (resJson != null && resJson != '' && resJson != 'null') {
				resObj = JSON.parse(resJson) as UTSJSONObject
			}
		} catch (e) {}
		
		if (resObj == null) {
			uni.showToast({ title: '提现失败', icon: 'none' })
			return
		}
		
		let codeAny: any | null = null
		try { codeAny = resObj.get('code') } catch (e) {}
		
		// 🔧 修复：兼容数字和字符串类型的响应码
		let isSuccess = false
		if (codeAny != null) {
			const codeStr = codeAny.toString()
			isSuccess = (codeStr == '200')
		}
		
		if (isSuccess == true) {
			uni.showToast({ title: '提现申请已提交', icon: 'success' })
			loadLotteryInfo()
		} else {
			let msgAny: any | null = null
			try { msgAny = resObj.get('msg') } catch (e) {}
			let messageAny: any | null = null
			try { messageAny = resObj.get('message') } catch (e) {}
			const msgVal = (msgAny != null && msgAny.toString() != '') ? msgAny.toString() : ((messageAny != null && messageAny.toString() != '') ? messageAny.toString() : '提现失败')
			uni.showToast({ title: msgVal, icon: 'none' })
		}
	}).then((ignore: any) => {}, (error: any) => {
		console.error('提现失败:', error)
		uni.showToast({ title: '提现失败，请重试', icon: 'none' })
	})
	// #endif
}

// 存入余额
// 🔧 修复 APP 端问题：使用 .then() 处理 Promise
const handleDeposit = (recordKid: string) => {
	// 安全读取 userKid
	const userKidSafe2 = getUserKid()
	if (userKidSafe2 == null || userKidSafe2 == '') {
		uni.showToast({ title: '请先登录', icon: 'none' })
		return
	}

	// 构造参数并断言类型
	const paramsJson = JSON.stringify({
		userKid: userKidSafe2,
		lotteryRecordKid: recordKid,
		actionType: 20
	})
	let paramsParsed: any = ''
	try {
		paramsParsed = (paramsJson != null && paramsJson != '') ? JSON.parse(paramsJson) as any : ''
	} catch (e) {
		console.error('存入余额参数解析失败:', e)
		uni.showToast({ title: '存入余额失败，请重试', icon: 'none' })
		return
	}
	if (paramsParsed == null || paramsParsed == '') {
		uni.showToast({ title: '存入余额失败，请重试', icon: 'none' })
		return
	}
	const params = paramsParsed as UTSJSONObject

	handleCashReward(params).then((resultRaw: any) => {
		let resObj: UTSJSONObject | null = null
		try {
			const resJson = JSON.stringify(resultRaw)
			if (resJson != null && resJson != '' && resJson != 'null') {
				resObj = JSON.parse(resJson) as UTSJSONObject
			}
		} catch (e) {}
		
		if (resObj == null) {
			uni.showToast({ title: '存入失败', icon: 'none' })
			return
		}
		
		let codeAny: any | null = null
		try { codeAny = resObj.get('code') } catch (e) {}
		
		// 🔧 修复：兼容数字和字符串类型的响应码
		let isSuccess = false
		if (codeAny != null) {
			const codeStr = codeAny.toString()
			isSuccess = (codeStr == '200')
		}

		if (isSuccess == true) {
			uni.showToast({ title: '已存入余额', icon: 'success' })
			loadLotteryInfo()
		} else {
			let msgAny: any | null = null
			try { msgAny = resObj.get('msg') } catch (e) {}
			let messageAny: any | null = null
			try { messageAny = resObj.get('message') } catch (e) {}
			const msgVal = (msgAny != null && msgAny.toString() != '') ? msgAny.toString() : ((messageAny != null && messageAny.toString() != '') ? messageAny.toString() : '存入失败')
			uni.showToast({ title: msgVal, icon: 'none' })
		}
	}).then((ignore: any) => {}, (error: any) => {
		console.error('存入余额失败:', error)
		uni.showToast({
			title: '存入余额失败，请重试',
			icon: 'none'
		})
	})
}

// 🎯 格式化VIP状态显示
// 本地日期格式化（在文件顶部或被调用处之前可用，避免函数声明顺序问题）
const formatDateLocal = (dateStr: string | Date): string => {
	try {
		if (dateStr == null) return ''
		const date = (typeof dateStr === 'string') ? new Date(dateStr) : dateStr
		const year = date.getFullYear()
		const month = (date.getMonth() + 1).toString().padStart(2, '0')
		const day = (date.getDate()).toString().padStart(2, '0')
		return `${year}-${month}-${day}`
	} catch (e) {}
	return ''
}

const getFormattedVipStatus = (): string => {
	try {
		// 🎯 使用从 API 获取的响应式数据
		const vipVal = userVipValue.value
		const vipExpireTime = userVipExpireTimeValue.value
		const vipType = userVipTypeValue.value
		
		// 🔧 修复：后端 vipType 只有两种：10=月卡，20=年卡
		let typeText = '月卡会员'
		if (vipType == 10) {
			typeText = '月卡会员'
		} else if (vipType == 20) {
			typeText = '年卡会员'
		}
	
		if (vipVal == 20 && vipExpireTime != null && vipExpireTime != '') {
			const dateStr = formatDateLocal(vipExpireTime)
			return `${typeText}${dateStr}到期`
		} else if (vipVal == 20) {
			return `${typeText}已开通`
		} else if (vipVal == 30) {
			return '会员已过期，请尽快续费'
		}
	} catch (e) {}
	return '当前会员状态：未开通'
}

// 格式化日期
const formatDate = (dateStr: string | Date): string => {
	if (dateStr == null) return ''
	const date = typeof dateStr === 'string' ? new Date(dateStr) : dateStr
	const year = date.getFullYear()
	const month = (date.getMonth().toString() + 1).padStart(2, '0')
	const day = (date.getDate().toString()).padStart(2, '0')
	return `${year}-${month}-${day}`
}

// 选择套餐
const selectPackage = (type: string) => {
	selectedPackage.value = type
}

// 启动反馈轮播
const startFeedbackCarousel = () => {
	feedbackTimer = setInterval(() => {
		currentFeedbackIndex.value = (currentFeedbackIndex.value + 1) % feedbackList.value.length
	}, 4000) as any // 每4秒切换一次
}

// 停止反馈轮播
const stopFeedbackCarousel = () => {
	if (feedbackTimer != null) {
		const t = feedbackTimer as number
		try { clearInterval(t) } catch (e) {}
		feedbackTimer = null
	}
}

// 手动切换反馈
const switchFeedback = (index: number) => {
	currentFeedbackIndex.value = index
	// 重新启动定时器
	stopFeedbackCarousel()
	startFeedbackCarousel()
}

// 🎯 初始化页面布局（获取状态栏高度）
const initPageLayout = () => {
	// 使用 composable 初始化布局
	initPageLayoutComposable()
	
	// 注意：pageStatusBarHeight 已由 composable 初始化，无需额外计算
}

// 生命周期：放在函数定义之后，确保所有函数已声明（UTS 要求）
onMounted(() => {
	console.log('[VIP] 页面加载')
	// 🎯 初始化页面布局
	initPageLayout()
	// 🔧 修复：主动调用 initUserInfoAction 确保用户信息被初始化
	initUserInfoAction()
	
	// 🎯 先从 Storage 加载基本信息（立即显示，避免白屏）
	loadUserInfoFromStorage()
	
	// 🎯 等待登录状态初始化后再从 API 加载最新用户信息
	waitForLoginStatus(2000).then((result: number) => {
		console.log('[VIP] 登录状态检查结果:', result)
		if (result == 1) {
			// 🎯 从 API 获取最新用户信息（包括头像、昵称、VIP状态）
			loadUserInfo()
			// 加载抽奖信息
			loadLotteryInfo()
		} else {
			console.log('[VIP] 用户未登录')
		}
	})
	
	// 获取用户信息（已在store中）
	console.log('当前用户信息:', userInfo.value)
	// 启动反馈轮播
	startFeedbackCarousel()
})

// 🎯 页面显示时刷新用户信息（支付成功返回后更新VIP状态）
onShow(() => {
	console.log('[VIP] 页面显示')
	// 🔧 修复 APP 端问题：先从 Storage 加载，确保有数据显示
	loadUserInfoFromStorage()
	
	// 🎯 加载抽奖开关状态
	loadLotterySwitchStatus()
	
	// 🔧 修复 APP 端问题：等待登录状态初始化后再从 API 加载
	waitForLoginStatus(1000).then((result: number) => {
		console.log('[VIP] onShow 登录状态检查结果:', result)
		if (result == 1) {
			// 🔧 修复：强制刷新用户信息，确保VIP状态是最新的（支付成功后返回）
			// 🎯 修复VIP状态不更新问题：刷新后更新Storage并重新加载页面数据
			refreshCurrentUserProfile().then((profile: any) => {
				console.log('[VIP] 用户信息刷新成功')
				if (profile != null) {
					// 🎯 关键修复：更新本地存储中的VIP状态
					const profileJson = JSON.stringify(profile)
					const profileObj = JSON.parse(profileJson) as UTSJSONObject
					updateUserInfoAction(profileObj)
					console.log('[VIP] 已更新Storage中的用户信息')
					
					// 🎯 修复：直接更新页面响应式数据，确保立即显示最新状态
					updateVipDataFromProfile(profile)
					console.log('[VIP] 已直接更新页面响应式数据')
				}
			}).catch((error: any | null): void => {
				console.error('[VIP] 刷新用户信息失败:', error)
			})
		} else {
			console.log('[VIP] onShow 用户未登录')
		}
	})
})

onUnmounted(() => {
	// 清除定时器
	stopFeedbackCarousel()
})

// 创建VIP订单（提前定义，确保在调用前存在）
// 🔧 修复 APP 端问题：使用 .then() 处理 Promise，避免 async/await 在 APP 端的问题
const createVipOrderHandler = () => {
	uni.showLoading({ title: '创建订单中...' })
	console.log('🔍 [VIP] 开始创建VIP订单')
	
	// 安全获取 userKid
	const userKidSafe = getUserKid()
	if (userKidSafe == null || userKidSafe == '') {
		uni.hideLoading()
		uni.showToast({ title: '用户信息不完整，请重新登录', icon: 'none' })
		return
	}
	
	const paramsObj = {
		totalMoney: getCurrentPrice.value,
		userKid: userKidSafe,
		vipType: getVipType.value
	}
	
	console.log('🔍 [VIP] 订单参数:', paramsObj)
	
	// 🔧 修复：使用 .then() 处理 Promise，避免 async/await 在 APP 端的问题
	post('/order/tourist/createVipOrder', paramsObj, true).then((resultRaw: any) => {
		console.log('🔍 [VIP] API响应:', resultRaw)
		uni.hideLoading()

		// 使用 UTSJSONObject 安全读取返回值
		let resObj: UTSJSONObject | null = null
		try {
			const resJson = JSON.stringify(resultRaw)
			if (resJson != null && resJson != '' && resJson != 'null') {
				resObj = JSON.parse(resJson) as UTSJSONObject
			}
		} catch (e) {
			console.error('🔍 [VIP] 响应解析失败:', e)
		}
		
		if (resObj == null) {
			uni.showToast({ title: '订单创建失败，请重试', icon: 'none' })
			return
		}
		
		let codeAny: any | null = null
		try { codeAny = resObj.get('code') } catch (e) {}
		
		// 🔧 修复：兼容数字和字符串类型的响应码
		let isSuccess = false
		if (codeAny != null) {
			const codeStr = codeAny.toString()
			isSuccess = (codeStr == '200')
		}

		if (isSuccess == true) {
			let orderAny: any | null = null
			try { orderAny = resObj.get('data') } catch (e) {}
			console.log('🔍 [VIP] 订单创建成功，跳转支付页面:', orderAny)
			
			if (orderAny != null) {
				// 🔧 修复：安全获取订单 kid
				let orderKid = ''
				try {
					const orderJson = JSON.stringify(orderAny)
					if (orderJson != null && orderJson != '' && orderJson != 'null') {
						const orderObj = JSON.parse(orderJson) as UTSJSONObject
						const kidVal = orderObj.get('kid')
						if (kidVal != null && kidVal.toString() != '') {
							orderKid = kidVal.toString()
						}
					}
				} catch (e) {
					console.error('🔍 [VIP] 订单数据解析失败:', e)
				}
				
				if (orderKid != '') {
					console.log('🔍 [VIP] 跳转支付页面, orderKid:', orderKid)
					const payUrl = '/pagesTrade/payment/payOrder/index?orderKid=' + orderKid
					uni.navigateTo({ 
						url: payUrl,
						success: () => {
							console.log('🔍 [VIP] 跳转支付页面成功')
						},
						fail: (err: any) => {
							console.error('🔍 [VIP] 跳转支付页面失败:', err)
							uni.showToast({ title: '跳转支付页面失败', icon: 'none' })
						}
					})
				} else {
					console.error('🔍 [VIP] 订单 kid 为空')
					uni.showToast({ title: '订单创建异常，请重试', icon: 'none' })
				}
			} else {
				console.error('🔍 [VIP] 订单数据为空')
				uni.showToast({ title: '订单创建异常，请重试', icon: 'none' })
			}
		} else {
			console.error('🔍 [VIP] 订单创建失败:', resultRaw)
			let msgAny: any | null = null
			try { msgAny = resObj.get('msg') } catch (e) {}
			let messageAny: any | null = null
			try { messageAny = resObj.get('message') } catch (e) {}
			const msgVal = (msgAny != null && msgAny.toString() != '') ? msgAny.toString() : ((messageAny != null && messageAny.toString() != '') ? messageAny.toString() : '订单创建失败')
			uni.showToast({ title: msgVal, icon: 'none' })
		}
	}).then((ignore: any) => {}, (error: any) => {
		console.error('创建VIP订单失败:', error)
		uni.hideLoading()
		uni.showToast({ title: '订单创建失败，请重试', icon: 'none' })
	})
}

// 确认购买
const confirmPurchase = () => {
	if (selectedPackage.value == null || selectedPackage.value.toString() == '') {
		uni.showToast({
			title: '请选择会员套餐',
			icon: 'none'
		})
		return
	}

	const kid = getUserKid()
	if (kid == null || kid == '') {
		uni.showToast({
			title: '用户信息不完整，请重新登录',
			icon: 'none'
		})
		return
	}

	// 直接创建订单并跳转支付页面
	createVipOrderHandler()
}

// （已在上方定义 createVipOrderHandler）

