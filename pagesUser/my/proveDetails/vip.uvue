		imageUrl: DEFAULT_SHARE_IMAGE_LOCAL
	}
})

onShareTimeline((): UTSJSONObject => {
	return {
		title: '网约向导 - 开通会员，尊享专属特权',
		query: '',
		imageUrl: DEFAULT_SHARE_IMAGE_LOCAL
	}
})
// #endif
</script>

