<template>
	<view class="vip-auth-page">
		<!-- 渐变背景 -->
		<view class="hear-bg" :style="headerGradientOuter()"><view class="hear-bg-mask" :style="headerGradientMask()"></view></view>
		<!-- #ifndef H5 -->
		<!-- APP端导航栏 -->
		<view class="nav-bar" :style="{ paddingTop: pageStatusBarHeight + 'px' }">
			<view class="nav-content">
				<view class="nav-back" @click="handleBack">
					<uni-icons type="left" size="22" color="#333333"></uni-icons>
				</view>
				<text class="nav-title">会员认证</text>
				<view class="nav-placeholder"></view>
			</view>
		</view>
		<!-- #endif -->
		
		<!-- 内容区域 -->
		<view class="content-area">

		<!-- 🎯 用户信息卡片 -->
		<view class="user-info-card">
			<!-- 用户头像 -->
			<view class="user-avatar-section">
				<Avatar 
					:url="userAvatar"
					size="large"
					:customSize="120"
					clickMode="none"
				/>
			</view>
			
			<!-- 用户信息 - 昵称和会员状态 -->
			<view class="user-info-section">
				<!-- 🎯 修复：使用 NicknameWithBadges 组件显示昵称+会员图标 -->
				<NicknameWithBadges
					:nickname="userNickname"
					:vipType="userVipTypeForBadge"
					:giftLevel="0"
					size="large"
				/>
				<text class="user-vip-status">{{ getFormattedVipStatus() }}</text>
			</view>
			
			<!-- 🎯 抽奖按钮（根据开关状态显示） -->
			<view class="lottery-btn-section" v-if="lotteryEnabled == true">
				<view class="lottery-btn" @click="handleLottery">
					<text class="lottery-text">抽奖</text>
				</view>
			</view>
		</view>

		<!-- 会员套餐选择 -->
		<view class="package-section">
			<text class="section-title">选择会员套餐</text>
			<text class="section-subtitle">立即开通，尊享专属特权</text>
			
			<view class="package-grid">
				<!-- 月卡会员 -->
				<view class="package-card" :class="{ 'selected': selectedPackage === 'month' }" @click="selectPackage('month')">
					<view class="package-ribbon experience" v-if="selectedPackage === 'month'">
						<text class="ribbon-text">体验</text>
					</view>
					<view class="package-header">
						<text class="package-name">月卡会员</text>
						<text class="package-period">1个月</text>
					</view>
					<view class="package-price-section">
						<view class="price-row">
							<text class="currency">¥</text>
							<text class="price-main">30</text>
							<text class="price-unit">/月</text>
						</view>
						<text class="original-price">原价¥59</text>
					</view>
						<view class="package-features">
							<text class="feature-item">• 联系方式查看</text>
							<text class="feature-item">• 会员认证标识</text>
							<text class="feature-item">• 专属客服服务</text>
					</view>
				</view>

				<!-- 年卡会员 -->
				<view class="package-card yearly" :class="{ 'selected': selectedPackage === 'year' }" @click="selectPackage('year')">
					<view class="package-ribbon recommended">
						<text class="ribbon-text">推荐</text>
					</view>
					<view class="package-header">
						<text class="package-name">年卡会员</text>
						<text class="package-period">12个月</text>
					</view>
					<view class="package-price-section">
						<view class="price-row">
							<text class="currency">¥</text>
							<text class="price-main">298</text>
							<text class="price-unit">/年</text>
						</view>
						<text class="original-price">原价¥708</text>
						<view class="discount-tag">
							<text class="discount-text">省410元</text>
						</view>
					</view>
					<view class="package-features">
						<text class="feature-item">• 包含月卡所有权益</text>
						<text class="feature-item">• 向导 官方精选认证</text>
						<text class="feature-item">• 运营 签约抽佣特权</text>
					</view>
				</view>
			</view>
		</view>

		<!-- 用户反馈轮播区域 -->
		<view class="feedback-section">
			<view class="feedback-carousel">
				<view class="feedback-wrapper">
					<view 
						class="feedback-item" 
						v-for="(feedback, index) in feedbackList" 
						:key="index"
						:class="{ 'active': index === currentFeedbackIndex }"
					>
						<view class="feedback-content">
							<UniIcons type="chatbubble" :size="60" color="#CCCCCC" />
							<text class="feedback-text">{{ feedback }}</text>
						</view>
					</view>
				</view>
				<view class="feedback-dots">
					<view 
						v-for="(item, index) in feedbackList" 
						:key="index"
						class="dot" 
						:class="{ 'active': index === currentFeedbackIndex }"
						@click="switchFeedback(index)"
					></view>
				</view>
			</view>
		</view>

		<!-- 底部固定区域 -->
		<view class="footer-section">
			<view class="price-summary">
				<view class="price-info">
					<text class="total-label">会员价格: </text>
					<text class="total-price">¥{{ getCurrentPrice }}</text>
					<text class="price-note">{{ selectedPackage === 'year' ? '平均¥25/月' : '首月特惠' }}</text>
				</view>
			</view>
		<view class="pay-btn" @click="confirmPurchase" :class="{ 'disabled': isPackageDisabled }">
				<text class="btn-text">立即开通</text>
			</view>
		</view>
		
		<!-- 抽奖弹窗 -->
			<LotteryModal
			:show="showLotteryModal"
			:userKid="userKid"
			:freeCount="lotteryFreeCount"
			:maxFreeCount="lotteryMaxFreeCount"
			:luckyPoints="lotteryLuckyPoints"
			@close="showLotteryModal = false"
			@lotterySuccess="handleLotterySuccess"
		/>
		
		<!-- 抽奖结果弹窗 -->
		<LotteryResult
			:show="showLotteryResult"
			:userKid="userKid"
			:reward="lotteryReward"
			:canDirectWithdraw="true"
			@close="showLotteryResult = false"
			@useGift="handleUseGift"
			@withdraw="handleWithdraw"
			@deposit="handleDeposit"
			@viewGiftBox="handleViewGiftBox"
		/>
		
		<!-- 礼物盒弹窗 -->
		<GiftBox
			:show="showGiftBox"
			:userKid="userKid"
			@close="showGiftBox = false"
			@sendGift="handleSendGiftFromBox"
		/>
	</view>
	</view>
</template>

<script setup lang="uts">
import { ref, computed, onMounted, onUnmounted } from 'vue'
import { onShow } from '@dcloudio/uni-app'
// #ifdef MP-WEIXIN
import { onShareAppMessage, onShareTimeline } from '@dcloudio/uni-app'
// #endif
import { headerGradientOuter, headerGradientMask } from '@/common/utils/themeHelper.uts'
import { useUserStore, initUserInfoAction, getUserAvatar, getUserNickname, getUserVipStatus, getUserVipExpireTime, getUserNumberProp, updateUserInfoAction } from '@/stores/user.uts'
import { DEFAULT_AVATAR_LOCAL, DEFAULT_SHARE_IMAGE_LOCAL } from '@/common/config/defaultImages.uts'
import { 
	pageStatusBarHeight, 
	initPageLayout as initPageLayoutComposable 
} from '@/common/composables/usePageLayout.uts'
import UniIcons from '@/components/base/UniIcons.uvue'
import Avatar from '@/components/base/Avatar.uvue'
import NicknameWithBadges from '@/components/base/NicknameWithBadges.uvue'
import LotteryModal from '@/components/lottery/LotteryModal.uvue'
import LotteryResult from '@/components/lottery/LotteryResult.uvue'
import GiftBox from '@/components/lottery/GiftBox.uvue'
import request from '@/utils/request'
import { post } from '@/utils/request'
import { getLotteryInfo } from '@/common/services/lotteryService'
import { useGift, handleCashReward } from '@/common/services/lotteryService'
import { getLotterySwitchStatus } from '@/api/lottery.uts'
import { requestUserHomePage, type QueryUserHomePageParams } from '@/common/services/userProfileApi.uts'
import { 
	checkUserLoginReliable, 
	getCurrentUserIdReliable,
	waitForLoginStatus
} from '@/common/utils/loginHelper.uts'
// 🎯 导入统一的用户信息缓存
import { 
	getCurrentUserProfile, 
	getCurrentUserVipStatus, 
	refreshCurrentUserProfile,
	hasValidCache
} from '@/common/composables/useCurrentUserProfile.uts'

const userStore = useUserStore()

// 辅助函数 - 获取用户ID（使用 loginHelper 可靠版本）
const getUserKidFromStoreVip = (): string => {
	return getCurrentUserIdReliable()
}

// 辅助函数 - 检查登录状态（使用 loginHelper 可靠版本）
const checkIsLoginVip = (): boolean => {
	return checkUserLoginReliable()
}

// 🎯 用户信息响应式状态（从 API 获取最新数据）
const userAvatarValue = ref<string>(DEFAULT_AVATAR_LOCAL)
const userNicknameValue = ref<string>('用户')
const userVipValue = ref<number>(10)
const userGiftLevelValue = ref<number>(0)

// 🎯 抽奖开关状态
const lotteryEnabled = ref<boolean>(false)
const userVipExpireTimeValue = ref<string>('')
const userVipTypeValue = ref<number>(0)

// 类型：userInfo 中我们需要的字段（局部，不导出，避免与其他文件冲突）
interface VipUserInfoData {
	vip?: number | string | null
	vipExpireTime?: string | null
	vipType?: string | null
	avatar?: string | null
	nickname?: string | null
	image?: string | null
}

// 类型：VIP 状态对象（避免直接访问 any 类型的属性）
interface VipStatusData {
	vip?: number | null
	vipExpireTime?: string | null
	vipType?: number | null
	isVip?: boolean | null
}

// 本文件局部类型：storage 中可能的 userInfo 结构（避免匿名对象字面量）
interface LocalUserKid {
	kid?: string | null
}

// 本文件局部类型：通用解析对象（避免直接对 any 使用动态访问）
interface LocalParsedCommon {
	rewards?: Array<any> | null
	kid?: string | null
	data?: any | null
}

// 本地订单类型
interface LocalOrder {
	kid?: string | null
}

// 安全读取对象字段，返回空字符串作为默认值（避免 null 给 Any）
const getInfoProp = (obj: any, key: string): any => {
	try {
		const json = JSON.stringify(obj)
		if (json == null || json == '') return ''
		const parsed = JSON.parse(json) as VipUserInfoData
		if (parsed == null) return ''
		if (key === 'vip') {
			return (parsed.vip != null) ? (parsed.vip as any) : ''
		}
		if (key === 'vipExpireTime') {
			return (parsed.vipExpireTime != null) ? (parsed.vipExpireTime as any) : ''
		}
		if (key === 'vipType') {
			return (parsed.vipType != null) ? (parsed.vipType as any) : ''
		}
		if (key === 'avatar') {
			// 优先使用 avatar，其次使用 image
			if (parsed.avatar != null && parsed.avatar != '') {
				return (parsed.avatar as any)
			}
			if (parsed.image != null && parsed.image != '') {
				return (parsed.image as any)
			}
			return ''
		}
		if (key === 'nickname') {
			return (parsed.nickname != null) ? (parsed.nickname as any) : ''
		}
	} catch (e) {}
	return ''
}

// 通用安全读取属性，避免直接点访问触发 error18
const safeGetProp = (obj: any, key: string): any => {
	try {
		const json = JSON.stringify(obj)
		if (json == null || json == '') return ''
		const parsed = JSON.parse(json) as LocalParsedCommon
		if (parsed == null) return ''
		// 明确列出常用字段（使用接口类型的点访问，避免 String.get 问题）
		if (key === 'rewards') {
			// 使用序列化/反序列化将具体值转换为 Any，避免类型不匹配
			try {
				const r = (parsed.rewards != null) ? parsed.rewards : []
				const rJson = JSON.stringify(r)
				if (rJson != null && rJson != '') {
					let parsedRTemp: any = ''
					try {
						parsedRTemp = JSON.parse(rJson) as any
					} catch (e) {}
					if (parsedRTemp != null && parsedRTemp != '') return parsedRTemp
				}
				return (JSON.parse('[]') as any)
			} catch (e) {
				return (JSON.parse('[]') as any)
			}
		}
		if (key === 'kid') {
			try {
				const k = (parsed.kid != null) ? parsed.kid : ''
				const kStr = (k != null) ? k.toString() : ''
				return (kStr != null) ? (kStr as any) : ('' as any)
			} catch (e) {
				return ('' as any)
			}
		}
		// 回退：尝试 data 字段中查找（通过序列化/解析再点访问，避免 String.get）
		if (parsed.data != null) {
			try {
				const dataJson = JSON.stringify(parsed.data)
				if (dataJson != null && dataJson != '') {
					const dataParsed = JSON.parse(dataJson) as LocalParsedCommon
					if (key === 'rewards' && dataParsed.rewards != null) return dataParsed.rewards as any
					if (key === 'kid' && dataParsed.kid != null) return dataParsed.kid as any
				}
			} catch (e) {}
		}
	} catch (e) {}
	return ''
}

// 安全获取 userInfo.kid（使用统一的 store 导出函数）
const getUserKid = (): string => {
	return getUserKidFromStoreVip()
}

// 响应式数据
const selectedPackage = ref('year') // 默认选择年卡
const currentFeedbackIndex = ref(0)
let feedbackTimer: any | null = null

// 是否禁用购买按钮（模板中使用，避免使用 !selectedPackage）
const isPackageDisabled = computed((): boolean => {
	try {
		return (selectedPackage.value == null || selectedPackage.value.toString() === '')
	} catch (e) {}
	return true
})

// 抽奖相关
const showLotteryModal = ref(false)
const showLotteryResult = ref(false)
const showGiftBox = ref(false)
// 明确指定可空 any 类型，避免 ref 泛型推断歧义
const lotteryInfo = ref<any | null>(null)
const lotteryReward = ref<any | null>(null)

// 反馈列表
const feedbackList = ref([
	'开通会员后，能直接联系向导，安排行程更方便了！服务质量大幅提升，出行体验更好！',
	'专属客服很贴心，有问题马上就能解决，体验很棒！24小时在线，响应迅速！',
	'开通年卡会员后，向导通过官方认证更权威，更有信任感，咨询联系更多了！',
	'很棒！开通年卡运营权限后，经常可以派单赚介绍佣金！收入增加了不少！',
	'会员认证标识让我在平台上更显专业，客户更信任，订单量明显增加！',
	'精选推荐功能真的很实用，我的向导服务获得了更多曝光机会！'
])

// 计算属性
// 使用统一的 store 导出函数获取用户信息
const userInfo = computed((): any => {
	try {
		const userId = getUserKidFromStoreVip()
		if (userId == '') return {} as any
		
		// 从 storage 读取完整用户信息（用于获取 vip 等字段）
		const storage = uni.getStorageSync('userInfo')
		const storageJson = (storage != null && storage != '') ? JSON.stringify(storage) : ''
		if (storageJson == null || storageJson == '') return {} as any
		const parsed = JSON.parse(storageJson) as any
		if (parsed != null) return parsed
	} catch (e) {}
	return {} as any
})

// 模板友好的字段（使用响应式 ref，从 API 获取最新数据）
const userAvatar = computed((): string => {
	return userAvatarValue.value
})

const userNickname = computed((): string => {
	return userNicknameValue.value
})

// 模板友好：userKid 与 lottery info 显示字段
const userKid = computed((): string => {
	try {
		return getUserKid()
	} catch (e) {}
	return ''
})

const lotteryFreeCount = computed((): number => {
	try {
		const v = safeGetProp((lotteryInfo.value != null) ? (lotteryInfo.value as any) : ('' as any), 'freeCount')
		if (v != null && v != '') return parseInt(v.toString())
	} catch (e) {}
	return 0
})

const lotteryMaxFreeCount = computed((): number => {
	try {
		const v = safeGetProp((lotteryInfo.value != null) ? (lotteryInfo.value as any) : ('' as any), 'maxFreeCount')
		if (v != null && v != '') return parseInt(v.toString())
	} catch (e) {}
	return 1
})

const lotteryLuckyPoints = computed((): number => {
	try {
		const v = safeGetProp((lotteryInfo.value != null) ? (lotteryInfo.value as any) : ('' as any), 'luckyPoints')
		if (v != null && v != '') return parseInt(v.toString())
	} catch (e) {}
	return 0
})

// 统一 VIP 状态：10 未开通, 20 已开通, 30 已过期
const vipStatus = computed((): number => {
	try {
		// 🎯 使用从 API 获取的响应式数据
		const vipVal = userVipValue.value
		const expireVal = userVipExpireTimeValue.value

		let resolved = vipVal
		if (expireVal != null && expireVal != '') {
			try {
				const expireDate: Date = new Date(expireVal)
				const now: Date = new Date()
				if (expireDate.getTime() <= now.getTime()) {
					resolved = 30
				} else if (resolved != 10) {
					resolved = 20
				}
			} catch (e) {}
		}
		return resolved
	} catch (e) {}
	return 10
})

// 🎯 新增：用于 NicknameWithBadges 组件的 VIP 类型
// 返回 'year' | 'normal' | ''
const userVipTypeForBadge = computed((): string => {
	// 只有 VIP 状态为已开通(20)时才显示图标
	if (vipStatus.value != 20) return ''
	
	// 🔧 修复：后端 vipType 只有两种：10=月卡，20=年卡
	const vipTypeNum = userVipTypeValue.value
	if (vipTypeNum == 20) return 'year'
	if (vipTypeNum == 10) return 'normal'
	// 如果 vipType 未知但 VIP 已开通，默认显示普通会员图标
	return 'normal'
})

const getCurrentPrice = computed(() => {
	return selectedPackage.value === 'month' ? 30 : 298
})

const getVipType = computed(() => {
	return selectedPackage.value === 'month' ? '10' : '20'
})

const getVipStatusBarText = (): string => {
	const status = vipStatus.value
	// 🎯 使用从 API 获取的响应式数据
	const expireTime = userVipExpireTimeValue.value
	if (status == 20) {
		const dateStr = (expireTime != null && expireTime != '') ? formatDate(expireTime) : ''
		return dateStr != ''
			? `当前会员状态：已开通，有效期至：${dateStr}`
			: '当前会员状态：已开通'
	}
	if (status == 30) {
		return '当前会员状态：已过期，请尽快续费'
	}
	// 🎯 按照用户要求，未开通状态显示固定文本
	return '当前会员状态：未开通'
}

// 生命周期（实际 onMounted/onUnmounted 将在文件末尾，确保函数定义在前）

// 方法
// 返回按钮处理
const handleBack = () => {
	uni.navigateBack({
		delta: 1,
		fail: () => {
			uni.navigateTo({ url: '/packageA/my/proveDetails/index' })
		}
	})
}

// 🎯 加载抽奖开关状态
const loadLotterySwitchStatus = () => {
	getLotterySwitchStatus().then((res: any) => {
		console.log('[VIP] 抽奖开关状态响应:', res)
		
		if (res == null) {
			// 默认显示按钮（降级策略）
			lotteryEnabled.value = true
			return
		}
		
		// 安全解析响应
		let resObj: UTSJSONObject | null = null
		try {
			const resJson = JSON.stringify(res)
			if (resJson != null && resJson != '' && resJson != 'null') {
				resObj = JSON.parse(resJson) as UTSJSONObject
			}
		} catch (e) {
			console.error('[VIP] 解析抽奖开关响应失败:', e)
			lotteryEnabled.value = true
			return
		}
		
		if (resObj == null) {
			lotteryEnabled.value = true
			return
		}
		
		// 获取响应码
		let codeAny: any | null = ''
		try { codeAny = resObj.get('code') } catch (e) {}
		
		// 兼容数字和字符串类型的响应码
		let isSuccess = false
		if (codeAny != null) {
			if (typeof codeAny == 'number') {
				const codeNum = codeAny as number
				isSuccess = (codeNum == 200)
			} else {
				const codeStr = codeAny.toString()
				isSuccess = (codeStr == '200')
			}
		}
		
		if (isSuccess == true) {
			let dataAny: any | null = ''
			try { dataAny = resObj.get('data') } catch (e) {}
			
			if (dataAny != null) {
				let dataObj: UTSJSONObject | null = null
				try {
					const dataJson = JSON.stringify(dataAny)
					if (dataJson != null && dataJson != '' && dataJson != 'null') {
						dataObj = JSON.parse(dataJson) as UTSJSONObject
					}
				} catch (e) {}
				
				if (dataObj != null) {
					let enabledAny: any | null = ''
					try { enabledAny = dataObj.get('enabled') } catch (e) {}
					
					if (enabledAny != null) {
						// 兼容布尔值和字符串
						if (typeof enabledAny == 'boolean') {
							lotteryEnabled.value = (enabledAny as boolean)
						} else {
							const enabledStr = enabledAny.toString().toLowerCase()
							lotteryEnabled.value = (enabledStr == 'true')
						}
					} else {
						lotteryEnabled.value = true
					}
				} else {
					lotteryEnabled.value = true
				}
			} else {
				lotteryEnabled.value = true
			}
		} else {
			// API 失败时默认显示按钮
			lotteryEnabled.value = true
		}
		
		console.log('[VIP] 抽奖开关状态:', lotteryEnabled.value)
	}).catch((error: any | null): void => {
		console.error('[VIP] 加载抽奖开关状态失败:', error)
		// 失败时默认显示按钮（降级策略）
		lotteryEnabled.value = true
	})
}

// 🎯 抽奖功能 - 跳转到抽奖页面
const handleLottery = () => {
	const kid = getUserKid()
	if (kid == null || kid == '') {
		uni.showToast({
			title: '请先登录',
			icon: 'none'
		})
		return
	}
	
	// 跳转到抽奖页面
	uni.navigateTo({
		url: '/pagesUser/my/proveDetails/lottery'
	})
}

// 🎯 修复：直接从 profile 对象更新 VIP 响应式数据
// 这样可以确保支付成功后返回时，页面立即显示最新的 VIP 状态
const updateVipDataFromProfile = (profile: any) => {
	if (profile == null) return
	
	let profileObj: UTSJSONObject | null = null
	try {
		const profileJson = JSON.stringify(profile)
		if (profileJson != null && profileJson != '' && profileJson != 'null') {
			profileObj = JSON.parse(profileJson) as UTSJSONObject
		}
	} catch (e) {
		console.error('[VIP] updateVipDataFromProfile - 解析 profile 失败:', e)
		return
	}
	
	if (profileObj == null) return
	
	// 更新头像
	let imageVal: any | null = null
	try { imageVal = profileObj.get('image') } catch (e) {}
	let avatarVal: any | null = null
	try { avatarVal = profileObj.get('avatar') } catch (e) {}
	
	const imageStr = (imageVal != null && imageVal.toString() != '') ? imageVal.toString() : ''
	const avatarStr = (avatarVal != null && avatarVal.toString() != '') ? avatarVal.toString() : ''
	
	if (imageStr != '') {
		userAvatarValue.value = imageStr
	} else if (avatarStr != '') {
		userAvatarValue.value = avatarStr
	}
	
	// 更新昵称
	let nicknameVal: any | null = null
	try { nicknameVal = profileObj.get('nickname') } catch (e) {}
	if (nicknameVal != null && nicknameVal.toString() != '') {
		userNicknameValue.value = nicknameVal.toString()
	}
	
	// 更新 VIP 状态
	let vipVal: any | null = null
	try { vipVal = profileObj.get('vip') } catch (e) {}
	if (vipVal != null) {
		const vipNum = parseInt(vipVal.toString())
		if (isNaN(vipNum) == false) {
			userVipValue.value = vipNum
			console.log('[VIP] updateVipDataFromProfile - VIP状态更新为:', vipNum)
		}
	}
	
	// 更新 VIP 到期时间
	let vipExpireVal: any | null = null
	try { vipExpireVal = profileObj.get('vipExpireTime') } catch (e) {}
	if (vipExpireVal != null && vipExpireVal.toString() != '') {
		userVipExpireTimeValue.value = vipExpireVal.toString()
		console.log('[VIP] updateVipDataFromProfile - VIP到期时间更新为:', userVipExpireTimeValue.value)
	}
	
	// 更新 VIP 类型
	let vipTypeVal: any | null = null
	try { vipTypeVal = profileObj.get('vipType') } catch (e) {}
	if (vipTypeVal != null) {
		const vipTypeNum = parseInt(vipTypeVal.toString())
		if (isNaN(vipTypeNum) == false) {
			userVipTypeValue.value = vipTypeNum
			console.log('[VIP] updateVipDataFromProfile - VIP类型更新为:', vipTypeNum)
		}
	}
	
	console.log('[VIP] updateVipDataFromProfile - 完成，VIP状态:', userVipValue.value, '到期时间:', userVipExpireTimeValue.value, '类型:', userVipTypeValue.value)
}

// 🎯 从 Storage 加载用户基本信息（作为降级方案）
// 注意：此函数必须在 loadUserInfo 之前定义，因为 UTS 没有函数提升
// 🔧 修复 APP 端问题：优先从 store 导出函数获取数据（与"我的"页面保持一致）
const loadUserInfoFromStorage = () => {
	try {
		// 🔧 修复 APP 端问题：优先从 store 的导出函数获取（更可靠）
		// 这与"我的"页面的实现保持一致
		const storeUserId = getUserKidFromStoreVip()
		const storeNickname = getUserNickname()
		const storeAvatar = getUserAvatar()
		const storeVipStatus = getUserVipStatus()
		const storeVipExpireTime = getUserVipExpireTime()
		const storeVipType = getUserNumberProp('vipType')
		
		// 如果 store 中有有效数据，直接使用
		if (storeUserId != null && storeUserId != '') {
			// 设置昵称
			if (storeNickname != null && storeNickname != '') {
				userNicknameValue.value = storeNickname
			}
			
			// 设置头像
			if (storeAvatar != null && storeAvatar != '') {
				userAvatarValue.value = storeAvatar
			}
			
			// 设置 VIP 状态
			userVipValue.value = storeVipStatus
			
			// 设置 VIP 到期时间
			if (storeVipExpireTime != null && storeVipExpireTime != '') {
				userVipExpireTimeValue.value = storeVipExpireTime
			}
			
			// 设置 VIP 类型
			userVipTypeValue.value = storeVipType
			
			return
		}
		
		// 备用方案：直接从 storage 读取
		const storage = uni.getStorageSync('userInfo')
		
		if (storage == null) {
			return
		}
		
		// 🔧 修复：处理不同类型的 storage 数据
		let storageJson = ''
		if (typeof storage === 'string') {
			storageJson = storage as string
		} else {
			try {
				storageJson = JSON.stringify(storage)
			} catch (e) {
				console.error('[VIP] Storage 数据序列化失败:', e)
				return
			}
		}
		
		if (storageJson == '' || storageJson == 'null' || storageJson == '{}') {
			return
		}
		
		let storageObj: UTSJSONObject | null = null
		try {
			storageObj = JSON.parse(storageJson) as UTSJSONObject
			
			// 🔧 修复 APP 端问题：如果解析结果是字符串，说明存储的是双重序列化的数据，需要再次解析
			if (typeof storageObj === 'string') {
				console.log('[VIP] Storage 数据是双重序列化，进行二次解析')
				const innerJson = storageObj as string
				if (innerJson != '' && innerJson != 'null') {
					storageObj = JSON.parse(innerJson) as UTSJSONObject
				}
			}
		} catch (e) {
			console.error('[VIP] Storage JSON 解析失败:', e)
			return
		}
		
		if (storageObj == null) {
			console.log('[VIP] Storage 对象为空')
			return
		}
		
		// 获取头像 - 🔧 修复：优先使用 image 字段（与后端 UserHomePageVO 一致）
		let imageVal: any | null = null
		try { imageVal = storageObj.get('image') } catch (e) {}
		let avatarVal: any | null = null
		try { avatarVal = storageObj.get('avatar') } catch (e) {}
		
		const imageStr = (imageVal != null && imageVal.toString() != '') ? imageVal.toString() : ''
		const avatarStr = (avatarVal != null && avatarVal.toString() != '') ? avatarVal.toString() : ''
		
		// 🔧 修复：优先使用 image 字段（后端返回的是 image）
		if (imageStr != '') {
			userAvatarValue.value = imageStr
			console.log('[VIP] Storage 设置头像(image):', imageStr)
		} else if (avatarStr != '') {
			userAvatarValue.value = avatarStr
			console.log('[VIP] Storage 设置头像(avatar):', avatarStr)
		}
		console.log('[VIP] Storage 用户头像:', userAvatarValue.value)
		
		// 获取昵称
		let nicknameVal: any | null = null
		try { nicknameVal = storageObj.get('nickname') } catch (e) {}
		let nickNameVal: any | null = null
		try { nickNameVal = storageObj.get('nickName') } catch (e) {}
		
		const nicknameStr = (nicknameVal != null && nicknameVal.toString() != '') ? nicknameVal.toString() : ''
		const nickNameStr = (nickNameVal != null && nickNameVal.toString() != '') ? nickNameVal.toString() : ''
		
		if (nicknameStr != '') {
			userNicknameValue.value = nicknameStr
		} else if (nickNameStr != '') {
			userNicknameValue.value = nickNameStr
		}
		console.log('[VIP] Storage 用户昵称:', userNicknameValue.value)
		
		// 获取 VIP 状态
		let vipVal: any | null = null
		try { vipVal = storageObj.get('vip') } catch (e) {}
		const vipNum = (vipVal != null && vipVal.toString() != '') ? parseInt(vipVal.toString()) : 10
		userVipValue.value = isNaN(vipNum) == false ? vipNum : 10
		console.log('[VIP] Storage VIP状态:', userVipValue.value)
		
		// 获取 VIP 到期时间
		let vipExpireVal: any | null = null
		try { vipExpireVal = storageObj.get('vipExpireTime') } catch (e) {}
		const vipExpireStr = (vipExpireVal != null && vipExpireVal.toString() != '') ? vipExpireVal.toString() : ''
		userVipExpireTimeValue.value = vipExpireStr
		console.log('[VIP] Storage VIP到期时间:', userVipExpireTimeValue.value)
		
		// 获取 VIP 类型
		let vipTypeVal: any | null = null
		try { vipTypeVal = storageObj.get('vipType') } catch (e) {}
		const vipTypeNum = (vipTypeVal != null && vipTypeVal.toString() != '') ? parseInt(vipTypeVal.toString()) : 0
		userVipTypeValue.value = isNaN(vipTypeNum) == false ? vipTypeNum : 0
		console.log('[VIP] Storage VIP类型:', userVipTypeValue.value)
		
		console.log('[VIP] Storage 加载完成')
	} catch (e) {
		console.error('[VIP] 从 Storage 加载用户信息失败:', e)
	}
}

// 🎯 加载用户信息（从统一缓存获取，复用登录时预加载的数据）
// 🔧 修复 APP 端问题：使用回调模式处理 API 响应，避免 async/await 在 APP 端的问题
const loadUserInfo = () => {
	const kid = getUserKid()
	if (kid == null || kid == '') {
		console.log('[VIP] 用户未登录，无法加载用户信息')
		return
	}
	
	console.log('[VIP] 开始加载用户信息, kid:', kid)
	
	// 🎯 使用统一的用户信息缓存（复用登录时预加载的数据）
	getCurrentUserProfile(false).then((profile: any) => {
		console.log('[VIP] 缓存响应:', profile)
		
		if (profile == null) {
			console.error('[VIP] 缓存响应为空')
			loadUserInfoFromStorage()
			return
		}
		
		// 安全转换为 UTSJSONObject
		let infoObj: UTSJSONObject | null = null
		try {
			const infoJson = JSON.stringify(profile)
			if (infoJson != null && infoJson != '' && infoJson != 'null') {
				infoObj = JSON.parse(infoJson) as UTSJSONObject
			}
		} catch (e) {
			console.error('[VIP] 响应解析失败:', e)
		}
		
		if (infoObj == null) {
			console.error('[VIP] 响应对象为空')
			loadUserInfoFromStorage()
			return
		}
		
		// 获取头像（优先 image，其次 avatar）
		let imageVal: any | null = null
		try { imageVal = infoObj.get('image') } catch (e) {}
		let avatarVal: any | null = null
		try { avatarVal = infoObj.get('avatar') } catch (e) {}
		
		const imageStr = (imageVal != null && imageVal.toString() != '') ? imageVal.toString() : ''
		const avatarStr = (avatarVal != null && avatarVal.toString() != '') ? avatarVal.toString() : ''
		
		if (imageStr != '') {
			userAvatarValue.value = imageStr
			console.log('[VIP] 设置头像(image):', imageStr)
		} else if (avatarStr != '') {
			userAvatarValue.value = avatarStr
			console.log('[VIP] 设置头像(avatar):', avatarStr)
		}
		console.log('[VIP] 用户头像:', userAvatarValue.value)
		
		// 获取昵称
		let nicknameVal: any | null = null
		try { nicknameVal = infoObj.get('nickname') } catch (e) {}
		const nicknameStr = (nicknameVal != null && nicknameVal.toString() != '') ? nicknameVal.toString() : ''
		if (nicknameStr != '') {
			userNicknameValue.value = nicknameStr
		}
		console.log('[VIP] 用户昵称:', userNicknameValue.value)
		
		// 🎯 使用统一的 VIP 状态获取函数
		const vipStatus = getCurrentUserVipStatus()
		try {
			const vipStatusJson = JSON.stringify(vipStatus)
			if (vipStatusJson != null && vipStatusJson != '') {
				const vipStatusParsed = JSON.parse(vipStatusJson) as any
				if (vipStatusParsed != null) {
					const vipStatusData = vipStatusParsed as VipStatusData
					userVipValue.value = (vipStatusData.vip != null) ? (vipStatusData.vip as number) : 10
					userVipExpireTimeValue.value = (vipStatusData.vipExpireTime != null) ? vipStatusData.vipExpireTime.toString() : ''
					userVipTypeValue.value = (vipStatusData.vipType != null) ? (vipStatusData.vipType as number) : 0
				}
			}
		} catch (e) {
			console.error('[VIP] 解析VIP状态失败:', e)
			userVipValue.value = 10
			userVipExpireTimeValue.value = ''
			userVipTypeValue.value = 0
		}
		
		console.log('[VIP] VIP状态:', userVipValue.value)
		console.log('[VIP] VIP到期时间:', userVipExpireTimeValue.value)
		console.log('[VIP] VIP类型:', userVipTypeValue.value)
		
		console.log('[VIP] ✅ 用户信息加载成功（使用统一缓存）')
	}).catch((error: any | null): void => {
		console.error('[VIP] 加载用户信息异常:', error)
		// 🎯 异常时，尝试从 Storage 加载作为降级方案
		loadUserInfoFromStorage()
	})
}

// 加载抽奖信息（先定义，避免在文件中被调用时未声明）
// 🔧 修复 APP 端问题：使用 .then() 处理 Promise
const loadLotteryInfo = () => {
	const kid = getUserKid()
	if (kid == null || kid == '') {
		return
	}
	
	// 构造参数安全传递
	const paramsJson = JSON.stringify({ userKid: kid })
	let paramsParsed: any = ''
	try {
		paramsParsed = (paramsJson != null && paramsJson != '') ? JSON.parse(paramsJson) as any : ''
	} catch (e) {
		console.error('[VIP] 抽奖参数解析失败:', e)
		return
	}
	if (paramsParsed == null || paramsParsed == '') return
	const params = paramsParsed as UTSJSONObject
	
	getLotteryInfo(params).then((resultRaw: any) => {
		// 安全读取返回值 (使用 UTSJSONObject .get)
		let resObj: UTSJSONObject | null = null
		try {
			const resJson = JSON.stringify(resultRaw)
			if (resJson != null && resJson != '' && resJson != 'null') {
				resObj = JSON.parse(resJson) as UTSJSONObject
			}
		} catch (e) {}
		
		if (resObj == null) return
		
		let codeAny: any | null = null
		try { codeAny = resObj.get('code') } catch (e) {}
		
		// 🔧 修复：兼容数字和字符串类型的响应码
		let isSuccess = false
		if (codeAny != null) {
			// 🔧 修复：同时支持数字和字符串比较
			if (typeof codeAny == 'number') {
				const codeNum = codeAny as number
				isSuccess = (codeNum == 200)
			} else {
				const codeStr = codeAny.toString()
				isSuccess = (codeStr == '200')
			}
		}
		
		if (isSuccess == true) {
			let dataAny: any | null = null
			try { dataAny = resObj.get('data') } catch (e) {}
			lotteryInfo.value = (dataAny != null) ? dataAny : null
		}
	}).catch((error: any | null): void => {
		console.error('加载抽奖信息失败:', error)
	})
}

// 抽奖成功回调
const handleLotterySuccess = (result: any) => {
	showLotteryModal.value = false
	try {
		if (result != null) {
			const rewardsAny = safeGetProp(result, 'rewards')
			if (rewardsAny != null && Array.isArray(rewardsAny) && rewardsAny.length > 0) {
				lotteryReward.value = rewardsAny[0]
				showLotteryResult.value = true
				// 刷新抽奖信息
				loadLotteryInfo()
			}
		}
	} catch (e) {}
}

