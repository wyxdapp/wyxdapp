	flex-direction: column;
	position: relative;
	z-index: 1;
	background-color: transparent;
}

.section {
	background-color: #ffffff;
	margin-top: 20rpx;
	flex-direction: column;
}

.section-header {
	padding: 24rpx 28rpx 12rpx 28rpx;
	flex-direction: row;
}

.section-title {
	font-size: 26rpx;
	color: #999999;
}

