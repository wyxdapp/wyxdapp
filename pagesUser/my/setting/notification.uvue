	flex-direction: row;
	align-items: center;
	justify-content: space-between;
	padding: 28rpx;
	border-bottom-width: 1rpx;
	border-bottom-style: solid;
	border-bottom-color: #f0f0f0;
}

.cell-left {
	flex: 1;
	flex-direction: column;
}

.label-row {
	flex-direction: row;
	align-items: center;
}

.cell-right {
	flex-direction: row;
	align-items: center;
}

.cell-label {
	font-size: 30rpx;
	color: #333333;
}

.cell-desc {
	font-size: 24rpx;
	color: #999999;
	margin-top: 8rpx;
}

.cell-desc-warn {
	color: #FF6B35;
}

.vip-btn {
	padding: 12rpx 24rpx;
	background-color: #FFD700;
	border-radius: 24rpx;
	flex-direction: row;
	align-items: center;
	justify-content: center;
}

.vip-btn-text {
	font-size: 24rpx;
	color: #8B4513;
	font-weight: bold;
}

.bind-btn {
	padding: 12rpx 24rpx;
	background-color: #07C160;
	border-radius: 24rpx;
	flex-direction: row;
	align-items: center;
	justify-content: center;
}

.bind-btn-text {
	font-size: 24rpx;
	color: #ffffff;
	font-weight: bold;
}

.qrcode-btn {
	padding: 12rpx 24rpx;
	background-color: #37B1F2;
	border-radius: 24rpx;
	flex-direction: row;
	align-items: center;
	justify-content: center;
}

.qrcode-btn-text {
	font-size: 24rpx;
	color: #ffffff;
	font-weight: bold;
}

.follow-btn {
	padding: 12rpx 24rpx;
	background-color: #07C160;
	border-radius: 24rpx;
	flex-direction: row;
	align-items: center;
	justify-content: center;
	margin-left: 16rpx;
}

.follow-btn-text {
	font-size: 24rpx;
	color: #ffffff;
	font-weight: bold;
}

.follow-btn-inline {
	padding: 4rpx 16rpx;
	background-color: #07C160;
	border-radius: 20rpx;
	flex-direction: row;
