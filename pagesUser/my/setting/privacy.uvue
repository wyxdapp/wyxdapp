	flex-direction: column;
}

.section-header {
	padding: 24rpx 28rpx 12rpx 28rpx;
	flex-direction: row;
}

.section-title {
	font-size: 26rpx;
	color: #999999;
}

.cell-item {
	flex-direction: row;
	align-items: center;
	justify-content: space-between;
	padding: 28rpx;
	border-bottom-width: 1rpx;
	border-bottom-style: solid;
	border-bottom-color: #f0f0f0;
}

.cell-left {
	flex: 1;
	flex-direction: column;
}

.cell-label {
	font-size: 30rpx;
	color: #333333;
}

.cell-desc {
	font-size: 24rpx;
	color: #999999;
	margin-top: 8rpx;
}

.cell-arrow {
	width: 40rpx;
	height: 40rpx;
	flex-direction: row;
	align-items: center;
	justify-content: center;
}
