<template>
	<view class="security-page">
		<!-- 顶部渐变背景 -->
		<view class="hear-bg" :style="headerGradientOuter()"><view class="hear-bg-mask" :style="headerGradientMask()"></view></view>
		<!-- #ifndef H5 -->
		<!-- APP端导航栏 -->
		<view class="nav-bar" :style="{ paddingTop: pageStatusBarHeight + 'px' }">
			<view class="nav-content">
				<view class="nav-back" @click="handleBack">
					<uni-icons type="left" size="22" color="#333333"></uni-icons>
				</view>
				<text class="nav-title">账户安全</text>
				<view class="nav-placeholder"></view>
			</view>
		</view>
		<!-- #endif -->
		
		<!-- #ifndef H5 -->
		<!-- APP端内容区域（需要留出导航栏空间） -->
		<view class="content-area" :style="{ marginTop: (pageStatusBarHeight + 44) + 'px' }">
		<!-- #endif -->
		<!-- #ifdef H5 -->
		<!-- H5端内容区域（无需额外 margin） -->
		<view class="content-area">
		<!-- #endif -->
		<!-- 安全设置列表 -->
		<view class="section-card">
			<view class="security-item" @click="handlePhoneClick">
				<text class="item-label">手机号设置</text>
				<text class="item-value">{{ maskedPhone }}</text>
				<text class="item-arrow">›</text>
			</view>
			<view class="security-item" @click="handleLoginPasswordClick">
				<text class="item-label">登录密码设置</text>
				<text class="item-value">{{ loginPasswordStatus }}</text>
				<text class="item-arrow">›</text>
			</view>
			<view class="security-item" @click="handlePayPasswordClick">
				<text class="item-label">支付密码设置</text>
				<text class="item-value">{{ payPasswordStatus }}</text>
				<text class="item-arrow">›</text>
			</view>
		</view>
		
		<!-- 注销账户 -->
		<view class="section-card danger-section">
			<view class="security-item danger-item" @click="handleDeleteAccountClick">
				<text class="item-label danger-label">注销账户</text>
				<text class="item-arrow">›</text>
			</view>
		</view>
		</view>
		
		<!-- 注销账户弹窗 -->
		<view v-if="deleteAccountVisible == true" class="popup-mask" @click="deleteAccountVisible = false">
			<view class="popup-container delete-popup" @click.stop>
				<view class="popup-header">
					<text class="popup-title danger-title">注销账户</text>
					<text class="close-btn" @click="deleteAccountVisible = false">✕</text>
				</view>
				<view class="popup-content">
					<view class="warning-box">
						<UniIcons type="info-filled" :size="48" color="#FF9800" />
						<text class="warning-title">注销账户后，以下信息将被永久删除且无法恢复：</text>
					</view>
					<view class="warning-list">
						<text class="warning-item">• 账户信息（昵称、头像、个人资料等）</text>
						<text class="warning-item">• 钱包余额及交易记录</text>
						<text class="warning-item">• 订单记录及评价</text>
						<text class="warning-item">• 聊天记录及好友关系</text>
						<text class="warning-item">• 发布的动态及收藏内容</text>
						<text class="warning-item">• 会员权益及优惠券</text>
					</view>
					<view class="warning-notice">
						<text class="notice-text">注销申请提交后，我们将在15个工作日内完成审核。审核期间您可以取消注销申请。</text>
					</view>
					
					<!-- 验证方式 -->
					<view class="form-item">
						<text class="form-label">验证手机号</text>
						<view class="code-row">
							<input 
								v-model="deleteAccountCode"
								class="form-input code-input"
								type="number"
								maxlength="4"
								placeholder="请输入验证码"
							/>
							<view 
								class="code-btn login-code-btn"
								:class="{ 'code-btn-disabled': canSendDeleteCode == false || deleteCodeCountdown > 0 }"
								@click="handleSendDeleteCodeClick"
							>
								<text class="code-btn-text">{{ deleteCodeCountdown > 0 ? `${deleteCodeCountdown}s` : '发送验证码' }}</text>
							</view>
						</view>
					</view>
					
					<view class="popup-buttons row-actions">
						<view class="btn cancel-btn" @click="deleteAccountVisible = false">
							<text class="btn-text cancel-btn-text">取消</text>
						</view>
						<view class="btn danger-btn" @click="confirmDeleteAccount">
							<text class="btn-text danger-btn-text">确认注销</text>
						</view>
					</view>
				</view>
			</view>
		</view>
		
		<!-- 更换手机号弹窗 -->
		<view v-if="phoneChangeVisible" class="popup-mask" @click="phoneChangeVisible = false">
			<view class="popup-container" @click.stop>
				<view class="popup-header">
					<text class="popup-title">更换手机号</text>
					<text class="close-btn" @click="phoneChangeVisible = false">✕</text>
				</view>
				<view class="popup-content">
					<view class="form-item">
						<text class="form-label">新手机号</text>
						<input 
							v-model="phoneFormPhone"
							class="form-input"
							type="number"
							maxlength="11"
							placeholder="请输入新手机号"
						/>
					</view>
					<view class="form-item">
						<view class="code-row">
							<input 
								v-model="phoneFormCode"
								class="form-input code-input"
								type="number"
								maxlength="4"
								placeholder="请输入验证码"
							/>
							<view 
								class="code-btn login-code-btn"
								:class="{ 'code-btn-disabled': canSendPhoneCode == false || phoneCodeCountdown > 0 }"
								@click="handleSendPhoneCodeClick"
							>
								<text class="code-btn-text">{{ phoneCodeCountdown > 0 ? `${phoneCodeCountdown}s` : '发送验证码' }}</text>
							</view>
						</view>
					</view>
					<view class="popup-buttons row-actions">
						<view class="btn cancel-btn" @click="phoneChangeVisible = false">
							<text class="btn-text cancel-btn-text">取消</text>
						</view>
						<view class="btn confirm-btn" @click="confirmPhoneChange">
							<text class="btn-text confirm-btn-text">确定</text>
						</view>
					</view>
				</view>
			</view>
		</view>
		
		<!-- 修改登录密码弹窗 -->
		<view v-if="passwordVisible" class="popup-mask" @click="passwordVisible = false">
			<view class="popup-container" @click.stop>
				<view class="popup-header">
					<text class="popup-title">{{ passwordDialogTitle }}</text>
					<text class="close-btn" @click="passwordVisible = false">✕</text>
				</view>
				<view class="popup-content">
					<!-- 验证方式选择 - Tab 切换样式 -->
					<view v-if="isFirstSetLoginPassword == false" class="form-item">
						<text class="form-label left-label">验证方式</text>
						<view class="verify-tabs">
							<view 
								:class="passwordVerifyType == 'original' ? 'verify-tab-item verify-tab-active' : 'verify-tab-item'"
								@click="passwordVerifyType = 'original'"
							>
								<text :class="passwordVerifyType == 'original' ? 'verify-tab-text verify-tab-text-active' : 'verify-tab-text'">原密码验证</text>
							</view>
							<view 
								:class="passwordVerifyType == 'sms' ? 'verify-tab-item verify-tab-active' : 'verify-tab-item'"
								@click="passwordVerifyType = 'sms'"
							>
								<text :class="passwordVerifyType == 'sms' ? 'verify-tab-text verify-tab-text-active' : 'verify-tab-text'">短信验证</text>
							</view>
						</view>
					</view>
					
					<!-- 原密码验证 -->
					<view v-if="isFirstSetLoginPassword == false && passwordVerifyType == 'original'" class="form-item">
						<text class="form-label field-title">原密码</text>
						<input 
							v-model="passwordFormOriginal"
							class="form-input"
							type="password"
							placeholder="请输入原密码"
						/>
					</view>
					
					<!-- 短信验证 -->
					<template v-if="isFirstSetLoginPassword == false && passwordVerifyType == 'sms'">
						<view class="form-item">
							<text class="form-label field-title">手机号</text>
							<input 
								v-model="currentPhone"
								class="form-input"
								disabled
								placeholder="当前绑定手机号"
							/>
						</view>
						<view class="form-item">
							<view class="code-row inline-row">
								<input 
									v-model="passwordFormSmsCode"
									class="form-input code-input"
									type="number"
									maxlength="4"
									placeholder="请输入验证码"
								/>
								<view 
									class="code-btn login-code-btn"
									:class="{ 'code-btn-disabled': canSendSmsCode == false || smsCodeCountdown > 0 }"
									@click="handleSendSmsCodeClick"
								>
									<text class="code-btn-text">{{ smsCodeCountdown > 0 ? `${smsCodeCountdown}s` : '发送验证码' }}</text>
								</view>
							</view>
						</view>
					</template>
					
					<view class="form-item">
						<text class="form-label field-title">新密码</text>
						<input 
							v-model="passwordFormNew"
							class="form-input"
							type="password"
							placeholder="请输入新密码（6-20位）"
						/>
					</view>
					<view class="form-item">
						<text class="form-label field-title">确认密码</text>
						<input 
							v-model="passwordFormConfirm"
							class="form-input"
							type="password"
							placeholder="请再次输入新密码"
						/>
					</view>
					<view class="popup-buttons row-actions">
						<view class="btn cancel-btn" @click="passwordVisible = false">
							<text class="btn-text cancel-btn-text">取消</text>
						</view>
						<view class="btn confirm-btn" @click="confirmPasswordChange">
							<text class="btn-text confirm-btn-text">确定</text>
						</view>
					</view>
				</view>
			</view>
		</view>
		
		<!-- 设置支付密码弹窗 -->
		<view v-if="payPasswordVisible == true" class="popup-mask" @click="payPasswordVisible = false">
			<view class="popup-container" @click.stop>
				<view class="popup-header">
					<text class="popup-title">{{ payPasswordTitleText }}</text>
					<text class="close-btn" @click="payPasswordVisible = false">✕</text>
				</view>
				<view class="popup-content">
					<!-- 修改支付密码时显示验证方式选择 - Tab 切换样式 -->
					<view v-if="isFirstSetPayPassword == false" class="form-item">
						<text class="form-label left-label">验证方式</text>
						<view class="verify-tabs">
							<view 
								:class="payPasswordVerifyType == 'original' ? 'verify-tab-item verify-tab-active' : 'verify-tab-item'"
								@click="payPasswordVerifyType = 'original'"
							>
								<text :class="payPasswordVerifyType == 'original' ? 'verify-tab-text verify-tab-text-active' : 'verify-tab-text'">原密码验证</text>
							</view>
							<view 
								:class="payPasswordVerifyType == 'sms' ? 'verify-tab-item verify-tab-active' : 'verify-tab-item'"
								@click="payPasswordVerifyType = 'sms'"
							>
								<text :class="payPasswordVerifyType == 'sms' ? 'verify-tab-text verify-tab-text-active' : 'verify-tab-text'">短信验证</text>
							</view>
						</view>
					</view>
					
					<!-- 原密码验证（修改时） -->
					<view v-if="isFirstSetPayPassword == false && payPasswordVerifyType == 'original'" class="form-item">
						<text class="form-label field-title">原密码</text>
						<input 
							v-model="payPasswordFormOld"
							class="form-input"
							type="number"
							maxlength="6"
							placeholder="请输入原支付密码"
						/>
					</view>
					
					<!-- 短信验证（修改时） -->
					<template v-if="isFirstSetPayPassword == false && payPasswordVerifyType == 'sms'">
						<view class="form-item">
							<text class="form-label field-title">手机号</text>
							<input 
								v-model="currentPhone"
								class="form-input"
								disabled
								placeholder="当前绑定手机号"
							/>
						</view>
						<view class="form-item">
							<view class="code-row inline-row">
								<input 
									v-model="payPasswordFormSmsCode"
									class="form-input code-input"
									type="number"
									maxlength="4"
									placeholder="请输入验证码"
								/>
								<view 
									class="code-btn login-code-btn"
									:class="{ 'code-btn-disabled': canSendPayPasswordSmsCode == false || payPasswordSmsCodeCountdown > 0 }"
									@click="handleSendPayPasswordSmsCodeClick"
								>
									<text class="code-btn-text">{{ payPasswordSmsCodeCountdown > 0 ? `${payPasswordSmsCodeCountdown}s` : '发送验证码' }}</text>
								</view>
							</view>
						</view>
					</template>
					
					<view class="form-item">
						<text class="form-label field-title">支付密码</text>
						<input 
							v-model="payPasswordFormValue"
							class="form-input"
							type="number"
							maxlength="6"
							placeholder="请输入6位数字支付密码"
						/>
					</view>
					<view class="form-item">
						<text class="form-label field-title">确认密码</text>
						<input 
							v-model="payPasswordFormAgain"
							class="form-input"
							type="number"
							maxlength="6"
							placeholder="请再次输入支付密码"
						/>
					</view>
					<view class="popup-buttons row-actions">
						<view class="btn cancel-btn" @click="payPasswordVisible = false">
							<text class="btn-text cancel-btn-text">取消</text>
						</view>
						<view class="btn confirm-btn" @click="confirmPayPasswordSet">
							<text class="btn-text confirm-btn-text">确定</text>
						</view>
					</view>
				</view>
			</view>
		</view>
	</view>
</template>

<script setup lang="uts">
import { ref, computed, onMounted, onUnmounted } from 'vue'
import { onLoad } from '@dcloudio/uni-app'
import { handlePageError, handleSilentError } from '@/common/utils/errorHandler.uts'
import UniIcons from '@/components/base/UniIcons.uvue'
import { useUserStore, getUserId, getUserPhone, getUserProp } from '@/stores/user'
import { getMobileCode, changePhone, retrievePassword, setPayPassword, updatePayPassword, updatePayPasswordBySms, checkLoginPassword, checkCode } from '@/pagesUser/services/authService'
import { post } from '@/utils/request'
import { getAccountBalance } from '@/api/wallet.uts'
import { pageStatusBarHeight, initPageLayout } from '@/common/composables/usePageLayout.uts'
import { headerGradientOuter, headerGradientMask } from '@/common/utils/themeHelper.uts'

const userStore = useUserStore()

// 返回按钮处理
const handleBack = () => {
	uni.navigateBack({
		delta: 1,
		fail: () => {
			uni.switchTab({ url: '/pages/my/index' })
		}
	})
}

// 参数类：AuthGetMobileCodeParams（本文件局部，用于构造请求参数，避免匿名对象字面量）
class AuthGetMobileCodeParams {
	phone: string = ''
	constructor(phone?: string) {
		this.phone = (phone != null && phone != '') ? phone : ''
	}
}

// 参数类：ChangePhoneParams（本文件局部，用于构造请求参数，避免匿名对象字面量）
class ChangePhoneParams {
	oldPhone: string = ''
	newPhone: string = ''
	code: string = ''
	userKid: string = ''
	constructor(oldPhone?: string, newPhone?: string, code?: string, userKid?: string) {
		this.oldPhone = (oldPhone != null && oldPhone != '') ? oldPhone : ''
		this.newPhone = (newPhone != null && newPhone != '') ? newPhone : ''
		this.code = (code != null && code != '') ? code : ''
		this.userKid = (userKid != null && userKid != '') ? userKid : ''
	}
}

// 弹窗控制
const phoneChangeVisible = ref(false)
const passwordVisible = ref(false)
const payPasswordVisible = ref(false)
const deleteAccountVisible = ref(false)

// 注销账户表单
const deleteAccountCodeRef = ref<string>('')
const deleteCodeCountdown = ref(0)
let deleteCodeTimer: number | null = null
const deleteAccountCode = deleteAccountCodeRef

// 更换手机号表单 - 使用独立 ref（UTS 不支持 computed getter/setter）
const phoneFormPhoneRef = ref<string>('')
const phoneFormCodeRef = ref<string>('')

// 修改登录密码表单 - 使用独立 ref
const passwordFormOriginalRef = ref<string>('')
const passwordFormSmsCodeRef = ref<string>('')
const passwordFormNewRef = ref<string>('')
const passwordFormConfirmRef = ref<string>('')
const passwordVerifyType = ref('original') // original: 原密码验证, sms: 短信验证

// 设置支付密码表单 - 使用独立 ref
const payPasswordFormOldRef = ref<string>('')
const payPasswordFormSmsCodeRef = ref<string>('')
const payPasswordFormValueRef = ref<string>('')
const payPasswordFormAgainRef = ref<string>('')
const payPasswordVerifyType = ref('original') // original: 原密码验证, sms: 短信验证

// 支付密码状态
const hasPayPassword = ref(false)

// 登录密码状态
const hasLoginPassword = ref(false)

// 倒计时
const phoneCodeCountdown = ref(0)
const smsCodeCountdown = ref(0)
const payPasswordSmsCodeCountdown = ref(0)
let phoneCodeTimer: number | null = null
let smsCodeTimer: number | null = null
let payPasswordSmsCodeTimer: number | null = null

// 表单字段别名（直接使用 ref，UTS 不支持 computed getter/setter）
const phoneFormPhone = phoneFormPhoneRef
const phoneFormCode = phoneFormCodeRef
const passwordFormOriginal = passwordFormOriginalRef
const passwordFormSmsCode = passwordFormSmsCodeRef
const passwordFormNew = passwordFormNewRef
const passwordFormConfirm = passwordFormConfirmRef
const payPasswordFormOld = payPasswordFormOldRef
const payPasswordFormSmsCode = payPasswordFormSmsCodeRef
const payPasswordFormValue = payPasswordFormValueRef
const payPasswordFormAgain = payPasswordFormAgainRef

// 点击发送短信验证码的包装处理，避免在模板内返回 Promise 导致类型不匹配
// （定义位置靠后，实际实现会被放在 sendSmsCode 定义之后）

// 安全访问辅助函数：使用统一的 store 函数获取用户信息
const getUserInfoProp = (key: string): string => {
	try {
		if (key == 'phone') {
			const phone = getUserPhone()
			return (phone != null && phone != '') ? phone : ''
		}
		if (key == 'kid' || key == 'shortKid') {
			const kid = getUserId()
			return (kid != null && kid != '') ? kid : ''
		}
		// 其他字段使用通用的 getUserProp 函数
		const val = getUserProp(key)
		return (val != null && val != '') ? val : ''
	} catch (e) {}
	return ''
}

// 计算属性（添加返回类型）
const maskedPhone = computed((): string => {
	try {
		const phone = getUserInfoProp('phone')
		if (phone == null || phone == '') return '未绑定'
		const phoneStr = phone.toString()
		return phoneStr.replace(/(\d{3})\d{4}(\d{4})/, '$1****$2')
	} catch (e) {
		return '未绑定'
	}
})

const currentPhone = computed((): string => {
	try {
		const phone = getUserInfoProp('phone')
		if (phone == null) return ''
		return phone.toString()
	} catch (e) {
		return ''
	}
})

const payPasswordStatus = computed((): string => {
	if (hasPayPassword.value == true) {
		return '修改'
	}
	return '设置'
})

const isFirstSetPayPassword = computed((): boolean => {
	return hasPayPassword.value == false
})

const payPasswordTitleText = computed((): string => {
	if (isFirstSetPayPassword.value == true) {
		return '设置支付密码'
	}
	return '修改支付密码'
})

const loginPasswordStatus = computed((): string => {
	if (hasLoginPassword.value == true) {
		return '修改'
	}
	return '设置'
})

const isFirstSetLoginPassword = computed((): boolean => {
	return hasLoginPassword.value == false
})

const passwordDialogTitle = computed((): string => {
	if (isFirstSetLoginPassword.value == true) {
		return '设置登录密码'
	}
	return '修改登录密码'
})

const canSendPhoneCode = computed((): boolean => {
	try {
		// 直接使用 ref 变量
		const phone = phoneFormPhoneRef.value
		if (phone == null || phone == '') return false
		return /^1[3-9]\d{9}$/.test(phone)
	} catch (e) {
		return false
	}
})

const canSendSmsCode = computed((): boolean => {
	try {
		const phone = currentPhone.value
		if (phone == null || phone == '') return false
		return /^1[3-9]\d{9}$/.test(phone)
	} catch (e) {
		return false
	}
})

const canSendPayPasswordSmsCode = computed((): boolean => {
	try {
		const phone = currentPhone.value
		if (phone == null || phone == '') return false
		return /^1[3-9]\d{9}$/.test(phone)
	} catch (e) {
		return false
	}
})

// 注销账户验证码发送条件
const canSendDeleteCode = computed((): boolean => {
	try {
		const phone = currentPhone.value
		if (phone == null || phone == '') return false
		return /^1[3-9]\d{9}$/.test(phone)
	} catch (e) {
		return false
	}
})

// 加载支付密码状态
const loadPayPasswordStatus = async () => {
	try {
		const userKid = getUserInfoProp('kid')
		if (userKid == null || userKid == '') {
			hasPayPassword.value = false
			return
		}
		
			const resRaw = await getAccountBalance(userKid.toString()) as UTSJSONObject
			// 安全读取返回值（UTSJSONObject）
			const resJson = JSON.stringify(resRaw)
			const resObj = (resJson != null && resJson != '') ? JSON.parse(resJson) as UTSJSONObject : null
			let codeGetVal: string | number | boolean | UTSJSONObject | null = null
			try { codeGetVal = (resObj != null) ? resObj.get('code') : null } catch (e) {}
			const codeVal = (codeGetVal != null) ? codeGetVal : ''
			if (codeVal == 200 || codeVal == '200') {
				let data: string | number | boolean | UTSJSONObject | null = null
				try { data = (resObj != null) ? resObj.get('data') : null } catch (e) { data = null }
			if (data != null) {
				try {
				let hasPassword: string | boolean = ''
						try {
							const dataJson2 = JSON.stringify(data)
							const dataObj2 = (dataJson2 != null && dataJson2 != '') ? JSON.parse(dataJson2) as UTSJSONObject : null
							let hpVal: string | boolean = ''
							try {
								if (dataObj2 != null) {
									const dataObj3Json = JSON.stringify(dataObj2)
									const dataObj3 = (dataObj3Json != null && dataObj3Json != '') ? JSON.parse(dataObj3Json) as UTSJSONObject : null
									let tmpHas: string | number | boolean | UTSJSONObject | null = null
									try {
										tmpHas = (dataObj3 != null) ? dataObj3.get('hasPayPassword') : null
									} catch (e) { tmpHas = null }
									hpVal = (tmpHas != null && tmpHas != '') ? tmpHas.toString() : ''
								}
					} catch (e) {
								hpVal = ''
							}
							hasPassword = (hpVal != null && hpVal != '') ? hpVal : ''
						} catch (e) {
							hasPassword = ''
					}
					hasPayPassword.value = (hasPassword == 'true' || hasPassword == '1')
				} catch (e) {
					hasPayPassword.value = false
				}
			} else {
				hasPayPassword.value = false
			}
		} else {
			hasPayPassword.value = false
		}
	} catch (error) {
		handleSilentError(error, '加载支付密码状态')
		// 默认认为未设置
		hasPayPassword.value = false
	}
}

// 加载登录密码状态
const loadLoginPasswordStatus = async () => {
	try {
		const userKid = getUserInfoProp('kid')
		if (userKid == null || userKid == '') {
			hasLoginPassword.value = true
			return
		}
		
		const paramsObj = {
			userKid: userKid.toString()
		} as UTSJSONObject
		const params = paramsObj
		
		const res = await post('/user/baseInfo/checkLoginPasswordStatus', params, false) as UTSJSONObject
		const resJson = JSON.stringify(res)
		const resObj = (resJson != null && resJson != '') ? JSON.parse(resJson) as UTSJSONObject : null
		let codeGetVal2: string | number | boolean | UTSJSONObject | null = null
		try { codeGetVal2 = (resObj != null) ? resObj.get('code') : null } catch (e) {}
		const codeVal = (codeGetVal2 != null) ? codeGetVal2 : ''
		if (codeVal == 200 || codeVal == '200') {
			let data: string | number | boolean | UTSJSONObject | null = null
			try { data = (resObj != null) ? resObj.get('data') : null } catch (e) { data = null }
			if (data != null) {
				try {
					let hasPassword: string | boolean = ''
					try {
						const dataJson2 = JSON.stringify(data)
						const dataObj2 = (dataJson2 != null && dataJson2 != '') ? JSON.parse(dataJson2) as UTSJSONObject : null
						let hpVal2: string | boolean = ''
						try {
							if (dataObj2 != null) {
								const dataObj3Json = JSON.stringify(dataObj2)
								const dataObj3 = (dataObj3Json != null && dataObj3Json != '') ? JSON.parse(dataObj3Json) as UTSJSONObject : null
								let tmpHas: string | number | boolean | UTSJSONObject | null = null
								try {
									tmpHas = (dataObj3 != null) ? dataObj3.get('hasLoginPassword') : null
								} catch (e) { tmpHas = null }
								hpVal2 = (tmpHas != null && tmpHas != '') ? tmpHas.toString() : ''
							}
						} catch (e) {
							hpVal2 = ''
						}
						hasPassword = (hpVal2 != null && hpVal2 != '') ? hpVal2 : ''
					} catch (e) {
						hasPassword = ''
					}
					hasLoginPassword.value = (hasPassword == 'true' || hasPassword == '1')
				} catch (e) {
					hasLoginPassword.value = true
				}
			} else {
				hasLoginPassword.value = true
			}
		} else {
			hasLoginPassword.value = true
		}
	} catch (error) {
		handleSilentError(error, '加载登录密码状态')
		// 默认认为已设置(更安全,显示完整验证选项)
		hasLoginPassword.value = true
	}
}

// 本地表单类型，避免在脚本中对 any 直接点访问导致 error18
interface PhoneFormData {
	phone?: string | null
	code?: string | null
}

// 错误解析类型
interface ErrorParsed {
	message?: string | null
	msg?: string | null
}

// 密码表单类型（顶层定义，避免局部接口）
interface PasswordFormData {
	originalPassword?: string | null
	smsCode?: string | null
	newPassword?: string | null
	confirmPassword?: string | null
}

// 通用接口响应类型（本地使用，避免在脚本中使用匿名对象字面量）
interface ApiResponseAny {
	code?: number | string | null
	msg?: string | null
	message?: string | null
	data?: UTSJSONObject | null
}

// 支付密码表单类型（顶层）
interface PayPasswordFormData {
	oldPassword?: string | null
	smsCode?: string | null
	payPassword?: string | null
	payPasswordAgain?: string | null
}

// 参数类：CheckLoginPasswordParams / CheckCodeParams / RetrievePasswordParams（本文件局部，用于构造请求参数）
class CheckLoginPasswordParams {
	userKid: string = ''
	password: string = ''
	constructor(userKid?: string, password?: string) {
		this.userKid = (userKid != null && userKid != '') ? userKid : ''
		this.password = (password != null && password != '') ? password : ''
	}
}

class CheckCodeParams {
	phone: string = ''
	code: string = ''
	constructor(phone?: string, code?: string) {
		this.phone = (phone != null && phone != '') ? phone : ''
		this.code = (code != null && code != '') ? code : ''
	}
}

class RetrievePasswordParams {
	phone: string = ''
	code: string = ''
	newPassword: string = ''
	constructor(phone?: string, code?: string, newPassword?: string) {
		this.phone = (phone != null && phone != '') ? phone : ''
		this.code = (code != null && code != '') ? code : ''
		this.newPassword = (newPassword != null && newPassword != '') ? newPassword : ''
	}
}

// 点击处理
