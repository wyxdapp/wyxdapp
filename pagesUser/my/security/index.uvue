// 确认更换手机号
const confirmPhoneChange = async () => {
	// 直接使用 ref 变量获取表单数据
	const phone = phoneFormPhoneRef.value
	if (phone == null || phone == '') {
		uni.showToast({ title: '请输入手机号', icon: 'none' })
		return
	}
	if (!/^1[3-9]\d{9}$/.test(phone)) {
		uni.showToast({ title: '请输入正确的手机号格式', icon: 'none' })
		return
	}
	const code = phoneFormCodeRef.value
	if (code == null || code == '') {
		uni.showToast({ title: '请输入验证码', icon: 'none' })
		return
	}
	if (!/^\d{4}$/.test(code)) {
		uni.showToast({ title: '验证码必须为4位数字', icon: 'none' })
		return
	}
	
	try {
		const oldPhone = getUserInfoProp('phone')
		const userKid = getUserInfoProp('kid')
		if (userKid == null || userKid == '' || oldPhone == null || oldPhone == '') {
			throw new Error('用户信息缺失，请重新登录后重试')
		}
		const newPhone = phone
		// 使用本地参数类并通过 post 调用，避免匿名对象类型导致的 error17
		const paramsInstance = new ChangePhoneParams(oldPhone.toString(), newPhone, code, userKid.toString())
		const paramsJson = JSON.stringify(paramsInstance)
		const paramsPlain = (paramsJson != null && paramsJson != '') ? JSON.parse(paramsJson) as UTSJSONObject : {}
		const res = await post('/user/baseInfo/changePhone', paramsPlain as UTSJSONObject, false) as UTSJSONObject
		const resJson = JSON.stringify(res)
		const resObj = (resJson != null && resJson != '') ? JSON.parse(resJson) as UTSJSONObject : null
		let codeGetVal8: string | number | boolean | UTSJSONObject | null = null
		try { codeGetVal8 = (resObj != null) ? resObj.get('code') : null } catch (e) {}
		let codeValNum = 0
		try { if (codeGetVal8 != null) codeValNum = parseInt(codeGetVal8.toString()) } catch (e) {}
		if (codeValNum == 200) {
			uni.showToast({ title: '手机号更换成功', icon: 'success' })
			// 更新本地缓存中的手机号（避免直接调用 store 方法导致编译错误）
			try {
				const storageVal = uni.getStorageSync('userInfo')
				const storageJson = (storageVal != null && typeof storageVal == 'string') ? storageVal : JSON.stringify(storageVal)
				const storageParsed = (storageJson != null && storageJson != '') ? JSON.parse(storageJson) as UTSJSONObject : null
				if (storageParsed != null) {
					// 使用 UTSJSONObject.get() 方法访问属性
					const nicknameVal = storageParsed.get('nickname')
					const imageVal = storageParsed.get('image')
					const kidVal = storageParsed.get('kid')
					const shortKidVal = storageParsed.get('shortKid')
					const newStorageObj = {
						phone: newPhone,
						nickname: (nicknameVal != null) ? nicknameVal.toString() : '',
						image: (imageVal != null) ? imageVal.toString() : '',
						kid: (kidVal != null) ? kidVal.toString() : '',
						shortKid: (shortKidVal != null) ? shortKidVal.toString() : ''
					} as UTSJSONObject
					try { uni.setStorageSync('userInfo', newStorageObj) } catch (e) {}
				}
			} catch (e) {}
			phoneChangeVisible.value = false
			// 重置表单
			phoneFormPhoneRef.value = ''
			phoneFormCodeRef.value = ''
		} else {
			let msg = '手机号更换失败'
			try {
				let msgGetVal6: string | number | boolean | UTSJSONObject | null = null
				try { msgGetVal6 = (resObj != null) ? resObj.get('msg') : null } catch (e) {}
				let messageGetVal6: string | number | boolean | UTSJSONObject | null = null
				try { messageGetVal6 = (resObj != null) ? resObj.get('message') : null } catch (e) {}
				msg = (msgGetVal6 != null && msgGetVal6 != '') ? msgGetVal6.toString() : ((messageGetVal6 != null && messageGetVal6 != '') ? messageGetVal6.toString() : msg)
			} catch (e) {}
			throw new Error(msg)
		}
	} catch (error) {
		handlePageError(error, '更换手机号', null)
	}
}

// 确认修改登录密码
const confirmPasswordChange = async () => {
	try {
		// 直接使用独立 ref 变量获取表单数据
		const newPassword = passwordFormNewRef.value
		if (newPassword == null || newPassword == '') {
			uni.showToast({ title: '请输入新密码', icon: 'none' })
			return
		}
		if (newPassword.length < 6 || newPassword.length > 20) {
			uni.showToast({ title: '密码长度为6-20位', icon: 'none' })
			return
		}
		const confirmPassword = passwordFormConfirmRef.value
		if (confirmPassword == null || confirmPassword == '') {
			uni.showToast({ title: '请再次输入新密码', icon: 'none' })
			return
		}
		if (newPassword != confirmPassword) {
			uni.showToast({ title: '两次输入的密码不一致', icon: 'none' })
			return
		}
		
		// 已有密码用户需要验证
		if (isFirstSetLoginPassword.value == false) {
			// 验证方式
			if (passwordVerifyType.value == 'original') {
				const originalPassword = passwordFormOriginalRef.value
				if (originalPassword == null || originalPassword == '') {
					uni.showToast({ title: '请输入原密码', icon: 'none' })
					return
				}
			} else {
				const smsCode = passwordFormSmsCodeRef.value
				if (smsCode == null || smsCode == '') {
					uni.showToast({ title: '请输入验证码', icon: 'none' })
					return
				}
				if (!/^\d{4}$/.test(smsCode)) {
					uni.showToast({ title: '验证码必须为4位数字', icon: 'none' })
					return
				}
			}
		}
		
		const userKid = getUserInfoProp('kid')
		const phone = currentPhone.value
		if (userKid == null || userKid == '' || phone == null || phone == '') {
			throw new Error('用户信息缺失，请重新登录后重试')
		}
		const userKidStr = userKid.toString()
		
		// 已有密码用户：根据验证方式先在后端校验
		if (isFirstSetLoginPassword.value == false) {
			if (passwordVerifyType.value == 'original') {
				const paramsCheckObj = {
					userKid: userKidStr,
					password: passwordFormOriginalRef.value
				} as UTSJSONObject
				const paramsCheck = paramsCheckObj
				await post('/user/baseInfo/checkPassword', paramsCheck, false)
			} else {
				const paramsCodeObj = {
					phone: phone,
					code: passwordFormSmsCodeRef.value
				} as UTSJSONObject
				const paramsCode = paramsCodeObj
				await post('/user/baseInfo/checkCode', paramsCode, false)
			}
		}
		
		// 首次设置密码调用 setPassword，已有密码根据验证方式调用不同接口
		let resRaw: UTSJSONObject | null = null
		if (isFirstSetLoginPassword.value == true) {
			const paramsSetObj = {
				userKid: userKidStr,
				newPassword: newPassword
			} as UTSJSONObject
			resRaw = await post('/user/baseInfo/setPassword', paramsSetObj, false) as UTSJSONObject
		} else if (passwordVerifyType.value == 'original') {
			// 原密码验证方式：调用 updatePassword 接口
			const paramsUpdateObj = {
				userKid: userKidStr,
				oldPassword: passwordFormOriginalRef.value,
				newPassword: newPassword
			} as UTSJSONObject
			resRaw = await post('/user/baseInfo/updatePassword', paramsUpdateObj, false) as UTSJSONObject
		} else {
			// 短信验证方式：调用 retrievePassword 接口
			const paramsRetrieveObj = {
				phone: phone,
				code: passwordFormSmsCodeRef.value,
				newPassword: newPassword
			} as UTSJSONObject
			resRaw = await post('/user/baseInfo/retrievePassword', paramsRetrieveObj, false) as UTSJSONObject
		}
		const resJson = (resRaw != null) ? JSON.stringify(resRaw) : ''
		let codeVal: string | number = ''
		try {
			const resParsed = (resJson != null && resJson != '') ? JSON.parse(resJson) as UTSJSONObject : null
			if (resParsed != null) {
				// 优先尝试作为 UTSJSONObject 调用 get()
				try {
					const resObj = resParsed as UTSJSONObject
					const codeGetResult = resObj.get('code')
					codeVal = (codeGetResult != null) ? codeGetResult.toString() : ''
				} catch (innerE) {
					// 回退为普通对象读取（使用顶层接口 ApiResponseAny）
					try {
						const tmp = resParsed as ApiResponseAny
						if (tmp != null && tmp.code != null) {
							codeVal = (tmp.code != null) ? tmp.code.toString() : ''
						}
					} catch (e2) {}
				}
			}
		} catch (e) {}
		if (codeVal == 200 || codeVal == '200') {
			const successMsg = isFirstSetLoginPassword.value == true ? '密码设置成功' : '密码修改成功'
			uni.showToast({ title: successMsg, icon: 'success' })
			passwordVisible.value = false
			// 重置表单
			passwordFormOriginalRef.value = ''
			passwordFormSmsCodeRef.value = ''
			passwordFormNewRef.value = ''
			passwordFormConfirmRef.value = ''
			passwordVerifyType.value = 'original'
			// 更新登录密码状态
			hasLoginPassword.value = true
		} else {
			let msg = '操作失败'
			try {
				// 优先使用 UTSJSONObject 安全读取 msg/message
				const resParsed2 = (resJson != null && resJson != '') ? JSON.parse(resJson) as UTSJSONObject : null
				if (resParsed2 != null) {
					try {
						const resObj2 = resParsed2 as UTSJSONObject
						const msgAny = resObj2.get('msg')
						const messageAny = resObj2.get('message')
						if (msgAny != null && msgAny != '') {
							msg = msgAny.toString()
						} else if (messageAny != null && messageAny != '') {
							msg = messageAny.toString()
						}
					} catch (innerE2) {
						// 回退到普通对象读取
						try {
							const tmp2 = resParsed2 as ApiResponseAny
							if (tmp2 != null) {
								if (tmp2.msg != null && tmp2.msg != '') msg = tmp2.msg.toString()
								else if (tmp2.message != null && tmp2.message != '') msg = tmp2.message.toString()
							}
						} catch (e3) {}
					}
				}
			} catch (e) {}
			throw new Error(msg)
		}
	} catch (error) {
		handlePageError(error, '修改登录密码', null)
	}
}

// 确认设置支付密码
const confirmPayPasswordSet = async () => {
	try {
		// 直接使用独立 ref 变量获取表单数据
		const payPwdVal = payPasswordFormValueRef.value
		const payPwdAgainVal = payPasswordFormAgainRef.value
		if (payPwdVal == null || payPwdVal == '') {
			uni.showToast({ title: '请输入支付密码', icon: 'none' })
			return
		}
		if (!/^\d{6}$/.test(payPwdVal)) {
			uni.showToast({ title: '支付密码必须为6位数字', icon: 'none' })
			return
		}
		if (payPwdAgainVal == null || payPwdAgainVal == '') {
			uni.showToast({ title: '请再次输入支付密码', icon: 'none' })
			return
		}
		if (payPwdVal != payPwdAgainVal) {
			uni.showToast({ title: '两次输入的密码不一致', icon: 'none' })
			return
		}
		
		// 修改支付密码时需要验证
		if (isFirstSetPayPassword.value == false) {
			if (payPasswordVerifyType.value == 'original') {
				// 原密码验证
				const oldPwdVal = payPasswordFormOldRef.value
				if (oldPwdVal == null || oldPwdVal == '') {
					uni.showToast({ title: '请输入原支付密码', icon: 'none' })
					return
				}
				if (!/^\d{6}$/.test(oldPwdVal)) {
					uni.showToast({ title: '原支付密码必须为6位数字', icon: 'none' })
					return
				}
			} else {
				// 短信验证码验证
				const smsCodeVal = payPasswordFormSmsCodeRef.value
				if (smsCodeVal == null || smsCodeVal == '') {
					uni.showToast({ title: '请输入验证码', icon: 'none' })
					return
				}
				if (!/^\d{4}$/.test(smsCodeVal)) {
					uni.showToast({ title: '验证码必须为4位数字', icon: 'none' })
					return
				}
			}
		}
		
		const userKid = getUserInfoProp('kid')
		if (userKid == null || userKid == '') {
			throw new Error('用户信息缺失，请重新登录后重试')
		}
		const userKidStr = userKid.toString()
		
		let res: UTSJSONObject = {} as UTSJSONObject
		if (isFirstSetPayPassword.value == true) {
			// 首次设置
			const paramsSetObj = {
				userKid: userKidStr,
				password: payPwdVal,
				confirmPassword: payPwdAgainVal
			} as UTSJSONObject
			const paramsSet = paramsSetObj
			res = await post('/user/userWallet/setPayPassword', paramsSet, false) as UTSJSONObject
		} else {
			// 修改支付密码
			const phone = currentPhone.value
			if (phone == null || phone == '') {
				throw new Error('手机号信息缺失')
			}
			
			if (payPasswordVerifyType.value == 'original') {
				// 原密码验证方式
				const paramsUpdateObj = {
					userKid: userKidStr,
					oldPassword: payPasswordFormOldRef.value,
					newPassword: payPwdVal
				} as UTSJSONObject
				const paramsUpdate = paramsUpdateObj
				res = await post('/user/userWallet/updatePayPassword', paramsUpdate, false) as UTSJSONObject
			} else {
				// 短信验证码方式
				const paramsUpdateSmsObj = {
					userKid: userKidStr,
					phone: phone,
					code: payPasswordFormSmsCodeRef.value,
					newPassword: payPwdVal
				} as UTSJSONObject
				const paramsUpdateSms = paramsUpdateSmsObj
				res = await post('/user/userWallet/updatePayPasswordBySms', paramsUpdateSms, false) as UTSJSONObject
			}
		}
		
		// 安全读取响应 code（优先 UTSJSONObject，再回退为普通对象）
		let codeValResult: string | number = ''
		try {
			const resJson = (res != null) ? JSON.stringify(res) : ''
			const resParsed = (resJson != null && resJson != '') ? JSON.parse(resJson) as UTSJSONObject : null
			if (resParsed != null) {
				try {
					const resObj = resParsed as UTSJSONObject
					const codeGetResult2 = resObj.get('code')
					codeValResult = (codeGetResult2 != null) ? codeGetResult2.toString() : ''
				} catch (eInner) {
					const tmp = resParsed as ApiResponseAny
					if (tmp != null && tmp.code != null) {
						codeValResult = (tmp.code != null) ? tmp.code.toString() : ''
					}
				}
			}
		} catch (e) {}
		const codeValNum = (codeValResult != null && codeValResult != '') ? parseInt(codeValResult.toString()) : 0
		if (codeValNum == 200) {
			const successMsg = isFirstSetPayPassword.value == true ? '支付密码设置成功' : '支付密码修改成功'
			uni.showToast({ title: successMsg, icon: 'success' })
			payPasswordVisible.value = false
			// 重置表单
			payPasswordFormOldRef.value = ''
			payPasswordFormSmsCodeRef.value = ''
			payPasswordFormValueRef.value = ''
			payPasswordFormAgainRef.value = ''
			payPasswordVerifyType.value = 'original'
			// 更新支付密码状态
			hasPayPassword.value = true
		} else {
			let msg = '操作失败'
			try {
				if (res != null) {
					const resJson = JSON.stringify(res)
					if (resJson != null && resJson != '') {
						const resParsed = JSON.parse(resJson) as ApiResponseAny
						if (resParsed != null) {
							if (resParsed.msg != null && resParsed.msg != '') msg = resParsed.msg.toString()
							else if (resParsed.message != null && resParsed.message != '') msg = resParsed.message.toString()
						}
					}
				}
			} catch (e) {}
			throw new Error(msg)
		}
	} catch (error) {
		handlePageError(error, '设置支付密码', null)
	}
}

// 页面加载 - 处理跳转参数
onLoad((options: OnLoadOptions) => {
	if (options != null) {
		try {
			const optionsStr = JSON.stringify(options)
			const optionsObj = (optionsStr != null && optionsStr != '') ? JSON.parse(optionsStr) as UTSJSONObject : null
			if (optionsObj != null) {
				let actionVal: string | number | boolean | UTSJSONObject | null = null
				try { actionVal = optionsObj.get('action') } catch (e) {}
				if (actionVal != null && actionVal.toString() == 'resetPayPassword') {
					payPasswordVisible.value = true
					payPasswordVerifyType.value = 'sms'
				}
			}
		} catch (e) {}
	}
})

// 生命周期
onMounted(() => {
	// 初始化页面布局（获取状态栏高度）
	initPageLayout()
	// 加载支付密码状态
	loadPayPasswordStatus()
	// 加载登录密码状态
	loadLoginPasswordStatus()
})

// 清除定时器
onUnmounted(() => {
	if (phoneCodeTimer != null) {
		const t = phoneCodeTimer as number
		try { clearInterval(t) } catch (e) {}
		phoneCodeTimer = null
	}
	if (smsCodeTimer != null) {
		const ts = smsCodeTimer as number
		try { clearInterval(ts) } catch (e) {}
		smsCodeTimer = null
	}
	if (payPasswordSmsCodeTimer != null) {
		const tp = payPasswordSmsCodeTimer as number
		try { clearInterval(tp) } catch (e) {}
		payPasswordSmsCodeTimer = null
	}
	if (deleteCodeTimer != null) {
		const td = deleteCodeTimer as number
		try { clearInterval(td) } catch (e) {}
		deleteCodeTimer = null
	}
})
</script>

