// 注销账户点击处理
const handleDeleteAccountClick = () => {
	deleteAccountVisible.value = true
}

// 开始注销验证码倒计时
const startDeleteCodeCountdown = () => {
	deleteCodeCountdown.value = 60
	deleteCodeTimer = setInterval(() => {
		deleteCodeCountdown.value = deleteCodeCountdown.value - 1
		if (deleteCodeCountdown.value <= 0) {
			if (deleteCodeTimer != null) {
				const t = deleteCodeTimer as number
				try { clearInterval(t) } catch (e) {}
				deleteCodeTimer = null
			}
		}
	}, 1000) as number
}

// 发送注销验证码
const sendDeleteCode = async () => {
	if (canSendDeleteCode.value == false) {
		uni.showToast({ title: '当前无绑定手机号', icon: 'none' })
		return
	}
	
	try {
		const paramsInstance = new AuthGetMobileCodeParams(currentPhone.value)
		const paramsJson = JSON.stringify(paramsInstance)
		const paramsPlain = (paramsJson != null && paramsJson != '') ? JSON.parse(paramsJson) as UTSJSONObject : {}
		const res = await post('/user/baseInfo/getCode', paramsPlain as UTSJSONObject, false) as UTSJSONObject
		const resJson = JSON.stringify(res)
		const resObj = (resJson != null && resJson != '') ? JSON.parse(resJson) as UTSJSONObject : null
		let codeGetVal3: string | number | boolean | UTSJSONObject | null = null
		try { codeGetVal3 = (resObj != null) ? resObj.get('code') : null } catch (e) {}
		let codeValNum = 0
		try { if (codeGetVal3 != null) codeValNum = parseInt(codeGetVal3.toString()) } catch (e) {}
		if (codeValNum == 200) {
			uni.showToast({ title: '验证码发送成功', icon: 'success' })
			startDeleteCodeCountdown()
		} else {
			let msg = '验证码发送失败'
			try {
				let msgGetVal: string | number | boolean | UTSJSONObject | null = null
				try { msgGetVal = (resObj != null) ? resObj.get('msg') : null } catch (e) {}
				let messageGetVal: string | number | boolean | UTSJSONObject | null = null
				try { messageGetVal = (resObj != null) ? resObj.get('message') : null } catch (e) {}
				msg = (msgGetVal != null && msgGetVal != '') ? msgGetVal.toString() : ((messageGetVal != null && messageGetVal != '') ? messageGetVal.toString() : msg)
			} catch (e) {}
			throw new Error(msg)
		}
	} catch (error) {
		handlePageError(error, '发送验证码', null)
	}
}

// 发送注销验证码点击处理
const handleSendDeleteCodeClick = (): void => {
	try {
		if (canSendDeleteCode.value == true && deleteCodeCountdown.value == 0) {
			try { sendDeleteCode() } catch (e) {}
		}
	} catch (e) {}
}

// 提交注销申请（必须在 confirmDeleteAccount 之前定义，因为 UTS 没有函数提升）
const submitDeleteAccount = async () => {
	try {
		const userKid = getUserInfoProp('kid')
		const phone = currentPhone.value
		const code = deleteAccountCodeRef.value
		
		if (userKid == null || userKid == '' || phone == null || phone == '') {
			throw new Error('用户信息缺失，请重新登录后重试')
		}
		
		const paramsObj = {
			userKid: userKid.toString(),
			phone: phone,
			code: code
		} as UTSJSONObject
		const params = paramsObj
		
		const res = await post('/user/baseInfo/deleteAccount', params, false) as UTSJSONObject
		const resJson = JSON.stringify(res)
		const resObj = (resJson != null && resJson != '') ? JSON.parse(resJson) as UTSJSONObject : null
		let codeGetVal4: string | number | boolean | UTSJSONObject | null = null
		try { codeGetVal4 = (resObj != null) ? resObj.get('code') : null } catch (e) {}
		let codeValNum = 0
		try { if (codeGetVal4 != null) codeValNum = parseInt(codeGetVal4.toString()) } catch (e) {}
		
		if (codeValNum == 200) {
			uni.showToast({ title: '注销申请已提交', icon: 'success' })
			deleteAccountVisible.value = false
			deleteAccountCodeRef.value = ''
			
			// 清除本地登录状态
			try { uni.removeStorageSync('token') } catch (e) {}
			try { uni.removeStorageSync('userInfo') } catch (e) {}
			
			// 延迟跳转到登录页
			setTimeout(() => {
				uni.reLaunch({
					url: '/pagesUser/login/index'
				})
			}, 1500)
		} else {
			let msg = '注销申请失败'
			let msgGetVal2: string | number | boolean | UTSJSONObject | null = null
			try { msgGetVal2 = (resObj != null) ? resObj.get('msg') : null } catch (e) {}
			let messageGetVal2: string | number | boolean | UTSJSONObject | null = null
			try { messageGetVal2 = (resObj != null) ? resObj.get('message') : null } catch (e) {}
			msg = (msgGetVal2 != null && msgGetVal2 != '') ? msgGetVal2.toString() : ((messageGetVal2 != null && messageGetVal2 != '') ? messageGetVal2.toString() : msg)
			throw new Error(msg)
		}
	} catch (error) {
		handlePageError(error, '注销账户', null)
	}
}

// 确认注销账户
const confirmDeleteAccount = async () => {
	const code = deleteAccountCodeRef.value
	if (code == null || code == '') {
		uni.showToast({ title: '请输入验证码', icon: 'none' })
		return
	}
	if (!/^\d{4}$/.test(code)) {
		uni.showToast({ title: '验证码必须为4位数字', icon: 'none' })
		return
	}
	
	uni.showModal({
		title: '最终确认',
		content: '账户注销后所有数据将被永久删除且无法恢复，确定要注销吗？',
		confirmText: '确认注销',
		confirmColor: '#FF4D4F',
		success: (res: UniShowModalResult) => {
			if (res.confirm == true) {
				submitDeleteAccount()
			}
		}
	})
}

// 发送手机验证码
const sendPhoneCode = async () => {
	if (canSendPhoneCode.value == false) {
		uni.showToast({ title: '请输入正确的手机号', icon: 'none' })
		return
	}
	
	// 倒计时函数（在本处定义，确保在调用前存在）
	const startPhoneCodeCountdown = () => {
		phoneCodeCountdown.value = 60
		phoneCodeTimer = setInterval(() => {
			phoneCodeCountdown.value--
			if (phoneCodeCountdown.value <= 0) {
				if (phoneCodeTimer != null) {
					const t = phoneCodeTimer as number
					try { clearInterval(t) } catch (e) {}
					phoneCodeTimer = null
				}
			}
		}, 1000) as number
	}

	try {
		// 直接使用 ref 变量获取手机号
		const phoneParam = phoneFormPhoneRef.value
		// 构造参数对象并显式转换为接口类型（避免 anonymous object）
		const paramsObjInstance = new AuthGetMobileCodeParams(phoneParam)
		const paramsForApiJson = JSON.stringify(paramsObjInstance)
		const paramsForApiPlain = (paramsForApiJson != null && paramsForApiJson != '') ? JSON.parse(paramsForApiJson) as UTSJSONObject : {} as UTSJSONObject
		const res = await post('/user/baseInfo/getCode', paramsForApiPlain as UTSJSONObject, false) as UTSJSONObject
		// 解析返回并统一为数字 code
		const resJson = JSON.stringify(res)
		const resObj = (resJson != null && resJson != '') ? JSON.parse(resJson) as UTSJSONObject : null
		let codeGetVal5: string | number | boolean | UTSJSONObject | null = null
		try { codeGetVal5 = (resObj != null) ? resObj.get('code') : null } catch (e) {}
		let codeValNum = 0
		try { if (codeGetVal5 != null) codeValNum = parseInt(codeGetVal5.toString()) } catch (e) {}
		if (codeValNum === 200) {
			uni.showToast({ title: '验证码发送成功', icon: 'success' })
			startPhoneCodeCountdown()
		} else {
			let msg = '验证码发送失败'
			try {
				if (resObj != null) {
					let msgGetVal3: string | number | boolean | UTSJSONObject | null = null
					try { msgGetVal3 = resObj.get('msg') } catch (e) {}
					let messageGetVal3: string | number | boolean | UTSJSONObject | null = null
					try { messageGetVal3 = resObj.get('message') } catch (e) {}
					msg = (msgGetVal3 != null && msgGetVal3 != '') ? msgGetVal3.toString() : ((messageGetVal3 != null && messageGetVal3 != '') ? messageGetVal3.toString() : '验证码发送失败')
				}
			} catch (e) {}
			throw new Error(msg)
		}
	} catch (error) {
		handlePageError(error, '发送验证码', null)
	}
}

// 包装：在 sendPhoneCode 定义之后再实现点击处理器（避免模板内直接调用 async）
