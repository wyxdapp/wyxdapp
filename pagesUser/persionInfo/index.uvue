/**
 * 关注/取消关注
 */
const handleAction = async () => {
	if (checkUserLogin() == false) {
		uni.showToast({ title: '请先登录', icon: 'none' })
		return
	}
	
	const infoKidVal = getInfoStringProperty(info.value, 'kid')
	if (infoKidVal == '') {
		console.warn('用户ID为空，无法关注')
		return
	}
	
	if (isProcessingFn(infoKidVal) == true) {
		return
	}
	
	try {
		const currentUserKidForFollow = getCurrentUserKid()
		const newStatus = await toggleFollowFn(currentUserKidForFollow, infoKidVal)
		
		// 更新本地粉丝数
		const followerCountVal = getInfoNumberProperty(info.value, 'followerCount')
		if (newStatus == true) {
			setInfoProperty(info.value, 'followerCount', followerCountVal + 1)
		} else {
			setInfoProperty(info.value, 'followerCount', Math.max(0, followerCountVal - 1))
		}
		
		updateInfoData()
		
		// 同步到缓存
		const followCacheObj = new UTSJSONObject()
		followCacheObj.set('followerCount', getInfoNumberProperty(info.value, 'followerCount'))
		followCacheObj.set('isFocus', newStatus)
		syncProfileCache(followCacheObj)
		
		uni.showToast({
			title: newStatus == true ? '关注成功' : '已取消关注',
			icon: 'success'
		})
	} catch (error) {
		handlePageError(error, '关注操作', null)
	}
}

/**
 * FollowButton 组件的关注状态变化回调
 */
const onFollowChange = (isFollow: boolean, targetUserKid: string) => {
	// 更新本地粉丝数
	const followerCountVal = getInfoNumberProperty(info.value, 'followerCount')
	if (isFollow == true) {
		setInfoProperty(info.value, 'followerCount', followerCountVal + 1)
	} else {
		setInfoProperty(info.value, 'followerCount', Math.max(0, followerCountVal - 1))
	}
	
	updateInfoData()
	
	// 同步到缓存
	const followChangeCacheObj = new UTSJSONObject()
	followChangeCacheObj.set('followerCount', getInfoNumberProperty(info.value, 'followerCount'))
	followChangeCacheObj.set('isFocus', isFollow)
	syncProfileCache(followChangeCacheObj)
}

