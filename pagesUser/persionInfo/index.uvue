		handleSilentError(error, '获取定位信息')
		hasLocation.value = false
	}
	await initTrends()
}

/**
 * 初始化用户定制列表
 */
const initRoute = async () => {
	const pageInfo = routePageInfo.value
	pageInfo.status = 'loading'
	
	try {
		const routeParams = new GetUserLinesParams()
		routeParams.userKid = pageInfo.userKid
		routeParams.pageNumber = pageInfo.pageNumber
		routeParams.pageSize = pageInfo.pageSize
		
		const responseRaw = await getUserLines(routeParams)
		const response = responseRaw as UTSJSONObject
		
		let entities: UTSJSONObject[] = []
		let hasResponseData = false
		
		try {
			const dataVal = response['data'] as UTSJSONObject | null
			if (dataVal != null) {
				hasResponseData = true
				const dataObj = dataVal as UTSJSONObject
				const entitiesVal = dataObj.get('entities')
				if (entitiesVal != null && Array.isArray(entitiesVal) == true) {
					entities = entitiesVal as UTSJSONObject[]
				}
			}
		} catch (e) {
			handleSilentError(e, '解析定制列表响应数据')
		}
		
		if (hasResponseData == true) {
			if (pageInfo.pageNumber == 1) {
				// 关键修复：通过整体替换 ref.value 触发响应式更新
				const newPageInfo = new PageInfoData()
				newPageInfo.userKid = pageInfo.userKid
				newPageInfo.pageNumber = pageInfo.pageNumber
				newPageInfo.pageSize = pageInfo.pageSize
				newPageInfo.list = entities
				newPageInfo.status = (entities.length == 0 || entities.length < pageInfo.pageSize) ? 'nomore' : 'loadmore'
				routePageInfo.value = newPageInfo
			} else {
				// 追加模式：也通过替换 ref.value 确保响应式
				const newPageInfo = new PageInfoData()
				newPageInfo.userKid = pageInfo.userKid
				newPageInfo.pageNumber = pageInfo.pageNumber
				newPageInfo.pageSize = pageInfo.pageSize
				const newList: UTSJSONObject[] = []
				for (let i = 0; i < pageInfo.list.length; i = i + 1) {
					newList.push(pageInfo.list[i])
				}
				for (let i = 0; i < entities.length; i = i + 1) {
					newList.push(entities[i])
				}
				newPageInfo.list = newList
				newPageInfo.status = (entities.length == 0 || entities.length < pageInfo.pageSize) ? 'nomore' : 'loadmore'
				routePageInfo.value = newPageInfo
			}
		} else {
			pageInfo.status = 'loadmore'
		}
	} catch (error) {
		handlePageError(error, '获取定制列表', null)
		pageInfo.status = 'loadmore'
	}
}

// ==================== Tab 切换 ====================

/**
 * Tab栏切换
 */
const handleTab = (index: number) => {
	tabIndex.value = index
}

/**
 * 上拉加载
 */
const scrolltolower = () => {
	if (trendsPageInfo.value.status == 'loadmore' && tabIndex.value == 0) {
		trendsPageInfo.value.pageNumber = trendsPageInfo.value.pageNumber + 1
		initTrends()
	}
	if (routePageInfo.value.status == 'loadmore' && tabIndex.value == 1) {
		routePageInfo.value.pageNumber = routePageInfo.value.pageNumber + 1
		initRoute()
	}
}

// ==================== 监听 Tab 切换 ====================
watch(tabIndex, (nV: number, oV: number) => {
	if (routeListLength.value == 0 && routePageInfo.value.pageNumber == 1 && nV == 1) {
		initRoute()
	}
})


// ==================== 上传功能 ====================

/**
 * 上传背景图
 */
const uploadBackground = () => {
	requestPermissionTip(PERMISSION_CAMERA_ALBUM).then((confirmed: boolean): void => {
		if (confirmed != true) return
	uni.chooseImage({
		count: 1,
		sizeType: ['compressed'],
		sourceType: ['album', 'camera'],
		success: (res: any | null) => {
			if (res == null) return
			try {
				const resStr = JSON.stringify(res)
				const resObj = JSON.parse(resStr) as UTSJSONObject
				const tempFilePathsVal = resObj.get('tempFilePaths')
				if (tempFilePathsVal == null || Array.isArray(tempFilePathsVal) == false) return
				const tempFilePaths = tempFilePathsVal as Array<string | null>
				if (tempFilePaths.length == 0) return
				
				const filePath = tempFilePaths[0]
				if (filePath == null || filePath == '') return
				
				backgroundLoading.value = true
				
				// 使用 cosUploader 上传（背景图使用 dynamic 类型）
				cosUploader.uploadDynamic(filePath!, (progress: number) => {
				}).then((result: UTSJSONObject) => {
					backgroundLoading.value = false
					
					if (result != null) {
						// 使用 JSON 序列化模式安全访问属性
						const resultStr = JSON.stringify(result)
						const resultObj = JSON.parse(resultStr) as UTSJSONObject
						const successVal = resultObj.get('success')
						const isSuccess = (successVal != null && successVal.toString() == 'true')
						
						if (isSuccess == true) {
							const dataVal = resultObj.get('data')
							if (dataVal != null) {
								const dataStr = JSON.stringify(dataVal)
								const dataObj = JSON.parse(dataStr) as UTSJSONObject
								let bgUrl = ''
								
								const compressedUrlVal = dataObj.get('compressedUrl')
								if (compressedUrlVal != null && compressedUrlVal.toString() != '') {
									bgUrl = compressedUrlVal.toString()
								} else {
									const originalUrlVal = dataObj.get('originalUrl')
									if (originalUrlVal != null && originalUrlVal.toString() != '') {
										bgUrl = originalUrlVal.toString()
									}
								}
								
								if (bgUrl != '') {
									setInfoProperty(info.value, 'background', bgUrl)
									uni.showToast({ title: '上传成功', icon: 'success' })
								} else {
									uni.showToast({ title: '上传失败', icon: 'none' })
								}
							} else {
								uni.showToast({ title: '上传失败', icon: 'none' })
							}
						} else {
							uni.showToast({ title: '上传失败', icon: 'none' })
						}
					} else {
						uni.showToast({ title: '上传失败', icon: 'none' })
					}
				}, (err: any) => {
					backgroundLoading.value = false
					handlePageError(err, '上传背景图', null)
				})
			} catch (e) {
				handleSilentError(e, '选择图片(背景)')
			}
		}
	})
	}, (error: any | null) => {
		handleSilentError(error as any, '请求相册权限(背景)')
	}) // requestPermissionTip
}

/**
 * 上传头像
 */
const uploadAvatar = () => {
	requestPermissionTip(PERMISSION_CAMERA_ALBUM).then((confirmed: boolean): void => {
		if (confirmed != true) return
	uni.chooseImage({
		count: 1,
		sizeType: ['compressed'],
		sourceType: ['album', 'camera'],
		success: (res: any | null) => {
			if (res == null) return
			try {
				const resStr = JSON.stringify(res)
				const resObj = JSON.parse(resStr) as UTSJSONObject
				const tempFilePathsVal = resObj.get('tempFilePaths')
				if (tempFilePathsVal == null || Array.isArray(tempFilePathsVal) == false) return
				const tempFilePaths = tempFilePathsVal as Array<string | null>
				if (tempFilePaths.length == 0) return
				
				const filePath = tempFilePaths[0]
				if (filePath == null || filePath == '') return
				
				avatarLoading.value = true
				
				// 使用 cosUploader 上传头像
				cosUploader.uploadAvatar(filePath!, (progress: number) => {
				}).then((result: UTSJSONObject) => {
					avatarLoading.value = false
					
					if (result != null) {
						// 使用 JSON 序列化模式安全访问属性
						const resultStr = JSON.stringify(result)
						const resultObj = JSON.parse(resultStr) as UTSJSONObject
						const successVal = resultObj.get('success')
						const isSuccess = (successVal != null && successVal.toString() == 'true')
						
						if (isSuccess == true) {
							const dataVal = resultObj.get('data')
							if (dataVal != null) {
								const dataStr = JSON.stringify(dataVal)
								const dataObj = JSON.parse(dataStr) as UTSJSONObject
								let imgUrl = ''
								
								const compressedUrlVal = dataObj.get('compressedUrl')
								if (compressedUrlVal != null && compressedUrlVal.toString() != '') {
									imgUrl = compressedUrlVal.toString()
								} else {
									const originalUrlVal = dataObj.get('originalUrl')
									if (originalUrlVal != null && originalUrlVal.toString() != '') {
										imgUrl = originalUrlVal.toString()
									}
								}
								
								if (imgUrl != '') {
									setInfoProperty(info.value, 'image', imgUrl)
									uni.showToast({ title: '上传成功', icon: 'success' })
								} else {
									uni.showToast({ title: '上传失败', icon: 'none' })
								}
							}
						} else {
							uni.showToast({ title: '上传失败', icon: 'none' })
						}
					}
				}, (err: any) => {
					avatarLoading.value = false
					handlePageError(err, '上传头像', null)
				})
			} catch (e) {
				handleSilentError(e, '选择图片(头像)')
			}
		}
	})
	}, (error: any | null) => {
		handleSilentError(error as any, '请求相册权限(头像)')
	}) // requestPermissionTip
}

