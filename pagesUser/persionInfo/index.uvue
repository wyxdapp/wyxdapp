// ==================== 用户信息加载 ====================

/**
 * 更新用户信息显示
 */
const updateUserInfoDisplay = (userInfo: UTSJSONObject | null) => {
	const converted = toUTSJSON(userInfo)
	if (converted == null) {
		console.error('updateUserInfoDisplay: 转换用户信息失败')
		return
	}
	info.value = converted
	
	// 更新统计信息
	updateInfoDataFromUserInfo(infoData.value, info.value)
	
	// 同步关注状态到全局 store
	const userInfoKid = getInfoStringProperty(info.value, 'kid')
	const userInfoIsFocus = getInfoProperty(info.value, 'isFocus')
	if (userInfoKid != '') {
		const isFollowed = (userInfoIsFocus == true) || (userInfoIsFocus == 10)
		setFollowStatusFn(userInfoKid, isFollowed)
	}
	
	initFinish.value = true
	
	// 🔧 缓存当前用户的 shortKid（用于分享推广链接的 fallback）
	const userInfoKidForCache = getInfoStringProperty(info.value, 'kid')
	const shortKidForCache = getInfoStringProperty(info.value, 'shortKid')
	if (userInfoKidForCache != '' && shortKidForCache != '') {
		const currentUserKidForCache = getCurrentUserKid()
		if (currentUserKidForCache == userInfoKidForCache) {
			try {
				uni.setStorageSync('user_shortKid_' + currentUserKidForCache, shortKidForCache)
				// 同步 shortKid 到 userStore（修复登录时未返回 shortKid 的问题）
				const existingShortKid = getUserShortKid()
				if (existingShortKid == '') {
					updateUserInfoAction({ shortKid: shortKidForCache } as UTSJSONObject)
				}
			} catch (e) {}
		}
	}
	
	// 设置H5分享（传递 info.value，确保分享数据正确获取）
	setupH5ShareFn(info.value)
	
	// 初始化微信分享（H5 微信浏览器环境）
	// #ifdef H5
	// 传递 info.value 和 guiderKid.value，确保分享数据正确获取
	initWechatShareFn(info.value, guiderKid.value)
	// #endif
	
	// 加载擅长标签
	const kidVal = getInfoStringProperty(info.value, 'kid')
	const fallbackLanguages = getArrayProp(info.value, 'userLanguageOutVos') as UTSJSONObject[]
	const fallbackLabels = getArrayProp(info.value, 'userLabelOutvos') as UTSJSONObject[]
	loadProfileSpecialities(
		(kidVal != '') ? kidVal : guiderKid.value,
		fallbackLanguages,
		fallbackLabels
	)
	
	// 设置分享SEO优化的Meta标签（传递 info.value，确保分享数据正确获取）
	setShareMetaTagsFn(info.value)
}

/**
 * 设置默认用户信息
 */
const setDefaultUserInfo = (userId: string) => {
	const infoVal = info.value
	infoVal.set('kid', userId)
	infoVal.set('nickname', (userId.length >= 6) ? '用户' + userId.slice(-6) : '用户' + userId)
	infoVal.set('image', 'https://jiasu.wyxdapp.com/iconimages/default_avatar.png')
	infoVal.set('focusCount', 0)
	infoVal.set('followerCount', 0)
	infoVal.set('beLikedCount', 0)
	infoVal.set('collectionCount', 0)
	infoVal.set('signature', '这个人很懒,什么都没留下')
	infoVal.set('birthPlace', '未知')
	infoVal.set('accessiblePlace', '暂未设置')
	infoVal.set('servicePrice', '0元')
	infoVal.set('serviceFeature', '这个导游很懒,什么也没留下')
	infoVal.set('starLevel', 0)
	infoVal.set('beEvaluateCount', 0)
	infoVal.set('onLineStatu', 10)
	infoVal.set('age', 0)
	infoVal.set('sex', '未知')
	infoVal.set('userLabelOutvos', [] as UTSJSONObject[])
	infoVal.set('userFortes', [] as UTSJSONObject[])

	// 更新统计信息
	for (let i = 0; i < infoData.value.length; i = i + 1) {
		infoData.value[i].value = 0
	}

	initFinish.value = true
}

/**
 * 同步数据到缓存
 */
const syncProfileCache = (payload: UTSJSONObject) => {
	try {
		const infoKidStr = getInfoStringProperty(info.value, 'kid')
		if (infoKidStr == '') return
		
		const focusKid = viewerKid.value
		// 确保 payload 是纯 UTSJSONObject，通过 JSON 序列化/反序列化转换
		const payloadStr = JSON.stringify(payload)
		if (payloadStr == '' || payloadStr == 'null' || payloadStr == '{}') return
		const safePayload = JSON.parse(payloadStr) as UTSJSONObject
		updateUserProfile(infoKidStr, safePayload, focusKid, DEFAULT_TTL)
	} catch (e) {
		handleSilentError(e, 'syncProfileCache')
	}
}

/**
 * 使用缓存管理器获取用户主页信息
 */
const initDataWithCache = async (profileKid: string) => {
	if (isLoadingUserInfo.value == true) {
		return
	}

	if (profileKid == '') {
		console.error('获取用户信息缺少kid参数')
		return
	}

	isLoadingUserInfo.value = true
	const focusKid = viewerKid.value
	const selfProfile = isSelfProfile(profileKid)
	
	try {
		// 非自己的主页，先尝试使用缓存
		if (selfProfile == false) {
			const cachedProfile = getCachedProfile(profileKid, focusKid)
			if (cachedProfile != null) {
				updateUserInfoDisplay(cachedProfile)
			}
		}
		
		// 请求最新数据
		const profileParams = {
			kid: profileKid,
			focusUserkid: focusKid,
			forceRefresh: selfProfile
		} as UTSJSONObject
		const latestProfile = await getUserProfile(profileParams)
		
		if (latestProfile != null) {
			updateUserInfoDisplay(latestProfile)
		} else if (initFinish.value == false) {
			setDefaultUserInfo(profileKid)
		}
	} catch (error) {
		handleSilentError(error, '获取用户信息')
		const fallbackProfile = getCachedProfile(profileKid, focusKid)
		if (fallbackProfile != null) {
			updateUserInfoDisplay(fallbackProfile)
			uni.showToast({ title: '网络波动，已展示缓存数据', icon: 'none' })
		} else {
			setDefaultUserInfo(profileKid)
			uni.showToast({ title: '获取用户信息失败，请重试', icon: 'none' })
		}
	} finally {
		isLoadingUserInfo.value = false
	}
}

