// ==================== 计算属性 - VIP 和礼物等级（用于 NicknameWithBadges 组件）====================
const infoVipType = computed((): string => {
	const vip = getInfoNumberProperty(info.value, 'vip')
	const vipExpireTime = getInfoStringProperty(info.value, 'vipExpireTime')
	const vipTypeNum = getInfoNumberProperty(info.value, 'vipType')
	
	// 检查 VIP 是否有效
	if (vip == VIP_ACTIVATED) {
		if (vipExpireTime != '') {
			const expireDate = new Date(vipExpireTime)
			const now = new Date()
			if (expireDate > now) {
				// 根据 VIP 类型返回图标类型：VIP_TYPE_MONTHLY=月卡，VIP_TYPE_YEARLY=年卡
				if (vipTypeNum == VIP_TYPE_YEARLY) return 'year'
				return 'normal'
			}
		} else {
			// 没有到期时间，认为是永久有效的
			if (vipTypeNum == VIP_TYPE_YEARLY) return 'year'
			return 'normal'
		}
	}
	return ''
})

