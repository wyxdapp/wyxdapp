}

/**
 * 视频点击 - 跳转到全屏视频播放页
 */
const onVideoClick = (item: UTSJSONObject | null) => {
	// 筛选出视频类型的动态（insertType == 3）
	const videoItems: Array<any> = []
	let clickedIndex = 0
	const list = trendsPageInfo.value.list
	
	for (let i = 0; i < list.length; i = i + 1) {
		const listItem = list[i]
		const insertType = getNumberProp(listItem as any, 'insertType')
		if (insertType == 3) {
			const mediaName = getStringProp(listItem as any, 'mediaName')
			if (mediaName != '') {
				// 检查是否是当前点击的视频
				const itemKid = getStringProp(item as any, 'kid')
				const listItemKid = getStringProp(listItem as any, 'kid')
				if (itemKid == listItemKid) {
					clickedIndex = videoItems.length
				}
				videoItems.push(listItem)
			}
		}
	}
	
	if (videoItems.length > 0) {
		// 设置视频数据到 Store
		setVideoFeedData(videoItems, clickedIndex)
		
		// 跳转到视频播放页
		uni.navigateTo({
			url: '/pagesBusiness/videoFeed/index'
		})
	} else {
		uni.showToast({
			title: '视频不可用',
			icon: 'none'
		})
	}
}

