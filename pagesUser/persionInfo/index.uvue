/**
 * 点赞/取消点赞
 */
const onLike = async (item: UTSJSONObject | null) => {
	const itemKid = getStringProp(item as any, 'kid')
	if (itemKid == '') return
	
	if (checkUserLogin() == false) {
		uni.showToast({ title: '请先登录', icon: 'none' })
		safeSetTimeout(() => {
			uni.navigateTo({ url: '/pagesUser/login/index' })
		}, 1500)
		return
	}
	
	if (isLikeProcessing(itemKid) == true) {
		return
	}
	
	try {
		const currentUserKidForLike = getCurrentUserKid()
		if (currentUserKidForLike == '') return
		
		const newStatus = await toggleLikeFn(currentUserKidForLike, itemKid)
		
		// 从全局 store 同步最新点赞状态
		const isLikedVal = getLikeStatus(itemKid)
		const likeCountVal = getLikeCount(itemKid)
		const newIsLike = (isLikedVal == true) ? 10 : 20
		
		// 更新列表项并强制触发响应式
		const updatedList: UTSJSONObject[] = []
		for (let i = 0; i < trendsPageInfo.value.list.length; i = i + 1) {
			const listItem = trendsPageInfo.value.list[i]
			if (listItem != null) {
				const listItemKid = getStringProp(listItem, 'kid')
				if (listItemKid == itemKid) {
					try {
						const listItemStr = JSON.stringify(listItem)
						const listItemObj = JSON.parse(listItemStr) as UTSJSONObject
						listItemObj.set('isLike', newIsLike)
						listItemObj.set('likeNum', likeCountVal)
						updatedList.push(listItemObj)
					} catch (eUpdate) {
						handleSilentError(eUpdate, '更新动态点赞状态')
						updatedList.push(listItem)
					}
				} else {
					updatedList.push(listItem)
				}
			}
		}
		trendsPageInfo.value.list = updatedList
		
		// 同步个人主页「获赞」统计
		const infoValKid = getInfoStringProperty(info.value, 'kid')
		if (infoValKid != '') {
			const beLikedCountVal = getInfoNumberProperty(info.value, 'beLikedCount')
			const delta = (newStatus == true) ? 1 : -1
			const newBeLikedCount = Math.max(0, beLikedCountVal + delta)
			setInfoProperty(info.value, 'beLikedCount', newBeLikedCount)
			updateInfoData()
			try {
				const cacheObj = new UTSJSONObject()
				cacheObj.set('beLikedCount', newBeLikedCount)
				syncProfileCache(cacheObj)
			} catch (_ignore) {
				// 缓存同步失败不影响功能
			}
		}
	} catch (error) {
		handlePageError(error, '点赞操作', null)
	}
}

