// ==================== Store 实例 ====================
const userStore = useUserStore()

// 定时器生命周期管理
let timerHandles: number[] = []

function safeSetTimeout(callback: () => void, ms: number): number {
	const handle = setTimeout(callback, ms)
	timerHandles.push(handle)
	return handle
}

function clearAllTimers(): void {
	for (const handle of timerHandles) {
		clearTimeout(handle)
	}
	timerHandles = []
}

// ==================== 辅助函数 - 登录状态（必须在 computed 之前定义）====================

/**
 * 获取当前用户 ID（使用 loginHelper 可靠版本）
 */
const getCurrentUserKid = (): string => {
	return getCurrentUserIdReliable()
}

/**
 * 检查用户登录状态（使用 loginHelper 可靠版本）
 */
const checkUserLogin = (): boolean => {
	return checkUserLoginReliable()
}

// ==================== 页面状态 ====================
const guiderKid = ref<string>('')
const initFinish = ref<boolean>(false)
const isLoadingUserInfo = ref<boolean>(false)
const backgroundLoading = ref<boolean>(false)
const avatarLoading = ref<boolean>(false)
const showSharePopup = ref<boolean>(false)
// 提前准备一个临时会话列表，确保在打开 SharePopup 时能立即传入已解析的数组，避免时序问题
const shareChatList = ref<Array<UTSJSONObject>>([])
const scrollViewHeight = ref<number>(0)

// 🎯 动态操作菜单相关（仅自己主页）
