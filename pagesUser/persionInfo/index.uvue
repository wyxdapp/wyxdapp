// ==================== 辅助函数 - 安全访问分享数据 ====================
const getShareDataValue = (): UTSJSONObject => {
	// 使用JSON序列化方式安全访问，避免直接访问ref属性
	const shareDataJson = JSON.stringify(shareData.value)
	const shareDataObj = JSON.parse(shareDataJson) as UTSJSONObject

	const titleVal = shareDataObj.get('title')
	const summaryVal = shareDataObj.get('summary')
	const linkVal = shareDataObj.get('link')
	const imageUrlVal = shareDataObj.get('imageUrl')
	const userIdVal = shareDataObj.get('userId')
	const referrerShortKidVal = shareDataObj.get('referrerShortKid')

	return {
		title: (titleVal != null) ? titleVal.toString() : '',
		summary: (summaryVal != null) ? summaryVal.toString() : '',
		desc: (summaryVal != null) ? summaryVal.toString() : '',
		link: (linkVal != null) ? linkVal.toString() : '',
		url: (linkVal != null) ? linkVal.toString() : '',
		imageUrl: (imageUrlVal != null) ? imageUrlVal.toString() : '',
		userId: (userIdVal != null) ? userIdVal.toString() : '',
		referrerShortKid: (referrerShortKidVal != null) ? referrerShortKidVal.toString() : ''
	}
}

// ==================== 微信小程序分享数据构建 ====================
// #ifdef MP-WEIXIN
/**
 * 同步构建微信小程序分享所需的数据
 * 从页面已有的响应式数据中读取用户信息，返回分享标题、路径、图片和描述
 */
const buildMpShareData = (): UTSJSONObject => {
	const result = new UTSJSONObject()
	try {
		const infoVal = info.value
		const userKid = guiderKid.value

		// 昵称：为空时使用默认值
		const nicknameVal = infoVal.get('nickname')
		const nicknameStr = (nicknameVal != null && nicknameVal.toString() != '') ? nicknameVal.toString() : '用户'

		// 头像：为空时使用默认头像，http 自动转 https
		const imageVal = infoVal.get('image')
		let imageStr = (imageVal != null && imageVal.toString() != '') ? imageVal.toString() : DEFAULT_SHARE_IMAGE
		if (imageStr.indexOf('http://') == 0) {
			imageStr = imageStr.replace('http://', 'https://')
		}

		// 描述：优先使用个性签名，否则使用城市+性别组合
		const signatureVal = infoVal.get('signature')
		const signatureStr = (signatureVal != null && signatureVal.toString() != '') ? signatureVal.toString() : ''
		let descStr = ''
		if (signatureStr != '') {
			descStr = signatureStr
		} else {
			const liveCityVal = infoVal.get('liveCity')
			const liveCityStr = (liveCityVal != null && liveCityVal.toString() != '') ? liveCityVal.toString() : ''
			const birthPlaceVal = infoVal.get('birthPlace')
			const birthPlaceStr = (birthPlaceVal != null && birthPlaceVal.toString() != '') ? birthPlaceVal.toString() : ''
			const cityPart = (liveCityStr != '') ? liveCityStr : ((birthPlaceStr != '') ? birthPlaceStr : '远方')
			const sexVal = infoVal.get('sex')
			const sexStr = (sexVal != null) ? sexVal.toString() : ''
			const genderPart = (sexStr == '女') ? '女生' : ((sexStr == '男') ? '男生' : 'TA')
			descStr = '来自' + cityPart + '的' + genderPart + '，欢迎关注！'
		}

		// 页面路径
		let pathStr = '/pagesUser/persionInfo/index'
		if (userKid != '') {
			pathStr = pathStr + '?id=' + userKid
		}

		result.set('title', nicknameStr + '的个人主页')
		result.set('path', pathStr)
		result.set('imageUrl', imageStr)
		result.set('desc', descStr)
	} catch (e) {
		handleSilentError(e, '[MP-SHARE] buildMpShareData 构建')
		result.set('title', '网约向导 - 个人主页')
		result.set('path', '/pagesUser/persionInfo/index')
		result.set('imageUrl', DEFAULT_SHARE_IMAGE_LOCAL)
		result.set('desc', '发现有趣的向导，欢迎关注！')
	}
	return result
}
// #endif

