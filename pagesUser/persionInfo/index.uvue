	return getCurrentUserIdReliable()
})

// 位置信息
const latitude = ref<number>(0)
const longitude = ref<number>(0)
const hasLocation = ref<boolean>(false)

// 默认背景图
const bg_image = 'https://gimg2.baidu.com/image_search/src=http%3A%2F%2Fpic.616pic.com%2Fbg_w1180%2F00%2F05%2F65%2FOuBwxE5sua.jpg&refer=http%3A%2F%2Fpic.616pic.com&app=2002&size=f9999,10000&q=a80&n=0&g=0n&fmt=jpeg?sec=1617810333&t=fd114ed1561980fc456a8c043ba54482'

// ==================== Tab 配置 ====================

class TabItemData {
	label: string = ''
	value: number = 0
	constructor(label: string, value: number) {
		this.label = label
		this.value = value
	}
