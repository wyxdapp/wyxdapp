/**
 * 更多操作点击
 */
const onMoreClick = (item: UTSJSONObject | null) => {
	// 仅自己主页才弹出操作菜单
	if (showSelf.value == false) return
	selectedTrendsItem.value = item
	showTrendsActionSheet.value = true
}

/**
 * 更新动态列表项状态
 */
const updateTrendsItemStatus = (kid: string, key: string, value: number) => {
	const list = trendsPageInfo.value.list
	for (let i = 0; i < list.length; i = i + 1) {
		const item = list[i]
		const itemKid = getStringProp(item, 'kid')
		if (itemKid == kid) {
			try {
				const itemStr = JSON.stringify(item)
				const itemObj = JSON.parse(itemStr) as UTSJSONObject
				itemObj.set(key, value)
				list[i] = itemObj
			} catch (e) {
				handleSilentError(e, '更新动态列表项状态')
			}
			break
		}
	}
}

/**
 * 从动态列表中移除项
 */
const removeTrendsItem = (kid: string) => {
	const list = trendsPageInfo.value.list
	const newList: Array<UTSJSONObject> = []
	for (let i = 0; i < list.length; i = i + 1) {
		const item = list[i]
		const itemKid = getStringProp(item, 'kid')
		if (itemKid != kid) {
			newList.push(item)
		}
	}
	trendsPageInfo.value.list = newList
}

/**
 * 分享动态操作
 */
const handleTrendsShare = async () => {
	if (selectedTrendsItem.value == null) return
	
	const item = selectedTrendsItem.value
	const kid = getStringProp(item, 'kid')
	const content = getStringProp(item, 'discoverContent')
	const itemUserKid = getStringProp(item, 'userKid')
	
	let title = content
	if (content.length > TEXT_PREVIEW_LENGTH) {
		title = content.substring(0, TEXT_PREVIEW_LENGTH) + '...'
	}
	
	// 图片：取 picList 第一张，无则用默认图
	let imageUrl = DEFAULT_SHARE_IMAGE
	const picList = getArrayProp(item, 'picList')
	if (picList.length > 0) {
		const firstPic = picList[0]
		const picStr = firstPic.toString()
		if (picStr != '' && picStr != '[object Object]') {
			imageUrl = picStr
		} else {
			const picUrl = getStringProp(firstPic, 'picUrl')
			if (picUrl != '') {
				imageUrl = picUrl
			}
		}
	}
	
	const shareUrl = 'https://m.wyxdapp.com/#/pagesBusiness/commend/index?kid=' + kid
	
	sharePayload.value = {
		title: title,
		desc: content,
		summary: content,
		imageUrl: imageUrl,
		url: shareUrl,
		link: shareUrl,
		discoverKid: kid,
		userId: itemUserKid
	}
	
	// 获取会话列表
	try {
		const result = await getChatListFn(userStore)
		try {
			if (result != null && Array.isArray(result) == true) {
				shareChatList.value = result as Array<UTSJSONObject>
			} else {
				try {
					let fallbackArr: Array<UTSJSONObject> = []
					try {
						const rawParsed = JSON.parse(JSON.stringify(chatList))
						if (Array.isArray(rawParsed) == true) {
							fallbackArr = rawParsed as Array<UTSJSONObject>
						}
					} catch (e) {
						handleSilentError(e, '[PersionInfo] 解析chatList原始数据')
					}
					if (fallbackArr.length == 0) {
						try {
							const chatListObj = toJsonObj(chatList)
							if (chatListObj != null) {
								try {
									const v = chatListObj.get('value')
									if (v != null) {
										const parsedV = JSON.parse(JSON.stringify(v))
										if (Array.isArray(parsedV) == true) {
											fallbackArr = parsedV as Array<UTSJSONObject>
										}
									}
								} catch (e) {
									handleSilentError(e, '[PersionInfo] 解析chatList.value')
								}
								try {
									const l = chatListObj.get('list')
									if (l != null) {
										const parsedL = JSON.parse(JSON.stringify(l))
										if (Array.isArray(parsedL) == true) {
											fallbackArr = parsedL as Array<UTSJSONObject>
										}
									}
								} catch (e) {
									handleSilentError(e, '[PersionInfo] 解析chatList.list')
								}
							}
						} catch (e) {
							handleSilentError(e, '[PersionInfo] 转换chatList为JSON对象')
						}
					}
					shareChatList.value = (fallbackArr.length > 0) ? fallbackArr : []
				} catch (e) {
					shareChatList.value = []
				}
			}
		} catch (e) {
			handleSilentError(e, '[PersionInfo] 动态分享会话列表赋值')
		}
	} catch (e) {
		handleSilentError(e, '[PersionInfo] 获取会话列表(动态分享)')
		shareChatList.value = []
	}
	
	showSharePopup.value = true
}

/**
 * 顶置操作（使用统一会员守卫）
 */
const handleTrendsTop = () => {
	if (selectedTrendsItem.value == null) return
	const selectedItem = selectedTrendsItem.value as any
	// 使用统一会员守卫检查权限
	if (checkMemberGuard('trends_top', '您没有权限此操作', '顶置功能需要开通会员，是否前往开通？') == false) return
	const kid = getStringProp(selectedItem, 'kid')
	const onTop = getNumberProp(selectedItem, 'onTop')
	const isCurrentlyTop = onTop == 10
	const params = { kid: kid, isTop: isCurrentlyTop == false } as UTSJSONObject
	setTrendsTop(params).then((res: UTSJSONObject) => {
		const newOnTop = isCurrentlyTop == true ? 20 : 10
		updateTrendsItemStatus(kid, 'onTop', newOnTop)
		uni.showToast({ title: isCurrentlyTop == true ? '已取消顶置' : '已顶置', icon: 'success' })
	}, (error: Error | null) => {
		uni.showToast({ title: '操作失败', icon: 'none' })
	})
}

/**
 * 私密操作
 */
const handleTrendsPrivate = () => {
	if (selectedTrendsItem.value == null) return
	const selectedItem = selectedTrendsItem.value as any
	const kid = getStringProp(selectedItem, 'kid')
	const privatel = getNumberProp(selectedItem, 'privatel')
	const isCurrentlyPrivate = privatel == 20
	const params = { kid: kid, isPrivate: isCurrentlyPrivate == false } as UTSJSONObject
	setTrendsPrivate(params).then((res: UTSJSONObject) => {
		const newPrivatel = isCurrentlyPrivate == true ? 10 : 20
		updateTrendsItemStatus(kid, 'privatel', newPrivatel)
		uni.showToast({ title: isCurrentlyPrivate == true ? '已取消私密' : '已设为私密', icon: 'success' })
	}, (error: Error | null) => {
		uni.showToast({ title: '操作失败', icon: 'none' })
	})
}

/**
 * 删除操作
 */
const handleTrendsDelete = () => {
	if (selectedTrendsItem.value == null) return
	const selectedItem = selectedTrendsItem.value as any
	uni.showModal({
		title: '提示',
		content: '确定删除这条动态吗？',
		success: (res: UniShowModalResult) => {
			if (res.confirm == true) {
				const kid = getStringProp(selectedItem, 'kid')
				const params = { kid: kid } as UTSJSONObject
				deleteTrends(params).then((res: UTSJSONObject) => {
					removeTrendsItem(kid)
					uni.showToast({ title: '已删除', icon: 'success' })
				}, (error: Error | null) => {
					uni.showToast({ title: '删除失败', icon: 'none' })
				})
			}
		}
	})
}

/**
 * 操作菜单选择
 */
const handleTrendsActionSelect = (index: number) => {
	showTrendsActionSheet.value = false
	
	// 检查审核状态：待审核(10)或审核中(20)的动态只允许删除
	const auditStatus = getNumberProp(selectedTrendsItem.value as any, 'auditStatus')
	if (auditStatus == 10 || auditStatus == 20) {
		if (index == 3) {
			handleTrendsDelete()
		} else {
			uni.showToast({ title: '动态审核中，暂不支持此操作', icon: 'none' })
		}
		return
	}
	
	if (index == 0) {
		handleTrendsTop()
	} else if (index == 1) {
		handleTrendsShare()
	} else if (index == 2) {
		handleTrendsPrivate()
	} else if (index == 3) {
		handleTrendsDelete()
	}
}

const handleTrendsActionCancel = () => {
	showTrendsActionSheet.value = false
	selectedTrendsItem.value = null
}

/**
 * 跳转到评论页面
 */
const goGuideComments = () => {
	const infoKidVal = getInfoStringProperty(info.value, 'kid')
	const userKid = (infoKidVal != '') ? infoKidVal : guiderKid.value
	if (userKid == '') {
		uni.showToast({ title: '用户信息异常', icon: 'none' })
		return
	}
	uni.navigateTo({ url: '/pagesUser/guideComments/index?id=' + userKid })
}


// ==================== 导航与分享 ====================

/**
 * 处理返回
 * 如果上一页仍然是个人主页（persionInfo），则直接返回首页，避免用户在多个主页间循环返回
 */
const handlePageBack = () => {
	const pages = getCurrentPages()
	if (pages.length >= 2) {
		const prevPage = pages[pages.length - 2]
		const prevRoute = prevPage.route ?? ''
		if (prevRoute.indexOf('persionInfo') != -1) {
			// 上一页也是个人主页，直接回首页避免循环
			uni.switchTab({ url: '/pages/index/index' })
			return
		}
		uni.navigateBack({
			delta: 1,
			fail: () => {
				uni.switchTab({ url: '/pages/index/index' })
			}
		})
	} else {
		// 没有上一页（外部链接直接进入等场景），直接跳首页兜底
		uni.switchTab({ url: '/pages/index/index' })
	}
}

/**
 * 处理分享
 */
const handleShare = async () => {
	if (checkUserLogin() == false) {
		uni.navigateTo({ url: '/pagesUser/login/index' })
		return
	}

	// 🔧 修复：直接从 info.value 构建分享数据，避免 prepareShareDataFn 中 ref 访问问题
	try {
		// 获取用户信息
		const infoVal = info.value
		const userKid = guiderKid.value
		
		// 安全获取用户信息字段
		const nicknameVal = infoVal.get('nickname')
		const nicknameStr = (nicknameVal != null && nicknameVal.toString() != '') ? nicknameVal.toString() : '用户'
		
		const signatureVal = infoVal.get('signature')
		const signatureStr = (signatureVal != null && signatureVal.toString() != '') ? signatureVal.toString() : ''
		
		const liveCityVal = infoVal.get('liveCity')
		const liveCityStr = (liveCityVal != null && liveCityVal.toString() != '') ? liveCityVal.toString() : ''
		
		const birthPlaceVal = infoVal.get('birthPlace')
		const birthPlaceStr = (birthPlaceVal != null && birthPlaceVal.toString() != '') ? birthPlaceVal.toString() : ''
		
		const sexVal = infoVal.get('sex')
		const sexStr = (sexVal != null) ? sexVal.toString() : ''
		
		const imageVal = infoVal.get('image')
		const imageStr = (imageVal != null && imageVal.toString() != '') ? imageVal.toString() : DEFAULT_SHARE_IMAGE
		
		// 构建分享标题：昵称的个人主页
		const shareTitle = nicknameStr + '的个人主页'
		
		// 构建分享描述：优先使用个性签名，否则使用默认描述
		let shareDesc = ''
		if (signatureStr != '') {
			shareDesc = signatureStr
		} else {
			const cityPart = (liveCityStr != '') ? liveCityStr : ((birthPlaceStr != '') ? birthPlaceStr : '远方')
			const genderPart = (sexStr == '女') ? '女生' : ((sexStr == '男') ? '男生' : 'TA')
			shareDesc = '来自' + cityPart + '的' + genderPart + '，欢迎关注！'
		}
		
		// 构建分享链接
		let shareLink = 'https://m.wyxdapp.com/#/pagesUser/persionInfo/index'
		if (userKid != '') {
			shareLink = shareLink + '?id=' + userKid
		}
		
		// 获取推广短号
		let referrerShortKid = ''
		try {
			referrerShortKid = getUserShortKid()
			// fallback：如果 userStore 中没有 shortKid，尝试从当前用户主页信息获取
			if (referrerShortKid == '') {
				const currentUserKidVal = getCurrentUserKid()
				// 分享时 referrerShortKid 应该是当前登录用户的短号，不是被查看用户的
				if (currentUserKidVal != '' && currentUserKidVal == userKid) {
					const infoShortKid = getInfoStringProperty(infoVal, 'shortKid')
					if (infoShortKid != '') {
						referrerShortKid = infoShortKid
					}
				}
				// 从缓存的当前用户 profile 中获取 shortKid
				if (referrerShortKid == '' && currentUserKidVal != '') {
					try {
						const cachedMyProfile = getCachedProfile(currentUserKidVal, currentUserKidVal)
						if (cachedMyProfile != null) {
							const cachedShortKidVal = cachedMyProfile.get('shortKid')
							if (cachedShortKidVal != null && cachedShortKidVal.toString() != '') {
								referrerShortKid = cachedShortKidVal.toString()
								// 同步到 userStore 和 localStorage，后续分享不再需要此 fallback
								updateUserInfoAction({ shortKid: referrerShortKid } as UTSJSONObject)
								try {
									uni.setStorageSync('user_shortKid_' + currentUserKidVal, referrerShortKid)
								} catch (e3) {}
							}
						}
					} catch (e2) {}
				}
				// 如果还是空，尝试从 localStorage 缓存获取
				if (referrerShortKid == '' && currentUserKidVal != '') {
					try {
						const storedInfo = uni.getStorageSync('user_shortKid_' + currentUserKidVal) as string
						if (storedInfo != null && storedInfo != '') {
							referrerShortKid = storedInfo
						}
					} catch (e2) {}
				}
			}
			if (referrerShortKid != '') {
				// 添加推广参数到链接
				if (shareLink.indexOf('?') >= 0) {
					shareLink = shareLink + '&ref=' + referrerShortKid
				} else {
					shareLink = shareLink + '?ref=' + referrerShortKid
				}
			}
		} catch (e) {
			handleSilentError(e, '[handleShare] 获取推广短号')
		}
		
		// 构建分享数据
		const newPayload: UTSJSONObject = {
			title: shareTitle,
			summary: shareDesc,
			desc: shareDesc,
			link: shareLink,
			url: shareLink,
			imageUrl: imageStr,
			userId: userKid,
			referrerShortKid: referrerShortKid
		}
		
		sharePayload.value = newPayload
		
	} catch (e) {
		handleSilentError(e, '[handleShare] 构建分享数据')
		// 使用默认值
		sharePayload.value = {
			title: '网约向导',
			summary: '发现有趣的向导',
			desc: '发现有趣的向导',
			link: 'https://m.wyxdapp.com/',
			url: 'https://m.wyxdapp.com/',
			imageUrl: DEFAULT_SHARE_IMAGE,
			userId: '',
			referrerShortKid: ''
		}
	}

	// 获取会话列表（异步请求） - 允许失败但仍显示弹窗
	try {
		const result = await getChatListFn(userStore)
		try {
			// 如果返回的是数组，直接使用；否则尝试从模块级 chatList ref 中读取
			if (result != null && Array.isArray(result) == true) {
				shareChatList.value = result as Array<UTSJSONObject>
			} else {
				// fallback: 安全解析模块级 chatList（兼容 ref / 包装对象）
				try {
					let fallbackArr: Array<UTSJSONObject> = []
					try {
						// 先尝试直接解析为数组
						try {
							const rawParsed = JSON.parse(JSON.stringify(chatList))
							if (Array.isArray(rawParsed) == true) {
								fallbackArr = rawParsed as Array<UTSJSONObject>
							}
						} catch (e) {
							handleSilentError(e, '[PersionInfo] 解析chatList原始数据(分享)')
						}

						// 如果不是直接数组，尝试通过 toJsonObj 安全读取 value 或 list 字段
						if (fallbackArr.length == 0) {
							try {
								const chatListObj = toJsonObj(chatList)
								if (chatListObj != null) {
									try {
										const v = chatListObj.get('value')
										if (v != null) {
											try {
												const parsedV = JSON.parse(JSON.stringify(v))
												if (Array.isArray(parsedV) == true) {
													fallbackArr = parsedV as Array<UTSJSONObject>
												}
											} catch (e) {
												handleSilentError(e, '[PersionInfo] 解析chatList.value(分享)')
											}
										}
									} catch (e) {
										handleSilentError(e, '[PersionInfo] 获取chatList.value(分享)')
									}
									try {
										const l = chatListObj.get('list')
										if (l != null) {
											try {
												const parsedL = JSON.parse(JSON.stringify(l))
												if (Array.isArray(parsedL) == true) {
													fallbackArr = parsedL as Array<UTSJSONObject>
												}
											} catch (e) {
												handleSilentError(e, '[PersionInfo] 解析chatList.list(分享)')
											}
										}
									} catch (e) {
										handleSilentError(e, '[PersionInfo] 获取chatList.list(分享)')
									}
								}
							} catch (e) {
								handleSilentError(e, '[PersionInfo] 转换chatList为JSON对象(分享)')
							}
						}
					} catch (e) {
						handleSilentError(e, '[PersionInfo] 解析chatList降级处理(分享)')
					}
					shareChatList.value = (fallbackArr.length > 0) ? fallbackArr : []
				} catch (e) {
					shareChatList.value = []
				}
			}
		} catch (e) {
			handleSilentError(e, '[PersionInfo] 会话列表赋值')
		}
	} catch (e) {
		handleSilentError(e, '获取会话列表')
		shareChatList.value = []
	}

	showSharePopup.value = true
}

/**
 * 分享到聊天
 */
const handleShareToChat = (data: UTSJSONObject | null) => {
	handleShareToChatFn(data as any, info.value as any)
}

/**
 * 分享到微信
 */
const handleShareWechat = () => {
	handleShareWechatFn(getShareDataValue())
}

/**
 * 分享到朋友圈
 */
const handleShareMoments = () => {
	handleShareMomentsFn(getShareDataValue())
}

/**
 * 复制链接
 */
const handleCopyLink = () => {
	handleCopyLinkFn(getShareDataValue())
}

/**
 * 显示二维码
 */
const handleShowQrcode = () => {
	handleShowQrcodeFn(getShareDataValue())
}

/**
 * H5 打开 App
 * 注意：微信环境检测已在 H5TopBar 组件中处理，此函数仅在非微信环境下被调用
 */
const handleOpenApp = () => {
	try {
		// handleAppFn 第四个参数为微信检测回调，由于 H5TopBar 已处理微信环境，这里传 null
		handleAppFn(info, guiderKid, userStore, null)
	} catch (e) {
		handleSilentError(e, 'handleOpenApp')
	}
}

/**
 * 处理聊天
 */
const handleChat = () => {
	if (checkUserLogin() == false) {
		uni.navigateTo({ url: '/pagesUser/login/index' })
		return
	}
	
	const infoValueKidForChat = getInfoStringProperty(info.value, 'kid')
	const targetUserId = (infoValueKidForChat != '') ? infoValueKidForChat : guiderKid.value
	if (targetUserId == '') {
		uni.showToast({ title: '用户信息异常，无法开始聊天', icon: 'none' })
		return
	}
	
	uni.navigateTo({ url: '/pagesTrade/news/detail?targetUserId=' + targetUserId })
}

/**
 * 跳转到预约页面
 */
const handleGoToSubmitOrder = () => {
	if (checkUserLogin() == false) {
		uni.showToast({ title: '请先登录', icon: 'none' })
		safeSetTimeout(() => {
			uni.navigateTo({ url: '/pagesUser/login/index' })
		}, 1500)
		return
	}
	
	const infoKidForOrder = getInfoStringProperty(info.value, 'kid')
	if (infoKidForOrder == '') {
		uni.showToast({ title: '向导信息不存在', icon: 'none' })
		return
	}
	
	// 构建URL参数
	const queryParts: string[] = []
	queryParts.push('guiderKid=' + encodeURIComponent(infoKidForOrder))
	
	const servicePriceVal = getInfoStringProperty(info.value, 'servicePrice')
	if (servicePriceVal != '') {
		// 提取纯数字部分，避免中文字符在微信小程序URL参数中编解码异常
		// 使用逐字符过滤确保编译后代码正确（replace正则在某些编译目标下可能被优化掉）
		let priceNumStr = ''
		let i = 0
		while (i < servicePriceVal.length) {
			const ch = servicePriceVal.charAt(i)
			if ((ch >= '0' && ch <= '9') || ch == '.') {
				priceNumStr = priceNumStr + ch
			}
			i = i + 1
		}
		if (priceNumStr != '') {
			queryParts.push('price=' + encodeURIComponent(priceNumStr))
		}
	}
	
	const liveCityVal = getInfoStringProperty(info.value, 'liveCity')
	if (liveCityVal != '') {
		queryParts.push('city=' + encodeURIComponent(liveCityVal))
	}
	
	uni.navigateTo({ url: '/pagesUser/persionInfo/submitOrder?' + queryParts.join('&') })
}

// ==================== VIP 和礼物图标点击事件 ====================

/**
 * VIP图标点击 - 跳转VIP页面
 */
const handleVipClick = () => {
	// 🔧 新增：检查会员功能是否开启
	if (isMemberFeatureEnabled() == false) {
		uni.showToast({
			title: '会员功能暂未开放',
			icon: 'none'
		})
		return
	}
	
	uni.navigateTo({
		url: '/pagesUser/my/proveDetails/vip'
	})
}

// ==================== 生命周期 ====================

// ==================== 微信小程序分享钩子 ====================
// #ifdef MP-WEIXIN
onShareAppMessage((): UTSJSONObject => {
	const data = buildMpShareData()
	const title = data.get('title')
	const path = data.get('path')
	const imageUrl = data.get('imageUrl')
	return {
		title: (title != null) ? title.toString() : '网约向导 - 个人主页',
		path: (path != null) ? path.toString() : '/pagesUser/persionInfo/index',
		imageUrl: (imageUrl != null) ? imageUrl.toString() : DEFAULT_SHARE_IMAGE_LOCAL
	}
})

onShareTimeline((): UTSJSONObject => {
	const data = buildMpShareData()
	const title = data.get('title')
	const imageUrl = data.get('imageUrl')
	const path = data.get('path')
	// 从 path 中提取 query 参数（去掉路径前缀和 ?）
	const pathStr = (path != null) ? path.toString() : ''
	const queryIndex = pathStr.indexOf('?')
	const queryStr = (queryIndex >= 0) ? pathStr.substring(queryIndex + 1) : ''
	return {
		title: (title != null) ? title.toString() : '网约向导 - 个人主页',
		query: queryStr,
		imageUrl: (imageUrl != null) ? imageUrl.toString() : DEFAULT_SHARE_IMAGE_LOCAL
	}
})
// #endif

onLoad((options: OnLoadOptions) => {
	// 主动调用 initUserInfoAction 确保用户信息被初始化
	initUserInfoAction()

	// 初始化页面布局
	initPageLayout()
	
	// 使用 pageWindowHeight 计算 scroll-view 高度
	if (pageWindowHeight.value > 0) {
		// #ifdef H5
		// H5端需要减去顶部导航栏高度（90rpx = 45px）
		scrollViewHeight.value = pageWindowHeight.value - 45
		// #endif
		// #ifndef H5
		scrollViewHeight.value = pageWindowHeight.value
		// #endif
	} else {
		// 默认高度
		scrollViewHeight.value = 800
	}
	
	// 获取用户ID参数（统一使用 id 参数，其他参数名作为兼容）
	let incomingId = ''
	const idVal = getOptionsStringProp(options, 'id')
	
	if (idVal != '') {
		incomingId = idVal
	} else {
		// 兼容旧参数名
		const kidVal = getOptionsStringProp(options, 'kid')
		const userIdVal = getOptionsStringProp(options, 'userId')
		const userKidVal = getOptionsStringProp(options, 'userKid')
		if (kidVal != '') {
			incomingId = kidVal
		} else if (userIdVal != '') {
			incomingId = userIdVal
		} else if (userKidVal != '') {
			incomingId = userKidVal
		}
	}
	
	// H5 场景兜底（统一使用 id 参数）
	// #ifdef H5
	if (incomingId == '') {
		const safeUrlParams = getUrlParams()
		const idVal2 = safeUrlParams.get('id')
		if (idVal2 != null && idVal2 != '') {
			incomingId = idVal2
		} else {
			// 兼容旧参数名
			const kidVal2 = safeUrlParams.get('kid')
			const userIdVal2 = safeUrlParams.get('userId')
			const userKidVal2 = safeUrlParams.get('userKid')
			if (kidVal2 != null && kidVal2 != '') {
				incomingId = kidVal2
			} else if (userIdVal2 != null && userIdVal2 != '') {
				incomingId = userIdVal2
			} else if (userKidVal2 != null && userKidVal2 != '') {
				incomingId = userKidVal2
			}
		}
	}
	// #endif
	
	if (incomingId == '') {
		console.error('个人主页缺少必要参数')
		uni.showToast({ title: '用户id参数缺失', icon: 'none' })
		safeSetTimeout(() => { uni.navigateBack() }, 1500)
		return
	}
	
	guiderKid.value = incomingId
	trendsPageInfo.value.userKid = incomingId
	routePageInfo.value.userKid = incomingId
	
	// 处理推广链接（解析 ref 参数并绑定推荐人）
	handlePromotionLink(options, incomingId)
	
	// 加载用户信息
	initDataWithCache(incomingId)
	
	// 加载用户动态
	initUserTrendsWithLocation()
	
	// 处理自动跳转APP逻辑
	handleAutoJumpToAppFn(options, guiderKid, userStore)
})

onShow(() => {
	if (guiderKid.value == '') {
		return
	}

	// 记录访客（无论是否登录都记录）
	recordVisitor(viewerKid, guiderKid)

	// 刷新用户信息
	initDataWithCache(guiderKid.value)
})

onUnmounted(() => {
	clearAllTimers()
})
</script>

