<template>
	<view class="page">
		<!-- 顶部渐变背景 -->
		<view class="hear-bg" :style="headerGradientOuter()"><view class="hear-bg-mask" :style="headerGradientMask()"></view></view>
		<!-- #ifndef H5 -->
		<!-- APP端导航栏 -->
		<view class="nav-bar" :style="{ paddingTop: statusBarHeight + 'px' }">
			<view class="nav-content">
				<view class="nav-back" @click="goBack">
					<uni-icons type="back" size="22" color="#333333"></uni-icons>
				</view>
				<text class="nav-title">预约</text>
				<view class="nav-share" @click="handleShare">
					<image src="https://jiasu.wyxdapp.com/iconimages/fenxiang.png" mode="aspectFit" class="nav-icon"></image>
				</view>
			</view>
		</view>
		<!-- #endif -->
		
		<!-- #ifndef H5 -->
		<!-- APP端滚动内容 -->
		<scroll-view class="scroll-view" :scroll-y="true" :scroll-with-animation="true">
		<!-- #endif -->
		<!-- #ifdef H5 -->
		<!-- H5端滚动内容 -->
		<scroll-view class="scroll-view-h5" :scroll-y="true" :scroll-with-animation="true">
		<!-- #endif -->
			
			<!-- 城市选择 -->
			<view class="section-card bg-white">
				<view class="section-header">
					<text class="fs-lg color-title font-bold">游玩城市</text>
					<view class="city-selector-btn" @click="openCitySelector">
						<text class="city-name">{{ cityName }}</text>
						<text class="arrow-icon">›</text>
					</view>
				</view>
			</view>
			
			<!-- 日期天数 -->
			<view class="section-card bg-white">
				<view class="section-header">
					<text class="fs-lg color-title font-bold">日期天数</text>
					<view class="days-selector-inline">
						<view class="number-btn" @click="decreaseDays">
							<text class="btn-text">-</text>
						</view>
						<text class="days-value">{{formServiceHours}}</text>
						<view class="number-btn" @click="increaseDays">
							<text class="btn-text">+</text>
						</view>
					</view>
				</view>
				<DatePicker 
					v-model="chooseDate"
					:minDate="minDate"
					:maxDate="maxDate"
					@change="handleDateChange"
				/>
			</view>
			
			<!-- 联系方式 -->
			<view class="section-card bg-white">
				<view class="section-header">
					<text class="fs-lg color-title font-bold">联系方式</text>
					<view class="more-btn" @click="showContactSelector = true">
						<text class="more-btn-text">新增</text>
						<text class="arrow-icon">›</text>
					</view>
				</view>
				
				<!-- 联系人卡片列表 -->
				<view class="contact-cards">
					<view 
						v-for="(contact, index) in displayContacts" 
						:key="getContactKid(contact)"
						class="contact-card"
						:class="{ 'contact-card--active': isContactSelected(contact) }"
						@click="selectContact(contact)"
					>
						<text class="contact-name">{{ getContactName(contact) }}</text>
					</view>
				</view>
				
				<!-- 已选联系人信息 -->
				<view v-if="hasSelectedContact" class="selected-contact-info">
					<view class="contact-detail">
						<text class="label">游客</text>
						<text class="info">{{ selectedContactName }} {{ selectedContactPhone }}</text>
				</view>
					<text class="delete-btn" @click="handleClearContact">删除</text>
				</view>
				
				<!-- 备注输入 -->
				<view class="remark-box">
					<textarea 
						v-model="formOrderRemarks"
						class="remark-input"
						placeholder="备注："
						maxlength="20"
						:auto-height="true"
					/>
					<text class="char-count">{{ orderRemarksLength }}/20</text>
				</view>
			</view>
			
			<!-- 预算(元) -->
			<view class="section-card bg-white">
				<view class="section-header">
					<text class="fs-lg color-title font-bold">预算(元)</text>
					<input 
						class="budget-input"
						type="number"
						:value="formTotalMoneyStr" 
						placeholder="请输入金额"
						placeholder-class="placeholder"
						@input="handleBudgetInput($event as UniInputEvent)" />
				</view>
			</view>
		</scroll-view>
		
		<!-- 固定底部 -->
		<view class="footer-bar bg-white">
			<view class="price-info">
				<text class="price-label">费用：</text>
				<text class="price-value">¥ {{ displayPrice }}</text>
			</view>
			<view 
				class="submit-btn"
				@click="handleSubmitOrder"
			>
				<text class="submit-text">确定</text>
			</view>
		</view>
		

		<!-- 联系人选择弹窗 -->
		<ContactSelector 
			:show="showContactSelector"
			:contactList="contactListForSelector"
			:selectedContactId="contactId"
			@close="closeContactSelector"
			@select="handleContactSelect"
			@add="openAddContactPopup"
			@delete="handleDeleteContactFromSelector"
			@update:show="closeContactSelector"
		/>
		
		<!-- 分享弹窗 -->
		<SharePopup 
			:visity="showSharePopup"
			:shareData="shareData"
			@update:visity="closeSharePopup"
		/>
		
		<!-- 新增联系人弹窗 -->
		<view v-if="addContactVisity == true" class="add-contact-mask">
			<view class="add-contact-popup" @click.stop>
				<!-- 头部 -->
				<view class="add-popup-header">
					<text class="add-popup-title">新增联系人</text>
					<view class="add-close-btn" @click="closeAddContactPopup">
						<text class="add-close-icon">×</text>
					</view>
				</view>
				
				<!-- 表单 -->
				<view class="add-form">
					<view class="add-form-item">
						<text class="add-form-label">姓名</text>
						<input 
							class="add-form-input"
							type="text"
							v-model="addFormName"
							placeholder="请输入联系人姓名"
							placeholder-class="placeholder"
						/>
					</view>
					<view class="add-form-item">
						<text class="add-form-label">手机号</text>
						<input 
							class="add-form-input"
							type="number"
							v-model="addFormPhone"
							placeholder="请输入手机号码"
							placeholder-class="placeholder"
							maxlength="11"
						/>
					</view>
				</view>
				
				<!-- 底部按钮 -->
				<view class="add-popup-footer">
					<view class="add-cancel-btn" @click="closeAddContactPopup">
						<text class="add-cancel-text">取消</text>
					</view>
					<view class="add-confirm-btn" @click="confirmAddContact">
						<text class="add-confirm-text">确定</text>
					</view>
				</view>
			</view>
		</view>
	</view>
</template>

<script setup lang="uts">
import { ref, computed, onMounted, onUnmounted, watch } from 'vue'
import { onLoad, onShow } from '@dcloudio/uni-app'
import { handlePageError, handleSilentError } from '@/common/utils/errorHandler.uts'
import UniIcons from '@/components/base/UniIcons.uvue'
import DatePicker from '@/components/business/DatePicker.uvue'
import ContactSelector from '@/components/business/ContactSelector.uvue'
import SharePopup from '@/components/common/SharePopup.uvue'
import { 
	checkUserLoginReliable, 
	getCurrentUserIdReliable 
} from '@/common/utils/loginHelper.uts'
import { 
	getContactList, 
	addTravelUser, 
	updateTravelUser, 
	delTravelUser, 
	setDefaultTravelUser,
	createGrabOrder,
	updateGrabOrder,
	getGuiderOrderInfo,
	GetContactListParams,
	AddTravelUserParams,
	DelTravelUserParams,
	UpdateGrabOrderParams,
	OrderDetailsParams,
	CreateGrabOrderParams
} from '@/api/order.uts'
import { checkPaymentRoute } from '@/utils/paymentRouter'
import { partnerWechatAppPay, partnerAlipayAppPay } from '@/api/openPlatform'
import { headerGradientOuter, headerGradientMask } from '@/common/utils/themeHelper.uts'
import { DEFAULT_SHARE_IMAGE } from '@/common/config/defaultImages.uts'

// 状态栏高度
const statusBarHeight = ref<number>(44)

// 联系人数据类
class ContactItemData {
	kid: string = ''
	name: string = ''
	phone: string = ''
	is_default: number = 0
	isDefault: number = 0
	
	constructor() {}
}

// 页面状态
const cityName = ref<string>('长沙市')
const chooseDate = ref<string>('')
// showCityPicker 已移除，不再使用 CityPicker 组件
const showContactSelector = ref<boolean>(false)
const showSharePopup = ref<boolean>(false)
const minDate = ref<string>('2022-01-01')
const maxDate = ref<string>('2050-01-01')

// 辅助函数 - 获取用户ID（使用 loginHelper 可靠版本）
const getCurrentUserKid = (): string => {
	return getCurrentUserIdReliable()
}

// 辅助函数 - 检查登录状态（使用 loginHelper 可靠版本）
const checkUserLogin = (): boolean => {
	return checkUserLoginReliable()
}

// 表单数据
const formServiceHours = ref<number>(1)
const formOrderRemarks = ref<string>('')
const formPhone = ref<string>('')
const formRealname = ref<string>('')
const formTotalMoney = ref<number>(0)
const formTotalMoneyStr = ref<string>('')  // 用于 input v-model 绑定
const formOrderLocation = ref<string>('')

// 兼容旧代码的 formData 对象
const formData = computed((): UTSJSONObject => {
	const raw = {
		serviceHours: formServiceHours.value,
		orderRemarks: formOrderRemarks.value,
		phone: formPhone.value,
		realname: formRealname.value,
		totalMoney: formTotalMoney.value,
		orderLocation: formOrderLocation.value
	} as UTSJSONObject
	return raw
})

// 联系人相关
const contactList = ref<Array<ContactItemData>>([])
const contactId = ref<string>('')
const addContactVisity = ref<boolean>(false)
const editContactVisity = ref<boolean>(false)
const addFormName = ref<string>('')
const addFormPhone = ref<string>('')
const editFormName = ref<string>('')
const editFormPhone = ref<string>('')

// 兼容旧代码
const addFormData = computed((): UTSJSONObject => {
	const raw = { name: addFormName.value, phone: addFormPhone.value } as UTSJSONObject
	return raw
})
const editFormData = computed((): UTSJSONObject => {
	const raw = { name: editFormName.value, phone: editFormPhone.value } as UTSJSONObject
	return raw
})

// 提交状态
const orderKid = ref<string>('')
const guiderKid = ref<string>('')
const isLocalSubmitting = ref<boolean>(false)

// 统一的提交状态
const isSubmit = computed((): boolean => {
	return isLocalSubmitting.value == true
})

// 计算属性 - 联系人显示（最多显示3个）
const displayContacts = computed((): Array<ContactItemData> => {
	try {
		const result: Array<ContactItemData> = []
		const maxCount = 3
		const listLen = contactList.value.length
		let i = 0
		while (i < listLen && i < maxCount) {
			result.push(contactList.value[i])
			i = i + 1
		}
		return result
	} catch (e) {
		return [] as Array<ContactItemData>
	}
})

// 计算属性 - 转换为普通对象数组供 ContactSelector 使用（解决 APP 端 JSON.stringify 类实例问题）
const contactListForSelector = computed((): Array<UTSJSONObject> => {
	try {
		const result: Array<UTSJSONObject> = []
		const listLen = contactList.value.length
		let i = 0
		while (i < listLen) {
			const item = contactList.value[i]
			// 手动构建普通对象
			const plainObj = {
				kid: item.kid,
				name: item.name,
				phone: item.phone,
				is_default: item.is_default,
				isDefault: item.isDefault
			} as UTSJSONObject
			result.push(plainObj)
			i = i + 1
		}
		return result
	} catch (e) {
		return [] as Array<UTSJSONObject>
	}
})

// 是否有选中的联系人
const hasSelectedContact = computed((): boolean => {
	return formPhone.value != '' && formRealname.value != ''
})

// 选中联系人的名字
const selectedContactName = computed((): string => {
	return formRealname.value
})

// 选中联系人的电话
const selectedContactPhone = computed((): string => {
	return formPhone.value
})

// 备注长度
const orderRemarksLength = computed((): number => {
	return formOrderRemarks.value.length
})

// 显示价格
const displayPrice = computed((): string => {
	try {
		const money = formTotalMoney.value
		if (money != null && money > 0) {
			const cents = Math.round(money * 100)
			const yuan = Math.floor(cents / 100)
			const fen = cents % 100
			const fenStr = (fen < 10) ? ('0' + fen.toString()) : fen.toString()
			return yuan.toString() + '.' + fenStr
		}
		return '0.00'
	} catch (e) {
		return '0.00'
	}
})

// 辅助函数 - 获取联系人kid
const getContactKid = (contact: UTSJSONObject | ContactItemData): string => {
	if (contact == null) return ''
	try {
		// 尝试直接访问类属性
		const contactItem = contact as ContactItemData
		if (contactItem.kid != null && contactItem.kid != '') {
			return contactItem.kid
		}
		// 回退到 JSON 序列化方式
		const contactStr = JSON.stringify(contact)
		const contactObj = JSON.parse(contactStr) as UTSJSONObject
		const kidVal = contactObj.get('kid')
		return (kidVal != null) ? kidVal.toString() : ''
	} catch (e) {
		return ''
	}
}

// 辅助函数 - 获取联系人名字
const getContactName = (contact: UTSJSONObject | ContactItemData): string => {
	if (contact == null) return ''
	try {
		// 尝试直接访问类属性
		const contactItem = contact as ContactItemData
		if (contactItem.name != null && contactItem.name != '') {
			return contactItem.name
		}
		// 回退到 JSON 序列化方式
		const contactStr = JSON.stringify(contact)
		const contactObj = JSON.parse(contactStr) as UTSJSONObject
		const nameVal = contactObj.get('name')
		return (nameVal != null) ? nameVal.toString() : ''
	} catch (e) {
		return ''
	}
}

// 辅助函数 - 获取联系人电话
const getContactPhone = (contact: UTSJSONObject | ContactItemData): string => {
	if (contact == null) return ''
	try {
		// 尝试直接访问类属性
		const contactItem = contact as ContactItemData
		if (contactItem.phone != null && contactItem.phone != '') {
			return contactItem.phone
		}
		// 回退到 JSON 序列化方式
		const contactStr = JSON.stringify(contact)
		const contactObj = JSON.parse(contactStr) as UTSJSONObject
		const phoneVal = contactObj.get('phone')
		return (phoneVal != null) ? phoneVal.toString() : ''
	} catch (e) {
		return ''
	}
}

// 关闭联系人选择器
const closeContactSelector = () => {
	showContactSelector.value = false
}

// 返回
const goBack = () => {
	uni.navigateBack()
}

// 初始化最小日期（4天后）- 必须在 initPageData 之前定义
const initMinDate = () => {
	const nowDate = new Date()
	nowDate.setDate(nowDate.getDate() + 4)
	const monthNum = nowDate.getMonth() + 1
	const dayNum = nowDate.getDate()
	const nowMon = (monthNum < 10) ? ('0' + monthNum.toString()) : monthNum.toString()
	const nowDay = (dayNum < 10) ? ('0' + dayNum.toString()) : dayNum.toString()
	minDate.value = nowDate.getFullYear().toString() + '-' + nowMon + '-' + nowDay
}

// 初始化状态栏高度
const initStatusBarHeight = () => {
	// #ifndef H5
	// APP端获取状态栏高度
	try {
		const systemInfo = uni.getSystemInfoSync()
		const systemInfoStr = JSON.stringify(systemInfo)
		const systemInfoObj = JSON.parse(systemInfoStr) as UTSJSONObject
		const statusBarVal = systemInfoObj.get('statusBarHeight')
		if (statusBarVal != null) {
			const sbHeight = parseInt(statusBarVal.toString())
			if (isNaN(sbHeight) == false && sbHeight > 0) {
				statusBarHeight.value = sbHeight
			}
		}
	} catch (e) {
		statusBarHeight.value = 44
	}
	// #endif
}

// 分享功能
const handleShare = () => {
	showSharePopup.value = true
}

// 关闭分享弹窗
const closeSharePopup = () => {
	showSharePopup.value = false
}

// 分享数据
const shareData = computed((): UTSJSONObject => {
	const data = {
		title: '找向导 - 网约向导趣游玩',
		desc: '发现专业向导，定制专属行程',
		summary: '发现专业向导，定制专属行程',
		imageUrl: DEFAULT_SHARE_IMAGE,
		url: 'https://m.wyxdapp.com/#/pagesUser/submitOrder/index',
		link: 'https://m.wyxdapp.com/#/pagesUser/submitOrder/index'
	} as UTSJSONObject
	return data
})

// 获取联系人列表 - 必须在 initPageData 之前定义
const Get_contact_list = async () => {
	// 未登录时不获取联系人列表
	const isLogin = checkUserLogin()
	if (isLogin == false) {
		return
	}
	
	const userIdVal = getCurrentUserKid()
	if (userIdVal == '') {
		return
	}
	
	try {
		const params = new GetContactListParams()
		params.userKid = userIdVal
		const res = await getContactList(params)
		
		// 清空列表
		contactList.value = [] as Array<ContactItemData>
		
		// 安全解析响应数据
		const resStr = JSON.stringify(res)
		const resObj = JSON.parse(resStr) as UTSJSONObject
		
		// 尝试获取数据数组
		let entitiesArr: Array<UTSJSONObject> = []
		const dataVal = resObj.get('data')
		if (dataVal != null) {
			if (Array.isArray(dataVal) == true) {
				entitiesArr = dataVal as Array<UTSJSONObject>
			} else {
				const dataStr = JSON.stringify(dataVal)
				const dataObj = JSON.parse(dataStr) as UTSJSONObject
				const entitiesVal = dataObj.get('entities')
				if (entitiesVal != null && Array.isArray(entitiesVal) == true) {
					entitiesArr = entitiesVal as Array<UTSJSONObject>
				} else {
					const innerDataVal = dataObj.get('data')
					if (innerDataVal != null) {
						if (Array.isArray(innerDataVal) == true) {
							entitiesArr = innerDataVal as Array<UTSJSONObject>
						} else {
							const innerDataStr = JSON.stringify(innerDataVal)
							const innerDataObj = JSON.parse(innerDataStr) as UTSJSONObject
							const innerEntitiesVal = innerDataObj.get('entities')
							if (innerEntitiesVal != null && Array.isArray(innerEntitiesVal) == true) {
								entitiesArr = innerEntitiesVal as Array<UTSJSONObject>
							}
						}
					}
				}
			}
		}
		
		// 处理联系人数据
		const resultList: Array<ContactItemData> = []
		const arrLen = entitiesArr.length
		let idx = 0
		while (idx < arrLen) {
			const item = entitiesArr[idx]
			if (item != null) {
				const itemStr = JSON.stringify(item)
				const itemObj = JSON.parse(itemStr) as UTSJSONObject
				
				// 获取 kid
				let kidResult = ''
				const kidVal = itemObj.get('kid')
				const idVal = itemObj.get('id')
				if (kidVal != null && kidVal.toString() != '') {
					kidResult = kidVal.toString()
				} else if (idVal != null && idVal.toString() != '') {
					kidResult = idVal.toString()
				}
				
				// 获取 name
				let nameResult = ''
				const nameVal = itemObj.get('name')
				const realnameVal = itemObj.get('realname')
				const realNameVal = itemObj.get('realName')
				const travellerNameVal = itemObj.get('travellerName')
				if (nameVal != null && nameVal.toString() != '') {
					nameResult = nameVal.toString()
				} else if (realnameVal != null && realnameVal.toString() != '') {
					nameResult = realnameVal.toString()
				} else if (realNameVal != null && realNameVal.toString() != '') {
					nameResult = realNameVal.toString()
				} else if (travellerNameVal != null && travellerNameVal.toString() != '') {
					nameResult = travellerNameVal.toString()
				}
				
				// 获取 phone
				let phoneResult = ''
				const phoneVal = itemObj.get('phone')
				const phoneNumberVal = itemObj.get('phoneNumber')
				const travellerPhoneVal = itemObj.get('travellerPhone')
				const mobileVal = itemObj.get('mobile')
				if (phoneVal != null && phoneVal.toString() != '') {
					phoneResult = phoneVal.toString()
				} else if (phoneNumberVal != null && phoneNumberVal.toString() != '') {
					phoneResult = phoneNumberVal.toString()
				} else if (travellerPhoneVal != null && travellerPhoneVal.toString() != '') {
					phoneResult = travellerPhoneVal.toString()
				} else if (mobileVal != null && mobileVal.toString() != '') {
					phoneResult = mobileVal.toString()
				}
				
				// 获取默认值
				let defaultValue = 0
				const isDefaultVal = itemObj.get('is_default')
				const isDefaultVal2 = itemObj.get('isDefault')
				const defaultFlagVal = itemObj.get('defaultFlag')
				const defaultStatusVal = itemObj.get('defaultStatus')
				let flagVal: string | number | null = ''
				if (isDefaultVal != null) {
					flagVal = isDefaultVal
				} else if (isDefaultVal2 != null) {
					flagVal = isDefaultVal2
				} else if (defaultFlagVal != null) {
					flagVal = defaultFlagVal
				} else if (defaultStatusVal != null) {
					flagVal = defaultStatusVal
				}
				if (flagVal != null) {
					const flagNum = parseInt(flagVal.toString())
					if (isNaN(flagNum) == false && flagNum == 10) {
						defaultValue = 10
					}
				}
				
				// 只添加有效数据
				if (kidResult != '' && nameResult != '' && phoneResult != '') {
					const contactItem = new ContactItemData()
					contactItem.kid = kidResult
					contactItem.name = nameResult
					contactItem.phone = phoneResult
					contactItem.is_default = defaultValue
					contactItem.isDefault = defaultValue
					resultList.push(contactItem)
				}
			}
			idx = idx + 1
		}
		
		// 排序：默认联系人排前面
		resultList.sort((a: ContactItemData, b: ContactItemData): number => {
			const aIsDefault = (a.is_default == 10 || a.isDefault == 10)
			const bIsDefault = (b.is_default == 10 || b.isDefault == 10)
			const ad = (aIsDefault == true) ? 0 : 1
			const bd = (bIsDefault == true) ? 0 : 1
			return ad - bd
		})
		
		contactList.value = resultList
		
		// 自动选择第一个联系人（如果没有已选择的联系人）
		if (formPhone.value == '' && contactList.value.length > 0) {
			const first = contactList.value[0]
			formRealname.value = first.name
			formPhone.value = first.phone
			contactId.value = first.kid
		}
		
		addContactVisity.value = false
	} catch (error) {
		handlePageError(error, '获取联系人列表', null)
	}
}

// 获取订单详情（编辑模式）
const Get_order_details = async () => {
	const orderKidVal = orderKid.value
	if (orderKidVal == null || orderKidVal == '') return
	
	try {
		const orderDetailsParams = new OrderDetailsParams()
		orderDetailsParams.orderKid = orderKidVal
		const res = await getGuiderOrderInfo(orderDetailsParams)
		
		// 安全解析响应数据
		const resStr = JSON.stringify(res)
		const resObj = JSON.parse(resStr) as UTSJSONObject
		let dataObj: UTSJSONObject | null = null
		
		const dataVal = resObj.get('data')
		if (dataVal != null) {
			const dataStr = JSON.stringify(dataVal)
			dataObj = JSON.parse(dataStr) as UTSJSONObject
		} else {
			dataObj = resObj
		}
		
		if (dataObj == null) return
		
		// 解析游玩天数
		let serviceHours = 1
		const travelTotalTimeVal = dataObj.get('travelTotalTime')
		if (travelTotalTimeVal != null) {
			const travelTotalTimeStr = travelTotalTimeVal.toString()
			if (travelTotalTimeStr != '') {
				const match = travelTotalTimeStr.match(/(\d+)天/)
				if (match != null && match.length > 1) {
					const matchVal = match[1]
					if (matchVal != null) {
						const parseIntResult = parseInt(matchVal)
						if (isNaN(parseIntResult) == false && parseIntResult > 0) {
							serviceHours = parseIntResult
						}
					}
				}
			}
		}

		// 解析城市名称
		const orderLocationVal = dataObj.get('orderLocation')
		let orderLocationStr = ''
		if (orderLocationVal != null) {
			orderLocationStr = orderLocationVal.toString()
			if (orderLocationStr != '' && orderLocationStr.includes('市') == false) {
				orderLocationStr = orderLocationStr + '市'
			}
		}
		cityName.value = (orderLocationStr != '') ? orderLocationStr : '长沙市'
		
		// 设置表单数据
		const orderRemarksVal = dataObj.get('orderRemarks')
		const orderDescribeVal = dataObj.get('orderDescribe')
		if (orderRemarksVal != null && orderRemarksVal.toString() != '') {
			formOrderRemarks.value = orderRemarksVal.toString()
		} else if (orderDescribeVal != null && orderDescribeVal.toString() != '') {
			formOrderRemarks.value = orderDescribeVal.toString()
		}
		
		const orderPhoneVal = dataObj.get('orderPhone')
		const phoneValData = dataObj.get('phone')
		if (orderPhoneVal != null && orderPhoneVal.toString() != '') {
			formPhone.value = orderPhoneVal.toString()
		} else if (phoneValData != null && phoneValData.toString() != '') {
			formPhone.value = phoneValData.toString()
		}
		
		const travellerNameVal = dataObj.get('travellerName')
		const realnameVal = dataObj.get('realname')
		if (travellerNameVal != null && travellerNameVal.toString() != '') {
			formRealname.value = travellerNameVal.toString()
		} else if (realnameVal != null && realnameVal.toString() != '') {
			formRealname.value = realnameVal.toString()
		}
		
		const budgetVal = dataObj.get('budget')
		const totalMoneyVal = dataObj.get('totalMoney')
		if (budgetVal != null) {
			const budgetNum = parseFloat(budgetVal.toString())
			if (isNaN(budgetNum) == false) {
				formTotalMoney.value = budgetNum
				formTotalMoneyStr.value = budgetNum.toString()
			}
		} else if (totalMoneyVal != null) {
			const totalNum = parseFloat(totalMoneyVal.toString())
			if (isNaN(totalNum) == false) {
				formTotalMoney.value = totalNum
				formTotalMoneyStr.value = totalNum.toString()
			}
		}
		
		formServiceHours.value = serviceHours
		formOrderLocation.value = orderLocationStr
		
		// 设置出发日期
		const travelDateVal = dataObj.get('travelDate')
		const startTimeVal = dataObj.get('startTime')
		if (travelDateVal != null && travelDateVal.toString() != '') {
			chooseDate.value = travelDateVal.toString()
		} else if (startTimeVal != null && startTimeVal.toString() != '') {
			chooseDate.value = startTimeVal.toString()
		}
		
		// 查找并选择对应的联系人
		if (formPhone.value != '' && formRealname.value != '') {
			const listLen = contactList.value.length
			let i = 0
			while (i < listLen) {
				const item = contactList.value[i]
				if (item.phone == formPhone.value && item.name == formRealname.value) {
					contactId.value = item.kid
					break
				}
				i = i + 1
			}
		}
	} catch (error) {
		handlePageError(error, '获取订单详情', null)
	}
}

// 初始化页面数据 - 必须在 onLoad 之前定义
const initPageData = () => {
	initStatusBarHeight()
	formServiceHours.value = 1
	formOrderRemarks.value = ''
	formPhone.value = ''
	formRealname.value = ''
	formTotalMoney.value = 0
	formTotalMoneyStr.value = ''
	formOrderLocation.value = ''
	cityName.value = '长沙市'
	initMinDate()
	Get_contact_list()
}

// 页面加载 - 必须在所有被调用函数之后定义
onLoad((options: OnLoadOptions) => {
	// 初始化页面数据（无需登录也可以访问）
	initPageData()
	
	// 接收参数
	if (options != null) {
		// 使用 UTSJSONObject 安全访问 options 属性
		const optionsStr = JSON.stringify(options)
		const optionsObj = JSON.parse(optionsStr) as UTSJSONObject
		
		const merchantNameVal = optionsObj.get('merchantName')
		if (merchantNameVal != null && merchantNameVal.toString() != '') {
			formOrderRemarks.value = merchantNameVal.toString() + '游玩需求：'
		}
		const cityVal = optionsObj.get('city')
		if (cityVal != null && cityVal.toString() != '') {
			cityName.value = cityVal.toString()
		}
		const guiderKidVal = optionsObj.get('guiderKid')
		if (guiderKidVal != null && guiderKidVal.toString() != '') {
			guiderKid.value = guiderKidVal.toString()
		}
		const orderKidVal = optionsObj.get('orderKid')
		if (orderKidVal != null && orderKidVal.toString() != '') {
			orderKid.value = orderKidVal.toString()
			// 编辑模式需要登录
			const isLoginCheck = checkUserLogin()
			if (isLoginCheck == true) {
				Get_order_details()
			}
		}
	}
})

// 联系人选择相关方法
const isContactSelected = (contact: UTSJSONObject | ContactItemData): boolean => {
	const contactPhone = getContactPhone(contact)
	const contactName = getContactName(contact)
	return contactPhone == formPhone.value && contactName == formRealname.value
}

const selectContact = (contact: UTSJSONObject | ContactItemData) => {
	formPhone.value = getContactPhone(contact)
	formRealname.value = getContactName(contact)
	contactId.value = getContactKid(contact)
}

const handleDeleteContact = (contact: UTSJSONObject | ContactItemData) => {
	formPhone.value = ''
	formRealname.value = ''
	contactId.value = ''
}

const handleClearContact = () => {
	formPhone.value = ''
	formRealname.value = ''
	contactId.value = ''
}

// ContactSelector组件事件处理
const handleContactSelect = (contact: UTSJSONObject | ContactItemData) => {
	selectContact(contact)
	showContactSelector.value = false
}

// 打开新增联系人弹窗
const openAddContactPopup = () => {
	// 检查登录状态
	const isLogin = checkUserLogin()
	if (isLogin == false) {
		uni.showModal({
			title: '提示',
			content: '请先登录后再添加联系人',
			confirmText: '去登录',
			cancelText: '取消',
			success: (res: UniShowModalResult) => {
				if (res.confirm == true) {
					uni.navigateTo({
						url: '/pagesUser/login/index'
					})
				}
			}
		})
		return
	}
	
	// 关闭联系人选择弹窗，打开新增联系人弹窗
	showContactSelector.value = false
	addFormName.value = ''
	addFormPhone.value = ''
	addContactVisity.value = true
}

// 关闭新增联系人弹窗
const closeAddContactPopup = () => {
	addContactVisity.value = false
}

// 添加联系人 - 必须在 confirmAddContact 之前定义
const handleAddContact = async () => {
	// 验证
	if (addFormName.value == '' || addFormPhone.value == '') {
		uni.showToast({
			title: '请填写完整信息',
			icon: 'none'
		})
		return
	}
	
	// 验证手机号
	const addPhoneRegex = /^1[3-9]\d{9}$/
	if (addPhoneRegex.test(addFormPhone.value) == false) {
		uni.showToast({
			title: '手机号码不正确',
			icon: 'none'
		})
		return
	}
	
	const userIdVal = getCurrentUserKid()
	if (userIdVal == '') {
		uni.showToast({
			title: '请先登录',
			icon: 'none'
		})
		return
	}
	
	try {
		const addParams = new AddTravelUserParams()
		addParams.userKid = userIdVal
		addParams.name = addFormName.value
		addParams.phone = addFormPhone.value
		await addTravelUser(addParams)
		
		// 关闭弹窗
		addContactVisity.value = false
		
		uni.showToast({
			title: '添加成功',
			icon: 'success'
		})
		
		// 刷新联系人列表
		Get_contact_list()
	} catch (error) {
		handlePageError(error, '添加联系人', null)
	}
}

// 确认新增联系人
const confirmAddContact = () => {
	handleAddContact()
}

// 执行删除联系人 - 必须在 handleDelContact 之前定义
const doDeleteContact = async () => {
	const userIdVal = getCurrentUserKid()
	if (userIdVal == '') return
	
	try {
		const delParams = new DelTravelUserParams()
		delParams.userKid = userIdVal
		delParams.kid = contactId.value
		await delTravelUser(delParams)
		
		// 更新本地列表
		const newList: Array<ContactItemData> = []
		const listLen = contactList.value.length
		let i = 0
		while (i < listLen) {
			const item = contactList.value[i]
			if (item.kid != contactId.value) {
				newList.push(item)
			}
			i = i + 1
		}
		contactList.value = newList
		
		// 清空表单
		formPhone.value = ''
		formRealname.value = ''
		contactId.value = ''
		
		// 如果还有联系人，选择第一个
		if (contactList.value.length > 0) {
			const first = contactList.value[0]
			formRealname.value = first.name
			formPhone.value = first.phone
			contactId.value = first.kid
		}
		
		uni.showToast({
			title: '删除成功',
			icon: 'success'
		})
	} catch (error) {
		handlePageError(error, '删除联系人', null)
	}
}

// 从联系人选择弹窗中删除联系人
const handleDeleteContactFromSelector = async (contact: any) => {
	const userIdVal = getCurrentUserKid()
	if (userIdVal == '') return
	
	// 获取要删除的联系人kid
	let deleteKid = ''
	try {
		const contactStr = JSON.stringify(contact)
		const contactObj = JSON.parse(contactStr) as UTSJSONObject
		const kidVal = contactObj.get('kid')
		if (kidVal != null) {
			deleteKid = kidVal.toString()
		}
	} catch (e) {}
	
	if (deleteKid == '') return
	
	try {
		const delParams = new DelTravelUserParams()
		delParams.userKid = userIdVal
		delParams.kid = deleteKid
		await delTravelUser(delParams)
		
		// 更新本地列表
		const newList: Array<ContactItemData> = []
		const listLen = contactList.value.length
		let i = 0
		while (i < listLen) {
			const item = contactList.value[i]
			if (item.kid != deleteKid) {
				newList.push(item)
			}
			i = i + 1
		}
		contactList.value = newList
		
		// 如果删除的是当前选中的联系人，清空选择
		if (contactId.value == deleteKid) {
			formPhone.value = ''
			formRealname.value = ''
			contactId.value = ''
			
			// 自动选择第一个
			if (contactList.value.length > 0) {
				const first = contactList.value[0]
				formRealname.value = first.name
				formPhone.value = first.phone
				contactId.value = first.kid
			}
		}
		
		uni.showToast({
			title: '删除成功',
			icon: 'success'
		})
	} catch (error) {
		handlePageError(error, '删除联系人', null)
	}
}

// 更新联系人 - 必须在 handleUpdateContactInfo 之前定义
const handleUpdateContact = async () => {
	if (contactId.value == '' || contactId.value == null) {
		uni.showToast({
			title: '请先选择联系人',
			icon: 'none'
		})
		return
	}
	
	// 验证
	if (editFormName.value == '' || editFormPhone.value == '') {
		uni.showToast({
			title: '请填写完整信息',
			icon: 'none'
		})
		return
	}
	
	// 验证手机号
	const phoneRegex = /^1[3-9]\d{9}$/
	if (phoneRegex.test(editFormPhone.value) == false) {
		uni.showToast({
			title: '手机号码不正确',
			icon: 'none'
		})
		return
	}
	
	try {
		// 使用 UTSJSONObject 类型避免 Android ClassCastException
		const updateParams = { kid: contactId.value, name: editFormName.value, phone: editFormPhone.value } as UTSJSONObject
		await updateTravelUser(updateParams)
		
		editContactVisity.value = false
		uni.showToast({
			title: '保存成功',
			icon: 'success'
		})
		Get_contact_list()
	} catch (error) {
		handlePageError(error, '更新联系人', null)
	}
}

// 删除联系人 - 必须在 handleDeleteContactInfo 之前定义
const handleDelContact = () => {
	if (contactId.value == '' || contactId.value == null) {
		uni.showToast({
			title: '请先选择联系人',
			icon: 'none'
		})
		return
	}
	
	uni.showModal({
		title: '提示',
		content: '确定删除该联系人吗？',
		success: (res: UniShowModalResult) => {
			if (res.confirm == true) {
				doDeleteContact()
			}
		}
	})
}

