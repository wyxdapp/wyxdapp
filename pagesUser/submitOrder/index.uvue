// 费用预算输入
const handleBudgetInput = (e: UniInputEvent) => {
	let value = '0'
	const inputValue = e.detail.value
	if (inputValue != '') {
		value = inputValue
	}
	const parseFloatVal = parseFloat(value)
	if (isNaN(parseFloatVal) == false && parseFloatVal > 0) {
		formTotalMoney.value = parseFloatVal
		formTotalMoneyStr.value = value
	} else {
		formTotalMoney.value = 0
		formTotalMoneyStr.value = ''
	}
}

// 监听新增联系人弹窗
watch(addContactVisity, (newVal: boolean, oldVal: boolean) => {
	if (newVal == true) {
		addFormName.value = ''
		addFormPhone.value = ''
	}
})


// 提交订单
const handleSubmitOrder = async () => {
	// 检查登录状态（提交时需要登录）
	const isLoginCheck = checkUserLogin()
	if (isLoginCheck == false) {
		uni.showModal({
			title: '提示',
			content: '请先登录后再发布向导需求',
			confirmText: '去登录',
			cancelText: '取消',
			success: (res: UniShowModalResult) => {
				if (res.confirm == true) {
					uni.navigateTo({
						url: '/pagesUser/login/index'
					})
				}
			}
		})
		return
	}
	
	// 验证联系人
	if (formPhone.value == '' || formRealname.value == '') {
		uni.showToast({
			title: '请选择联系人信息',
			icon: 'none'
		})
		return
	}

	// 验证日期
	if (chooseDate.value == '') {
		uni.showToast({
			title: '请选择出发时间',
			icon: 'none'
		})
		return
	}

	// 验证预算金额
	if (formTotalMoney.value <= 0) {
		uni.showToast({
			title: '请输入预算金额',
			icon: 'none'
		})
		return
	}

	// 验证城市
	const cityNameVal = cityName.value
	if (cityNameVal == '' || cityNameVal == '全部') {
		uni.showToast({
			title: '请选择城市',
			icon: 'none'
		})
		return
	}

	// 防止重复提交
	if (isLocalSubmitting.value == true) {
		return
	}

	// 验证登录
	const userIdVal = getCurrentUserKid()
	if (userIdVal == '') {
		uni.showToast({
			title: '请先登录',
			icon: 'none'
		})
		return
	}

	// 标记为提交中
	isLocalSubmitting.value = true

	try {
		// 构建订单数据
		const totalMoneyResult = (formTotalMoney.value > 0) ? formTotalMoney.value : 0
		const remarksResult = formOrderRemarks.value
		const cityNameResult = (cityNameVal != '全部') ? cityNameVal : ''
		const realnameStr = formRealname.value
		const phoneStr = formPhone.value
		
		if (orderKid.value != '' && orderKid.value != null) {
			// 更新订单
			const updateParams = new UpdateGrabOrderParams()
			updateParams.kid = orderKid.value!
			updateParams.userKid = userIdVal
			updateParams.travelDate = chooseDate.value
			updateParams.serviceHours = formServiceHours.value
			updateParams.realname = realnameStr
			updateParams.phone = phoneStr
			updateParams.totalMoney = totalMoneyResult
			updateParams.orderRemarks = remarksResult
			updateParams.orderLocation = cityNameResult
			updateParams.orderSource = 1
			
			const res = await updateGrabOrder(updateParams)
			
			isLocalSubmitting.value = false
			uni.showToast({
				title: '订单更新成功',
				icon: 'success'
			})
			
			// 发送事件通知
			const resStr = JSON.stringify(res)
			const resObj = JSON.parse(resStr) as UTSJSONObject
			const dataVal = resObj.get('data')
			if (dataVal != null) {
				uni.$emit('orderUpdated', dataVal)
			}
			
			setTimeout(() => {
				uni.navigateBack()
			}, 1500)
		} else {
			// 创建订单
			// 后端字段非空约束：trip_order.guide_comment 不能为 null
			// guideComment 是 Integer 类型，10=未评价，20=已评价
			const createParams = new CreateGrabOrderParams()
			createParams.userKid = userIdVal
			createParams.travelDate = chooseDate.value
			createParams.serviceHours = formServiceHours.value
			createParams.realname = realnameStr
			createParams.phone = phoneStr
			createParams.totalMoney = totalMoneyResult
			createParams.orderLocation = cityNameResult
			createParams.orderRemarks = remarksResult
			createParams.orderSource = 1
			createParams.guideComment = 10  // 10=未评价（Integer类型）
			
			const res = await createGrabOrder(createParams)
			
			// 解析创建订单返回的 orderKid
			let createdOrderKid = ''
			try {
				const createResStr = JSON.stringify(res)
				const createResObj = JSON.parse(createResStr) as UTSJSONObject
				const createDataVal = createResObj.get('data')
				if (createDataVal != null) {
					const createDataStr = JSON.stringify(createDataVal)
					const createDataObj = JSON.parse(createDataStr) as UTSJSONObject
					const orderKidVal = createDataObj.get('orderKid')
					const kidVal = createDataObj.get('kid')
					if (orderKidVal != null && orderKidVal.toString() != '') {
						createdOrderKid = orderKidVal.toString()
					} else if (kidVal != null && kidVal.toString() != '') {
						createdOrderKid = kidVal.toString()
					}
				}
			} catch (parseErr) {
				handleSilentError(parseErr, '解析订单响应')
			}
			
			// 支付路由：创建订单后、发起支付前，检查是否走合作方支付
			const guideKidForRoute = guiderKid.value
			if (guideKidForRoute != '' && createdOrderKid != '' && totalMoneyResult > 0) {
				try {
					const routeResult = await checkPaymentRoute(guideKidForRoute)
					if (routeResult.isOpenPlatform == true && routeResult.partnerId != '') {
						// 走合作方支付通道（wyxdkey 通过请求拦截器的 X-Partner-Id 请求头传递）
						console.log('📱 [submitOrder] 使用合作方支付')
						isLocalSubmitting.value = false
						
						// 根据平台选择支付方式，调用 open 模块的合作方支付接口
						// #ifdef APP-PLUS
						try {
							const payRes = await partnerWechatAppPay({
								orderId: createdOrderKid,
								txnAmt: totalMoneyResult.toString(),
								goodsName: '订单支付'
							} as UTSJSONObject)
							uni.showToast({
								title: '支付成功',
								icon: 'success'
							})
							setTimeout(() => {
								uni.navigateBack()
							}, 1500)
						} catch (payErr) {
							handleSilentError(payErr, '合作方微信支付回退默认流程')
							// 合作方支付失败，回退到默认支付流程
							uni.showToast({
								title: '订单发布成功',
								icon: 'success'
							})
							setTimeout(() => {
								uni.navigateBack()
							}, 1500)
						}
						// #endif
						// #ifndef APP-PLUS
						// 非APP端暂时走默认流程
						uni.showToast({
							title: '订单发布成功',
							icon: 'success'
						})
						setTimeout(() => {
							uni.navigateBack()
						}, 1500)
						// #endif
						return
					}
				} catch (routeErr) {
					// 路由查询失败，走默认支付流程
					handleSilentError(routeErr, '支付路由查询')
				}
			}
			
			// 默认支付流程：无合作方支付或路由失败
			isLocalSubmitting.value = false
			uni.showToast({
				title: '订单发布成功',
				icon: 'success'
			})
			
			setTimeout(() => {
				uni.navigateBack()
			}, 1500)
		}
	} catch (error) {
		handlePageError(error, '提交订单', null)
		isLocalSubmitting.value = false
	}
}

// 处理城市选择事件（必须在 onShow 之前定义）
function handleCitySelected(data: UTSJSONObject): void {
	if (data != null) {
		try {
			const dataStr = JSON.stringify(data)
			const dataObj = JSON.parse(dataStr) as UTSJSONObject
			const cityVal = dataObj.get('city')
			if (cityVal != null && cityVal.toString() != '') {
				const selectedCity = cityVal.toString()
				cityName.value = selectedCity
				formOrderLocation.value = selectedCity
				console.log('📱 [submitOrder] 城市已选择:', selectedCity)
			}
		} catch (e) {
			handleSilentError(e, '解析城市数据')
		}
	}
}

// 初始化
onMounted(() => {
	initMinDate()
})

// 页面显示时重新检查登录状态
onShow(() => {
	// 检查登录状态
	const isLogin = checkUserLoginReliable()
	console.log('📱 [submitOrder] onShow - 登录状态:', isLogin)
	
	// 如果已登录且联系人列表为空，重新获取联系人列表
	if (isLogin == true && contactList.value.length == 0) {
		console.log('📱 [submitOrder] onShow - 重新获取联系人列表')
		Get_contact_list()
	}
	
	// 监听城市选择事件
	uni.$on('onCitySelected', handleCitySelected)
})

// 页面卸载时移除监听
onUnmounted(() => {
	uni.$off('onCitySelected', handleCitySelected)
})
</script>

