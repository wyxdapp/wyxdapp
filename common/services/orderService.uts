}

/**
 * 取消订单
 */
export const setOrderCancel = (data: UTSJSONObject) => {
	const dataObj = toJsonObj(data)
	const orderKidVal = getObjString(dataObj, 'orderKid')
	return request.post('/order/tourist/cancelOrder?orderKid=' + orderKidVal, data, false)
}

