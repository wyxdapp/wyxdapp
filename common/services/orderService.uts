/**
 * 订单模块服务 API
 * 
 * ⚠️ 重要：此文件已从 pagesTrade/services/ 移动到 common/services/
 * 原因：解决微信小程序跨分包引用限制
 * - pagesUser 不能直接引用 pagesTrade
 * - 将共享服务移到主包，所有分包都可以引用
 */
import { request } from '@/utils/request'
import { toJsonObj } from '@/common/utils/utsSafe.uts'

// 辅助函数：将任意值转换为 UTSJSONObject (使用通用工具)

// 辅助函数：从对象获取字符串属性
const getObjString = (obj: UTSJSONObject | null, key: string): string => {
	if (obj == null) return ''
	const val = obj.get(key)
	if (val != null && val.toString() != '') {
		return val.toString()
	}
	return ''
}

// 辅助函数：从对象获取数字属性
const getObjNumber = (obj: UTSJSONObject | null, key: string): number => {
	if (obj == null) return 0
	const val = obj.get(key)
	if (val != null) {
		const num = parseInt(val.toString())
		if (isNaN(num) == false) {
			return num
		}
	}
	return 0
}

/**
 * 获取支出订单列表（游客端）
 */
export const getExpenditureList = (data: UTSJSONObject) => {
	return request.post('/order/tourist/queryOrderList', data, false)
}

/**
 * 获取收入订单列表（向导端）
 */
export const getIncomeList = (data: UTSJSONObject) => {
	return request.post('/order/guide/queryGuideAcceptOrder', data, false)
}

/**
 * 创建向导订单
 */
export const setGuiderOrder = (data: UTSJSONObject) => {
	return request.post('/order/tourist/createFreeTravelOrder', data, false)
}

/**
 * 创建定制订单
