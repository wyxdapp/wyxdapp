		className: '!rounded-full !h-[72rpx] !border-[#cfcfcf] !bg-white',
		label: {
			className: 'text-[28rpx]',
			color: 'dark'
		}
	} as any
	return config
}

/**
 * 文本按钮配置（链接样式按钮）
 */
export function getTextButtonPt(): any {
	const config = {
		className: '!bg-transparent !p-0',
		label: {
			className: 'text-[28rpx]',
			color: 'primary'
		}
	} as any
	return config
}

/**
 * 禁用按钮配置
 */
export function getDisabledButtonPt(): any {
	const config = {
		className: '!rounded-full !h-[88rpx] !w-full !bg-[#CCCCCC]',
		label: {
			className: 'text-[32rpx] font-bold',
			color: 'light'
		}
	} as any
	return config
}

// ==================== Input 组件配置 ====================

/**
 * Input PassThrough 配置接口
 */
interface InputPtConfig {
	className: string
	inner: InputInnerConfig
	prefixIcon: InputIconConfig
	suffixIcon: InputIconConfig
}

interface InputInnerConfig {
	className: string
}

interface InputIconConfig {
	size: number
	className: string
}

/**
 * 默认输入框配置
 */
export function getDefaultInputPt(): any {
	const config = {
		className: '!bg-white/95 !rounded-[16rpx] !h-[96rpx] !px-[32rpx]',
		inner: {
			className: 'text-[32rpx] text-[#333333]'
		},
		prefixIcon: {
			size: 32,
			className: 'mr-[12rpx]'
		},
		suffixIcon: {
			size: 32,
			className: 'ml-[12rpx]'
		}
	} as any
	return config
}

/**
 * 登录页输入框配置（半透明白色背景）
 */
export function getLoginInputPt(): any {
	const config = {
		className: '!bg-white/95 !rounded-[16rpx] !h-[96rpx] !px-[32rpx] !border-transparent',
		inner: {
			className: 'text-[32rpx] text-[#333333]'
		}
	} as any
	return config
}

/**
 * 搜索输入框配置
 */
export function getSearchInputPt(): any {
	const config = {
		className: '!bg-[#F5F5F5] !rounded-full !h-[72rpx] !px-[24rpx]',
		inner: {
			className: 'text-[28rpx] text-[#333333]'
		},
		prefixIcon: {
			size: 28,
			className: 'mr-[8rpx] text-[#999999]'
		}
	} as any
	return config
}

// ==================== Loading 组件配置 ====================

/**
 * Loading PassThrough 配置接口
 */
interface LoadingPtConfig {
	className: string
	mask: LoadingMaskConfig
	content: LoadingContentConfig
}

interface LoadingMaskConfig {
	className: string
}

interface LoadingContentConfig {
	className: string
}

/**
 * 全屏加载配置
 */
export function getFullscreenLoadingPt(): any {
	const config = {
		className: '',
		mask: {
			className: '!bg-black/50'
		},
		content: {
			className: '!bg-black/70 !rounded-[16rpx] !p-[40rpx]'
		}
	} as any
	return config
}

/**
 * 内联加载配置
 */
export function getInlineLoadingPt(): any {
	const config = {
		className: '',
		content: {
			className: '!bg-transparent'
		}
	} as any
	return config
}

