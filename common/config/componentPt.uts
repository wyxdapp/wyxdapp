/**
 * Cool Unix 组件 PassThrough 默认配置
 * 
 * PassThrough (pt) 是 cool-unix 提供的样式穿透 API
 * 允许开发者将任意属性和样式直接应用于组件内部的 DOM 元素
 * 
 * 本文件定义了项目中各组件的默认 pt 配置，确保 UI 一致性
 * 
 * @author WYXD Team
 * @date 2025-12-27
 */


// ==================== Button 组件配置 ====================

/**
 * Button PassThrough 配置接口
 */
interface ButtonPtConfig {
	className: string
	label: ButtonLabelConfig
	icon: ButtonIconConfig
	loading: ButtonLoadingConfig
}

interface ButtonLabelConfig {
	className: string
	color: string
}

interface ButtonIconConfig {
	size: number
	color: string
	className: string
}

interface ButtonLoadingConfig {
	size: number
	color: string
}

/**
 * 主按钮默认配置（登录、提交等主要操作）
 */
export function getPrimaryButtonPt(): any {
	const config = {
		className: '!rounded-full !h-[88rpx] !w-full !bg-[#37B1F2]',
		label: {
			className: 'text-[32rpx] font-bold',
			color: 'light'
		},
		icon: {
			size: 36,
			color: 'light',
			className: 'mr-[8rpx]'
		},
		loading: {
			size: 28,
			color: 'light'
		}
	} as any
	return config
}

/**
 * 微信登录按钮配置
 */
export function getWechatButtonPt(): any {
	const config = {
		className: '!rounded-full !h-[96rpx] !w-full !bg-[#07C160]',
		label: {
			className: 'text-[32rpx] font-bold',
			color: 'light'
		},
		icon: {
			size: 40,
			color: 'light',
			className: 'mr-[12rpx]'
		}
	} as any
	return config
}

