/**
 * 表情配置文件
 * 使用 Unicode Emoji，无需图片资源
 */

export class EmojiItem {
	emoji: string = ''
	name: string = ''
	category: string = ''
	
	constructor(emoji: string, name: string, category: string) {
		this.emoji = emoji
		this.name = name
		this.category = category
	}
	
	/**
	 * 转换为普通对象，确保在APP端JSON序列化正确
	 * 解决APP端类实例JSON.stringify返回对象引用字符串的问题
	 */
	toPlainObject(): any {
		return {
			emoji: this.emoji,
			name: this.name,
			category: this.category,
			type: 'unicode'
		} as any
	}
}

