// 表情分类配置
export class EmojiCategory {
	key: string = ''
	label: string = ''
	
	constructor(key: string, label: string) {
		this.key = key
		this.label = label
	}
	
	/**
	 * 转换为普通对象，确保在APP端JSON序列化正确
	 * 解决APP端类实例属性访问问题
	 */
	toPlainObject(): any {
		return {
			key: this.key,
			label: this.label
		} as any
	}
}

export const EMOJI_CATEGORIES: Array<EmojiCategory> = [
	new EmojiCategory('common', '常用'),
	new EmojiCategory('custom', '自定义')
]
