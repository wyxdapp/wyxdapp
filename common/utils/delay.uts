/**
 * 延时工具函数
 * 基于 Promise 封装 setTimeout，供 async/await 使用，替代嵌套 setTimeout
 */

/**
 * Promise 化的延时函数
 * @param ms 延时毫秒数
 * @returns Promise<void> 在指定毫秒后 resolve
 */
export function delay(ms: number): Promise<void> {
	return new Promise<void>((resolve) => {
		setTimeout(() => {
			resolve()
		}, ms)
	})
}
