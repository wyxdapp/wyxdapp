/**
 * 检查登录状态，未登录则跳转登录页
 * 
 * @deprecated 此函数已废弃，请使用 requireLoginReliable() from '@/common/utils/loginHelper.uts'
 * 
 * 迁移示例：
 * ```typescript
 * // 旧代码
 * import { requireLogin } from '@/common/utils/utsSafe.uts'
 * if (requireLogin(true, '/pages/my/index') == false) {
 *   return
 * }
 * 
 * // 新代码
 * import { requireLoginReliable } from '@/common/utils/loginHelper.uts'
 * if (requireLoginReliable(true, '/pages/my/index') == false) {
 *   return
 * }
 * ```
 * 
 * @param showToast 是否显示提示
 * @param redirectUrl 登录后跳转的页面（可选）
 * @returns 是否已登录
 */
export const requireLogin = (showToast: boolean = true, redirectUrl: string = ''): boolean => {
	console.warn('⚠️ [utsSafe] requireLogin() 已废弃，请使用 requireLoginReliable()')
	
	// 🔧 优化：内部调用 requireLoginReliable()，确保行为一致
	try {
		const { requireLoginReliable } = require('@/common/utils/loginHelper.uts')
		if (requireLoginReliable != null) {
			return requireLoginReliable(showToast, redirectUrl)
		}
	} catch (e) {
		console.error('❌ [utsSafe] 调用 requireLoginReliable() 失败:', e)
	}
	
	// 降级方案：使用原有逻辑
	const isLogin = checkUserLogin()
	if (isLogin == false) {
		if (showToast == true) {
			uni.showToast({
				title: '请先登录',
				icon: 'none'
			})
		}
		
		// 保存登录后跳转地址
		if (redirectUrl != '') {
			safeSetStorageSync(SK_LOGIN_REDIRECT_URL, redirectUrl)
		}
		
		setTimeout(() => {
			uni.navigateTo({
				url: '/pagesUser/login/index'
			})
		}, 1500)
		return false
	}
	return true
}

/**
 * 跳转到登录页
 * @param redirectUrl 登录后跳转的页面（可选）
 */
export const goToLoginPage = (redirectUrl: string = '') => {
	// 保存登录后跳转地址
	if (redirectUrl != '') {
		safeSetStorageSync(SK_LOGIN_REDIRECT_URL, redirectUrl)
	}
	
	uni.navigateTo({
		url: '/pagesUser/login/index'
	})
}


// ==================== 系统信息获取 ====================

/**
 * 获取状态栏高度
 * 统一处理 APP 端状态栏高度，避免内容被系统状态栏遮挡
 * @returns 状态栏高度（px）
 */
export const getStatusBarHeight = (): number => {
	try {
		const systemInfo = uni.getSystemInfoSync()
		const systemInfoObj = toUTSJSON(systemInfo)
		if (systemInfoObj != null) {
			const statusBarVal = systemInfoObj.get('statusBarHeight')
			if (statusBarVal != null) {
				const sbHeight = parseInt(statusBarVal.toString())
				if (isNaN(sbHeight) == false && sbHeight > 0) {
					return sbHeight
				}
			}
		}
	} catch (e) {
		console.error('❌ [utsSafe] 获取状态栏高度失败:', e)
	}
	// 默认状态栏高度（iOS 约 44px，Android 约 24-48px）
	return 44
}

/**
 * 获取窗口高度
 * @returns 窗口高度（px）
 */
export const getWindowHeight = (): number => {
	try {
		const systemInfo = uni.getSystemInfoSync()
		const systemInfoObj = toUTSJSON(systemInfo)
		if (systemInfoObj != null) {
			const windowHeightVal = systemInfoObj.get('windowHeight')
			if (windowHeightVal != null) {
				const wHeight = parseInt(windowHeightVal.toString())
				if (isNaN(wHeight) == false && wHeight > 0) {
					return wHeight
				}
			}
		}
	} catch (e) {
		console.error('❌ [utsSafe] 获取窗口高度失败:', e)
	}
	return 667 // 默认高度
}

/**
 * 获取屏幕宽度
 * @returns 屏幕宽度（px）
 */
export const getScreenWidth = (): number => {
	try {
		const systemInfo = uni.getSystemInfoSync()
		const systemInfoObj = toUTSJSON(systemInfo)
		if (systemInfoObj != null) {
			const screenWidthVal = systemInfoObj.get('screenWidth')
			if (screenWidthVal != null) {
				const sWidth = parseInt(screenWidthVal.toString())
				if (isNaN(sWidth) == false && sWidth > 0) {
					return sWidth
				}
			}
		}
	} catch (e) {
		console.error('❌ [utsSafe] 获取屏幕宽度失败:', e)
	}
	return 375 // 默认宽度
}

/**
 * 获取导航栏高度（状态栏 + 标题栏）
 * 标题栏高度：iOS 44px，Android 48px
 * @returns 导航栏总高度（px）
 */
export const getNavBarHeight = (): number => {
	const statusBarHeight = getStatusBarHeight()
	// 标题栏高度统一使用 44px
	return statusBarHeight + 44
}

/**
 * 获取系统信息对象
 * @returns UTSJSONObject 或 null
 */
export const getSystemInfo = (): UTSJSONObject | null => {
	try {
		const systemInfo = uni.getSystemInfoSync()
		return toUTSJSON(systemInfo)
	} catch (e) {
		console.error('❌ [utsSafe] 获取系统信息失败:', e)
	}
	return null
}

/**
 * 判断是否为 iOS 平台
 * @returns 是否为 iOS
 */
export const isIOS = (): boolean => {
	try {
		const systemInfo = getSystemInfo()
		if (systemInfo != null) {
			const platformVal = systemInfo.get('platform')
			if (platformVal != null) {
				const platform = platformVal.toString().toLowerCase()
				return platform == 'ios'
			}
		}
	} catch (e) {}
	return false
}

/**
 * 判断是否为 Android 平台
 * @returns 是否为 Android
 */
export const isAndroid = (): boolean => {
	try {
		const systemInfo = getSystemInfo()
		if (systemInfo != null) {
			const platformVal = systemInfo.get('platform')
			if (platformVal != null) {
				const platform = platformVal.toString().toLowerCase()
				return platform == 'android'
			}
		}
	} catch (e) {}
	return false
}


// ==================== 页面跳转工具 ====================

/**
 * 跳转到首页
 * 根据不同平台跳转到对应的首页
 * - 所有平台：/pages/index/index
 */
export const goToHome = () => {
	uni.reLaunch({
		url: '/pages/index/index'
	})
}

/**
 * 获取首页路径
 * 根据不同平台返回对应的首页路径
 * @returns 首页路径
 */
export const getHomePath = (): string => {
	return '/pages/index/index'
}

/**
 * 跳转到首页（使用 switchTab，适用于 Tab 页）
 * 如果首页是 Tab 页，使用此方法
 */
export const switchToHome = () => {
	uni.switchTab({
		url: '/pages/index/index'
	})
}


// ==================== 平台检测工具 ====================

/**
 * 获取当前平台
 * @returns 平台标识字符串
 */
export function getCurrentPlatform(): string {
	try {
		const systemInfo = uni.getSystemInfoSync()
		const infoObj = toUTSJSON(systemInfo)
		if (infoObj != null) {
			const platformVal = infoObj.get('uniPlatform')
			if (platformVal != null) {
				return platformVal.toString()
			}
		}
	} catch (e) {
		console.error('[utsSafe] 获取平台信息失败:', e)
	}
	return ''
}

/**
 * 检查是否为 APP 端
 * @returns 是否为 APP 端
 */
export function isAppPlatform(): boolean {
	const platform = getCurrentPlatform()
	return platform == 'app' || platform == 'app-plus' || platform == 'app-android' || platform == 'app-ios'
}

/**
 * 检查是否为 H5 端
 * @returns 是否为 H5 端
 */
export function isH5Platform(): boolean {
	const platform = getCurrentPlatform()
	return platform == 'web' || platform == 'h5'
}

/**
 * 检查是否为微信小程序端
 * @returns 是否为微信小程序端
 */
export function isMpWeixinPlatform(): boolean {
	const platform = getCurrentPlatform()
	return platform == 'mp-weixin'
}

/**
 * 获取平台类型字符串
 * @returns 平台类型：'app' | 'mp-weixin' | 'h5' | 'unknown'
 */
export function getPlatformType(): string {
	if (isAppPlatform()) {
		return 'app'
	} else if (isMpWeixinPlatform()) {
		return 'mp-weixin'
	} else if (isH5Platform()) {
		return 'h5'
	}
	return 'unknown'
}
