}

/**
 * 获取用户信息数字属性
 * @param key 属性名
 * @returns 属性值数字
 */
export const getAuthUserNumberProp = (key: string): number => {
	return getUserNumberProp(key)
}

// ==================== 组合式函数 ====================

/**
 * 统一登录状态管理组合式函数
 * 在组件中使用，自动管理登录状态和用户信息
 * 
 * 使用示例：
 * const { isLogin, userId, userNickname, userAvatar, requireLogin, refreshUserInfo } = useAuth()
 */
export const useAuth = () => {
	// 响应式状态
	const isLogin = ref<boolean>(false)
	const userId = ref<string>('')
	const userNickname = ref<string>('')
	const userAvatar = ref<string>('')
	const userShortKid = ref<string>('')
	const userPhone = ref<string>('')
	const isGuide = ref<boolean>(false)
	const isVip = ref<boolean>(false)
	
	// 刷新用户信息
	const refreshUserInfo = () => {
		isLogin.value = getUserLoginStatus()
		userId.value = getUserId()
		userNickname.value = getUserNickname()
		userAvatar.value = getUserAvatar()
		userShortKid.value = getUserShortKid()
		userPhone.value = getUserPhone()
		isGuide.value = getUserIsGuide()
		isVip.value = isUserVip()
	}
	
	// 检查登录状态
	const requireLogin = (showToast: boolean = true): boolean => {
		if (isLogin.value == false) {
			if (showToast == true) {
				uni.showToast({
					title: '请先登录',
					icon: 'none'
				})
			}
			return false
		}
		return true
	}
	
	// 检查登录并跳转
	const requireLoginAndRedirect = (showToast: boolean = true, redirectUrl: string = ''): boolean => {
		return requireLoginWithRedirect(showToast, redirectUrl)
	}
	
	// 取消监听函数
	let unsubscribe: (() => void) | null = null
	
	// 组件挂载时初始化
	onMounted(() => {
		// 确保用户信息已初始化
		initUserInfoAction()
		
		// 刷新用户信息
		refreshUserInfo()
		
		// 监听登录状态变化
		unsubscribe = onLoginStatusChange((loginStatus: boolean, uid: string) => {
			isLogin.value = loginStatus
			userId.value = uid
			if (loginStatus == true) {
				refreshUserInfo()
			} else {
				// 清空用户信息
				userNickname.value = ''
				userAvatar.value = ''
				userShortKid.value = ''
				userPhone.value = ''
				isGuide.value = false
				isVip.value = false
			}
		})
	})
	
	// 组件卸载时清理
	onUnmounted(() => {
		if (unsubscribe != null) {
			unsubscribe()
			unsubscribe = null
		}
	})
	
	return {
		// 响应式状态
		isLogin,
		userId,
		userNickname,
		userAvatar,
		userShortKid,
		userPhone,
		isGuide,
		isVip,
		
		// 方法
		refreshUserInfo,
		requireLogin,
		requireLoginAndRedirect,
		goToLogin
	}
}

// ==================== 默认导出 ====================

export default useAuth
