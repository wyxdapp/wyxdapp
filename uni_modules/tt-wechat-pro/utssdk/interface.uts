export interface TTWeChatOpenCustomerServiceFail extends IUniError {}

export type TTWeChatOpenCustomerServiceSuccessCallback =  (res: TTWeChatOpenCustomerServiceSuccess) => void;
export type TTWeChatOpenCustomerServiceFailCallback = (res: TTWeChatOpenCustomerServiceFail) => void;
