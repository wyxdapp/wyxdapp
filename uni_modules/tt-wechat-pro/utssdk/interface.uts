export type TTWeChatShareOptions = {
	/**
	 * WXTypeText		= 0,  < 文本
	 * WXTypeImage		= 1,  < 图片
	 * WXTypeVideo		= 2,  < 视频
	 * WXTypeWeb		= 3,  < web
	 * WXTypeMP			= 4,  < 小程序
	 * WXTypeMusic		= 5,  < 音乐
	 */
	type: number,
	/**
	 *  WXSceneSession          = 0,  	< 聊天界面
     * 	WXSceneTimeline         = 1,    < 朋友圈
	 * 	WXSceneFavorite         = 2,    < 收藏
	 */
	scene : number,
	/* 
	 * 分享内容的标题,限制长度不超过512Bytes
	 */
	title?: string | null,
	/*
	 * 分享内容的摘要,限制长度不超过1KB
	 */
	desc?: string | null,
	/*
	 * 分享图片地址（仅支持本地路径,内容大小不超过10MB）
	 */
	imageUrl?: string | null,
	/*
	 * 缩略图路径（仅支持本地路径,限制内容大小不超过32KB）
	 */
	thumbImageUrl?: string | null,
	/*
	 * 分享音视频地址(限制长度不超过10KB)
	 */
	videoUrl?: string | null,
	/*
	 * 分享音乐地址(限制长度不超过10KB)
	 */
	musicUrl?: string | null,
	/*
	 * 分享网址(限制长度不超过10KB)
	 */
	href?: string | null,
	/*
	 * 分享到小程序
	 */
	miniProgram?: TTWeChatShareMiniProgramOptions | null,
	success?: TTWeChatShareSuccessCallback | null,
	fail?: TTWeChatShareFailCallback | null,
	complete?: TTWeChatShareCompleteCallback | null
}

export type TTWeChatPaySuccess = {}
export interface TTWeChatPayFail extends IUniError {}

export type TTWeChatPaySuccessCallback =  (res: TTWeChatPaySuccess) => void;
export type TTWeChatPayFailCallback = (res: TTWeChatPayFail) => void;
export type TTWeChatPayCompleteCallback = (res: any) => void;

export type TTWeChatLaunchMiniProgramSuccess = {
	message : string
}
export interface TTWeChatLaunchMiniProgramFail extends IUniError {}

export type TTWeChatLaunchMiniProgramSuccessCallback =  (res: TTWeChatLaunchMiniProgramSuccess) => void;
