export type TTWeChatLoginSuccess = {
	/**
	 * 用于换取 access_token 的 code
	 */
	code: string,
	/*
	 * 用来标识请求的唯一性的标志
	 */
	state : string
};


export interface TTWeChatLoginFail extends IUniError {

}

export type TTWeChatLoginSuccessCallback = (result: TTWeChatLoginSuccess) => void;
export type TTWeChatLoginFailCallback = (result: TTWeChatLoginFail) => void;
export type TTWeChatLoginCompleteCallback = (result: any) => void;

export type TTWeChatLoginOptions = {
	/**
	 * 用来标识请求的唯一性，最后跳转回第三方程序时，由微信终端回传，字符串长度不能超过1K。
	 */
	state: string | null,

	success : TTWeChatLoginSuccessCallback | null,

	fail : TTWeChatLoginFailCallback | null,

	complete : TTWeChatLoginCompleteCallback | null
}

export type TTWeChatShareSuccess = {}
export interface TTWeChatShareFail extends IUniError {}

export type TTWeChatShareSuccessCallback =  (res: TTWeChatShareSuccess) => void;
export type TTWeChatShareFailCallback = (res: TTWeChatShareFail) => void;
export type TTWeChatShareCompleteCallback = (res: any) => void;

export type TTWeChatShareMiniProgramOptions = {
	/* 
	 *小程序id
	 */
	userName: string,
	/*
	 *小程序页面路径
	 */
	path: string,
	/*
	 * 兼容低版本网页的URL
	 */
	webpageUrl: string,
	/*
	 * 版本类型，可取值： 0-正式版； 1-开发版； 2-体验版。 默认值为0
	 */
	miniProgramType : number | null
}

