// 导出 setUserInfo 操作供外部直接调用（接受 UTSJSONObject 类型参数）
export const setUserInfoDataAction = (userInfo: UTSJSONObject) => {
	try {
		// userInfo 已经是 UTSJSONObject 类型，直接使用
		const userInfoParsed = userInfo
		
		// 构建 UserInfo 对象
		const newUserInfo = new UserInfo()
		
		const kidVal = userInfoParsed.get('kid')
		newUserInfo.kid = (kidVal != null && kidVal.toString() != '') ? kidVal.toString() : ''
		
		const tokenVal = userInfoParsed.get('token')
		const phoneWebTokenVal = userInfoParsed.get('phoneWebToken')
		const accessTokenVal = userInfoParsed.get('accessToken')
		const tokenStr = (tokenVal != null && tokenVal.toString() != '') ? tokenVal.toString() : ''
		const phoneWebTokenStr = (phoneWebTokenVal != null && phoneWebTokenVal.toString() != '') ? phoneWebTokenVal.toString() : ''
		const accessTokenStr = (accessTokenVal != null && accessTokenVal.toString() != '') ? accessTokenVal.toString() : ''
		
		newUserInfo.token = (tokenStr != '') ? tokenStr : ((phoneWebTokenStr != '') ? phoneWebTokenStr : accessTokenStr)
		newUserInfo.phoneWebToken = (phoneWebTokenStr != '') ? phoneWebTokenStr : ((tokenStr != '') ? tokenStr : accessTokenStr)
		newUserInfo.accessToken = (accessTokenStr != '') ? accessTokenStr : tokenStr
		
		const shortKidVal = userInfoParsed.get('shortKid')
		newUserInfo.shortKid = (shortKidVal != null && shortKidVal.toString() != '') ? shortKidVal.toString() : ''
		
		const nicknameVal = userInfoParsed.get('nickname')
		const nickNameVal = userInfoParsed.get('nickName')
		const nicknameStr = (nicknameVal != null && nicknameVal.toString() != '') ? nicknameVal.toString() : ''
		const nickNameStr = (nickNameVal != null && nickNameVal.toString() != '') ? nickNameVal.toString() : ''
		newUserInfo.nickname = (nicknameStr != '') ? nicknameStr : ((nickNameStr != '') ? nickNameStr : '用户')
		
		const avatarVal = userInfoParsed.get('avatar')
		const imageVal = userInfoParsed.get('image')
		const avatarStr = (avatarVal != null && avatarVal.toString() != '') ? avatarVal.toString() : ''
		const imageStr = (imageVal != null && imageVal.toString() != '') ? imageVal.toString() : ''
		// 🎯 修复：优先使用 image 字段（后端返回的是 image），其次使用 avatar
		newUserInfo.avatar = (imageStr != '') ? imageStr : ((avatarStr != '') ? avatarStr : DEFAULT_AVATAR_LOCAL)
		newUserInfo.image = (imageStr != '') ? imageStr : avatarStr
		
		const phoneVal = userInfoParsed.get('phone')
		newUserInfo.phone = (phoneVal != null && phoneVal.toString() != '') ? phoneVal.toString() : ''
		
		const isGuideVal = userInfoParsed.get('isGuide')
		if (isGuideVal != null) {
			const isGuideNum = parseInt(isGuideVal.toString())
			if (isNaN(isGuideNum) == false) {
				newUserInfo.isGuide = isGuideNum
			}
		}
		
		const vipVal = userInfoParsed.get('vip')
		if (vipVal != null) {
			const vipNum = parseInt(vipVal.toString())
			if (isNaN(vipNum) == false) {
				newUserInfo.vip = vipNum
			}
		}
		
		const vipExpireTimeVal = userInfoParsed.get('vipExpireTime')
		newUserInfo.vipExpireTime = (vipExpireTimeVal != null && vipExpireTimeVal.toString() != '') ? vipExpireTimeVal.toString() : ''
		
		const vipTypeVal = userInfoParsed.get('vipType')
		if (vipTypeVal != null) {
			const vipTypeNum = parseInt(vipTypeVal.toString())
			if (isNaN(vipTypeNum) == false) {
				newUserInfo.vipType = vipTypeNum
			}
		}
		
		// 🎯 礼物等级字段
		const giftLevelVal = userInfoParsed.get('giftLevel')
		if (giftLevelVal != null) {
			const giftLevelNum = parseInt(giftLevelVal.toString())
			if (isNaN(giftLevelNum) == false) {
				newUserInfo.giftLevel = giftLevelNum
			}
		}
		
		// 调用 login 方法保存用户信息
		login(newUserInfo)
	} catch (e) {
		const errorOptions = new ErrorHandleOptions()
		errorOptions.showToast = false
		errorOptions.rethrow = false
		handleError(e, 'UserStore setUserInfoDataAction', errorOptions)
		throw e
	}
}

