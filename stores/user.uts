}

// 导出获取用户 VIP 状态的函数
export const getUserVipStatus = (): number => {
	const userInfo = userInfoRef.value
	if (userInfo == null) return VIP_NOT_ACTIVATED
	return userInfo.vip != null ? userInfo.vip : VIP_NOT_ACTIVATED
}

// 导出检查用户是否为 VIP 的函数
export const isUserVip = (): boolean => {
	const userInfo = userInfoRef.value
	if (userInfo == null) return false
	const vip = userInfo.vip
	const vipExpireTime = userInfo.vipExpireTime
	if (vip == VIP_ACTIVATED) {
		if (vipExpireTime != null && vipExpireTime != '') {
			const expireDate = new Date(vipExpireTime)
			const now = new Date()
			return expireDate > now
		}
		return true
	}
	return false
}

// 导出获取用户 VIP 到期时间的函数
export const getUserVipExpireTime = (): string => {
	const userInfo = userInfoRef.value
	if (userInfo == null) return ''
	return userInfo.vipExpireTime != null ? userInfo.vipExpireTime : ''
}

