	const userInfo = userInfoRef.value
	if (userInfo == null) return ''
	const userInfoObj = toUTSJSON(userInfo)
	return getString(userInfoObj, key)
}

// 导出获取用户数字属性的函数
export const getUserNumberProp = (key: string): number => {
	const userInfo = userInfoRef.value
	if (userInfo == null) return 0
	const userInfoObj = toUTSJSON(userInfo)
	return getNumber(userInfoObj, key)
}

const refreshTokenAction = async (): Promise<boolean> => {
	const currentUserInfo = userInfoRef.value
	if (currentUserInfo == null) return false
	const refreshTokenVal = currentUserInfo.refreshToken
	if (refreshTokenVal == null || refreshTokenVal == '') {
		return false
	}
	
	try {
		const requestResult = await uni.request({
			url: 'https://api.example.com/auth/refresh',
			method: 'POST',
			data: {
				refreshToken: refreshTokenVal
			}
		})
		
		// 解析响应 - 使用 typeConverter 替代重复 JSON 序列化
		if (requestResult == null) return false
		
		const resParsed = toUTSJSON(requestResult)
		if (resParsed == null) return false
		
		const resStatusCodeVal = resParsed.getNumber('statusCode')
		const resStatusCode = (resStatusCodeVal != null) ? Math.floor(resStatusCodeVal as number) : 0
		const resData = resParsed.getAny('data')
		
		if (resStatusCode === 200 && resData != null) {
			const dataParsed = toUTSJSON(resData)
			if (dataParsed == null) return false
			
			const codeVal = dataParsed.getNumber('code')
			const code = (codeVal != null) ? Math.floor(codeVal as number) : 0
			
			if (code === 200) {
				const innerData = dataParsed.getJSON('data')
				if (innerData == null) return false
				
				const tokenVal = innerData.getString('token')
				const accessTokenVal = innerData.getString('accessToken')
				const refreshTokenNewVal = innerData.getString('refreshToken')
				
				const newToken = (tokenVal != null && tokenVal != '') ? tokenVal : ((accessTokenVal != null && accessTokenVal != '') ? accessTokenVal : '')
				const newRefreshToken = (refreshTokenNewVal != null) ? refreshTokenNewVal : ''
				
				if (newToken != '' && userInfoRef.value != null) {
					userInfoRef.value.token = newToken
					userInfoRef.value.phoneWebToken = newToken
					if (newRefreshToken != '') {
						userInfoRef.value.refreshToken = newRefreshToken
					}
					
					saveUserInfoToStorage(userInfoRef.value)
					return true
				}
			}
		}
		
		return false
	} catch (e) {
		secureError('UserStore', 'Token refresh failed', 'TOKEN_REFRESH_FAILED')
		const errorOptions = new ErrorHandleOptions()
		errorOptions.showToast = false
		errorOptions.rethrow = false
		handleError(e, 'UserStore refreshToken', errorOptions)
		return false
	}
}

// 导出 useUserStore 函数
// UTS 规范：对象字面量不支持 getter/setter 语法，改为直接返回属性值
export const useUserStore = () => {
	// UTS 规范：先将 computed 值存入局部变量，避免属性名与变量名相同导致的递归问题
	const userInfoVal = userInfoRef.value
	const isLoginVal = isLoginRef.value
	const isUserGuideVal = isUserGuide.value
	const userIdVal = userId.value
	const tokenVal = token.value
	const isMemberVal = isMember.value
	const memberStatusTextVal = memberStatusText.value
	
	return {
		// State - 直接返回当前值
		// 保留 userInfo 属性名以保持向后兼容
		userInfo: userInfoVal,
		isLogin: isLoginVal,
		
		// Getters - 直接返回计算属性的当前值
		isUserGuide: isUserGuideVal,
		userId: userIdVal,
		token: tokenVal,
		isMember: isMemberVal,
		memberStatusText: memberStatusTextVal,
		
		// Actions - 包装为箭头函数以确保正确导出
		initUserInfo: () => initUserInfo(),
		login: (userInfo: UserInfo) => login(userInfo),
		// 注意：方法重命名为 setUserInfoData 避免与 userInfo 属性的 setter 产生 JVM 签名冲突
		setUserInfoData: (userInfo: UserInfo) => setUserInfo(userInfo),
		updateUserInfo: (userInfo: UTSJSONObject) => updateUserInfo(userInfo),
		logout: () => logout(),
		refreshToken: (): Promise<boolean> => refreshTokenAction(),
		
		// Setter 方法 - 用于更新状态
		setUserInfoValue: (val: UserInfo | null) => { userInfoRef.value = val },
		setIsLogin: (val: boolean) => { isLoginRef.value = val }
	}
}

// 导出UserStore 类型
// 注意：为避免 JVM 签名冲突，setUserInfo 方法重命名为 setUserInfoData
export interface UserStore {
	userInfo: UserInfo | null
	isLogin: boolean
	isUserGuide: boolean
	userId: string
	token: string
	isMember: boolean
	memberStatusText: string
	initUserInfo(): void
	login(userInfo: UserInfo): void
	logout(): void
	updateUserInfo(userInfo: UTSJSONObject): void
	refreshToken(): Promise<boolean>
	setUserInfoData(userInfo: UserInfo): void
	setUserInfoValue(val: UserInfo | null): void
	setIsLogin(val: boolean): void
}

// 显式导出
export default useUserStore