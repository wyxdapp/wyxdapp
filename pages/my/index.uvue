	font-size: 24rpx;
	color: #666666;
}

.arrow-right {
	font-size: 28rpx;
	color: #666666;
}

/* 统计数据卡片 */
.head-box {
	width: 750rpx;
	height: 140rpx;
	z-index: 2;
	position: fixed;
	left: 0;
	padding-left: 24rpx;
	padding-right: 24rpx;
}

.head-box-content {
	width: 100%;
	border-radius: 24rpx;
	height: 140rpx;
	background-color: #ffffff;
	flex-direction: row;
	justify-content: space-around;
	align-items: center;
	padding-left: 28rpx;
	padding-right: 28rpx;
}

.stat-item {
	flex-direction: column;
	align-items: center;
	justify-content: center;
}

