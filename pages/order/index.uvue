<template>
	<view class="fix-page bg-light-base">
		<image class="bg-my-header" src="https://jiasu.wyxdapp.com/iconimages/my_bg_head.png" mode="aspectFill" />
		<view class="fixed-header" :style="{ paddingTop: pageStatusBarHeight + 'px' }">
			<!-- Tab 栏 - 与发现页面结构完全一致 -->
			<view class="tabs-row">
				<view class="tab-item" @click="switchTab(0)">
					<text class="tab-text" :class="{ 'tab-text-active': tabIndex == 0 }">支出</text>
					<view v-if="tabIndex == 0" class="tab-underline"></view>
					<view v-if="expenditureDotVisible == true && tabIndex != 0" class="tab-dot"></view>
				</view>
				<view class="tab-item" @click="switchTab(1)">
