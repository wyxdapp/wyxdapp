}

// 取消收入订单
const doCancelIncomeOrder = async (orderKid: string, userKid: string) => {
	try {
		const params = new CancelOrderParams()
		params.orderKid = orderKid
		params.userKid = userKid
		await cancelOrder(params)
		incomeList.value = removeOrderFromList(incomeList.value, orderKid)
		uni.showToast({ title: '取消成功', icon: 'success' })
		calculateIncompleteOrderCount()
	} catch (error) {
		let errMsg = '取消失败'
		const errorObj = toJsonObj(error)
		if (errorObj != null) {
			const msg = getObjString(errorObj, 'message')
			if (msg != '') {
				errMsg = msg
			}
		}
		uni.showToast({ title: errMsg, icon: 'none' })
	}
}

