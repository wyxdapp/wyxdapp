					<input
						class="search-input"
						type="text"
						placeholder="搜索订单"
						placeholder-class="search-placeholder"
						v-model="currentSearchKeywordValue"
						@input="handleSearchInput"
					/>
				</view>
			</view>
		</view>

		<view v-if="isLoginValue == false" class="login-placeholder" :style="{ marginTop: headerHeight + 'px' }">
			<text class="login-placeholder-title">登录后可查看订单列表</text>
			<text class="login-placeholder-desc">登录后可查看你的支出和收入订单，并进行支付、退款等操作</text>
			<view class="login-btn" @click="goToLogin">
				<text class="login-btn-text">点击登录</text>
			</view>
		</view>

		<swiper v-else class="swiper" :style="{ marginTop: headerHeight + 'px', height: contentHeight + 'px' }" :current="tabIndex" @change="handleSwiperChange">
			<swiper-item class="swiper-item">
				<scroll-view
					class="scroll-view"
					:style="{ height: contentHeight + 'px' }"
					:scroll-y="true"
					:show-scrollbar="false"
					@scrolltolower="onScrollToLower"
					:lower-threshold="0"
					refresher-enabled="true"
					:refresher-triggered="expenditureRefreshing"
					@refresherrefresh="onExpenditureRefresh"
				>
					<view
						v-if="expenditureList.length > 0"
						class="plr-24"
					>
						<view
							v-for="(item, index) in expenditureList"
							:key="getItemKey(item, index)"
							class="mt-20 bg-white plr-28 border-radius-16 pb-32 order-card"
							@click="handleOrderClick(item, true)"
						>
							<view class="flex-row space-between align-center ptb-32">
								<view class="flex-row align-center" @click.stop="handleUserClick(item, true)">
									<Avatar
										:url="getItemAvatar(item, true)"
										:userId="getItemUserId(item, true)"
										:customSize="80"
										clickMode="none"
									/>
									<text class="color-title fs-lg font-bold ml-16">
										{{ getItemName(item, true) }}
									</text>
								</view>
								<view class="flex-row align-center">
									<text
										class="fs-md"
										:class="getStatusClass(item)"
									>{{ getStatusText(item) }}</text>
								</view>
							</view>
							<view class="border-line bg-light-base"></view>
							<view class="flex-row align-center mt-32">
								<text class="fs-md color-title">订单编号：</text>
								<text class="fs-md color-title">{{ getItemOrderNo(item) }}</text>
							</view>
							<view class="flex-row align-center space-between mt-32">
