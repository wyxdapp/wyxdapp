					<view v-if="tabIndex == 1" class="tab-underline"></view>
					<view v-if="incomeDotVisible == true && tabIndex != 1" class="tab-dot"></view>
				</view>
			</view>
			<view class="search-container">
				<view class="search-box">
					<image
