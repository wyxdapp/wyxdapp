	try {
		const params = new RemoveOrderParams()
		params.orderKid = orderKid
		params.userKid = userKid
		await delOrderInfo(params)
		incomeList.value = removeOrderFromList(incomeList.value, orderKid)
		uni.showToast({ title: '已删除', icon: 'success' })
		calculateIncompleteOrderCount()
	} catch (e) {
		console.error('删除订单失败:', e)
		uni.showToast({ title: '删除订单失败', icon: 'none' })
	}
}

// 获取退款记录的refundKid
const getRefundKid = async (orderKid: string): Promise<string> => {
	const params = new QueryRefundDetailParams()
	params.orderKid = orderKid
	const res = await queryRefundDetail(params)
	const resObj = toJsonObj(res)
	if (resObj == null) return ''
	const dataVal = resObj.get('data')
	if (dataVal == null) return ''
	const refundObj = toJsonObj(dataVal)
	if (refundObj == null) return ''
	return getObjString(refundObj, 'kid')
}

// 同意退款（收入订单）
const doAgreeRefund = async (orderKid: string) => {
	try {
		const refundKid = await getRefundKid(orderKid)
		if (refundKid == '') {
			uni.showToast({ title: '获取退款信息失败', icon: 'none' })
			return
		}
		const params = new GuiderAcceptRefundParams()
		params.refundKid = refundKid
		await guiderAcceptRefund(params)
		// 更新本地状态
		const idx = findOrderIndexInList(incomeList.value, orderKid)
		if (idx >= 0) {
			const itemObj = toJsonObj(incomeList.value[idx])
			if (itemObj != null) {
				itemObj.set('refundStatu', 20)
				itemObj.set('refundStatus', 20)
				incomeList.value.splice(idx, 1, itemObj)
			}
		}
		uni.showToast({ title: '已同意退款', icon: 'success' })
	} catch (e) {
		console.error('同意退款失败:', e)
		uni.showToast({ title: '同意退款失败', icon: 'none' })
	}
}

// 拒绝退款（收入订单）
const doRejectRefund = async (orderKid: string, reason: string) => {
	try {
		const refundKid = await getRefundKid(orderKid)
		if (refundKid == '') {
			uni.showToast({ title: '获取退款信息失败', icon: 'none' })
			return
		}
		const params = new GuiderRejectRefundParams()
		params.refundKid = refundKid
		params.refuseReason = reason
		await guiderRejectRefund(params)
		// 更新本地状态
		const idx = findOrderIndexInList(incomeList.value, orderKid)
		if (idx >= 0) {
			const itemObj = toJsonObj(incomeList.value[idx])
			if (itemObj != null) {
				itemObj.set('refundStatu', 30)
				itemObj.set('refundStatus', 30)
				incomeList.value.splice(idx, 1, itemObj)
			}
		}
		uni.showToast({ title: '已拒绝退款', icon: 'success' })
	} catch (e) {
		console.error('拒绝退款失败:', e)
		uni.showToast({ title: '拒绝退款失败', icon: 'none' })
	}
}

// ========== 收入订单操作 ==========
const handleIncomeAction = async (action: string, item: UTSJSONObject | null) => {
	const loginOk = ensureLogin()
	if (loginOk == false) return
	
	const orderKid = getItemOrderKid(item)
	if (orderKid == '') return
	const userId = getUserId()
	
	if (action == 'cancel') {
		uni.showModal({
			title: '提示',
			content: '确认取消订单？',
			success: (res: UniShowModalResult) => {
				if (res.confirm == true) {
					doCancelIncomeOrder(orderKid, userId)
				}
			}
		})
		return
	}
	
	if (action == 'accept') {
		uni.showModal({
			title: '提示',
			content: '确认接受订单？',
			success: (res: UniShowModalResult) => {
				if (res.confirm == true) {
					doAcceptOrder(orderKid, item)
				}
			}
		})
		return
	}
	
	if (action == 'reject') {
		uni.showModal({
			title: '提示',
			content: '确认拒绝订单？',
			success: (res: UniShowModalResult) => {
				if (res.confirm == true) {
					doRejectOrder(orderKid, item)
				}
			}
		})
		return
	}
	
	if (action == 'delete') {
		uni.showModal({
			title: '提示',
			content: '确认删除订单？',
			success: (res: UniShowModalResult) => {
				if (res.confirm == true) {
					doDeleteIncomeOrder(orderKid, userId)
				}
			}
		})
		return
	}
	
	if (action == 'agreeRefund') {
		uni.showModal({
			title: '提示',
			content: '确认同意该退款申请？同意后款项将退还给游客。',
			success: (res: UniShowModalResult) => {
				if (res.confirm == true) {
					doAgreeRefund(orderKid)
				}
			}
		})
		return
	}
	
	if (action == 'rejectRefund') {
		uni.showModal({
			title: '拒绝退款',
			content: '请确认拒绝该退款申请',
			editable: true,
			placeholderText: '请输入拒绝原因',
			success: (res: UniShowModalResult) => {
				if (res.confirm == true) {
					const reason = res.content != null ? res.content as string : ''
					if (reason == '') {
						uni.showToast({ title: '请输入拒绝原因', icon: 'none' })
						return
					}
					doRejectRefund(orderKid, reason)
				}
			}
		})
		return
	}
}

// ========== 修改价格弹窗 ==========
const onChangePriceClick = (item: UTSJSONObject | null) => {
	const loginOk = ensureLogin()
	if (loginOk == false) return
	
	const orderKid = getItemOrderKid(item)
	if (orderKid == '') return
	
	const itemObj = toJsonObj(item)
	let currentPrice = 0
	if (itemObj != null) {
		currentPrice = getObjFloat(itemObj, 'orderPrice')
		if (currentPrice == 0) {
			currentPrice = getObjFloat(itemObj, 'totalMoney')
		}
	}
	
	priceEditingOrderKid.value = orderKid
	priceInput.value = currentPrice > 0 ? currentPrice.toString() : ''
	priceDialogVisible.value = true
}

const closePriceDialog = () => {
	priceDialogVisible.value = false
	priceEditingOrderKid.value = ''
	priceInput.value = ''
}

const submitPriceChange = async () => {
	const loginOk = ensureLogin()
	if (loginOk == false) return
	
	if (priceEditingOrderKid.value == '') {
		priceDialogVisible.value = false
		return
	}
	
	const val = priceInput.value
	if (val == '') {
		uni.showToast({ title: '请输入价格', icon: 'none' })
		return
	}
	
	const num = parseFloat(val)
	if (isNaN(num) == true || num <= 0) {
		uni.showToast({ title: '价格必须大于0', icon: 'none' })
		return
	}
	
	try {
		const params = new UpdateOrderPriceParams()
		params.orderKid = priceEditingOrderKid.value
		params.orderPrice = num
		params.orderAmount = num
		await updateGuiderOrderPrice(params)
		
		// 更新本地数据并触发响应式更新
		const idx = findOrderIndexInList(incomeList.value, priceEditingOrderKid.value)
		if (idx >= 0) {
			const itemObj = toJsonObj(incomeList.value[idx])
			if (itemObj != null) {
				itemObj.set('orderPrice', num)
				itemObj.set('totalMoney', num)
				// 替换数组元素以触发 Vue 响应式更新
				incomeList.value.splice(idx, 1, itemObj)
			}
		}
		
		uni.showToast({ title: '价格已修改', icon: 'success' })
		priceDialogVisible.value = false
		priceEditingOrderKid.value = ''
		priceInput.value = ''
	} catch (e) {
		console.error('修改订单价格失败:', e)
		uni.showToast({ title: '修改价格失败', icon: 'none' })
	}
}

// ========== 事件监听 ==========
const handleOrderChanged = () => {
	forceRefresh()
}

// ========== 布局初始化函数 ==========
const initPageLayout = () => {
	// 使用 composable 初始化布局
	initPageLayoutComposable()
	
	// 计算登录框顶部位置
	loginBoxTop.value = pageStatusBarHeight.value + 64
	
	// 计算头部高度（与发现页面一致：状态栏 + Tab栏约90rpx = 状态栏 + 45px）
	// 订单页面多了搜索栏，需要额外加上搜索栏高度（72rpx≈36px + 间距40rpx≈20px）
	headerHeight.value = pageStatusBarHeight.value + 45 + 56
	
	// 计算内容区域高度（窗口高度 - 头部高度）
	if (pageWindowHeight.value > 0) {
		contentHeight.value = pageWindowHeight.value - headerHeight.value
		
		// 确保内容高度有效
		if (contentHeight.value < 200) {
			contentHeight.value = pageWindowHeight.value - 100
		}
	}
	
	console.log('订单页面布局 - 状态栏高度:', pageStatusBarHeight.value, '头部高度:', headerHeight.value, '内容高度:', contentHeight.value)
	
	// 如果内容高度仍然无效，设置默认值
	if (contentHeight.value <= 0) {
		contentHeight.value = 600
	}
}

// ========== 初始化函数 ==========
const initPageData = () => {
	// 🔧 优化：使用 checkUserLoginReliable 进行可靠的登录检查
	const isLogin = checkUserLoginReliable()
	const userId = getCurrentUserIdReliable()
	
	// 更新响应式登录状态
	isLoginValue.value = isLogin
	
	console.log('📢 [订单页面] 初始化 - 登录状态:', isLogin, '用户ID:', userId)
	
	if (isLogin == false || userId == '') {
		console.log('📢 [订单页面] 用户未登录，显示登录提示')
		return
	}
	
	try {
		const dirty = uni.getStorageSync('order:dirty')
		const dirtyObj = toJsonObj(dirty)
		if (dirtyObj != null) {
			const ts = getObjNumber(dirtyObj, 'ts')
			if (ts > 0 && Date.now() - ts < 300000) {
				forceRefresh()
				uni.removeStorageSync('order:dirty')
				return
			}
		}
	} catch (e) {}
	
	loadExpenditureList()
	syncOrderTabRedDotsFromServer()
}

// ========== 登录状态变化回调（必须在 onMounted 之前定义）==========
const handleLoginStatusChange = (data: UTSJSONObject | null) => {
	const dataObj = parseLoginStatusData(data)
	if (dataObj == null) return
	
	const isLogin = getIsLoginFromData(dataObj)
	const wasLoggedIn = isLoginValue.value
	isLoginValue.value = isLogin
	
	console.log('📢 [订单页面] 登录状态变化:', isLogin, '之前状态:', wasLoggedIn)
	
	// 如果刚登录，加载数据
	if (wasLoggedIn == false && isLogin == true) {
		console.log('📢 [订单页面] 用户刚登录，加载订单数据')
		initPageData()
	}
}

// ========== 生命周期 ==========
onMounted(() => {
	// 初始化布局
	initPageLayout()
	
	// 🔧 优化：注册登录状态变化监听
	onLoginStatusChange(handleLoginStatusChange)
	
	// 🔧 优化：使用 waitForLoginStatus 等待 Store 初始化
	// 返回 1=已登录，0=未登录
	// UTS 规范：onMounted 不能是 async，使用 .then() 处理 Promise
	waitForLoginStatus(2000).then((loginResult: number) => {
		isLoginValue.value = (loginResult == 1)
		
		console.log('📢 [订单页面] onMounted - 登录状态:', isLoginValue.value)
		
		// 初始化页面数据
		initPageData()
	})
	
	try {
		uni.$on('ORDER_CHANGED', handleOrderChanged)
	} catch (e) {}
})

// 页面显示时重新检查登录状态（用户可能从登录页返回）
onShow(() => {
	// 🔧 优化：使用 checkUserLoginReliable 进行可靠的登录检查
	const isLogin = checkUserLoginReliable()
	const wasLoggedIn = isLoginValue.value
	isLoginValue.value = isLogin
	
	console.log('📢 [订单页面] onShow - 登录状态:', isLogin, '之前状态:', wasLoggedIn)
	
	// 如果之前未登录，现在已登录，则加载数据
	if (wasLoggedIn == false && isLogin == true) {
		console.log('📢 [订单页面] 用户刚登录，加载订单数据')
		initPageData()
		return
	}
	
	// 🔧 新增：从子页面返回时，如果有待刷新标记则刷新当前列表
	if (pendingRefresh.value == true && isLogin == true) {
		pendingRefresh.value = false
		forceRefresh()
	}
})

onUnmounted(() => {
	// 🔧 优化：取消登录状态变化监听
	offLoginStatusChange(handleLoginStatusChange)
	
	try {
		uni.$off('ORDER_CHANGED', handleOrderChanged)
	} catch (e) {}
})

// ========== Watch ==========
const tabIndexComputed = computed((): number => {
	return tabIndex.value
})

watch(tabIndexComputed, (val: number) => {
	const isLogin = getUserLoginStatus()
	if (val == 1 && isLogin == true && incomeList.value.length == 0 && incomePageNumber.value == 1) {
		loadIncomeList()
	}
})
</script>


