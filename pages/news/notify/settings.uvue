}

.save-btn-wrapper {
	padding-top: 40rpx;
	padding-left: 28rpx;
	padding-right: 28rpx;
	padding-bottom: 80rpx;
}

.save-btn {
	width: 694rpx;
	height: 88rpx;
	background-color: #37B1F2;
	border-radius: 44rpx;
	color: #ffffff;
	font-size: 32rpx;
	font-weight: bold;
	flex-direction: row;
	align-items: center;
	justify-content: center;
}
