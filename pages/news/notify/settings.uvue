<template>
	<view class="settings-page">
		<!-- 自定义导航栏 -->
		<view class="custom-navbar">
			<view class="navbar-content">
				<view class="navbar-left" @click="goBack">
					<UniIcons type="back" :size="44" class="back-icon-img" />
				</view>
				<text class="navbar-title">通知设置</text>
				<view class="navbar-right"></view>
			</view>
		</view>
		
		<scroll-view class="scroll-view" scroll-y :show-scrollbar="false">
			<!-- 通知总开关 -->
			<view class="setting-section">
				<view class="section-header">
					<text class="section-title">通知开关</text>
				</view>
				<view class="setting-item">
					<view class="item-left">
						<UniIcons type="notification-filled" :size="36" color="#FF9800" />
						<text class="item-label">接收通知</text>
					</view>
					<switch :checked="settingsEnabled" @change="handleEnabledChange" :color="currentTheme.primaryColor" />
				</view>
			</view>
			
			<!-- 通知类型设置 -->
			<view class="setting-section">
				<view class="section-header">
					<text class="section-title">通知类型</text>
					<text class="section-desc">选择您想接收的通知类型</text>
				</view>
				<view class="setting-item">
					<view class="item-left">
						<UniIcons type="shop" :size="36" :color="currentTheme.primaryColor" />
						<text class="item-label">订单通知</text>
					</view>
					<switch 
						:checked="settingsOrderNotify" 
						:disabled="settingsEnabled == false"
						@change="handleOrderNotifyChange" 
						:color="currentTheme.primaryColor" 
					/>
				</view>
				<view class="setting-item">
					<view class="item-left">
						<UniIcons type="notification-filled" :size="36" color="#FF9800" />
						<text class="item-label">系统通知</text>
					</view>
					<switch 
						:checked="settingsSystemNotify" 
						:disabled="settingsEnabled == false"
						@change="handleSystemNotifyChange" 
						:color="currentTheme.primaryColor" 
					/>
				</view>
				<view class="setting-item">
					<view class="item-left">
						<UniIcons type="chatbubble-filled" :size="36" :color="currentTheme.primaryColor" />
						<text class="item-label">互动通知</text>
					</view>
					<switch 
						:checked="settingsInteractNotify" 
						:disabled="settingsEnabled == false"
						@change="handleInteractNotifyChange" 
						:color="currentTheme.primaryColor" 
					/>
				</view>
			</view>
			
			<!-- 免打扰设置 -->
			<view class="setting-section">
				<view class="section-header">
					<text class="section-title">免打扰时段</text>
					<text class="section-desc">在此时段内不会收到通知提醒</text>
				</view>
				<view class="setting-item">
					<view class="item-left">
						<text class="item-icon">🌙</text>
						<text class="item-label">开启免打扰</text>
					</view>
					<switch 
						:checked="settingsDndEnabled" 
						:disabled="settingsEnabled == false"
						@change="handleDndEnabledChange" 
						:color="currentTheme.primaryColor" 
					/>
				</view>
				<view v-if="settingsDndEnabled == true" class="time-picker-group">
					<view class="setting-item">
						<text class="item-label">开始时间</text>
						<picker 
							mode="time" 
							:value="settingsDndStart" 
							:disabled="settingsEnabled == false"
							@change="handleDndStartChange"
						>
							<view class="picker-value">
								<text class="picker-text">{{ settingsDndStart }}</text>
								<text class="arrow">›</text>
							</view>
						</picker>
					</view>
					<view class="setting-item">
						<text class="item-label">结束时间</text>
						<picker 
							mode="time" 
							:value="settingsDndEnd" 
							:disabled="settingsEnabled == false"
							@change="handleDndEndChange"
						>
							<view class="picker-value">
								<text class="picker-text">{{ settingsDndEnd }}</text>
								<text class="arrow">›</text>
							</view>
						</picker>
					</view>
				</view>
			</view>
			
			<!-- 声音和震动 -->
			<view class="setting-section">
				<view class="section-header">
					<text class="section-title">提醒方式</text>
				</view>
				<view class="setting-item">
					<view class="item-left">
						<text class="item-icon">🔊</text>
						<text class="item-label">声音提醒</text>
					</view>
					<switch 
						:checked="settingsSoundEnabled" 
						:disabled="settingsEnabled == false"
						@change="handleSoundEnabledChange" 
						:color="currentTheme.primaryColor" 
					/>
				</view>
				<view class="setting-item">
					<view class="item-left">
						<text class="item-icon">📳</text>
						<text class="item-label">震动提醒</text>
					</view>
					<switch 
						:checked="settingsVibrateEnabled" 
						:disabled="settingsEnabled == false"
						@change="handleVibrateEnabledChange" 
						:color="currentTheme.primaryColor" 
					/>
				</view>
			</view>
			
			<!-- 保存按钮 -->
			<view class="save-btn-wrapper">
				<button class="save-btn" @click="handleSave">保存设置</button>
			</view>
		</scroll-view>
	</view>
</template>

<script setup lang="uts">
import { ref, onMounted } from 'vue'
import UniIcons from '@/components/base/UniIcons.uvue'
import { currentTheme } from '@/stores/theme.uts'

// ==================== 辅助函数 ====================
import { toJsonObj, countArrayItems } from '@/common/utils/utsSafe.uts'

const getObjString = (obj: UTSJSONObject | null, key: string): string => {
	if (obj == null) return ''
	const val = obj.get(key)
	if (val != null && val.toString() != '') {
		return val.toString()
	}
	return ''
}

const getObjBoolean = (obj: UTSJSONObject | null, key: string): boolean => {
	if (obj == null) return false
	const val = obj.get(key)
	if (val != null) {
		const str = val.toString()
		return str == 'true' || str == '1'
	}
	return false
}

// ==================== 设置数据（拆分为独立 ref）====================
const settingsEnabled = ref<boolean>(true)
const settingsOrderNotify = ref<boolean>(true)
const settingsSystemNotify = ref<boolean>(true)
const settingsInteractNotify = ref<boolean>(true)
const settingsDndEnabled = ref<boolean>(false)
const settingsDndStart = ref<string>('22:00')
const settingsDndEnd = ref<string>('08:00')
const settingsSoundEnabled = ref<boolean>(true)
const settingsVibrateEnabled = ref<boolean>(true)

// ==================== 方法定义（必须在生命周期之前）====================

// 返回
const goBack = () => {
	uni.navigateBack()
}

// 加载设置
const loadSettings = () => {
	try {
		const savedSettings = uni.getStorageSync('notification_settings')
		if (savedSettings != null && savedSettings != '') {
			const settingsStr = savedSettings.toString()
			if (settingsStr != '') {
				const settingsObj = JSON.parse(settingsStr) as UTSJSONObject
				if (settingsObj != null) {
					const enabledVal = settingsObj.get('enabled')
					if (enabledVal != null) {
						settingsEnabled.value = getObjBoolean(settingsObj, 'enabled')
					}
					const orderNotifyVal = settingsObj.get('orderNotify')
					if (orderNotifyVal != null) {
						settingsOrderNotify.value = getObjBoolean(settingsObj, 'orderNotify')
					}
					const systemNotifyVal = settingsObj.get('systemNotify')
					if (systemNotifyVal != null) {
						settingsSystemNotify.value = getObjBoolean(settingsObj, 'systemNotify')
					}
					const interactNotifyVal = settingsObj.get('interactNotify')
					if (interactNotifyVal != null) {
						settingsInteractNotify.value = getObjBoolean(settingsObj, 'interactNotify')
					}
					const dndEnabledVal = settingsObj.get('dndEnabled')
					if (dndEnabledVal != null) {
						settingsDndEnabled.value = getObjBoolean(settingsObj, 'dndEnabled')
					}
					const dndStartVal = settingsObj.get('dndStart')
					if (dndStartVal != null && dndStartVal.toString() != '') {
						settingsDndStart.value = dndStartVal.toString()
					}
					const dndEndVal = settingsObj.get('dndEnd')
					if (dndEndVal != null && dndEndVal.toString() != '') {
						settingsDndEnd.value = dndEndVal.toString()
					}
					const soundEnabledVal = settingsObj.get('soundEnabled')
					if (soundEnabledVal != null) {
						settingsSoundEnabled.value = getObjBoolean(settingsObj, 'soundEnabled')
					}
					const vibrateEnabledVal = settingsObj.get('vibrateEnabled')
					if (vibrateEnabledVal != null) {
						settingsVibrateEnabled.value = getObjBoolean(settingsObj, 'vibrateEnabled')
					}
				}
			}
		}
	} catch (error) {
		console.error('加载设置失败:', error)
	}
}

// 开关变更处理
const handleEnabledChange = (e: UTSJSONObject) => {
	if (e != null) {
		const eObj = toJsonObj(e)
		if (eObj != null) {
			const detailVal = eObj.get('detail')
			const detailObj = toJsonObj(detailVal)
			if (detailObj != null) {
				const valueVal = detailObj.get('value')
				if (valueVal != null) {
					settingsEnabled.value = valueVal.toString() == 'true'
				}
			}
		}
	}
}

const handleOrderNotifyChange = (e: UTSJSONObject) => {
	if (e != null) {
		const eObj = toJsonObj(e)
		if (eObj != null) {
			const detailVal = eObj.get('detail')
			const detailObj = toJsonObj(detailVal)
			if (detailObj != null) {
				const valueVal = detailObj.get('value')
				if (valueVal != null) {
					settingsOrderNotify.value = valueVal.toString() == 'true'
				}
			}
		}
	}
}

const handleSystemNotifyChange = (e: UTSJSONObject) => {
	if (e != null) {
		const eObj = toJsonObj(e)
		if (eObj != null) {
			const detailVal = eObj.get('detail')
			const detailObj = toJsonObj(detailVal)
			if (detailObj != null) {
				const valueVal = detailObj.get('value')
				if (valueVal != null) {
					settingsSystemNotify.value = valueVal.toString() == 'true'
				}
			}
		}
	}
}

const handleInteractNotifyChange = (e: UTSJSONObject) => {
	if (e != null) {
		const eObj = toJsonObj(e)
		if (eObj != null) {
			const detailVal = eObj.get('detail')
			const detailObj = toJsonObj(detailVal)
			if (detailObj != null) {
				const valueVal = detailObj.get('value')
				if (valueVal != null) {
					settingsInteractNotify.value = valueVal.toString() == 'true'
				}
			}
		}
	}
}

const handleDndEnabledChange = (e: UTSJSONObject) => {
	if (e != null) {
		const eObj = toJsonObj(e)
		if (eObj != null) {
			const detailVal = eObj.get('detail')
			const detailObj = toJsonObj(detailVal)
			if (detailObj != null) {
				const valueVal = detailObj.get('value')
				if (valueVal != null) {
					settingsDndEnabled.value = valueVal.toString() == 'true'
				}
			}
		}
	}
}

const handleSoundEnabledChange = (e: UTSJSONObject) => {
	if (e != null) {
		const eObj = toJsonObj(e)
		if (eObj != null) {
			const detailVal = eObj.get('detail')
			const detailObj = toJsonObj(detailVal)
			if (detailObj != null) {
				const valueVal = detailObj.get('value')
				if (valueVal != null) {
					settingsSoundEnabled.value = valueVal.toString() == 'true'
				}
			}
		}
	}
}

const handleVibrateEnabledChange = (e: UTSJSONObject) => {
	if (e != null) {
		const eObj = toJsonObj(e)
		if (eObj != null) {
			const detailVal = eObj.get('detail')
			const detailObj = toJsonObj(detailVal)
			if (detailObj != null) {
				const valueVal = detailObj.get('value')
				if (valueVal != null) {
					settingsVibrateEnabled.value = valueVal.toString() == 'true'
				}
			}
		}
	}
}

// 时间选择器变更
const handleDndStartChange = (e: UTSJSONObject) => {
	if (e != null) {
		const eObj = toJsonObj(e)
		if (eObj != null) {
			const detailVal = eObj.get('detail')
			const detailObj = toJsonObj(detailVal)
			if (detailObj != null) {
				const valueVal = detailObj.get('value')
				if (valueVal != null && valueVal.toString() != '') {
					settingsDndStart.value = valueVal.toString()
				}
			}
		}
	}
}

const handleDndEndChange = (e: UTSJSONObject) => {
	if (e != null) {
		const eObj = toJsonObj(e)
		if (eObj != null) {
			const detailVal = eObj.get('detail')
			const detailObj = toJsonObj(detailVal)
			if (detailObj != null) {
				const valueVal = detailObj.get('value')
				if (valueVal != null && valueVal.toString() != '') {
					settingsDndEnd.value = valueVal.toString()
				}
			}
		}
	}
}

// 保存设置
const handleSave = () => {
	try {
		const settingsData = {
			enabled: settingsEnabled.value,
			orderNotify: settingsOrderNotify.value,
			systemNotify: settingsSystemNotify.value,
			interactNotify: settingsInteractNotify.value,
			dndEnabled: settingsDndEnabled.value,
			dndStart: settingsDndStart.value,
			dndEnd: settingsDndEnd.value,
			soundEnabled: settingsSoundEnabled.value,
			vibrateEnabled: settingsVibrateEnabled.value
		} as UTSJSONObject
		uni.setStorageSync('notification_settings', JSON.stringify(settingsData))
		uni.showToast({
			title: '设置已保存',
			icon: 'success'
		})
	} catch (error) {
		console.error('保存设置失败:', error)
		uni.showToast({
			title: '保存失败',
			icon: 'none'
		})
	}
}

// ==================== 生命周期 ====================
onMounted(() => {
	loadSettings()
})
</script>

<style scoped>
