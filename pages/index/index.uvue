<template>
	<view class="page">
		<!-- 渐变背景 -->
		<view class="bg-index-header" :style="headerGradientOuter()">
			<view class="bg-index-header-mask" :style="headerGradientMask()"></view>
		</view>
		
		<!-- 顶部搜索栏 -->
		<view class="header" :style="{ paddingTop: pageStatusBarHeight + 'px' }">
			<view class="search-bar" :style="{ paddingRight: (menuButtonRight > 0 ? menuButtonRight + 6 : 28) + 'px' }">
				<view class="location" @click="openCityPicker">
					<image class="location-icon" src="https://jiasu.wyxdapp.com/iconimages/n_index_location.png" mode="aspectFit"></image>
					<text class="location-text">{{ cityName }}</text>
					<text class="arrow">▼</text>
				</view>
				<view class="search-input" @click="goToSearch">
					<image class="search-icon" src="https://jiasu.wyxdapp.com/iconimages/n_index_search.png" mode="aspectFit"></image>
					<text class="search-placeholder">搜索昵称或定制</text>
				</view>
			</view>
			
			<!-- Tab 切换 -->
			<view class="tabs-row">
				<view class="tabs-left">
					<view class="tab-item" @click="switchTab(0)">
						<text class="tab-text" :class="{ 'tab-text-active': currentTab == 0 }">向导</text>
						<view v-if="currentTab == 0" class="tab-underline"></view>
					</view>
					<view class="tab-item" @click="switchTab(1)">
						<text class="tab-text" :class="{ 'tab-text-active': currentTab == 1 }">接单</text>
						<view v-if="currentTab == 1" class="tab-underline"></view>
					</view>
				</view>
				<view class="publish-btn" @click="goToPublish">
					<image class="publish-icon" src="https://jiasu.wyxdapp.com/iconimages/n_index_send.png" mode="aspectFit"></image>
					<text class="publish-text">发布</text>
				</view>
			</view>
		</view>
		
		<!-- Swiper 内容区域 -->
		<swiper 
			class="swiper-container"
			:style="{ marginTop: headerHeight + 'px', height: contentHeight + 'px' }"
			:current="currentTab"
			@change="onSwiperChange"
		>
			<!-- 向导列表 -->
			<swiper-item>
				<scroll-view 
					class="scroll-view"
					:style="{ height: contentHeight + 'px' }"
					scroll-y="true"
					refresher-enabled="true"
					:refresher-triggered="guiderRefreshing"
					:show-scrollbar="false"
					@refresherrefresh="onRefresh"
					@scrolltolower="loadMore"
				>
					<ListStatus 
						v-if="guiderLoading == true && guiderListLength == 0" 
						status="loading" 
					/>
					<ListStatus 
						v-else-if="guiderListLength == 0" 
						status="empty" 
						emptyText="暂无向导" 
					/>
					<view v-else class="guider-list">
						<guider-card 
							v-for="(item, index) in guiderList" 
							:key="getGuiderKey(item, index)"
							:data="item"
							:isOnline="getGuiderOnlineStatus(item)"
							@click="goToGuiderDetail"
						/>
					</view>
					<ListStatus 
						v-if="guiderHasMore == true && guiderLoading == false && guiderListLength > 0" 
						status="loadMore" 
					/>
					<ListStatus 
						v-if="guiderHasMore == false && guiderListLength > 0" 
						status="noMore" 
					/>
				</scroll-view>
			</swiper-item>
			
			<!-- 接单列表 -->
			<swiper-item>
				<scroll-view 
					class="scroll-view"
					:style="{ height: contentHeight + 'px' }"
					scroll-y="true"
					:show-scrollbar="false"
					refresher-enabled="true"
					:refresher-triggered="grabOrderRefreshing"
					@refresherrefresh="onRefresh"
					@scrolltolower="loadMore"
				>
					<view v-if="grabOrderLoading == true && grabOrderListLength == 0" class="loading">
						<text class="loading-text">加载中...</text>
					</view>
					
					<ListStatus 
						v-else-if="grabOrderListLength == 0" 
						status="empty" 
						emptyText="暂无接单"
					/>
					
					<view v-else class="list grab-order-list">
						<view 
							v-for="(item, index) in grabOrderList" 
							:key="getGrabOrderItemKey(item, index)"
							class="order-card"
							@click="handleGrabOrderClick(item)"
						>
							<!-- 头部：头像 + 用户名 + 分享按钮 -->
							<view class="order-card-header">
								<view class="order-card-user" @click.stop="handleGrabOrderUserClick(item)">
									<Avatar
										:url="getGrabOrderAvatar(item)"
										:userId="getGrabOrderUserKid(item)"
										size="small"
										clickMode="none"
									/>
									<text class="order-username">{{ getGrabOrderUserName(item) }}</text>
								</view>
								<view class="order-share-btn" @click.stop="handleGrabOrderShare(item)">
									<uni-icons type="redo" :size="24" color="#999999"></uni-icons>
								</view>
							</view>
							<!-- 分割线 -->
							<view class="order-divider"></view>
							<!-- 订单编号 -->
							<view class="order-info-row">
								<text class="order-info-label">订单编号：</text>
								<text class="order-info-value">{{ getGrabOrderNo(item) }}</text>
							</view>
							<!-- 订单描述 -->
							<view class="order-desc-row">
								<text class="order-desc-text">{{ getGrabOrderTitle(item) }}</text>
							</view>
							<!-- 出发时间 -->
							<view class="order-time-row">
								<image
									class="order-time-icon"
									src="https://jiasu.wyxdapp.com/iconimages/order_icon_startTime.png"
									mode="aspectFill"
								/>
								<text class="order-time-label">出发时间：</text>
								<text class="order-time-value">{{ getGrabOrderTime(item) }}</text>
							</view>
							<!-- 操作按钮行：预算 + 抢单按钮 -->
							<view class="order-btn-row" @click.stop>
								<view class="order-budget-box">
									<text class="order-budget-label">预算：</text>
									<text class="order-price-symbol">¥</text>
									<text class="order-price-value">{{ getGrabOrderPrice(item) }}</text>
								</view>
								<view class="order-btn order-btn-primary" @click="handleGrabOrder(item)">
									<text class="order-btn-primary-text">立即接单</text>
								</view>
							</view>
						</view>
					</view>
					
					<!-- 加载更多 -->
					<view v-if="grabOrderListLength > 0" class="load-status">
						<text v-if="grabOrderLoadStatus == 'loading'" class="status-text">加载中...</text>
						<text v-else-if="grabOrderLoadStatus == 'nomore'" class="status-text">没有更多了</text>
						<text v-else class="status-text-more">上拉加载更多</text>
					</view>
				</scroll-view>
			</swiper-item>
		</swiper>
		
		<!-- 找向导悬浮按钮 -->
		<view v-if="currentTab == 0" class="find-guide-btn" @click="goToFindGuide">
			<text class="btn-text">找向导</text>
		</view>
		
		<!-- 营销活动弹窗 -->
		<MarketingPopup 
			:visible="marketingPopupVisible"
			:popupData="marketingPopupData"
			@close="handlePopupClose"
			@buttonClick="handlePopupButtonClick"
		/>
		
		<!-- 🔒 隐私政策弹窗（首次启动时显示，必须在敏感API调用前获得用户同意） -->
		<PrivacyPopup 
			:visible="privacyPopupVisible"
			@agree="handlePrivacyAgree"
			@disagree="handlePrivacyDisagree"
		/>
		
		<!-- 分享弹窗组件 -->
		<SharePopup
			v-model:visity="showSharePopup"
			:shareData="sharePayload"
			:chatList="shareChatList"
			@share-to-chat="handleShareToChat"
			@wechat-share="handleShareWechat"
			@moments-share="handleShareMoments"
			@copy-link="handleCopyLink"
			@show-qrcode="handleShowQrcode">
		</SharePopup>
	</view>
</template>

<script setup lang="uts">
import { ref, computed, onMounted, onUnmounted } from 'vue'
import { onShow } from '@dcloudio/uni-app'
// #ifdef MP-WEIXIN
import { onShareAppMessage, onShareTimeline } from '@dcloudio/uni-app'
// #endif
import { handlePageError, handleSilentError, isAuthError } from '@/common/utils/errorHandler.uts'
import { headerGradientOuter, headerGradientMask } from '@/common/utils/themeHelper.uts'
import GuiderCard from '@/components/guider-card/index.uvue'
import ListStatus from '@/components/base/ListStatus.uvue'
import MarketingPopup from '@/components/common/MarketingPopup.uvue'
import PrivacyPopup from '@/components/common/PrivacyPopup.uvue'
import Avatar from '@/components/base/Avatar.uvue'
import SharePopup from '@/components/common/SharePopup.uvue'
import request from '@/utils/request'
import { getGuiderList } from '@/common/services/homeService.uts'
import { isSharedDataDisplayEnabled, isFeatureTogglesLoaded } from '@/common/composables/useFeatureToggles.uts'
import { getLocationInfo } from '@/common/utils/location.uts'
import { isPrivacyAgreed, PRIVACY_AGREED_EVENT, broadcastPrivacyAgreed } from '@/common/utils/privacyManager.uts'
import { 
	pageStatusBarHeight, 
	pageWindowHeight,
	initPageLayout as initPageLayoutComposable 
} from '@/common/composables/usePageLayout.uts'
import { 
	getStringProp, 
	getResponseCode, 
	getResponseData, 
	getEntities, 
	getDataCount,
	getItemKeyByField,
	toJsonObj
} from '@/common/utils/utsSafe.uts'
import {
	MARKETING_POPUP_TRIGGER,
	TRIGGER_TYPE_PAGE_LOAD,
	fetchActivePopup,
	shouldShowPopup,
	saveDisplayRecord,
	navigateToUrl
} from '@/common/services/marketingPopupService.uts'
import { 
	fetchOnlineStatus, 
	getOnlineStatusDirect, 
	setOnlineStatusDirect 
} from '@/stores/onlineStatus.uts'
import { DEFAULT_AVATAR_LOCAL, DEFAULT_SHARE_IMAGE_LOCAL, HOME_SHARE_IMAGE_LOCAL } from '@/common/config/defaultImages.uts'
import { getCurrentUserIdReliable } from '@/common/utils/loginHelper.uts'
import { checkMemberGuard } from '@/common/composables/useMemberGuard.uts'
import { 
	getChatList as getChatListFn, 
	getChatListRef,
	handleShareToChat as handleShareToChatFn
} from '@/common/composables/useChatAndShare.uts'
import { 
	handleShareWechat as handleShareWechatFn,
	handleShareMoments as handleShareMomentsFn,
	handleCopyLink as handleCopyLinkFn,
	handleShowQrcode as handleShowQrcodeFn
} from '@/common/composables/useShareUi.uts'
import { useUserStore, getUserShortKid, updateUserInfoAction } from '@/stores/user.uts'
import { TEXT_PREVIEW_LENGTH } from '@/common/config/uiConfig.uts'
import { getCachedProfile } from '@/common/composables/useUserProfileCache.uts'

// ==================== 类型定义 ====================

class PageListData {
	pageNumber: number = 1
	pageSize: number = 10
	status: string = 'loadmore'
	total: number = 0
}

// ==================== 辅助函数（必须在使用前定义）====================

// 获取字符串属性
const getItemStringProp = (item: UTSJSONObject, key: string): string => {
	if (item == null) return ''
	try {
		const itemObj = JSON.parse(JSON.stringify(item)) as UTSJSONObject
		const val = itemObj.get(key)
		return (val != null && val.toString() != '') ? val.toString() : ''
	} catch (e) {
		return ''
	}
}

// 获取数字属性
const getItemNumberProp = (item: UTSJSONObject, key: string): number => {
	if (item == null) return 0
	try {
		const itemObj = JSON.parse(JSON.stringify(item)) as UTSJSONObject
		const val = itemObj.get(key)
		if (val != null) {
			const num = parseInt(val.toString())
			if (isNaN(num) == false) return num
		}
	} catch (e) {}
	return 0
}

// 内联金额格式化
const formatMoney = (value: number): string => {
	if (isNaN(value)) return '0.00'
	const cents = Math.round(value * 100)
	const absCents = (cents < 0) ? -cents : cents
	const yuan = Math.floor(absCents / 100)
	const fen = absCents % 100
	const fenStr = (fen < 10) ? ('0' + fen.toString()) : fen.toString()
	const result = yuan.toString() + '.' + fenStr
	return (cents < 0) ? ('-' + result) : result
}


// 从 loginHelper 获取用户 Kid（可靠版本）
const getUserKidFromStore = (): string => {
	return getCurrentUserIdReliable()
}

// ==================== 响应式状态 ====================

// 布局相关
const headerHeight = ref<number>(0)
const contentHeight = ref<number>(0)
const menuButtonRight = ref<number>(0)  // 胶囊按钮右边距（屏幕宽度 - 胶囊左边界，即胶囊宽度+右间距）

// Tab 相关
const currentTab = ref<number>(0)
const cityName = ref<string>('中国')

// 位置信息
const latitude = ref<number>(0)
const longitude = ref<number>(0)

// 营销弹窗状态
const marketingPopupVisible = ref<boolean>(false)
const marketingPopupData = ref<UTSJSONObject | null>(null)

// 🔒 隐私弹窗状态
const privacyPopupVisible = ref<boolean>(false)

// 向导列表状态（独立 ref）
const guiderList = ref<Array<UTSJSONObject>>([])
const guiderPage = ref<number>(1)
const guiderTotal = ref<number>(0)
const guiderLoading = ref<boolean>(false)
const guiderRefreshing = ref<boolean>(false)
const guiderHasMore = ref<boolean>(true)

// 接单列表状态
const grabOrderList = ref<Array<UTSJSONObject>>([])
const grabOrderLoading = ref<boolean>(false)
const grabOrderRefreshing = ref<boolean>(false)
const grabOrderPageData = ref<PageListData>(new PageListData())

// 分享相关状态
const showSharePopup = ref(false)
const sharePayload = ref<UTSJSONObject>({
	title: '',
	desc: '',
	summary: '',
	link: '',
	url: '',
	imageUrl: '',
	userId: '',
	referrerShortKid: ''
} as UTSJSONObject)
const shareChatList = ref<Array<UTSJSONObject>>([])
const userStore = useUserStore()
const currentShareItem = ref({} as UTSJSONObject)

// ==================== 计算属性 ====================

// 列表长度计算属性
const guiderListLength = computed((): number => {
	try {
		const list = guiderList.value
		if (list != null && Array.isArray(list) == true) {
			return (list as Array<UTSJSONObject>).length
		}
	} catch (e) {}
	return 0
})

const grabOrderListLength = computed((): number => {
	try {
		const list = grabOrderList.value
		if (list != null && Array.isArray(list) == true) {
			return (list as Array<UTSJSONObject>).length
		}
	} catch (e) {}
	return 0
})

const grabOrderLoadStatus = computed((): string => {
	try {
		return grabOrderPageData.value.status
	} catch (e) {}
	return 'loadmore'
})

// ==================== 模板辅助函数 ====================

const getGuiderKey = (item: UTSJSONObject | null, index: number): string => {
	return getItemKeyByField(item as any, index, 'memberGuideKid')
}

// 获取向导在线状态
const getGuiderOnlineStatus = (item: UTSJSONObject | null): boolean => {
	const guideKid = getStringProp(item as any, 'memberGuideKid')
	if (guideKid == '') return false
	return getOnlineStatusDirect(guideKid)
}

// 处理在线状态变更事件
const handleOnlineStatusChange = (data: UTSJSONObject | null) => {
	console.log('[Index] 收到在线状态变更事件:', data)
	try {
		const dataJson = JSON.stringify(data)
		const dataObj = JSON.parse(dataJson) as UTSJSONObject
		
		const userId = dataObj.getString('userId')
		const isOnlineVal = dataObj.getBoolean('isOnline')
		const isOnline = isOnlineVal == true
		
		if (userId == null || userId == '') {
			return
		}
		
		// 更新本地缓存
		setOnlineStatusDirect(userId, isOnline)
		
		// 强制触发列表重新渲染（通过修改列表引用）
		// 由于 guiderList 中的 item 是原始对象，在线状态通过 getGuiderOnlineStatus 动态获取
		// 需要触发组件重新渲染
		const tempList = guiderList.value
		guiderList.value = []
		for (let i = 0; i < tempList.length; i = i + 1) {
			guiderList.value.push(tempList[i])
		}
		
		console.log('[Index] 更新向导在线状态: userId=' + userId + ', isOnline=' + isOnline.toString())
	} catch (e) {
		console.error('[Index] 处理在线状态变更事件失败:', e)
	}
}

// 获取城市名（用于 API）
const getCityNameForApi = (): string => {
	const city = cityName.value
	if (city == '中国' || city == '全部') {
		return ''
	}
	return city
}

// ==================== 抢单属性获取辅助函数 ====================

// 抢单列表 key
const getGrabOrderItemKey = (item: UTSJSONObject, index: number): string => {
	const kid = getItemStringProp(item, 'kid')
	return (kid != '') ? kid : index.toString()
}

// 抢单属性获取
const getGrabOrderTitle = (item: UTSJSONObject): string => {
	let title = getItemStringProp(item, 'orderDescribe')
	if (title == '') title = getItemStringProp(item, 'orderTitle')
	return (title != '') ? title : '待抢订单'
}

const getGrabOrderPrice = (item: UTSJSONObject): string => {
	let price = getItemNumberProp(item, 'orderPrice')
	if (price == 0) price = getItemNumberProp(item, 'totalMoney')
	return formatMoney(price)
}

const getGrabOrderTime = (item: UTSJSONObject): string => {
	let time = getItemStringProp(item, 'startTime')
	if (time == '') time = getItemStringProp(item, 'serviceTime')
	if (time == '') time = getItemStringProp(item, 'travelDate')
	return (time != '') ? time : '-'
}

const getGrabOrderNo = (item: UTSJSONObject): string => {
	let orderNo = getItemStringProp(item, 'orderNo')
	if (orderNo == '') orderNo = getItemStringProp(item, 'shortKid')
	return (orderNo != '') ? orderNo : '-'
}

const getGrabOrderAvatar = (item: UTSJSONObject): string => {
	let avatar = getItemStringProp(item, 'touristAvatar')
	if (avatar == '') avatar = getItemStringProp(item, 'userImg')
	if (avatar == '') avatar = getItemStringProp(item, 'avatar')
	return (avatar != '') ? avatar : DEFAULT_AVATAR_LOCAL
}

const getGrabOrderUserName = (item: UTSJSONObject): string => {
	let name = getItemStringProp(item, 'touristName')
	if (name == '') name = getItemStringProp(item, 'userNickname')
	if (name == '') name = getItemStringProp(item, 'nickname')
	return (name != '') ? name : '游客'
}

// 获取抢单用户 ID
const getGrabOrderUserKid = (item: UTSJSONObject): string => {
	let userKid = getItemStringProp(item, 'touristKid')
	if (userKid == '') userKid = getItemStringProp(item, 'userKid')
	return userKid
}

// ==================== 数据加载函数 ====================

// 加载向导列表
const loadGuiderList = async (refresh: boolean) => {
	if (refresh == true) {
		guiderPage.value = 1
		guiderList.value = []
	}
	
	if (guiderLoading.value == true) return
	guiderLoading.value = true
	
	try {
		const params = {
			pageNumber: guiderPage.value,
			pageSize: 10,
			latitude: latitude.value,
			longitude: longitude.value,
			userCityName: getCityNameForApi()
		} as UTSJSONObject
		// 功能开关已加载时才传递 sharedDataEnabled，否则让后端从数据库查询商户配置
		if (isFeatureTogglesLoaded() == true) {
			params['sharedDataEnabled'] = isSharedDataDisplayEnabled()
		}
		
		const res = await getGuiderList(params)
		const code = getResponseCode(res)
		const dataObj = getResponseData(res)
		
		if (code == 200 && dataObj != null) {
			const items = getEntities(dataObj)
			const totalCount = getDataCount(dataObj)
			
			guiderTotal.value = totalCount
			
			// 转换数组类型
			const typedItems: UTSJSONObject[] = []
			for (let i = 0; i < items.length; i = i + 1) {
				typedItems.push(items[i] as UTSJSONObject)
			}
			
			if (refresh == true) {
				guiderList.value = typedItems
			} else {
				for (let i = 0; i < typedItems.length; i = i + 1) {
					guiderList.value.push(typedItems[i])
				}
			}
			
			guiderHasMore.value = guiderList.value.length < guiderTotal.value
			
			// ⭐ 新增：批量查询在线状态
			const userIdsToQuery: Array<string> = []
			for (let j = 0; j < typedItems.length; j = j + 1) {
				const item = typedItems[j]
				const guideKid = getStringProp(item as any, 'memberGuideKid')
				if (guideKid != '') {
					userIdsToQuery.push(guideKid)
				}
			}
			if (userIdsToQuery.length > 0) {
				fetchOnlineStatus(userIdsToQuery)
			}
		}
	} catch (error) {
		if (!isAuthError(error)) {
			handlePageError(error, '加载向导列表', guiderLoading)
		}
	} finally {
		guiderLoading.value = false
		guiderRefreshing.value = false
	}
}

// 获取接单列表
const fetchGrabOrderList = async (isRefresh: boolean) => {
	try {
		if (isRefresh == true) {
			grabOrderPageData.value.pageNumber = 1
			grabOrderPageData.value.status = 'loadmore'
		}
		
		if (grabOrderPageData.value.status == 'nomore') return
		
		grabOrderLoading.value = true
		grabOrderPageData.value.status = 'loading'
		
		const params = {
			pageNumber: grabOrderPageData.value.pageNumber,
			pageSize: grabOrderPageData.value.pageSize
		} as UTSJSONObject
		
		const res = await request.post('/order/guide/queryGrabOrder', params, false)
		
		if (res != null) {
			const resStr = JSON.stringify(res)
			const resObj = JSON.parse(resStr) as UTSJSONObject
			
			// 先获取 data 字段
			const dataVal = resObj.get('data')
			let dataObj: UTSJSONObject | null = null
			if (dataVal != null) {
				const dataStr = JSON.stringify(dataVal)
				dataObj = JSON.parse(dataStr) as UTSJSONObject
			}
			
			// 从 data 中获取 entities 和 count
			let entities: Array<UTSJSONObject> = []
			let count = 0
			
			if (dataObj != null) {
				const entitiesVal = dataObj.get('entities')
				const countVal = dataObj.get('count')
				
				if (entitiesVal != null && Array.isArray(entitiesVal) == true) {
					entities = entitiesVal as Array<UTSJSONObject>
				}
				
				if (countVal != null) {
					const num = parseInt(countVal.toString())
					if (isNaN(num) == false) count = num
				}
			}
			
			if (isRefresh == true) {
				grabOrderList.value = entities
			} else {
				const currentList = grabOrderList.value
				for (let i = 0; i < entities.length; i = i + 1) {
					currentList.push(entities[i])
				}
				grabOrderList.value = currentList
			}
			
			grabOrderPageData.value.total = count
			
			const currentLength = grabOrderList.value.length
			if (currentLength >= count || entities.length < grabOrderPageData.value.pageSize) {
				grabOrderPageData.value.status = 'nomore'
			} else {
				grabOrderPageData.value.status = 'loadmore'
				grabOrderPageData.value.pageNumber = grabOrderPageData.value.pageNumber + 1
			}
		}
	} catch (error: Error) {
		if (!isAuthError(error)) {
			handlePageError(error, '获取接单列表', null)
		}
		grabOrderPageData.value.status = 'loadmore'
	} finally {
		grabOrderLoading.value = false
	}
}

// ==================== 抢单操作函数 ====================

// 抢单操作
const handleGrabOrder = async (item: UTSJSONObject) => {
	// 会员权限守卫：内部已包含登录检查、会员状态检查和功能开关检查
	if (checkMemberGuard('grab_order') == false) {
		return
	}
	
	const userKid = getUserKidFromStore()
	const orderKid = getItemStringProp(item, 'kid')
	
	if (userKid == '' || orderKid == '') return
	
	try {
		const params = {
			orderKid: orderKid,
			guideKid: userKid
		} as UTSJSONObject
		
		await request.post('/order/guide/grabOrder', params, true)
		
		uni.showToast({
			title: '抢单成功',
			icon: 'success'
		})
		
		// 刷新列表
		fetchGrabOrderList(true)
	} catch (error: Error) {
		if (!isAuthError(error)) {
			handlePageError(error, '抢单', null)
		}
	}
}

// 抢单点击 - 跳转订单详情
const handleGrabOrderClick = (item: UTSJSONObject) => {
	const orderKid = getItemStringProp(item, 'kid')
	if (orderKid != '') {
		uni.navigateTo({
			url: '/pagesTrade/orderDetails/index?orderKid=' + orderKid
		})
	}
}

// 抢单用户头像/昵称点击 - 跳转个人主页
const handleGrabOrderUserClick = (item: UTSJSONObject) => {
	let userKid = getItemStringProp(item, 'touristKid')
	if (userKid == '') userKid = getItemStringProp(item, 'userKid')
	if (userKid == '') userKid = getItemStringProp(item, 'userId')
	
	if (userKid != '') {
		uni.navigateTo({
			url: '/pagesUser/persionInfo/index?id=' + userKid
		})
	}
}

// 抢单分享按钮点击
const handleGrabOrderShare = async (item: UTSJSONObject) => {
	console.log('[Index] handleGrabOrderShare called')
	currentShareItem.value = item
	
	try {
		// 构建分享标题
		const orderTitle = getGrabOrderTitle(item)
		const shareTitle = '待抢订单：' + orderTitle
		
		// 构建分享描述
		const orderNo = getGrabOrderNo(item)
		const price = getGrabOrderPrice(item)
		const time = getGrabOrderTime(item)
		const shareDesc = '订单编号：' + orderNo + '\n价格：¥' + price + '\n出发时间：' + time
		
		// 构建分享链接
		const kid = getItemStringProp(item, 'kid')
		let shareLink = 'https://m.wyxdapp.com/#/pagesTrade/orderDetails/index?orderKid=' + kid
		
		// 获取推广短号
		let referrerShortKid = ''
		try {
			referrerShortKid = getUserShortKid()
			if (referrerShortKid == '') {
				// 使用 toJsonObj 安全访问 store
				const userStoreObj = toJsonObj(userStore)
				if (userStoreObj != null) {
					const userInfoVal = userStoreObj.get('userInfo')
					if (userInfoVal != null) {
						const userInfoJson = JSON.stringify(userInfoVal)
						if (userInfoJson != null && userInfoJson != '') {
							const userInfoObj = JSON.parse(userInfoJson) as UTSJSONObject
							const shortKidVal = userInfoObj.get('shortKid')
							if (shortKidVal != null && shortKidVal.toString() != '') {
								referrerShortKid = shortKidVal.toString()
							}
						}
					}
				}
			}
			// 从缓存的当前用户 profile 中获取 shortKid
			if (referrerShortKid == '') {
				const currentUserKidForRef = getUserKidFromStore()
				if (currentUserKidForRef != '') {
					try {
						const cachedMyProfile = getCachedProfile(currentUserKidForRef, currentUserKidForRef)
						if (cachedMyProfile != null) {
							const cachedShortKidVal = cachedMyProfile.get('shortKid')
							if (cachedShortKidVal != null && cachedShortKidVal.toString() != '') {
								referrerShortKid = cachedShortKidVal.toString()
								console.log('[handleShare] 从缓存profile获取推广短号:', referrerShortKid)
								updateUserInfoAction({ shortKid: referrerShortKid } as UTSJSONObject)
							}
						}
					} catch (e2) {}
				}
			}
			if (referrerShortKid != '') {
				shareLink = shareLink + '&ref=' + referrerShortKid
			}
		} catch (e) {
			handleSilentError(e, '获取推广短号')
		}
		
		// 构建分享数据
		const newPayload = {
			title: shareTitle,
			summary: shareDesc,
			desc: shareDesc,
			link: shareLink,
			url: shareLink,
			imageUrl: DEFAULT_SHARE_IMAGE_LOCAL,
			userId: '',
			referrerShortKid: referrerShortKid,
			orderKid: kid
		}
		
		sharePayload.value = newPayload
		
		console.log('[handleGrabOrderShare] 分享数据构建完成')
	} catch (e) {
		handleSilentError(e, '构建抢单分享数据')
		sharePayload.value = {
			title: '待抢订单',
			summary: '精彩订单，等你来抢！',
			desc: '精彩订单，等你来抢！',
			link: 'https://m.wyxdapp.com',
			url: 'https://m.wyxdapp.com',
			imageUrl: DEFAULT_SHARE_IMAGE_LOCAL,
			userId: '',
			referrerShortKid: ''
		}
	}
	
	// 获取会话列表
	try {
		const result = await getChatListFn(userStore)
		if (result != null && Array.isArray(result) == true) {
			shareChatList.value = result as Array<UTSJSONObject>
		} else {
			shareChatList.value = []
		}
	} catch (e) {
		handleSilentError(e, '获取抢单会话列表')
		shareChatList.value = []
	}
	
	showSharePopup.value = true
}

// 分享事件处理函数
const handleShareToChat = (data: UTSJSONObject) => {
	console.log('[Index] handleShareToChat called with data:', JSON.stringify(data))
	
	if (currentShareItem.value == null) {
		uni.showToast({
			title: '分享失败，请重试',
			icon: 'none'
		})
		return
	}
	
	// 从 data 中提取 chatItem
	let chatItem: UTSJSONObject = {} as UTSJSONObject
	try {
		const dataObj = JSON.parse(JSON.stringify(data)) as UTSJSONObject
		const chatItemVal = dataObj.get('chatItem')
		if (chatItemVal != null) {
			chatItem = chatItemVal as UTSJSONObject
		}
	} catch (e) {
		handleSilentError(e, '解析分享数据')
	}
	
	if (chatItem == null) {
		uni.showToast({
			title: '分享失败，会话信息不完整',
			icon: 'none'
		})
		return
	}
	
	// 订单分享
	const orderInfo = {
		kid: getItemStringProp(currentShareItem.value, 'kid'),
		orderNo: getGrabOrderNo(currentShareItem.value),
		orderTitle: getGrabOrderTitle(currentShareItem.value),
		totalMoney: getGrabOrderPrice(currentShareItem.value),
		travelDate: getGrabOrderTime(currentShareItem.value),
		touristName: getGrabOrderUserName(currentShareItem.value),
		touristAvatar: getGrabOrderAvatar(currentShareItem.value)
	}
	
	const shareData = {
		chatItem: chatItem
	} as UTSJSONObject
	
	handleShareToChatFn(shareData, orderInfo)
}

