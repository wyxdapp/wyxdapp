	flex: 1;
	height: 64rpx;
	background-color: #FFFFFF;
	border-radius: 32rpx;
	flex-direction: row;
	align-items: center;
	justify-content: flex-start;
	padding-left: 26rpx;
	padding-right: 26rpx;
	padding-top: 0;
	padding-bottom: 0;
	margin-left: 24rpx;
}

