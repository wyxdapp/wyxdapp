const handleCitySelected = (data: UTSJSONObject | null) => {
	if (data != null) {
		try {
			const dataObj = JSON.parse(JSON.stringify(data)) as UTSJSONObject
			const cityVal = dataObj.get('city')
			if (cityVal != null && cityVal.toString() != '') {
				const selectedCity = cityVal.toString()
				cityName.value = selectedCity
				refreshAllLists()
			}
		} catch (e) {
			console.error('解析城市数据失败:', e)
		}
	}
}

