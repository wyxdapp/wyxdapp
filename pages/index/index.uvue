	line-height: 40rpx;
}

.tab-text-active {
	font-size: 32rpx;
	color: #333333;
	font-weight: bold;
}

.tab-underline {
	width: 40rpx;
	height: 6rpx;
	background-color: #37B1F2;
	border-radius: 3rpx;
	margin-top: 8rpx;
}

/* ==================== 发布按钮（移到 Tab 栏右侧） ==================== */
.publish-btn {
	flex-direction: column;
	align-items: center;
	justify-content: center;
	margin-left: 24rpx;
}

.publish-icon {
	width: 30rpx;
	height: 30rpx;
	margin-bottom: 6rpx;
}

.publish-text {
	font-size: 22rpx;
	color: #333333;
}

/* ==================== Swiper 容器 ==================== */
.swiper-container {
	width: 750rpx;
	background-color: transparent;
	z-index: 10;
}

/* APP 端：使用 flex: 1 自动填充 */
/* #ifndef H5 */
.scroll-view {
	flex: 1;
	flex-direction: column;
	width: 750rpx;
	background-color: transparent;
}
/* #endif */

/* H5 端：使用明确高度 */
/* #ifdef H5 */
.scroll-view-h5 {
	flex-direction: column;
	width: 750rpx;
	background-color: transparent;
}
/* #endif */

/* ==================== 列表容器 ==================== */
.guider-list {
	flex-direction: column;
	width: 750rpx;
	padding-top: 0;
	padding-left: 28rpx;
	padding-right: 28rpx;
	padding-bottom: 120rpx;
