// 加载当前 Tab 数据
const loadTabData = (index: number, refresh: boolean) => {
	if (index == 0) {
		if (refresh == true || guiderListLength.value == 0) {
			loadGuiderList(refresh)
		}
	} else if (index == 1) {
		if (refresh == true || grabOrderListLength.value == 0) {
			fetchGrabOrderList(refresh)
		}
	}
}

// 刷新所有列表
const refreshAllLists = () => {
	// 重置向导列表
	guiderList.value = []
	guiderPage.value = 1
	guiderTotal.value = 0
	guiderLoading.value = false
	guiderRefreshing.value = false
	guiderHasMore.value = true
	
	// 重置接单列表
	grabOrderList.value = []
	grabOrderLoading.value = false
	grabOrderRefreshing.value = false
	grabOrderPageData.value = new PageListData()
	
	loadTabData(currentTab.value, true)
}

// 🔧 修复：防止重复定位调用
let isLocating = false

// 获取定位
const getLocation = async () => {
	// 防止重复调用
	if (isLocating == true) {
		console.log('📍 [Index] 定位进行中，跳过重复调用')
		return
	}
	
	isLocating = true
	console.log('📍 [Index] getLocation 开始执行')
	
	// 保存定位前的城市名称
	const oldCity = cityName.value
	const oldLatitude = latitude.value
	const oldLongitude = longitude.value
	
	try {
		console.log('📍 [Index] 调用 getLocationInfo...')
		const location = await getLocationInfo()
		console.log('📍 [Index] getLocationInfo 返回:', location.city, location.latitude, location.longitude)
		
		// 更新位置信息
		latitude.value = location.latitude
		longitude.value = location.longitude
		cityName.value = location.city
		
		console.log('📍 [Index] 城市更新为:', cityName.value)
		
		// 城市变化 或 经纬度从无效(0)变为有效时，刷新列表以获取正确的距离
		const cityChanged = oldCity != location.city
		const locationBecameValid = (oldLatitude == 0 && oldLongitude == 0) && (location.latitude != 0 || location.longitude != 0)
		
		if (cityChanged || locationBecameValid) {
			console.log('📍 [Index] 刷新列表, 城市变化:', cityChanged, '定位变有效:', locationBecameValid)
			refreshAllLists()
		}
	} catch (err) {
		console.error('❌ [Index] 定位失败:', err)
		// 定位失败时不刷新列表，保持当前数据
		// 用户可以手动选择城市
	} finally {
		// 重置标记
		isLocating = false
	}
}

// ==================== 营销弹窗相关函数 ====================

// 检查并展示弹窗
const checkAndShowPopup = (triggerType: string) => {
	fetchActivePopup(triggerType).then((config: UTSJSONObject | null) => {
		if (config != null && shouldShowPopup(config) == true) {
			marketingPopupData.value = config
			marketingPopupVisible.value = true
		}
	}).catch((error: any | null): void => {
		// 静默处理
		console.error('检查营销弹窗失败:', error)
	})
}

// 处理弹窗关闭
const handlePopupClose = () => {
	marketingPopupVisible.value = false
	// 保存关闭记录
	const popupData = marketingPopupData.value
	if (popupData != null) {
		const kid = getStringProp(popupData, 'kid')
		if (kid != '') {
			saveDisplayRecord(kid, 'close')
		}
	}
	// 清空弹窗数据，防止闪现
	marketingPopupData.value = null
}

// 处理弹窗按钮点击
const handlePopupButtonClick = (buttonType: string, url: string) => {
	// 保存点击记录
	const popupData = marketingPopupData.value
	if (popupData != null) {
		const kid = getStringProp(popupData, 'kid')
		if (kid != '') {
			saveDisplayRecord(kid, 'click')
		}
	}
	
	// 关闭弹窗并清空数据
	marketingPopupVisible.value = false
	marketingPopupData.value = null
	
	// 执行跳转
	if (url != null && url != '') {
		navigateToUrl(url)
	}
}

// ==================== 🔒 移除自定义隐私弹窗相关函数 ====================
// 系统隐私声明会自动处理，无需自定义弹窗

// 🔒 隐私同意后定位的防重复标记
let privacyLocationHandled = false

// 🔒 隐私同意后的定位处理函数
const handlePrivacyAgreedForLocation = () : void => {
	if (privacyLocationHandled == true) return
	privacyLocationHandled = true
	console.log('📍 [Index] 收到隐私同意事件，开始定位')
	privacyPopupVisible.value = false
	getLocation()
}

// 🔒 隐私弹窗 - 用户点击"同意"
const handlePrivacyAgree = () : void => {
	privacyPopupVisible.value = false
	// 广播隐私同意事件，通知 App.uvue 初始化敏感服务 + 触发定位
	broadcastPrivacyAgreed()
}

// 🔒 隐私弹窗 - 用户点击"不继续"
const handlePrivacyDisagree = () : void => {
	// #ifdef APP-ANDROID
	uni.exit()
	// #endif
}

// 初始化
const initPage = () => {
	// 使用 composable 初始化布局
	initPageLayoutComposable()
	
	// 计算头部高度（状态栏 + 搜索栏84rpx≈42px + Tab栏90rpx≈45px）
	headerHeight.value = pageStatusBarHeight.value + 87
	
	// 计算内容区域高度（窗口高度 - 头部高度）
	if (pageWindowHeight.value > 0) {
		contentHeight.value = pageWindowHeight.value - headerHeight.value
		
		// 确保内容高度有效
		if (contentHeight.value < 200) {
			contentHeight.value = pageWindowHeight.value - 100
		}
	}
	
	console.log('状态栏高度:', pageStatusBarHeight.value, '头部高度:', headerHeight.value, '内容高度:', contentHeight.value)
	
	// 如果内容高度仍然无效，设置默认值
	if (contentHeight.value <= 0) {
		contentHeight.value = 600
	}
	
	// 🔧 微信小程序：获取胶囊按钮信息，计算右侧安全区域
	// #ifdef MP-WEIXIN
	try {
		const menuButtonInfo = uni.getMenuButtonBoundingClientRect()
		if (menuButtonInfo != null) {
			const menuButtonObj = JSON.parse(JSON.stringify(menuButtonInfo)) as UTSJSONObject
			const leftVal = menuButtonObj.get('left')
			if (leftVal != null) {
				const leftPx = parseFloat(leftVal.toString())
				if (isNaN(leftPx) == false) {
					// 获取屏幕宽度
					const systemInfo = uni.getSystemInfoSync()
					const systemInfoObj = JSON.parse(JSON.stringify(systemInfo)) as UTSJSONObject
					const screenWidthVal = systemInfoObj.get('screenWidth')
					if (screenWidthVal != null) {
						const screenWidth = parseFloat(screenWidthVal.toString())
						if (isNaN(screenWidth) == false && screenWidth > 0) {
							// 计算右边距（屏幕宽度 - 胶囊左边界），确保搜索栏不会被胶囊按钮遮挡
							menuButtonRight.value = screenWidth - leftPx
							console.log('微信小程序胶囊按钮右侧占用宽度:', menuButtonRight.value, 'px')
						}
					}
				}
			}
		}
	} catch (e) {
		console.error('获取胶囊按钮信息失败:', e)
		menuButtonRight.value = 0
	}
	// #endif
	
	// 1. 先立即加载当前Tab数据（城市为"中国"，API参数为空，获取全部数据）
	loadTabData(currentTab.value, true)
	
	// 2. 🔒 隐私合规：检查隐私状态后再定位（防止腾讯定位SDK在同意前被调用）
	if (isPrivacyAgreed() == true) {
		// 已同意，正常定位
		console.log('📍 [Index] 用户已同意隐私政策，开始定位')
		getLocation()
	} else {
		// 未同意，显示隐私弹窗，监听同意事件后再定位
		console.log('📍 [Index] 用户未同意隐私政策，显示隐私弹窗，延迟定位')
		privacyPopupVisible.value = true
		uni.$on(PRIVACY_AGREED_EVENT, handlePrivacyAgreedForLocation)
	}
	
	// 检查并展示营销弹窗（页面加载触发）
	checkAndShowPopup(TRIGGER_TYPE_PAGE_LOAD)
}

// 处理营销弹窗触发事件
const handleMarketingPopupTrigger = (data: UTSJSONObject | null) => {
	if (data != null) {
		try {
			const dataObj = JSON.parse(JSON.stringify(data)) as UTSJSONObject
			const triggerTypeVal = dataObj.get('triggerType')
			if (triggerTypeVal != null && triggerTypeVal.toString() != '') {
				checkAndShowPopup(triggerTypeVal.toString())
			}
		} catch (e) {
			console.error('解析弹窗触发数据失败:', e)
		}
	}
}

// ==================== 事件处理函数 ====================

// Tab 切换
const switchTab = (index: number) => {
	if (currentTab.value != index) {
		currentTab.value = index
	}
	loadTabData(index, false)
}

// Swiper 切换
const onSwiperChange = (e: UniSwiperChangeEvent) => {
	try {
		const index = e.detail.current
		if (currentTab.value != index) {
			currentTab.value = index
		}
		loadTabData(index, false)
	} catch (err) {}
}

// 下拉刷新
const onRefresh = async () => {
	if (currentTab.value == 0) {
		guiderRefreshing.value = true
		await loadGuiderList(true)
	} else if (currentTab.value == 1) {
		grabOrderRefreshing.value = true
		await fetchGrabOrderList(true)
		grabOrderRefreshing.value = false
	}
}

// 加载更多
const loadMore = () => {
	if (currentTab.value == 0 && guiderLoading.value == false && guiderHasMore.value == true) {
		guiderPage.value = guiderPage.value + 1
		loadGuiderList(false)
	} else if (currentTab.value == 1 && grabOrderPageData.value.status == 'loadmore') {
		fetchGrabOrderList(false)
	}
}

