// ==================== 生命周期 ====================

onMounted(() => {
	// 注册城市选择事件监听
	uni.$on('onCitySelected', handleCitySelected)
	
	// 注册营销弹窗触发事件监听
	uni.$on(MARKETING_POPUP_TRIGGER, handleMarketingPopupTrigger)
	
	// ⭐ 新增：注册在线状态变更事件监听
	uni.$on('online:statusChange', handleOnlineStatusChange)
	console.log('[Index] 已注册在线状态变更监听')
	
	initPage()
})

onUnmounted(() => {
	// 注销城市选择事件监听
	uni.$off('onCitySelected', handleCitySelected)
	
	// 注销营销弹窗触发事件监听
	uni.$off(MARKETING_POPUP_TRIGGER, handleMarketingPopupTrigger)
	
	// ⭐ 新增：注销在线状态变更事件监听
	uni.$off('online:statusChange', handleOnlineStatusChange)
	
	// 🔒 注销隐私同意事件监听
	uni.$off(PRIVACY_AGREED_EVENT, handlePrivacyAgreedForLocation)
})

// 🔧 修复：优化页面显示时的定位逻辑
onShow(() => {
	console.log('📍 [Index] onShow - 页面显示，检查定位状态')
	
	// 🔒 隐私合规：未同意隐私政策时不尝试定位
	if (isPrivacyAgreed() == false) {
		console.log('📍 [Index] onShow - 用户未同意隐私政策，跳过定位')
		return
	}
	
	// 如果还没有获取到精确定位，且没有正在定位，尝试重新获取
	if (latitude.value === 0 && longitude.value === 0 && isLocating == false) {
		console.log('📍 [Index] onShow - 检测到未获取定位，重新尝试')
		// 延迟执行，确保页面完全显示
		setTimeout(() => {
			getLocation()
		}, 500)
	}
})

// ==================== 微信小程序分享钩子 ====================
// #ifdef MP-WEIXIN
